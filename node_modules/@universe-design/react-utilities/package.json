{
  "name": "@universe-design/react-utilities",
  "version": "0.13.3",
  "description": "Some shared utilities",
  "license": "MIT",
  "author": "guxiang",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./lib-esm/index.js",
      "require": "./lib-commonjs/index.js",
      "types": "./lib-esm/index.d.ts"
    },
    "./package.json": "./package.json",
    "./loading": "./lib-esm/components/loading/index.js"
  },
  "main": "lib-commonjs/index.js",
  "module": "lib-esm/index.js",
  "types": "lib-esm/index.d.ts",
  "files": [
    "lib-esm",
    "lib-commonjs",
    "dist",
    "docs"
  ],
  "dependencies": {
    "@babel/runtime": "^7.23.8",
    "@emotion/cache": "^11.6.0",
    "@emotion/hash": "^0.8.0",
    "@emotion/sheet": "^1.1.0",
    "@juggle/resize-observer": "^3.3.1",
    "clsx": "^1.1.1",
    "immer": "^9.0.15",
    "lodash": "^4.17.21",
    "react-is": "^17.0.2",
    "react-transition-group": "^4.4.2",
    "tslib": "^2.3.1",
    "type-fest": "^4.6.0",
    "use-sync-external-store": "^1.2.0",
    "utility-types": "^3.10.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.6.1",
    "@playwright/experimental-ct-react17": "^1.48.1",
    "@rushstack/heft": "^0.56.2",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^12.1.2",
    "@testing-library/react-hooks": "^7.0.2",
    "@testing-library/user-event": "^13.5.0",
    "@types/heft-jest": "^1.0.3",
    "@types/lodash": "^4.14.191",
    "@types/node": "^18.14.6",
    "@types/react": "^17.0.39",
    "@types/react-dom": "^17.0.11",
    "@types/react-is": "^17.0.2",
    "@types/react-transition-group": "^4.4.4",
    "@types/testing-library__jest-dom": "^5.14.5",
    "@types/use-sync-external-store": "^0.0.3",
    "@universe-design/babel-plugin-global-token": "^0.1.3",
    "@universe-design/config": "~0.1.0",
    "@universe-design/heft-rig": "^0.7.5",
    "@universe-design/react-provider": "^0.6.0",
    "@universe-design/storykit": "^0.2.2",
    "eslint": "^8.33.0",
    "lint-staged": "~11.0.0",
    "nyc": "~15.1.0",
    "prettier": "^2.8.7",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-error-boundary": "^4.0.13",
    "react-test-renderer": "^17.0.2",
    "typescript": "^5.2.2",
    "v8-to-istanbul": "^9.3.0",
    "@universe-design/eslint-config": "1.1.8"
  },
  "peerDependencies": {
    "@universe-design/react-provider": "*",
    "react": ">=16.8",
    "react-dom": ">=16.8"
  },
  "scripts": {
    "_phase:api-doc-generate": "heft run --only api-doc-generate -- --clean",
    "_phase:build": "heft run --only build -- --clean",
    "_phase:build-esm-bundle": "heft run --only build-esm-bundle -- --clean",
    "_phase:lint": "heft run --only lint -- --clean",
    "_phase:storybook-build": "heft run --only storybook -- --storybook --clean",
    "_phase:test-dist": "heft run --only test -- --clean",
    "api-doc-generate": "heft api-doc-generate --clean",
    "build": "heft build --clean",
    "clean": "heft clean",
    "fix": "eslint --ext .js,.ts,.tsx . --fix",
    "lint": "heft lint --clean",
    "mono:precommit": "lint-staged",
    "nyc:report": "nyc report --reporter=lcov --reporter=text  --reporter=text-summary --reporter=clover --temp-dir='./.nyc_output'",
    "storybook": "heft storybook-watch --serve --storybook",
    "storybook-build": "heft storybook --storybook --clean",
    "test": "playwright install && rm -rf .nyc_output && npm run test:e2e && npm run test:unit && npm run nyc:report",
    "test:e2e": "playwright test",
    "test:unit": "heft test --clean",
    "watch": "heft test-watch"
  }
}