    "storybook:build": "NODE_OPTIONS=--max_old_space_size=4096 sb build -c config/storybook -o .doc && find ${OUTPUT_DIR} -name \"*.LEGAL.txt\" -type f -size 0c | xargs -n 1 rm -f",
