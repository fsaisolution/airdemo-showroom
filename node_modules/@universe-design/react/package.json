    "component-server:build": "rm -rf test-utils/component-server/dist && NODE_ENV=development webpack build --config test-utils/component-server/webpack.config.ts --progress --profile --json > stats.json && webpack-bundle-analyzer stats.json",
    "fix": "rushx lint:js --fix && rushx lint:style:prettier --write && rushx lint:style:stylelint --fix && rushx lint:md --write",
    "goodjob": "run-p -l lint check:types test test:screenshot build",
    "generate:stories": "ts-node-script scripts/generate-stories.ts",
    "i18n:d": "ROUTE_IP=10.225.130.44 heft i18n-download",
    "license-checker": "npx license-checker --production --json > licenses.json",
    "lint:md": "prettier \"src/**/*.md\"",
    "lint:style:prettier": "prettier \"src/**/*.{less,css}\"",
    "lint:style:stylelint": "stylelint \"src/**/*.{less,css}\"",
    "lint:dts": "dtslint --expectOnly --localTs node_modules/typescript/lib type-tests",
    "lint:js": "NODE_OPTIONS=\"--max-old-space-size=4096\" eslint --ext .js,.ts,.tsx src type-tests --quiet",
    "lint": "rushx lint:js && rushx lint:dts && rushx lint:style:stylelint && rushx lint:md",
    "mono:precommit": "NODE_OPTIONS=\"--max-old-space-size=4096\" lint-staged",
    "mono:clean": "rushx clean",
