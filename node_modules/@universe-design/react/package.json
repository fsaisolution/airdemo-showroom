  "sandboxEntry": "./dist/universe-design-react.esm-all-in-one.bundle.js",
  "scripts": {
    "_phase:build": "rushx build",
    "_phase:build-esm-bundle": "rushx build:esm-all-in-one:bundle 2>&1",
    "_phase:api-doc-generate": "rushx rollup:types 2>&1 && gulp buildApiDoc 2>&1",
    "_phase:lint": "rushx lint",
    "build": "rushx clean && rushx update-pkg-json-exports && rushx build:esm,cjs && rushx update-main-entry-apis",
    "assets:svgs:build": "shx rm -rf src/_assets/svgs && svgr -d src/_assets/svgs --config-file config/svgr.svgs.js assets/svgs && rushx fix && git add src/_assets/svgs",
    "build:api-docs": "rushx build:esm,cjs && rushx rollup:types && gulp buildApiDoc",
    "build:esm:bundle": "UD_TOOLS_PKG_MODULE=dist/universe-design-react.esm.bundle.js npx ud-tools build -l util -f esm  -c config/ud-tools.config.js",
    "build:esm-all-in-one:bundle": "ud-tools build -l util -f esm-all-in-one  -c config/ud-tools.config.js",
    "build:esm,cjs": "ud-tools build -l component -f types -f cjs -f esm -c config/ud-tools.config.js",
    "build:umd": "ud-tools build -f umd -c config/ud-tools.config.js",
