{
  "name": "@universe-design/colors",
  "version": "1.3.14",
  "license": "UNLICENSED",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "typings": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "lint-staged": {
    "src/**/*.(js|jsx|ts|tsx)": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "eslintConfig": {
    "extends": "@universe-design"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/dist/"
    ]
  },
  "dependencies": {
    "@babel/runtime": "^7.23.8",
    "@ctrl/tinycolor": "^3.4.0",
    "@types/chroma-js": "^2.1.3",
    "chroma-js": "^2.1.1",
    "lodash": "^4.17.21",
    "tslib": "^2.3.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.3",
    "@types/lodash": "^4.14.191",
    "@types/node": "^18.14.6",
    "@types/prettier": "^2.7.1",
    "@universe-design/config": "~0.1.0",
    "@universe-design/eslint-config": "~1.1.7",
    "@universe-design/ud-tools": "~2.1.3",
    "axios": "^1.2.2",
    "eslint": "^8.33.0",
    "jest": "^29.3.1",
    "jest-environment-jsdom": "^29.3.1",
    "lint-staged": "~11.0.0",
    "prettier": "^2.8.7",
    "typescript": "^5.2.2"
  },
  "scripts": {
    "_phase:build": "rushx build",
    "_phase:lint": "rushx lint:js",
    "_phase:test": "rushx test 2>&1",
    "build": "rushx clean && ud-tools build --format esm --format cjs --format types --project tsconfig.build.json",
    "clean": "rm -rf dist",
    "fix": "prettier \"src/**/*.{js,jsx,ts,tsx,json,less}\" --write && rushx lint:js --fix",
    "get-preset-colors": "ts-node-script scripts/get-preset-colors.ts",
    "lint:js": "eslint  --ext .js,.ts,.tsx src",
    "mono:build:umd": "ud-tools build -f umd",
    "mono:precommit": "lint-staged",
    "start": "run-p -l \"build:* -w\"",
    "test": "jest --coverage"
  }
}