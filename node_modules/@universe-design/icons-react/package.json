{
  "name": "@universe-design/icons-react",
  "version": "3.252.0",
  "private": false,
  "license": "MIT",
  "sideEffects": [
    "*.css"
  ],
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "typings": "dist/esm/index.d.ts",
  "scripts": {
    "fix:prettier": "prettier --write src scripts preview",
    "fix:standard-lint": "standard-lint --fix --set-exit-status 0 src scripts preview",
    "fix": "npm run fix:standard-lint && npm run fix:prettier",
    "clean:dist": "shx rm -rf dist",
    "clean": "run-p -l clean:*",
    "code-connect": "node scripts/icons-figma-connect.js",
    "build:icons": "shx rm -rf src/icons && bun scripts/run-build-icons.ts",
    "build:src:esm": "tsc -p ./tsconfig.build.json --noEmit false --outDir ./dist/esm && rollup --config config/rollup.config.esm.js",
    "build:src:es2017": "tsc -p ./tsconfig.build.json --noEmit false --outDir ./es2017 && rollup --config config/rollup.config.es2017.js",
    "build:src:cjs": "tsc -p ./tsconfig.build.json --noEmit false --outDir ./dist/cjs --module CommonJS && rollup --config config/rollup.config.cjs.js",
    "build:src": "run-p -l \"build:src:*\"",
    "build": "npm run build-icons && npm run build-src",
    "build-icons": "npm run build:icons && npm run fix && git add .",
    "build-src": "npm run clean:dist && npm run build:src",
    "test:unit": "jest",
    "get": "npm run build-icons; echo",
    "_phase:publish": "node scripts/copy-to-npm-pack.js && sh scripts/npm-publish.sh",
    "_phase:ttp-publish": "npm run _phase:publish",
    "mono:precommit": "lint-staged",
    "mono:prepare": "npm run build",
    "publish:local": "npm run build && npm run _phase:publish",
    "preview:dev": "vite ./preview",
    "preview:build": "vite build ./preview --base ''"
  },
  "lint-staged": {
    "*.{css,md,json}": "prettier --write",
    "*.{js,ts,jsx,tsx}": [
      "standard-lint --quiet --fix",
      "prettier --write"
    ]
  },
  "browserslist": [
    "> 1%, last 2 versions, not dead",
    "Firefox ESR",
    "IE 11"
  ],
  "dependencies": {
    "@babel/runtime": "^7.15.3",
    "clsx": "^1.1.1"
  },
  "devDependencies": {
    "@babel/core": "^7.14.3",
    "@babel/plugin-transform-runtime": "^7.15.0",
    "@babel/preset-env": "^7.14.4",
    "@babel/preset-react": "^7.14.5",
    "@babel/preset-typescript": "^7.13.0",
    "@babel/types": "^7.14.2",
    "@figma/code-connect": "~0.1.1",
    "@rollup/plugin-babel": "^5.3.0",
    "@rollup/plugin-commonjs": "^14.0.0",
    "@rollup/plugin-json": "^4.1.0",
    "@rollup/plugin-node-resolve": "^8.4.0",
    "@svgr/cli": "^5.4.0",
    "@swc/core": "^1.10.1",
    "@swc/jest": "^0.2.37",
    "@tanstack/react-virtual": "^3.11.2",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/jest": "^26.0.23",
    "@types/react": "^19.0.0",
    "@types/svg-parser": "^2.0.6",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitejs/plugin-react-refresh": "^1.3.1",
    "babel-jest": "^27.0.2",
    "change-case": "^4.1.2",
    "deep-object-diff": "^1.1.0",
    "jest": "^27.0.3",
    "jotai": "^2.11.0",
    "jsdom": "^16.6.0",
    "lint-staged": "^10.2.11",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.1.1",
    "rollup": "^2.21.0",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-terser": "^6.1.0",
    "shelljs": "^0.8.4",
    "shx": "^0.3.2",
    "svg-parser": "^2.0.4",
    "tinycolor2": "^1.4.2",
    "ts-jest": "^29.2.5",
    "typescript": "^4.4.2",
    "vite": "^5.3.5",
    "zod": "^3.24.1"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "gitHead": "fec15aef2684903df93a8cf5967b3502afcc8814"
}
