{
  "name": "@universe-design/react-aurora",
  "version": "0.1.77",
  "license": "MIT",
  "author": "wanghao.wong",
  "sideEffects": [
    "*.less"
  ],
  "exports": {
    ".": {
      "import": "./lib-esm/index.js",
      "require": "./lib-commonjs/index.js",
      "types": "./lib-esm/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "main": "lib-commonjs/index.js",
  "module": "lib-esm/index.js",
  "types": "lib-esm/index.d.ts",
  "files": [
    "lib-esm",
    "lib-commonjs",
    "dist",
    "docs"
  ],
  "dependencies": {
    "@babel/runtime": "^7.23.8",
    "clsx": "^1.1.1",
    "immer": "^9.0.15",
    "tslib": "^2.3.1"
  },
  "devDependencies": {
    "@jest/globals": "^29.6.1",
    "@rushstack/heft": "^0.56.2",
    "@testing-library/react": "^12.1.2",
    "@types/heft-jest": "^1.0.3",
    "@types/react": "^17.0.39",
    "@types/react-dom": "^17.0.11",
    "@universe-design/config": "~0.1.0",
    "@universe-design/heft-rig": "^0.7.6",
    "@universe-design/site-template": "^2.11.10",
    "@universe-design/storykit": "^0.2.3",
    "@universe-design/styles": "^11.18.0",
    "eslint": "^8.33.0",
    "lint-staged": "~11.0.0",
    "prettier": "^2.8.7",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "typescript": "^5.2.2",
    "utility-types": "^3.10.0",
    "@universe-design/eslint-config": "1.1.8",
    "@universe-design/react": "3.28.4"
  },
  "peerDependencies": {
    "@universe-design/styles": "11.18.0",
    "react": ">=16.8",
    "react-dom": ">=16.8"
  },
  "scripts": {
    "_phase:api-doc-generate": "heft run --only api-doc-generate -- --clean",
    "_phase:build": "heft run --only build -- --clean",
    "_phase:build-esm-bundle": "heft run --only build-esm-bundle -- --clean",
    "_phase:lint": "heft run --only lint -- --clean",
    "_phase:storybook-build": "heft run --only storybook -- --storybook --clean",
    "_phase:test-dist": "heft run --only test -- --clean",
    "api-doc-generate": "heft api-doc-generate --clean",
    "build": "heft build --clean",
    "clean": "heft clean",
    "fix": "eslint --ext .js,.ts,.tsx . --fix",
    "lint": "heft lint --clean",
    "mono:precommit": "lint-staged",
    "site": "heft site",
    "site:build": "heft site-build",
    "site:deploy": "heft site-deploy",
    "storybook": "PORT=8003 heft storybook-watch --serve --storybook",
    "storybook-build": "heft storybook --storybook --clean",
    "test": "heft test --clean",
    "watch": "heft test-watch"
  }
}