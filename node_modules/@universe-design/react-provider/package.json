    "type-fest": "^4.6.0",
    "use-sync-external-store": "^1.2.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.6.1",
    "@rushstack/heft": "^0.56.2",
    "@testing-library/react": "^12.1.2",
    "@types/heft-jest": "^1.0.3",
    "@types/lodash": "^4.14.191",
    "@types/node": "^18.14.6",
    "@types/react": "^17.0.39",
    "@types/react-dom": "^17.0.11",
