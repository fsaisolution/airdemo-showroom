{
  "name": "@universe-design/stylex",
  "version": "0.5.0",
  "license": "MIT",
  "author": "guxiang",
  "sideEffects": false,
  "exports": {
    ".": {
      "require": "./lib-commonjs/index.js",
      "import": "./lib-esm/index.js",
      "types": "./lib-esm/index.d.ts"
    },
    "./react": {
      "require": "./lib-commonjs/react/index.js",
      "import": "./lib-esm/react/index.js",
      "types": "./lib-esm/react/index.d.ts"
    }
  },
  "main": "./lib-commonjs/index.js",
  "module": "lib-esm/index.js",
  "types": "./lib-esm/index.d.ts",
  "files": [
    "lib-esm",
    "lib-commonjs",
    "docs"
  ],
  "lint-staged": {
    "**/*.(js|jsx|ts|tsx)": [
      "prettier --write",
      "eslint --fix"
    ],
    "**/*.(json)": [
      "prettier --write"
    ]
  },
  "eslintConfig": {
    "parserOptions": {
      "project": [
        "./tsconfig.json",
        "./config/tsconfig.json",
        "./scripts/tsconfig.json"
      ]
    },
    "extends": "@universe-design"
  },
  "dependencies": {
    "@babel/runtime": "^7.23.8",
    "@universe-design/react-utilities": "^0.13.2",
    "@universe-design/stylex-types": "^0.2.0",
    "clsx": "^1.1.1",
    "csstype": "~3.0.11",
    "lodash": "^4.17.21",
    "tiny-invariant": "^1.2.0",
    "tiny-warning": "^1.0.3",
    "tslib": "^2.3.1"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.23.8",
    "@babel/preset-typescript": "^7.23.3",
    "@jest/types": "^29.3.1",
    "@rushstack/heft": "^0.56.2",
    "@testing-library/react-hooks": "^7.0.2",
    "@types/heft-jest": "^1.0.3",
    "@types/jest": "^29.5.3",
    "@types/lodash": "^4.14.191",
    "@types/node": "^18.14.6",
    "@types/react": "^17.0.39",
    "@types/react-dom": "^17.0.11",
    "@universe-design/babel-plugin-transform-stylex": "^0.3.4",
    "@universe-design/config": "~0.1.0",
    "@universe-design/heft-rig": "^0.7.5",
    "@universe-design/site-template": "^2.10.3",
    "@universe-design/ud-tools": "~2.1.5",
    "eslint": "^8.33.0",
    "jest": "^29.3.1",
    "lint-staged": "~11.0.0",
    "prettier": "^2.8.7",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-test-renderer": "^17.0.2",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2",
    "@universe-design/eslint-config": "1.1.8"
  },
  "peerDependencies": {
    "react": ">=16.8",
    "react-dom": ">=16.8"
  },
  "scripts": {
    "_phase:api-doc-generate": "heft run --only api-doc-generate -- --clean",
    "_phase:build": "heft run --only build -- --clean",
    "_phase:build-esm-bundle": "heft run --only build-esm-bundle -- --clean",
    "_phase:lint": "heft run --only lint -- --clean",
    "_phase:test-dist": "heft run --only test -- --clean",
    "api-doc-generate": "heft api-doc-generate --clean",
    "build": "heft build --clean",
    "clean": "heft clean",
    "docs:start": "site-cli start",
    "fix": "eslint --ext .js,.ts,.tsx . --fix",
    "lint": "heft lint --clean",
    "mono:precommit": "lint-staged",
    "site": "heft site",
    "site:build": "heft site-build",
    "test": "heft test --clean",
    "watch": "heft test-watch"
  }
}