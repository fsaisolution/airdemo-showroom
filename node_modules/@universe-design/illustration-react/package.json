{
  "name": "@universe-design/illustration-react",
  "version": "1.57.3",
  "description": "",
  "license": "MIT",
  "sideEffects": [
    "*.css"
  ],
  "main": "dist/cjs/index.svgs.js",
  "module": "dist/esm/index.svgs.js",
  "types": "dist/esm/index.svgs.d.ts",
  "typings": "dist/esm/index.svgs.d.ts",
  "files": [
    "dist",
    "es2017"
  ],
  "scripts": {
    "_phase:publish": "npm publish",
    "_phase:ttp-publish": "npm publish || echo 'publish failed, this version may already exists'",
    "build": "npm run transform && npm run build:esm && npm run build:es2017",
    "build:es2017": "rm -rf ./es2017 && rollup --config build/rollup-2017.config.js",
    "build:esm": "rm -rf ./dist && rollup --config build/rollup.config.js",
    "code-connect": "node scripts/figma-connect.js",
    "code-connect:publish": "npx figma connect publish ",
    "mono:prepare": "npm run build",
    "preview:build": "vite build ./preview --base ''",
    "preview:dev": "vite ./preview",
    "publish:local": "npm run build && npm run _phase:publish",
    "transform": "bun ./scripts/transform.ts",
    "vite:build": "vite build"
  },
  "dependencies": {
    "@universe-design/illustration": "1.57.1"
  },
  "devDependencies": {
    "@figma/code-connect": "~0.1.1",
    "@rollup/plugin-commonjs": "^20.0.0",
    "@rollup/plugin-node-resolve": "^13.0.4",
    "@rollup/plugin-typescript": "^8.2.5",
    "@svgr/core": "^5.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@universe-design/styles": "^10.20.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitejs/plugin-react-refresh": "^1.3.1",
    "chalk": "^4.1.0",
    "dotenv": "^16.4.5",
    "less": "^4.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rollup": "^2.56.2",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-delete": "^2.0.0",
    "rollup-plugin-multi-input": "^1.3.1",
    "rollup-plugin-typescript2": "^0.36.0",
    "ts-node": "^10.2.0",
    "typescript": "^4.3.2",
    "vite": "^5.3.5"
  }
}
