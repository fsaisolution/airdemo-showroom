{
  "name": "@universe-design/styles",
  "version": "11.19.0",
  "license": "UNLICENSED",
  "sideEffects": [
    "font/lark-circular/index.js"
  ],
  "main": "cjs/index.js",
  "module": "esm/index.js",
  "types": "esm/index.d.ts",
  "typings": "esm/index.d.ts",
  "files": [
    "cjs",
    "esm",
    "json",
    "font",
    "less",
    "scss",
    "ts",
    "json-dist",
    "css-var-mixins",
    "CHANGELOG.md"
  ],
  "lint-staged": {
    "**/*.(less|json)": [
      "prettier --write"
    ],
    "**/*.(js|jsx|ts|tsx)": [
      "eslint --fix"
    ]
  },
  "browserslist": [
    "> 1%, last 2 versions, not dead",
    "Firefox ESR",
    "IE 11"
  ],
  "eslintConfig": {
    "extends": "@universe-design"
  },
  "dependencies": {
    "@universe-design/colors": "^1.3.14",
    "glob": "~7.1.7",
    "tslib": "^2.3.1"
  },
  "devDependencies": {
    "@microsoft/rush-lib": "^5.162.0",
    "@testing-library/react": "^12.1.2",
    "@types/eslint": "^7.29.0",
    "@types/fs-extra": "~9.0.11",
    "@types/glob": "~7.1.3",
    "@types/inquirer": "^9.0.3",
    "@types/jest": "^29.5.3",
    "@types/less": "^3.0.3",
    "@types/lodash": "^4.14.191",
    "@types/mkdirp": "^1.0.2",
    "@types/npmlog": "^4.1.4",
    "@types/prettier": "^2.7.1",
    "@types/react": "^17.0.39",
    "@types/react-dom": "^17.0.11",
    "@types/semver": "^7.3.9",
    "@universe-design/config": "~0.1.0",
    "axios": "^1.2.2",
    "chalk": "~4.1.1",
    "change-case": "~4.1.2",
    "dotenv": "^10.0.0",
    "dotenv-expand": "^5.1.0",
    "eslint": "^8.33.0",
    "execa": "^5.1.1",
    "fs-extra": "~10.0.0",
    "jest": "^29.3.1",
    "less": "^4.2.2",
    "lint-staged": "~11.0.0",
    "lodash": "^4.17.21",
    "mkdirp": "^1.0.4",
    "prettier": "^2.8.7",
    "react": "^17.0.2",
    "react-16": "npm:react@^16.14.0",
    "react-18": "npm:react@^18.0.0",
    "react-dom": "^17.0.2",
    "semver": "^7.3.5",
    "shx": "^0.3.3",
    "temp-write": "^4.0.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2",
    "xlsx": "^0.16.9",
    "@universe-design/eslint-config": "1.1.8"
  },
  "peerDependencies": {
    "less": "^3.13.1",
    "react": ">=16.8",
    "react-dom": ">=16.8"
  },
  "scripts": {
    "_phase:build": "rushx build",
    "_phase:lint": "rushx lint:js",
    "_phase:test": "rushx test 2>&1",
    "build": "rushx clean && rushx build:json && rushx build:ts && rushx build:less && rushx build:biz-ts && rushx build:js && rushx build:mixin && rushx build:variables",
    "build:biz-ts": "ts-node-script scripts/gen-biz-ts-from-biz-less.ts",
    "build:js": "tsc -p tsconfig.build.json --noEmit false --outDir esm --module esnext && tsc -p tsconfig.build.json --noEmit false --outDir cjs --module commonjs",
    "build:json": "ts-node-script scripts/gen-json.ts",
    "build:less": "ts-node-script scripts/gen-less-from-json.ts",
    "build:mixin": "ts-node-script scripts/gen-mixins-from-json.ts",
    "build:ts": "ts-node-script scripts/gen-ts-from-json.ts",
    "build:variables": "ts-node-script scripts/gen-figma-variables.ts",
    "changelog": "ts-node scripts/patch-change-log.ts",
    "clean": "shx rm -rf esm cjs",
    "fix": "rushx run:prettier --write && rushx lint:js --fix",
    "get-token-list-xlsx": "ts-node-script scripts/get-token-list-xlsx.ts",
    "if-new-updates-exist": "node -e \"console.log('process.argv: ', process.argv);var changes = process.argv[1].split('\\n').filter(o => !o.includes('scripts/token_list.xlsx'));if(changes.length === 0) throw new Error('No new updates exist.');\" \"$(git status -s)\"",
    "lint:js": "eslint --ext .js,.ts .",
    "mono:precommit": "lint-staged",
    "run:prettier": "prettier \"**/*.{json,less}\"",
    "test": "jest",
    "update-token": "rushx get-token-list-xlsx && rushx build && rushx if-new-updates-exist && rushx test -u && rushx build && git add . && git commit -m 'chore(styles): 更新 token'"
  }
}