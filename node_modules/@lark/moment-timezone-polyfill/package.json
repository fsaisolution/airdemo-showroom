{
  "name": "@lark/moment-timezone-polyfill",
  "version": "0.0.12",
  "files": [
    "dist",
    "node.d.ts",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./node.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "main": "dist/index.js",
  "types": "node.d.ts",
  "repository": {
    "url": "https://code.byted.org/lark/moment-timezone.git",
    "directory": "packages/moment-timezone-polyfill"
  },
  "dependencies": {
    "moment": "^2.29.0",
    "moment-timezone": "^0.5.45",
    "@lark/moment-timezone-intl": "^0.0.11"
  },
  "devDependencies": {
    "@types/node": "^18.19.3",
    "tsup": "^8.0.1",
    "typescript": "^5.1.6",
    "vitest": "^1.0.4"
  },
  "scripts": {
    "build": "rm -rf dist && tsup",
    "test": "TZ=Asia/Shanghai pnpm test:integration",
    "test:integration": "SHOULD_POLYFILL=true node --test ./tests/** && SHOULD_POLYFILL=false node --test ./tests/**"
  }
