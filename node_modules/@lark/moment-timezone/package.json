{
  "name": "@lark/moment-timezone",
  "version": "0.0.65",
  "description": "moment-timezone 的 lark 封装",
  "main": "lib/index.js",
  "module": "es/index.mjs",
  "typings": "es/index.d.mts",
  "files": [
    "dist",
    "lib",
    "es",
    "src",
    "dynamic-locales.d.ts",
    "dynamic-locales.js",
    "es.d.ts",
    "index.d.ts",
    "locales.d.ts",
    "locales.js",
    "isolate.d.ts",
    "isolate.js",
    "isolate/locales.d.ts",
    "isolate/locales.js",
    "LICENSE",
    "CHANGELOG.md",
    "README.md"
  ],
  "sideEffects": [
    "es/locales/*.js",
    "es/static.js",
    "lib/locales/*.js",
    "lib/static.js"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./es/index.d.mts",
        "default": "./es/index.mjs"
      },
      "require": {
        "types": "./lib/index.d.ts",
        "default": "./lib/index.js"
      }
    },
    "./locales": {
      "import": {
        "types": "./es/locales.d.mts",
        "default": "./es/locales.mjs"
      },
      "require": {
        "types": "./lib/locales.d.ts",
        "default": "./lib/locales.js"
      }
    },
    "./isolate": {
      "import": {
        "types": "./es/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./lib/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./isolate/locales": {
      "import": {
        "types": "./es/locales.d.mts",
        "default": "./dist/locales.mjs"
      },
      "require": {
        "types": "./lib/locales.d.ts",
        "default": "./dist/locales.js"
      }
    },
    "./es": {
      "types": "./es/index.d.mts",
      "default": "./es/index.mjs"
    },
    "./lib": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "./es/*": {
      "types": "./es/*.d.mts",
      "default": "./es/*.mjs"
    },
    "./lib/*": {
      "types": "./lib/*.d.mts",
      "default": "./lib/*.js"
    },
    "./*": {
      "import": {
        "types": "./es/*.d.mts",
        "default": "./es/*.mjs"
      },
      "require": {
        "types": "./lib/*.d.ts",
        "default": "./lib/*.js"
      }
    }
  },
  "repository": {
    "url": "https://code.byted.org/lark/moment-timezone.git",
    "directory": "packages/moment-timezone"
  },
  "author": "Cheng Cheng",
  "license": "MIT",
  "homepage": "https://code.byted.org/lark/moment-timezone",
  "dependencies": {
    "moment": "^2.29.0",
    "@lark/moment-timezone-polyfill": "^0.0.12"
  },
  "devDependencies": {
    "@ies/starling-cli": "^2.7.3",
    "@types/fs-extra": "^8.1.0",
    "@types/node": "^18.19.3",
    "@typescript-eslint/eslint-plugin": "^2.30.0",
    "@typescript-eslint/parser": "^2.30.0",
    "@vitest/coverage-v8": "^1.0.4",
    "chalk": "^4.0.0",
    "eslint": "^6.8.0",
    "fs-extra": "^11.2.0",
    "husky": "^4.2.5",
    "lint-staged": "^10.2.0",
    "tsup": "^8.0.1",
    "typescript": "^4.8.4",
    "vitest": "^1.0.4"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged & jest -u"
    }
  },
  "lint-staged": {
    "*.{.ts,.js}": [
      "eslint",
      "git add"
    ]
  },
  "scripts": {
    "di18n": "starling fetch",
    "build": "tsup && rm -rf ./es/locales/*.d.mts",
    "test": "pnpm test:unit && pnpm test:integration",
    "test:unit": "vitest run --dir ./test",
    "test:integration": "SHOULD_POLYFILL=true node --test ./integration/** && SHOULD_POLYFILL=false node --test ./integration/**",
    "lint": "eslint --ext .js,.ts ./src",
    "lint:fix": "eslint --fix --ext .js,.ts ./src"
  }
}