{
  "DateDayCombineFormat": "{{date}} ({{day}})",
  "DateTimeCombineFormat": "{{date}} {{time}}",
  "GMTTimeFormat": "{{time}} ({{GMT}})",
  "LongDateFormat": "YYYY年M月D日",
  "LongMonthFormat": "YYYY年M月",
  "LongSecondFormat": "Ah:mm:ss||||HH:mm:ss",
  "LongWeekdayFormat": "dddd",
  "MeridiemFormat": "A||||",
  "MinHourFormat": "h点||||HH:mm",
  "MinMinuteFormat": "h:mm||||HH:mm",
  "ShortDateFormat": "M月D日",
  "ShortHourFormat": "Ah点||||HH:mm",
  "ZeroMinuteHourFormat": "Ah:00||||HH:00",
  "ShortMinuteFormat": "Ah:mm||||HH:mm",
  "ShortMonthFormat": "MMM",
  "ShortWeekdayFormat": "ddd",
  "TimeRangeFormat": "{{startTime}} - {{endTime}}",
  "TimeRangeInOneDayFormat": "{{date}} {{rangeTime}}",
