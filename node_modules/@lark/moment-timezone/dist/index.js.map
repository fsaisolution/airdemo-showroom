{
  "DateDayCombineFormat": "{{day}}, {{date}}",
  "DateTimeCombineFormat": "{{date}} {{time}}",
  "GMTTimeFormat": "{{time}} ({{GMT}})",
  "LongDateFormat": "D. MMM YYYY",
  "LongMonthFormat": "MMM YYYY",
  "LongSecondFormat": "h:mm:ss A||||HH:mm:ss",
  "LongWeekdayFormat": "dddd",
  "MeridiemFormat": "A||||",
  "MinHourFormat": "h:mm||||HH:mm",
  "MinMinuteFormat": "h:mm||||HH:mm",
  "ShortDateFormat": "D. MMM",
  "ShortHourFormat": "h A||||HH:mm",
  "ZeroMinuteHourFormat": "h:00 A||||HH:00",
  "ShortMinuteFormat": "h:mm A||||HH:mm",
  "ShortMonthFormat": "MMMM",
  "ShortWeekdayFormat": "ddd",
  "TimeRangeFormat": "{{startTime}} - {{endTime}}",
  "TimeRangeInOneDayFormat": "{{date}} {{rangeTime}}",
