c6","main":"./dist/index.cjs","devDependencies":{"@rslib/core":"^0.6.3","globals":"^16.0.0","@types/luxon":"^3.4.2","@biomejs/biome":"^1.9.4","eslint":"^9.27.0","typescript-eslint":"^8.29.0","@vitest/coverage-v8":"3.1.1","typescript":"^5.8.3","shx":"^0.3.4","@types/jsonwebtoken":"^8.5.1","@types/node-fetch":"^2.6.11","vitest":"^3.1.1","@types/json-schema":"^7.0.15","@types/estree":"^1.0.5","prettier":"^3.5.3","@eslint/js":"^9.27.0","@types/node":"^22.8.1","ts-node":"^10.9.2"},"dist":{"unpackedSize":76886,"fileCount":13,"shasum":"223bab2548ae78066e2c5c743905ef85e75fe8e3","integrity":"sha512-1M112TTvvVx0NhMkLBVtEYE+cHCeT9+LEYibiXqiZj9MyJmVLHgzLybFiUafFzaloMJXnBc0Z/7RMhs/ogG7xg==","tarball":"https://bnpm.byted.org/@byted/mcp-proxy/-/mcp-proxy-1.3.7-rc6.tgz","size":12599},"_npmUser":{"email":"mario7lorenzo@bytedance.com","name":"mario7lorenzo"},"_id":"@byted/mcp-proxy@1.3.7-rc6","license":"MIT","module":"./dist/index.js","bin":{"mcp-proxy":"dist/index.js"},"readme":"# @byted/mcp-proxy\n\n## 0. Introduction\n\n`@byted/mcp-proxy` 是一个用于将 ByteFaaS MCP Server 代理到本地的工具，适配各种第三方 MCP Client，如：\n\n- Trae (推荐)\n- Cursor\n- Windsurf\n- VS Code Cline\n\n## 1. Bnpm\n\n- https://bnpm.bytedance.net/package/@byted/mcp-proxy\n\n## 2. Precondition\n\n- 需要安装 Node.js v22 或更高版本。推荐使用 `nvm` 进行安装和管理：\n\n```bash\ncurl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.2/install.sh | bash\nnvm install 22 && nvm use 22 && nvm alias default 22\n```\n\n## 3. Config sample\n\n`@byted/mcp-proxy` 支持通过 4 种方案进行鉴权：\n\n- `bytefaas-cli` SSO 鉴权（个人账号的推荐方案）\n- 通过环境变量指定配置文件鉴权（服务账号的推荐方案）\n- 通过环境变量指定 `SERVICE_ACCOUNT_SECRET_KEY` 鉴权\n- 通过环境变量指定 `USER_JWT_TOKEN` 鉴权\n\n### 3.1 `bytefaas-cli` SSO 鉴权\n\n配置 `@byted/mcp-proxy` 前，需要先下载 [bytefaas-cli](https://cloud.bytedance.net/docs/faas/docs/63d786117df7d2021dfc68e3/648a99992ca7dd02263c0d85) 并且完成登录:\n\n```shell\n# CN 或 BOE 区域登录命令\nAPP_ENV=production bytefaas login\n\n# I18N 区域登录命令\nAPP_ENV=i18n bytefaas login\n```\n\n获取 `bytefaas-cli` 登录态后，以当前用户个人账号身份使用 `@byted/mcp-proxy` 时，不再需要配置任何鉴权字段。\n\n```json\n{\n  \"mcpServers\": {\n    \"mcp-server-sample\": {\n      \"command\": \"npx\",\n      \"args\": [\"--registry\", \"https://bnpm.byted.org\", \"-y\", \"@byted/mcp-proxy@latest\"],\n      \"env\": {\n        \"MCP_SERVER_PSM\": \"inf.sinf.sample_mcp\",\n        \"MCP_GATEWAY_REGION\": \"CN\"\n      }\n    }\n  }\n}\n```\n\n### 3.2 通过环境变量指定配置文件鉴权\n\n```json\n{\n  \"mcpServers\": {\n    \"mcp-server-sample\": {\n      \"command\": \"npx\",\n      \"args\": [\"--registry\", \"https://bnpm.byted.org\", \"-y\", \"@byted/mcp-proxy@latest\"],\n      \"env\": {\n        \"MCP_SERVER_PSM\": \"inf.sinf.sample_mcp\",\n        \"MCP_GATEWAY_REGION\": \"CN\",\n        \"AUTHENTICATION_PROFILE_PATH\": \"/Users/bytedance/myAuthenticationProfile.json\"\n      }\n    }\n  }\n}\n```\n\n`authenticationProfile.json` 文件模板:\n\n```json\n{\n  \"serviceAccountSecretKey\": \"******\",\n  \"userJwtToken\": \"******\"\n}\n```\n\n注意：`serviceAccountSecretKey` 和 `userJwtToken` 不能同时被赋值。且由于 `userJwtToken` 存在过期机制，推荐使用 `serviceAccountSecretKey` 进行鉴权。\n\n### 3.3 通过环境变量指定 `SERVICE_ACCOUNT_SECRET_KEY` 鉴权\n\n```json\n{\n  \"mcpServers\": {\n    \"mcp-server-sample\": {\n      \"command\": \"npx\",\n      \"args\": [\"--registry\", \"https://bnpm.byted.org\", \"-y\", \"@byted/mcp-proxy@latest\"],\n      \"env\": {\n        \"MCP_SERVER_PSM\": \"inf.sinf.sample_mcp\",\n        \"MCP_GATEWAY_REGION\": \"CN\",\n        \"SERVICE_ACCOUNT_SECRET_KEY\": \"******\"\n      }\n    }\n  }\n}\n```\n\n### 3.4 通过环境变量指定 `USER_JWT_TOKEN` 鉴权\n\n```json\n{\n  \"mcpServers\": {\n    \"mcp-server-sample\": {\n      \"command\": \"npx\",\n      \"args\": [\"--registry\", \"https://bnpm.byted.org\", \"-y\", \"@byted/mcp-proxy@latest\"],\n      \"env\": {\n        \"MCP_SERVER_PSM\": \"inf.sinf.sample_mcp\",\n        \"MCP_GATEWAY_REGION\": \"CN\",\n        \"USER_JWT_TOKEN\": \"******\"\n      }\n    }\n  }\n}\n```\n\n### 3.5 使用 `MCP_SERVER_CALL_TOOL_HEADERS` 指定 Call Tool 阶段的 Headers\n\n```json\n{\n  \"mcpServers\": {\n    \"mcp-server-sample\": {\n      \"command\": \"npx\",\n      \"args\": [\"--registry\", \"https://bnpm.byted.org\", \"-y\", \"@byted/mcp-proxy@latest\"],\n      \"env\": {\n        \"MCP_SERVER_PSM\": \"inf.sinf.sample_mcp\",\n        \"MCP_GATEWAY_REGION\": \"CN\",\n        \"MCP_SERVER_CALL_TOOL_HEADERS\": \"key1=value1,key2=value2\"\n      }\n    }\n  }\n}\n```\n\n### 3.6 使用 `MCP_SERVER_CALL_TOOL_COOKIES` 指定 Call Tool 阶段的 Cookies\n\n```json\n{\n  \"mcpServers\": {\n    \"mcp-server-sample\": {\n      \"command\": \"npx\",\n      \"args\": [\"--registry\", \"https://bnpm.byted.org\", \"-y\", \"@byted/mcp-proxy@latest\"],\n      \"env\": {\n        \"MCP_SERVER_PSM\": \"inf.sinf.sample_mcp\",\n        \"MCP_GATEWAY_REGION\": \"CN\",\n        \"MCP_SERVER_CALL_TOOL_COOKIES\": \"cookie1=value1; cookie2=value2\"\n      }\n    }\n  }\n}\n```\n\n## 4. Environment variables\n\n- `MCP_SERVER_PSM`：目标 MCP Server 的 PSM，必填。可以在 ByteFaaS 平台查看完整服务列表 [[Link](https://cloud.bytedance.net/faas/mcp_servers?x-resource-account=public&x-bc-region-id=bytedance)]\n- `MCP_GATEWAY_REGION`：MCP Gateway 的区域，必填，可选值：`BOE`、`CN`、`I18N`\n- `AUTHENTICATION_PROFILE_PATH`：鉴权配置文件路径，选填。`AUTHENTICATION_PROFILE_PATH`、`SERVICE_ACCOUNT_SECRET_KEY`、`USER_JWT_TOKEN` 最多只能赋值 1 个，如果都不赋值，`@byted/mcp-proxy` 将不会携带鉴权信息访问 MCP Server。\n- `SERVICE_ACCOUNT_SECRET_KEY`: 服务账号 SecretKey，选填。`AUTHENTICATION_PROFILE_PATH`、`SERVICE_ACCOUNT_SECRET_KEY`、`USER_JWT_TOKEN` 最多只能赋值 1 个，如果都不赋值，`@byted/mcp-proxy` 将不会携带鉴权信息访问 MCP Server。\n- `USER_JWT_TOKEN`: 用户 JWT Token，选填。`AUTHENTICATION_PROFILE_PATH`、`SERVICE_ACCOUNT_SECRET_KEY`、`USER_JWT_TOKEN` 最多只能赋值 1 个，如果都不赋值，`@byted/mcp-proxy` 将不会携带鉴权信息访问 MCP Server。\n- `MCP_REQUEST_TIMEOUT_MS`: 配置 MCP 请求的超时时间，默认超时时间为 60 秒\n- `MCP_SERVER_CALL_TOOL_HEADERS`: 指定 Call Tool 阶段的 Headers，例如：key1=value1,key2=value2\n- `MCP_SERVER_CALL_TOOL_PARAMS`: 指定 Call Tool 阶段的 Params，例如：param1=value1,param2=value2\n- `MCP_SERVER_CALL_TOOL_WITH_COOKIES`: 是否在 Call Tool 阶段透传字节云的 Cookie，默认为 false\n- `MCP_SERVER_CALL_TOOL_COOKIES`: 指定 Call Tool 阶段的 Cookies，例如：cookie1=value1; cookie2=value2\n- `MCP_SERVER_TOOL_BLOCK_LIST`: MCP Server 提供的 Tool list 黑名单\n- `MCP_SERVER_TOOL_ALLOW_LIST`: MCP Server 提供的 Tool list 白名单\n- `LOG_LEVEL`: MCP Proxy 日志级别，可选值：`trace`、`debug`、`info`、`warn`、`error`，默认值：`info`\n\n\n## 5. Change log\n\n- `1.3.4`:\n  - 🏗 集成 `@byted/ai-paas-env`\n  - 🐛 修复 `MCP_SERVER_CALL_TOOL_COOKIES` 未成功透传 Cookie 的问题\n  - 🐛 修复 Non-TT 域名拉闸导致的 I18N MCP 网关域名访问不了的问题\n- `1.2.3`:\n  - ✨ 支持通过环境变量 `LOG_LEVEL` 指定日志级别\n  - 🏗 升级 `@byted/mcp-client-sdk` 依赖版本到 `1.1.1`\n- `1.1.0`:\n  - ✨ 支持通过环境变量 `MCP_SERVER_CALL_TOOL_COOKIES` 指定 Call Tool 阶段的 Cookies\n- `1.0.0`:\n  - 🏗 发布正式版本\n- `0.0.20250701-1`:\n  - 🏗 修改通过 Tiktok SSO 获取 JWT 的超时时间为 10 秒\n- `0.0.20250618-1`:\n  - 🏗 修改通过 Service account secret key 获取 JWT 的超时时间为 10 秒\n- `0.0.20250609-1`:\n  - ✨ 当 `bytefaas-cli` 登录态过期后，在 Init 阶段的日志里提示用户重新登录\n- `0.0.20250528-1`:\n  - ✨ 支持通过环境变量 `MCP_SERVER_TOOL_BLOCK_LIST` 和 `MCP_SERVER_TOOL_ALLOW_LIST` 对 MCP Server 提供的 Tool list 进行限制\n- `0.0.20250523-2`:\n  - ✨ 支持通过环境变量 `MCP_SERVER_CALL_TOOL_WITH_COOKIES` 指定，是否在 Call Tool 阶段透传字节云的 Cookie\n- `0.0.20250521-4`:\n  - 🏗 升级 `@byted/mcp-client-sdk` 依赖版本到 `0.0.20250521-2`\n  - 🏗 强制指定网络环境为办公网\n  - 🏗 标准化日志输出\n  - 🏗 修改默认超时时间为 60 秒\n  - 🏗 在 MCP Server Init 阶段提前执行一次 `listToolsHandler` ，以便将 List Tool 阶段的 401 错误提前暴露\n- `0.0.20250520-1`:\n  - ✨ 支持通过环境变量 `MCP_SERVER_CALL_TOOL_HEADERS` 和 `MCP_SERVER_CALL_TOOL_PARAMS` 指定 Call Tool 阶段的 Headers 和 Params\n- `0.0.20250507-1`:\n  - 🏗 升级 `@byted/mcp-client-sdk` 依赖版本到 `0.0.20250430-1`\n  - 🐛 修复 I18N 区域无法通过 `serviceAccountSecretKey` 获取 JWT 的问题\n- `0.0.20250428-3`:\n  - 🏗 当 `BytedMcpClient.loadAllTools` 失败时，捕获异常并且打印日志\n  - ✨ 支持 I18N 区域的 MCP Server 自动从 [bytefaas-cli](https://cloud.bytedance.net/docs/faas/docs/63d786117df7d2021dfc68e3/648a99992ca7dd02263c0d85) 的 SSO 数据里获取 JWT Token (不再需要显式指定`USER_JWT_TOKEN`)，通过 `APP_ENV=i18n bytefaas login` 登录后，登录态可以最长可以维持 1 个月\n- `0.0.20250427-2`:\n  - 🏗 在通过任意方式获取 JWT 后，进行 auth 验证，拦截无效的 JWT，并且打印有效 JWT 的身份信息\n  - ✨ 支持 CN 和 BOE 区域的 MCP Server 自动从 [bytefaas-cli](https://cloud.bytedance.net/docs/faas/docs/63d786117df7d2021dfc68e3/648a99992ca7dd02263c0d85) 的 SSO 数据里获取 JWT Token (不再需要显式指定`USER_JWT_TOKEN`)，通过 `APP_ENV=production bytefaas login` 登录后，登录态可以最长可以维持 1 年\n- `0.0.20250425-2`:\n  - 🏗 打印 Call Tool 阶段的 Request Header, Request Body, Response Body\n  - ✨ 支持通过环境变量 `MCP_REQUEST_TIMEOUT_MS` 配置 MCP 请求的超时时间，默认超时时间为 10 秒\n- `0.0.20250424-1`:\n  - 🏗 升级 `@byted/mcp-client-sdk` 依赖版本到 `0.0.20250423-1`\n- `0.0.20250422-2`:\n  - 🏗 升级 `@byted/mcp-client-sdk` 依赖版本到 `0.0.20250421-6`\n  - ✨ 支持每 30 分钟更新由 `serviceAccountSecretKey` 生成的 JWT Token\n  - ✨ 支持在环境变量中直接指定 `SERVICE_ACCOUNT_SECRET_KEY` 和 `USER_JWT_TOKEN` (不过，为了避免 `serviceAccountSecretKey` 泄露，以及提升鉴权配置文件的复用度，推荐配置 `AUTHENTICATION_PROFILE_PATH` 鉴权 )\n- `0.0.20250420-2`:\n  - ✨ 支持透传 `AUTHENTICATION_PROFILE_PATH` 里的 `userJwtToken`\n  - ✨ 支持通过 `serviceAccountSecretKey` 获取 JWT Token 后调用 MCP Server\n\n## 6. Luban\n\n- https://luban.bytedance.net/npm/publish/detail/8489/versions\n","type":"module","description":"## 0. Introduction","name":"@byted/mcp-proxy","dependencies":{"@modelcontextprotocol/sdk":"^1.0.3","jsonwebtoken":"^8.5.1","zod":"^3.24.1","@byted-service/fetch":"^2.6.5","@byted/ai-paas-env":"^1.0.6","@byted/mcp-client-sdk":"^1.3.3"},"files":["dist"]},"1.0.0":{"version":"1.0.0","maintainers":[{"email":"yangyang.jeff@bytedance.com","name":"yangyang.jeff"}],"module":"./dist/index.js","dependencies":{"zod":"^3.24.1","@modelcontextprotocol/sdk":"^1.0.3","@byted/mcp-client-sdk":"0.0.20250521-2","jsonwebtoken":"^8.5.1","@byted-service/fetch":"^2.6.5"},"exports":{".":{"types":"./dist/index.d.ts","import":"./dist/index.js","require":"./dist/index.cjs"}},"_npmUser":{"name":"yangyang.jeff","email":"yangyang.jeff@bytedance.com"},"files":["dist"],"types":"./dist/index.d.ts","devDependencies":{"@types/node":"^22.8.1","typescript-eslint":"^8.29.0","vitest":"^3.1.1","ts-node":"^10.9.2","@types/jsonwebtoken":"^8.5.1","globals":"^16.0.0","@eslint/js":"^9.27.0","prettier":"^3.5.3","eslint":"^9.27.0","@rslib/core":"^0.6.3","typescript":"^5.8.3","@biomejs/biome":"^1.9.4","shx":"^0.3.4"},"readmeFilename":"README.md","license":"MIT","name":"@byted/mcp-proxy","_id":"@byted/mcp-proxy@1.0.0","dist":{"fileCount":8,"shasum":"de3fca2d11dd4b3278040c95d94ca76a6cd561bc","integrity":"sha512-97b3v3SMUQAz7XCO3HrCsQmLsm/LED7P+sOe8zI1fKZYRBHFi1qFfLdCYG0/8CxHAUpHrlec0+XGp6qWCcRpBw==","tarball":"https://bnpm.byted.org/@byted/mcp-proxy/-/mcp-proxy-1.0.0.tgz","size":10975,"unpackedSize":66560},"bin":{"mcp-proxy":"dist/index.js"},"description":"## 0. Introduction","type":"module","scripts":{"build":"rslib build","check":"biome check --write","dev":"rslib build --watch","format":"prettier --write .","lint":"eslint .","test":"vitest run","playground":"ts-node __test__/playground.ts"},"main":"./dist/index.cjs","readme":"# @byted/mcp-proxy\n\n## 0. Introduction\n\n`@byted/mcp-proxy` 是一个用于将 ByteFaaS MCP Server 代理到本地的工具，适配各种第三方 MCP Client，如：\n\n- Trae (推荐)\n- Cursor\n- Windsurf\n- VS Code Cline\n\n## 1. Bnpm\n\n- https://bnpm.bytedance.net/package/@byted/mcp-proxy\n\n## 2. Precondition\n\n- 需要安装 Node.js v22 或更高版本。推荐使用 `nvm` 进行安装和管理：\n\n```bash\ncurl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.2/install.sh | bash\nnvm install 22 && nvm use 22 && nvm alias default 22\n```\n\n## 3. Config sample\n\n`@byted/mcp-proxy` 支持通过 4 种方案进行鉴权：\n\n- `bytefaas-cli` SSO 鉴权（个人账号的推荐方案）\n- 通过环境变量指定配置文件鉴权（服务账号的推荐方案）\n- 通过环境变量指定 `SERVICE_ACCOUNT_SECRET_KEY` 鉴权\n- 通过环境变量指定 `USER_JWT_TOKEN` 鉴权\n\n### 3.1 `bytefaas-cli` SSO 鉴权\n\n配置 `@byted/mcp-proxy` 前，需要先下载 [bytefaas-cli](https://cloud.bytedance.net/docs/faas/docs/63d786117df7d2021dfc68e3/648a99992ca7dd02263c0d85) 并且完成登录:\n\n```shell\n# CN or BOE 区域登录命令\nAPP_ENV=production bytefaas login\n\n# I18N 区域登录命令\nAPP_ENV=i18n bytefaas login\n```\n\n获取 `bytefaas-cli` 登录态后，以当前用户个人账号身份使用 `@byted/mcp-proxy` 时，不再需要配置任何鉴权字段。\n\n```json\n{\n  \"mcpServers\": {\n    \"mcp-server-sample\": {\n      \"command\": \"npx\",\n      \"args\": [\"--registry\", \"https://bnpm.byted.org\", \"-y\", \"@byted/mcp-proxy@latest\"],\n      \"env\": {\n        \"MCP_SERVER_PSM\": \"inf.sinf.sample_mcp\",\n        \"MCP_GATEWAY_REGION\": \"CN\"\n      }\n    }\n  }\n}\n```\n\n### 3.2 通过环境变量指定配置文件鉴权\n\n```json\n{\n  \"mcpServers\": {\n    \"mcp-server-sample\": {\n      \"command\": \"npx\",\n      \"args\": [\"--registry\", \"https://bnpm.byted.org\", \"-y\", \"@byted/mcp-proxy@latest\"],\n      \"env\": {\n        \"MCP_SERVER_PSM\": \"inf.sinf.sample_mcp\",\n        \"MCP_GATEWAY_REGION\": \"CN\",\n        \"AUTHENTICATION_PROFILE_PATH\": \"/Users/bytedance/myAuthenticationProfile.json\"\n      }\n    }\n  }\n}\n```\n\n`authenticationProfile.json` 文件模板:\n\n```json\n{\n  \"serviceAccountSecretKey\": \"******\",\n  \"userJwtToken\": \"******\"\n}\n```\n\n注意：`serviceAccountSecretKey` 和 `userJwtToken` 不能同时被赋值。且由于 `userJwtToken` 存在过期机制，推荐使用 `serviceAccountSecretKey` 进行鉴权。\n\n### 3.3 通过环境变量指定 `SERVICE_ACCOUNT_SECRET_KEY` 鉴权\n\n```json\n{\n  \"mcpServers\": {\n    \"mcp-server-sample\": {\n      \"command\": \"npx\",\n      \"args\": [\"--registry\", \"https://bnpm.byted.org\", \"-y\", \"@byted/mcp-proxy@latest\"],\n      \"env\": {\n        \"MCP_SERVER_PSM\": \"inf.sinf.sample_mcp\",\n        \"MCP_GATEWAY_REGION\": \"CN\",\n        \"SERVICE_ACCOUNT_SECRET_KEY\": \"******\"\n      }\n    }\n  }\n}\n```\n\n### 3.4 通过环境变量指定 `USER_JWT_TOKEN` 鉴权\n\n```json\n{\n  \"mcpServers\": {\n    \"mcp-server-sample\": {\n      \"command\": \"npx\",\n      \"args\": [\"--registry\", \"https://bnpm.byted.org\", \"-y\", \"@byted/mcp-proxy@latest\"],\n      \"env\": {\n        \"MCP_SERVER_PSM\": \"inf.sinf.sample_mcp\",\n        \"MCP_GATEWAY_REGION\": \"CN\",\n        \"USER_JWT_TOKEN\": \"******\"\n      }\n    }\n  }\n}\n```\n\n## 4. Environment variables\n\n- `MCP_SERVER_PSM`：目标 MCP Server 的 PSM，必填。可以在 ByteFaaS 平台查看完整服务列表 [[Link](https://cloud.bytedance.net/faas/mcp_servers?x-resource-account=public&x-bc-region-id=bytedance)]\n- `MCP_GATEWAY_REGION`：MCP Gateway 的区域，必填，可选值：`BOE`、`CN`、`I18N`\n- `AUTHENTICATION_PROFILE_PATH`：鉴权配置文件路径，选填。`AUTHENTICATION_PROFILE_PATH`、`SERVICE_ACCOUNT_SECRET_KEY`、`USER_JWT_TOKEN` 最多只能赋值 1 个，如果都不赋值，`@byted/mcp-proxy` 将不会携带鉴权信息访问 MCP Server。\n- `SERVICE_ACCOUNT_SECRET_KEY`: 服务账号 SecretKey，选填。`AUTHENTICATION_PROFILE_PATH`、`SERVICE_ACCOUNT_SECRET_KEY`、`USER_JWT_TOKEN` 最多只能赋值 1 个，如果都不赋值，`@byted/mcp-proxy` 将不会携带鉴权信息访问 MCP Server。\n- `USER_JWT_TOKEN`: 用户 JWT Token，选填。`AUTHENTICATION_PROFILE_PATH`、`SERVICE_ACCOUNT_SECRET_KEY`、`USER_JWT_TOKEN` 最多只能赋值 1 个，如果都不赋值，`@byted/mcp-proxy` 将不会携带鉴权信息访问 MCP Server。\n- `MCP_REQUEST_TIMEOUT_MS`: 配置 MCP 请求的超时时间，默认超时时间为 60 秒\n- `MCP_SERVER_CALL_TOOL_HEADERS`: 指定 Call Tool 阶段的 Headers\n- `MCP_SERVER_CALL_TOOL_PARAMS`: 指定 Call Tool 阶段的 Params\n- `MCP_SERVER_CALL_TOOL_WITH_COOKIES`: 是否在 Call Tool 阶段透传字节云的 Cookie，默认为 false\n- `MCP_SERVER_TOOL_BLOCK_LIST`: MCP Server 提供的 Tool list 黑名单\n- `MCP_SERVER_TOOL_ALLOW_LIST`: MCP Server 提供的 Tool list 白名单\n\n\n## 5. Change log\n\n- `1.0.0`:\n  - 🏗 发布正式版本\n- `0.0.20250701-1`:\n  - 🏗 修改通过 Tiktok SSO 获取 JWT 的超时时间为 10 秒\n- `0.0.20250618-1`:\n  - 🏗 修改通过 Service account secret key 获取 JWT 的超时时间为 10 秒\n- `0.0.20250609-1`:\n  - ✨ 当 `bytefaas-cli` 登录态过期后，在 Init 阶段的日志里提示用户重新登录\n- `0.0.20250528-1`:\n  - ✨ 支持通过环境变量 `MCP_SERVER_TOOL_BLOCK_LIST` 和 `MCP_SERVER_TOOL_ALLOW_LIST` 对 MCP Server 提供的 Tool list 进行限制\n- `0.0.20250523-2`:\n  - ✨ 支持通过环境变量 `MCP_SERVER_CALL_TOOL_WITH_COOKIES` 指定，是否在 Call Tool 阶段透传字节云的 Cookie\n- `0.0.20250521-4`:\n  - 🏗 升级 `@byted/mcp-client-sdk` 依赖版本到 `0.0.20250521-2`\n  - 🏗 强制指定网络环境为办公网\n  - 🏗 标准化日志输出\n  - 🏗 修改默认超时时间为 60 秒\n  - 🏗 在 MCP Server Init 阶段提前执行一次 `listToolsHandler` ，以便将 List Tool 阶段的 401 错误提前暴露\n- `0.0.20250520-1`:\n  - ✨ 支持通过环境变量 `MCP_SERVER_CALL_TOOL_HEADERS` 和 `MCP_SERVER_CALL_TOOL_PARAMS` 指定 Call Tool 阶段的 Headers 和 Params\n- `0.0.20250507-1`:\n  - 🏗 升级 `@byted/mcp-client-sdk` 依赖版本到 `0.0.20250430-1`\n  - 🐛 修复 I18N 区域无法通过 `serviceAccountSecretKey` 获取 JWT 的问题\n- `0.0.20250428-3`:\n  - 🏗 当 `BytedMcpClient.loadAllTools` 失败时，捕获异常并且打印日志\n  - ✨ 支持 I18N 区域的 MCP Server 自动从 [bytefaas-cli](https://cloud.bytedance.net/docs/faas/docs/63d786117df7d2021dfc68e3/648a99992ca7dd02263c0d85) 的 SSO 数据里获取 JWT Token (不再需要显式指定`USER_JWT_TOKEN`)，通过 `APP_ENV=i18n bytefaas login` 登录后，登录态可以最长可以维持 1 个月\n- `0.0.20250427-2`:\n  - 🏗 在通过任意方式获取 JWT 后，进行 auth 验证，拦截无效的 JWT，并且打印有效 JWT 的身份信息\n  - ✨ 支持 CN 和 BOE 区域的 MCP Server 自动从 [bytefaas-cli](https://cloud.bytedance.net/docs/faas/docs/63d786117df7d2021dfc68e3/648a99992ca7dd02263c0d85) 的 SSO 数据里获取 JWT Token (不再需要显式指定`USER_JWT_TOKEN`)，通过 `APP_ENV=production bytefaas login` 登录后，登录态可以最长可以维持 1 年\n- `0.0.20250425-2`:\n  - 🏗 打印 Call Tool 阶段的 Request Header, Request Body, Response Body\n  - ✨ 支持通过环境变量 `MCP_REQUEST_TIMEOUT_MS` 配置 MCP 请求的超时时间，默认超时时间为 10 秒\n- `0.0.20250424-1`:\n  - 🏗 升级 `@byted/mcp-client-sdk` 依赖版本到 `0.0.20250423-1`\n- `0.0.20250422-2`:\n  - 🏗 升级 `@byted/mcp-client-sdk` 依赖版本到 `0.0.20250421-6`\n  - ✨ 支持每 30 分钟更新由 `serviceAccountSecretKey` 生成的 JWT Token\n  - ✨ 支持在环境变量中直接指定 `SERVICE_ACCOUNT_SECRET_KEY` 和 `USER_JWT_TOKEN` (不过，为了避免 `serviceAccountSecretKey` 泄露，以及提升鉴权配置文件的复用度，推荐配置 `AUTHENTICATION_PROFILE_PATH` 鉴权 )\n- `0.0.20250420-2`:\n  - ✨ 支持透传 `AUTHENTICATION_PROFILE_PATH` 里的 `userJwtToken`\n  - ✨ 支持通过 `serviceAccountSecretKey` 获取 JWT Token 后调用 MCP Server\n\n## 6. Luban\n\n- https://luban.bytedance.net/npm/publish/detail/8489/versions\n"},"1.1.0":{"scripts":{"playground":"ts-node __test__/playground.ts","build":"rslib build","check":"biome check --write","dev":"rslib build --watch","format":"prettier --write .","lint":"eslint .","test":"vitest run"},"license":"MIT","name":"@byted/mcp-proxy","files":["dist"],"readme":"# @byted/mcp-proxy\n\n## 0. Introduction\n\n`@byted/mcp-proxy` 是一个用于将 ByteFaaS MCP Server 代理到本地的工具，适配各种第三方 MCP Client，如：\n\n- Trae (推荐)\n- Cursor\n- Windsurf\n- VS Code Cline\n\n## 1. Bnpm\n\n- https://bnpm.bytedance.net/package/@byted/mcp-proxy\n\n## 2. Precondition\n\n- 需要安装 Node.js v22 或更高版本。推荐使用 `nvm` 进行安装和管理：\n\n```bash\ncurl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.2/install.sh | bash\nnvm install 22 && nvm use 22 && nvm alias default 22\n```\n\n## 3. Config sample\n\n`@byted/mcp-proxy` 支持通过 4 种方案进行鉴权：\n\n- `bytefaas-cli` SSO 鉴权（个人账号的推荐方案）\n- 通过环境变量指定配置文件鉴权（服务账号的推荐方案）\n- 通过环境变量指定 `SERVICE_ACCOUNT_SECRET_KEY` 鉴权\n- 通过环境变量指定 `USER_JWT_TOKEN` 鉴权\n\n### 3.1 `bytefaas-cli` SSO 鉴权\n\n配置 `@byted/mcp-proxy` 前，需要先下载 [bytefaas-cli](https://cloud.bytedance.net/docs/faas/docs/63d786117df7d2021dfc68e3/648a99992ca7dd02263c0d85) 并且完成登录:\n\n```shell\n# CN 或 BOE 区域登录命令\nAPP_ENV=production bytefaas login\n\n# I18N 区域登录命令\nAPP_ENV=i18n bytefaas login\n```\n\n获取 `bytefaas-cli` 登录态后，以当前用户个人账号身份使用 `@byted/mcp-proxy` 时，不再需要配置任何鉴权字段。\n\n```json\n{\n  \"mcpServers\": {\n    \"mcp-server-sample\": {\n      \"command\": \"npx\",\n      \"args\": [\"--registry\", \"https://bnpm.byted.org\", \"-y\", \"@byted/mcp-proxy@latest\"],\n      \"env\": {\n        \"MCP_SERVER_PSM\": \"inf.sinf.sample_mcp\",\n        \"MCP_GATEWAY_REGION\": \"CN\"\n      }\n    }\n  }\n}\n```\n\n### 3.2 通过环境变量指定配置文件鉴权\n\n```json\n{\n  \"mcpServers\": {\n    \"mcp-server-sample\": {\n      \"command\": \"npx\",\n      \"args\": [\"--registry\", \"https://bnpm.byted.org\", \"-y\", \"@byted/mcp-proxy@latest\"],\n      \"env\": {\n        \"MCP_SERVER_PSM\": \"inf.sinf.sample_mcp\",\n        \"MCP_GATEWAY_REGION\": \"CN\",\n        \"AUTHENTICATION_PROFILE_PATH\": \"/Users/bytedance/myAuthenticationProfile.json\"\n      }\n    }\n  }\n}\n```\n\n`authenticationProfile.json` 文件模板:\n\n```json\n{\n  \"serviceAccountSecretKey\": \"******\",\n  \"userJwtToken\": \"******\"\n}\n```\n\n注意：`serviceAccountSecretKey` 和 `userJwtToken` 不能同时被赋值。且由于 `userJwtToken` 存在过期机制，推荐使用 `serviceAccountSecretKey` 进行鉴权。\n\n### 3.3 通过环境变量指定 `SERVICE_ACCOUNT_SECRET_KEY` 鉴权\n\n```json\n{\n  \"mcpServers\": {\n    \"mcp-server-sample\": {\n      \"command\": \"npx\",\n      \"args\": [\"--registry\", \"https://bnpm.byted.org\", \"-y\", \"@byted/mcp-proxy@latest\"],\n      \"env\": {\n        \"MCP_SERVER_PSM\": \"inf.sinf.sample_mcp\",\n        \"MCP_GATEWAY_REGION\": \"CN\",\n        \"SERVICE_ACCOUNT_SECRET_KEY\": \"******\"\n      }\n    }\n  }\n}\n```\n\n### 3.4 通过环境变量指定 `USER_JWT_TOKEN` 鉴权\n\n```json\n{\n  \"mcpServers\": {\n    \"mcp-server-sample\": {\n      \"command\": \"npx\",\n      \"args\": [\"--registry\", \"https://bnpm.byted.org\", \"-y\", \"@byted/mcp-proxy@latest\"],\n      \"env\": {\n        \"MCP_SERVER_PSM\": \"inf.sinf.sample_mcp\",\n        \"MCP_GATEWAY_REGION\": \"CN\",\n        \"USER_JWT_TOKEN\": \"******\"\n      }\n    }\n  }\n}\n```\n\n### 3.5 使用 `MCP_SERVER_CALL_TOOL_HEADERS` 指定 Call Tool 阶段的 Headers\n\n```json\n{\n  \"mcpServers\": {\n    \"mcp-server-sample\": {\n      \"command\": \"npx\",\n      \"args\": [\"--registry\", \"https://bnpm.byted.org\", \"-y\", \"@byted/mcp-proxy@latest\"],\n      \"env\": {\n        \"MCP_SERVER_PSM\": \"inf.sinf.sample_mcp\",\n        \"MCP_GATEWAY_REGION\": \"CN\",\n        \"MCP_SERVER_CALL_TOOL_HEADERS\": \"key1=value1,key2=value2\"\n      }\n    }\n  }\n}\n```\n\n### 3.6 使用 `MCP_SERVER_CALL_TOOL_COOKIES` 指定 Call Tool 阶段的 Cookies\n\n```json\n{\n  \"mcpServers\": {\n    \"mcp-server-sample\": {\n      \"command\": \"npx\",\n      \"args\": [\"--registry\", \"https://bnpm.byted.org\", \"-y\", \"@byted/mcp-proxy@latest\"],\n      \"env\": {\n        \"MCP_SERVER_PSM\": \"inf.sinf.sample_mcp\",\n        \"MCP_GATEWAY_REGION\": \"CN\",\n        \"MCP_SERVER_CALL_TOOL_COOKIES\": \"cookie1=value1; cookie2=value2\"\n      }\n    }\n  }\n}\n```\n\n## 4. Environment variables\n\n- `MCP_SERVER_PSM`：目标 MCP Server 的 PSM，必填。可以在 ByteFaaS 平台查看完整服务列表 [[Link](https://cloud.bytedance.net/faas/mcp_servers?x-resource-account=public&x-bc-region-id=bytedance)]\n- `MCP_GATEWAY_REGION`：MCP Gateway 的区域，必填，可选值：`BOE`、`CN`、`I18N`\n- `AUTHENTICATION_PROFILE_PATH`：鉴权配置文件路径，选填。`AUTHENTICATION_PROFILE_PATH`、`SERVICE_ACCOUNT_SECRET_KEY`、`USER_JWT_TOKEN` 最多只能赋值 1 个，如果都不赋值，`@byted/mcp-proxy` 将不会携带鉴权信息访问 MCP Server。\n- `SERVICE_ACCOUNT_SECRET_KEY`: 服务账号 SecretKey，选填。`AUTHENTICATION_PROFILE_PATH`、`SERVICE_ACCOUNT_SECRET_KEY`、`USER_JWT_TOKEN` 最多只能赋值 1 个，如果都不赋值，`@byted/mcp-proxy` 将不会携带鉴权信息访问 MCP Server。\n- `USER_JWT_TOKEN`: 用户 JWT Token，选填。`AUTHENTICATION_PROFILE_PATH`、`SERVICE_ACCOUNT_SECRET_KEY`、`USER_JWT_TOKEN` 最多只能赋值 1 个，如果都不赋值，`@byted/mcp-proxy` 将不会携带鉴权信息访问 MCP Server。\n- `MCP_REQUEST_TIMEOUT_MS`: 配置 MCP 请求的超时时间，默认超时时间为 60 秒\n- `MCP_SERVER_CALL_TOOL_HEADERS`: 指定 Call Tool 阶段的 Headers，例如：key1=value1,key2=value2\n- `MCP_SERVER_CALL_TOOL_PARAMS`: 指定 Call Tool 阶段的 Params，例如：param1=value1,param2=value2\n- `MCP_SERVER_CALL_TOOL_WITH_COOKIES`: 是否在 Call Tool 阶段透传字节云的 Cookie，默认为 false\n- `MCP_SERVER_CALL_TOOL_COOKIES`: 指定 Call Tool 阶段的 Cookies，例如：cookie1=value1; cookie2=value2\n- `MCP_SERVER_TOOL_BLOCK_LIST`: MCP Server 提供的 Tool list 黑名单\n- `MCP_SERVER_TOOL_ALLOW_LIST`: MCP Server 提供的 Tool list 白名单\n\n\n## 5. Change log\n\n- `1.1.0`:\n  - ✨ 支持通过环境变量 `MCP_SERVER_CALL_TOOL_COOKIES` 指定 Call Tool 阶段的 Cookies\n- `1.0.0`:\n  - 🏗 发布正式版本\n- `0.0.20250701-1`:\n  - 🏗 修改通过 Tiktok SSO 获取 JWT 的超时时间为 10 秒\n- `0.0.20250618-1`:\n  - 🏗 修改通过 Service account secret key 获取 JWT 的超时时间为 10 秒\n- `0.0.20250609-1`:\n  - ✨ 当 `bytefaas-cli` 登录态过期后，在 Init 阶段的日志里提示用户重新登录\n- `0.0.20250528-1`:\n  - ✨ 支持通过环境变量 `MCP_SERVER_TOOL_BLOCK_LIST` 和 `MCP_SERVER_TOOL_ALLOW_LIST` 对 MCP Server 提供的 Tool list 进行限制\n- `0.0.20250523-2`:\n  - ✨ 支持通过环境变量 `MCP_SERVER_CALL_TOOL_WITH_COOKIES` 指定，是否在 Call Tool 阶段透传字节云的 Cookie\n- `0.0.20250521-4`:\n  - 🏗 升级 `@byted/mcp-client-sdk` 依赖版本到 `0.0.20250521-2`\n  - 🏗 强制指定网络环境为办公网\n  - 🏗 标准化日志输出\n  - 🏗 修改默认超时时间为 60 秒\n  - 🏗 在 MCP Server Init 阶段提前执行一次 `listToolsHandler` ，以便将 List Tool 阶段的 401 错误提前暴露\n- `0.0.20250520-1`:\n  - ✨ 支持通过环境变量 `MCP_SERVER_CALL_TOOL_HEADERS` 和 `MCP_SERVER_CALL_TOOL_PARAMS` 指定 Call Tool 阶段的 Headers 和 Params\n- `0.0.20250507-1`:\n  - 🏗 升级 `@byted/mcp-client-sdk` 依赖版本到 `0.0.20250430-1`\n  - 🐛 修复 I18N 区域无法通过 `serviceAccountSecretKey` 获取 JWT 的问题\n- `0.0.20250428-3`:\n  - 🏗 当 `BytedMcpClient.loadAllTools` 失败时，捕获异常并且打印日志\n  - ✨ 支持 I18N 区域的 MCP Server 自动从 [bytefaas-cli](https://cloud.bytedance.net/docs/faas/docs/63d786117df7d2021dfc68e3/648a99992ca7dd02263c0d85) 的 SSO 数据里获取 JWT Token (不再需要显式指定`USER_JWT_TOKEN`)，通过 `APP_ENV=i18n bytefaas login` 登录后，登录态可以最长可以维持 1 个月\n- `0.0.20250427-2`:\n  - 🏗 在通过任意方式获取 JWT 后，进行 auth 验证，拦截无效的 JWT，并且打印有效 JWT 的身份信息\n  - ✨ 支持 CN 和 BOE 区域的 MCP Server 自动从 [bytefaas-cli](https://cloud.bytedance.net/docs/faas/docs/63d786117df7d2021dfc68e3/648a99992ca7dd02263c0d85) 的 SSO 数据里获取 JWT Token (不再需要显式指定`USER_JWT_TOKEN`)，通过 `APP_ENV=production bytefaas login` 登录后，登录态可以最长可以维持 1 年\n- `0.0.20250425-2`:\n  - 🏗 打印 Call Tool 阶段的 Request Header, Request Body, Response Body\n  - ✨ 支持通过环境变量 `MCP_REQUEST_TIMEOUT_MS` 配置 MCP 请求的超时时间，默认超时时间为 10 秒\n- `0.0.20250424-1`:\n  - 🏗 升级 `@byted/mcp-client-sdk` 依赖版本到 `0.0.20250423-1`\n- `0.0.20250422-2`:\n  - 🏗 升级 `@byted/mcp-client-sdk` 依赖版本到 `0.0.20250421-6`\n  - ✨ 支持每 30 分钟更新由 `serviceAccountSecretKey` 生成的 JWT Token\n  - ✨ 支持在环境变量中直接指定 `SERVICE_ACCOUNT_SECRET_KEY` 和 `USER_JWT_TOKEN` (不过，为了避免 `serviceAccountSecretKey` 泄露，以及提升鉴权配置文件的复用度，推荐配置 `AUTHENTICATION_PROFILE_PATH` 鉴权 )\n- `0.0.20250420-2`:\n  - ✨ 支持透传 `AUTHENTICATION_PROFILE_PATH` 里的 `userJwtToken`\n  - ✨ 支持通过 `serviceAccountSecretKey` 获取 JWT Token 后调用 MCP Server\n\n## 6. Luban\n\n- https://luban.bytedance.net/npm/publish/detail/8489/versions\n","bin":{"mcp-proxy":"dist/index.js"},"maintainers":[{"name":"yangyang.jeff","email":"yangyang.jeff@bytedance.com"}],"type":"module","version":"1.1.0","dist":{"integrity":"sha512-wOUXb6lnSW/F//ahCp3eiw5159pwsOOLod7ruUFLZb0aYNiSxANvWaJQB+AO2hsANdvMVP8Ekt0/ntqPwHW4PQ==","tarball":"https://bnpm.byted.org/@byted/mcp-proxy/-/mcp-proxy-1.1.0.tgz","size":11229,"unpackedSize":68901,"fileCount":8,"shasum":"0d1a407b241720600a0743c7b1df5415dc95a798"},"dependencies":{"@byted-service/fetch":"^2.6.5","zod":"^3.24.1","@mode