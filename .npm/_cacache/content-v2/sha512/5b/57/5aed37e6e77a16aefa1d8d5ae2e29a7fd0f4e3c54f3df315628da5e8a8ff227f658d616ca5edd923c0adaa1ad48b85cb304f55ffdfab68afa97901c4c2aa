xy/-/mcp-proxy-0.0.20250420-1.tgz","size":4801,"unpackedSize":22675,"fileCount":6,"shasum":"aab69e13a140616cc46ac71846c05e50e65d1988"},"scripts":{"dev":"rslib build --watch","format":"prettier --write .","lint":"eslint .","test":"vitest run","build":"rslib build","check":"biome check --write"},"module":"./dist/index.js","devDependencies":{"shx":"^0.3.4","@rslib/core":"^0.6.3","@types/node":"^22.8.1","@biomejs/biome":"^1.9.4","prettier":"^3.5.3","vitest":"^3.1.1","@eslint/js":"^9.23.0","typescript":"^5.8.3","typescript-eslint":"^8.29.0","eslint":"^9.23.0","globals":"^16.0.0"},"description":"## Bnpm - https://bnpm.bytedance.net/package/@byted/mcp-proxy","dependencies":{"@byted/mcp-client-sdk":"0.0.20250418-4","zod":"^3.24.1","@modelcontextprotocol/sdk":"^1.0.3"},"bin":{"mcp-proxy":"dist/index.js"}},"0.0.20250521-2":{"version":"0.0.20250521-2","types":"./dist/index.d.ts","files":["dist"],"dependencies":{"jsonwebtoken":"^8.5.1","@byted-service/fetch":"^2.6.5","zod":"^3.24.1","@modelcontextprotocol/sdk":"^1.0.3","@byted/mcp-client-sdk":"0.0.20250521-2"},"readmeFilename":"README.md","bin":{"mcp-proxy":"dist/index.js"},"maintainers":[{"email":"yangyang.jeff@bytedance.com","name":"yangyang.jeff"}],"scripts":{"check":"biome check --write","dev":"rslib build --watch","format":"prettier --write .","lint":"eslint .","test":"vitest run","playground":"ts-node __test__/playground.ts","build":"rslib build"},"_id":"@byted/mcp-proxy@0.0.20250521-2","_npmUser":{"name":"yangyang.jeff","email":"yangyang.jeff@bytedance.com"},"main":"./dist/index.cjs","name":"@byted/mcp-proxy","module":"./dist/index.js","type":"module","exports":{".":{"types":"./dist/index.d.ts","import":"./dist/index.js","require":"./dist/index.cjs"}},"readme":"# @byted/mcp-proxy\n\n## 0. Introduction\n\n`@byted/mcp-proxy` 是一个用于将 ByteFaaS MCP Server 代理到本地的工具，适配各种第三方 MCP Client，如：\n\n- Trae (推荐)\n- Cursor\n- Windsurf\n- VS Code Cline\n\n## 1. Bnpm\n\n- https://bnpm.bytedance.net/package/@byted/mcp-proxy\n\n## 2. Precondition\n\n- 需要安装 Node.js v22 或更高版本。推荐使用 `nvm` 进行安装和管理：\n\n```bash\ncurl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.2/install.sh | bash\nnvm install 22 && nvm use 22 && nvm alias default 22\n```\n\n## 3. Config sample\n\n`@byted/mcp-proxy` 支持通过 4 种方案进行鉴权：\n\n- `bytefaas-cli` SSO 鉴权（个人账号的推荐方案）\n- 通过环境变量指定配置文件鉴权（服务账号的推荐方案）\n- 通过环境变量指定 `SERVICE_ACCOUNT_SECRET_KEY` 鉴权\n- 通过环境变量指定 `USER_JWT_TOKEN` 鉴权\n\n### 3.1 `bytefaas-cli` SSO 鉴权\n\n配置 `@byted/mcp-proxy` 前，需要先下载 [bytefaas-cli](https://cloud.bytedance.net/docs/faas/docs/63d786117df7d2021dfc68e3/648a99992ca7dd02263c0d85) 并且完成登录:\n\n```shell\n# CN or BOE 区域登录命令\nAPP_ENV=production bytefaas login\n\n# I18N 区域登录命令\nAPP_ENV=i18n bytefaas login\n```\n\n获取 `bytefaas-cli` 登录态后，以当前用户个人账号身份使用 `@byted/mcp-proxy` 时，不再需要配置任何鉴权字段。\n\n```json\n{\n  \"mcpServers\": {\n    \"mcp-server-sample\": {\n      \"command\": \"npx\",\n      \"args\": [\"--registry\", \"https://bnpm.byted.org\", \"-y\", \"@byted/mcp-proxy@latest\"],\n      \"env\": {\n        \"MCP_SERVER_PSM\": \"inf.sinf.sample_mcp\",\n        \"MCP_GATEWAY_REGION\": \"CN\"\n      }\n    }\n  }\n}\n```\n\n### 3.2 通过环境变量指定配置文件鉴权\n\n```json\n{\n  \"mcpServers\": {\n    \"mcp-server-sample\": {\n      \"command\": \"npx\",\n      \"args\": [\"--registry\", \"https://bnpm.byted.org\", \"-y\", \"@byted/mcp-proxy@latest\"],\n      \"env\": {\n        \"MCP_SERVER_PSM\": \"inf.sinf.sample_mcp\",\n        \"MCP_GATEWAY_REGION\": \"CN\",\n        \"AUTHENTICATION_PROFILE_PATH\": \"/Users/bytedance/myAuthenticationProfile.json\"\n      }\n    }\n  }\n}\n```\n\n`authenticationProfile.json` 文件模板:\n\n```json\n{\n  \"serviceAccountSecretKey\": \"******\",\n  \"userJwtToken\": \"******\"\n}\n```\n\n注意：`serviceAccountSecretKey` 和 `userJwtToken` 不能同时被赋值。且由于 `userJwtToken` 存在过期机制，推荐使用 `serviceAccountSecretKey` 进行鉴权。\n\n### 3.3 通过环境变量指定 `SERVICE_ACCOUNT_SECRET_KEY` 鉴权\n\n```json\n{\n  \"mcpServers\": {\n    \"mcp-server-sample\": {\n      \"command\": \"npx\",\n      \"args\": [\"--registry\", \"https://bnpm.byted.org\", \"-y\", \"@byted/mcp-proxy@latest\"],\n      \"env\": {\n        \"MCP_SERVER_PSM\": \"inf.sinf.sample_mcp\",\n        \"MCP_GATEWAY_REGION\": \"CN\",\n        \"SERVICE_ACCOUNT_SECRET_KEY\": \"******\"\n      }\n    }\n  }\n}\n```\n\n### 3.4 通过环境变量指定 `USER_JWT_TOKEN` 鉴权\n\n```json\n{\n  \"mcpServers\": {\n    \"mcp-server-sample\": {\n      \"command\": \"npx\",\n      \"args\": [\"--registry\", \"https://bnpm.byted.org\", \"-y\", \"@byted/mcp-proxy@latest\"],\n      \"env\": {\n        \"MCP_SERVER_PSM\": \"inf.sinf.sample_mcp\",\n        \"MCP_GATEWAY_REGION\": \"CN\",\n        \"USER_JWT_TOKEN\": \"******\"\n      }\n    }\n  }\n}\n```\n\n## 4. Environment variables\n\n- `MCP_SERVER_PSM`：目标 MCP Server 的 PSM，必填。可以在 ByteFaaS 平台查看完整服务列表 [[Link](https://cloud.bytedance.net/faas/mcp_servers?x-resource-account=public&x-bc-region-id=bytedance)]\n- `MCP_GATEWAY_REGION`：MCP Gateway 的区域，必填，可选值：`BOE`、`CN`、`I18N`\n- `AUTHENTICATION_PROFILE_PATH`：鉴权配置文件路径，选填。`AUTHENTICATION_PROFILE_PATH`、`SERVICE_ACCOUNT_SECRET_KEY`、`USER_JWT_TOKEN` 最多只能赋值 1 个，如果都不赋值，`@byted/mcp-proxy` 将不会携带鉴权信息访问 MCP Server。\n- `SERVICE_ACCOUNT_SECRET_KEY`: 服务账号 SecretKey，选填。`AUTHENTICATION_PROFILE_PATH`、`SERVICE_ACCOUNT_SECRET_KEY`、`USER_JWT_TOKEN` 最多只能赋值 1 个，如果都不赋值，`@byted/mcp-proxy` 将不会携带鉴权信息访问 MCP Server。\n- `USER_JWT_TOKEN`: 用户 JWT Token，选填。`AUTHENTICATION_PROFILE_PATH`、`SERVICE_ACCOUNT_SECRET_KEY`、`USER_JWT_TOKEN` 最多只能赋值 1 个，如果都不赋值，`@byted/mcp-proxy` 将不会携带鉴权信息访问 MCP Server。\n\n## 5. Change log\n\n- `0.0.20250521-2`:\n  - 🏗 升级 `@byted/mcp-client-sdk` 依赖版本到 `0.0.20250521-2`\n  - 🏗 强制指定网络环境为办公网\n  - 🏗 标准化日志输出\n  - 🏗 修改默认超时时间为 60 秒\n- `0.0.20250520-1`:\n  - ✨ 支持通过环境变量 `MCP_SERVER_CALL_TOOL_HEADERS` 和 `MCP_SERVER_CALL_TOOL_PARAMS` 指定 Call Tool 阶段的 Headers 和 Params\n- `0.0.20250507-1`:\n  - 🏗 升级 `@byted/mcp-client-sdk` 依赖版本到 `0.0.20250430-1`\n  - 🐛 修复 I18N 区域无法通过 `serviceAccountSecretKey` 获取 JWT 的问题\n- `0.0.20250428-3`:\n  - 🏗 当 `BytedMcpClient.loadAllTools` 失败时，捕获异常并且打印日志\n  - ✨ 支持 I18N 区域的 MCP Server 自动从 [bytefaas-cli](https://cloud.bytedance.net/docs/faas/docs/63d786117df7d2021dfc68e3/648a99992ca7dd02263c0d85) 的 SSO 数据里获取 JWT Token (不再需要显式指定`USER_JWT_TOKEN`)，通过 `APP_ENV=i18n bytefaas login` 登录后，登录态可以最长可以维持 1 个月\n- `0.0.20250427-2`:\n  - 🏗 在通过任意方式获取 JWT 后，进行 auth 验证，拦截无效的 JWT，并且打印有效 JWT 的身份信息\n  - ✨ 支持 CN 和 BOE 区域的 MCP Server 自动从 [bytefaas-cli](https://cloud.bytedance.net/docs/faas/docs/63d786117df7d2021dfc68e3/648a99992ca7dd02263c0d85) 的 SSO 数据里获取 JWT Token (不再需要显式指定`USER_JWT_TOKEN`)，通过 `APP_ENV=production bytefaas login` 登录后，登录态可以最长可以维持 1 年\n- `0.0.20250425-2`:\n  - 🏗 打印 Call Tool 阶段的 Request Header, Request Body, Response Body\n  - ✨ 支持通过环境变量 `MCP_REQUEST_TIMEOUT_MS` 配置 MCP 请求的超时时间，默认超时时间为 10 秒\n- `0.0.20250424-1`:\n  - 🏗 升级 `@byted/mcp-client-sdk` 依赖版本到 `0.0.20250423-1`\n- `0.0.20250422-2`:\n  - 🏗 升级 `@byted/mcp-client-sdk` 依赖版本到 `0.0.20250421-6`\n  - ✨ 支持每 30 分钟更新由 `serviceAccountSecretKey` 生成的 JWT Token\n  - ✨ 支持在环境变量中直接指定 `SERVICE_ACCOUNT_SECRET_KEY` 和 `USER_JWT_TOKEN` (不过，为了避免 `serviceAccountSecretKey` 泄露，以及提升鉴权配置文件的复用度，推荐配置 `AUTHENTICATION_PROFILE_PATH` 鉴权 )\n- `0.0.20250420-2`:\n  - ✨ 支持透传 `AUTHENTICATION_PROFILE_PATH` 里的 `userJwtToken`\n  - ✨ 支持通过 `serviceAccountSecretKey` 获取 JWT Token 后调用 MCP Server\n\n## 6. Luban\n\n- https://luban.bytedance.net/npm/publish/detail/8489/versions\n","description":"## 0. Introduction","devDependencies":{"prettier":"^3.5.3","@eslint/js":"^9.27.0","@rslib/core":"^0.6.3","@biomejs/biome":"^1.9.4","globals":"^16.0.0","typescript-eslint":"^8.29.0","eslint":"^9.27.0","shx":"^0.3.4","typescript":"^5.8.3","ts-node":"^10.9.2","vitest":"^3.1.1","@types/jsonwebtoken":"^8.5.1","@types/node":"^22.8.1"},"dist":{"integrity":"sha512-q3UbYC13+eU+TxKd69w/g1DMsmYYIL35aK1oiIBX12GeOu5KT5uN12BY9Yuf2Vv0N+sLaUXgPmxN5+Bz/39fKg==","tarball":"https://bnpm.byted.org/@byted/mcp-proxy/-/mcp-proxy-0.0.20250521-2.tgz","size":10069,"unpackedSize":60299,"fileCount":8,"shasum":"b6f6e4b4855d1fe1734d8b2655eb9c7758587597"}},"0.0.20250521-4-rollback":{"name":"@byted/mcp-proxy","types":"./dist/index.d.ts","_id":"@byted/mcp-proxy@0.0.20250521-4-rollback","dist":{"size":9957,"unpackedSize":59342,"fileCount":8,"shasum":"1f780228d84b3a59124822d30b508cd428b8f3e3","integrity":"sha512-UYSuvWof9c+M7x+JTaJIoro44xf7tjOMYuxZrmi6zBj/i9JhOBC4y4ifvshPIgjSzCl7GOtqy5aVi5fd9PSSnw==","tarball":"https://bnpm.byted.org/@byted/mcp-proxy/-/mcp-proxy-0.0.20250521-4-rollback.tgz"},"dependencies":{"@modelcontextprotocol/sdk":"^1.0.3","@byted/mcp-client-sdk":"0.0.20250520-2","jsonwebtoken":"^8.5.1","@byted-service/fetch":"^2.6.5","zod":"^3.24.1"},"readme":"# @byted/mcp-proxy\n\n## 0. Introduction\n`@byted/mcp-proxy` 是一个用于将 ByteFaaS MCP Server 代理到本地的工具，适配各种第三方 MCP Client，如：\n- Trae (推荐)\n- Cursor\n- Windsurf\n- VS Code Cline\n\n## 1. Bnpm\n- https://bnpm.bytedance.net/package/@byted/mcp-proxy\n\n## 2. Precondition\n\n- 需要安装 Node.js v22 或更高版本。推荐使用 `nvm` 进行安装和管理：\n\n```bash\ncurl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.2/install.sh | bash\nnvm install 22 && nvm use 22 && nvm alias default 22\n```\n\n## 3. Config sample\n\n`@byted/mcp-proxy` 支持通过 4 种方案进行鉴权：\n- `bytefaas-cli` SSO 鉴权（个人账号的推荐方案）\n- 通过环境变量指定配置文件鉴权（服务账号的推荐方案）\n- 通过环境变量指定 `SERVICE_ACCOUNT_SECRET_KEY` 鉴权\n- 通过环境变量指定 `USER_JWT_TOKEN` 鉴权\n\n### 3.1 `bytefaas-cli` SSO 鉴权\n\n配置 `@byted/mcp-proxy` 前，需要先下载 [bytefaas-cli](https://cloud.bytedance.net/docs/faas/docs/63d786117df7d2021dfc68e3/648a99992ca7dd02263c0d85) 并且完成登录:\n\n```shell\n# CN or BOE 区域登录命令\nAPP_ENV=production bytefaas login\n\n# I18N 区域登录命令\nAPP_ENV=i18n bytefaas login\n```\n\n获取 `bytefaas-cli` 登录态后，以当前用户个人账号身份使用 `@byted/mcp-proxy` 时，不再需要配置任何鉴权字段。\n```json\n{\n  \"mcpServers\": {\n    \"mcp-server-sample\": {\n      \"command\": \"npx\",\n      \"args\": [\n        \"--registry\",\n        \"https://bnpm.byted.org\",\n        \"-y\",\n        \"@byted/mcp-proxy@latest\"\n      ],\n      \"env\": {\n        \"MCP_SERVER_PSM\": \"inf.sinf.sample_mcp\",\n        \"MCP_GATEWAY_REGION\": \"CN\"\n      }\n    }\n  }\n}\n```\n\n### 3.2 通过环境变量指定配置文件鉴权\n\n```json\n{\n  \"mcpServers\": {\n    \"mcp-server-sample\": {\n      \"command\": \"npx\",\n      \"args\": [\n        \"--registry\",\n        \"https://bnpm.byted.org\",\n        \"-y\",\n        \"@byted/mcp-proxy@latest\"\n      ],\n      \"env\": {\n        \"MCP_SERVER_PSM\": \"inf.sinf.sample_mcp\",\n        \"MCP_GATEWAY_REGION\": \"CN\",\n        \"AUTHENTICATION_PROFILE_PATH\": \"/Users/bytedance/myAuthenticationProfile.json\"\n      }\n    }\n  }\n}\n```\n\n`authenticationProfile.json` 文件模板:\n\n```json\n{\n  \"serviceAccountSecretKey\": \"******\",\n  \"userJwtToken\": \"******\"\n}\n```\n\n注意：`serviceAccountSecretKey` 和 `userJwtToken` 不能同时被赋值。且由于 `userJwtToken` 存在过期机制，推荐使用 `serviceAccountSecretKey` 进行鉴权。\n\n\n### 3.3 通过环境变量指定 `SERVICE_ACCOUNT_SECRET_KEY` 鉴权\n\n```json\n{\n  \"mcpServers\": {\n    \"mcp-server-sample\": {\n      \"command\": \"npx\",\n      \"args\": [\n        \"--registry\",\n        \"https://bnpm.byted.org\",\n        \"-y\",\n        \"@byted/mcp-proxy@latest\"\n      ],\n      \"env\": {\n        \"MCP_SERVER_PSM\": \"inf.sinf.sample_mcp\",\n        \"MCP_GATEWAY_REGION\": \"CN\",\n        \"SERVICE_ACCOUNT_SECRET_KEY\": \"******\"\n      }\n    }\n  }\n}\n```\n\n### 3.4 通过环境变量指定 `USER_JWT_TOKEN` 鉴权\n\n```json\n{\n  \"mcpServers\": {\n    \"mcp-server-sample\": {\n      \"command\": \"npx\",\n      \"args\": [\n        \"--registry\",\n        \"https://bnpm.byted.org\",\n        \"-y\",\n        \"@byted/mcp-proxy@latest\"\n      ],\n      \"env\": {\n        \"MCP_SERVER_PSM\": \"inf.sinf.sample_mcp\",\n        \"MCP_GATEWAY_REGION\": \"CN\",\n        \"USER_JWT_TOKEN\": \"******\"\n      }\n    }\n  }\n}\n```\n\n\n## 4. Environment variables\n- `MCP_SERVER_PSM`：目标 MCP Server 的 PSM，必填。可以在 ByteFaaS 平台查看完整服务列表 [[Link](https://cloud.bytedance.net/faas/mcp_servers?x-resource-account=public&x-bc-region-id=bytedance)]\n- `MCP_GATEWAY_REGION`：MCP Gateway 的区域，必填，可选值：`BOE`、`CN`、`I18N`\n- `AUTHENTICATION_PROFILE_PATH`：鉴权配置文件路径，选填。`AUTHENTICATION_PROFILE_PATH`、`SERVICE_ACCOUNT_SECRET_KEY`、`USER_JWT_TOKEN` 最多只能赋值 1 个，如果都不赋值，`@byted/mcp-proxy` 将不会携带鉴权信息访问 MCP Server。\n- `SERVICE_ACCOUNT_SECRET_KEY`: 服务账号 SecretKey，选填。`AUTHENTICATION_PROFILE_PATH`、`SERVICE_ACCOUNT_SECRET_KEY`、`USER_JWT_TOKEN` 最多只能赋值 1 个，如果都不赋值，`@byted/mcp-proxy` 将不会携带鉴权信息访问 MCP Server。\n- `USER_JWT_TOKEN`: 用户 JWT Token，选填。`AUTHENTICATION_PROFILE_PATH`、`SERVICE_ACCOUNT_SECRET_KEY`、`USER_JWT_TOKEN` 最多只能赋值 1 个，如果都不赋值，`@byted/mcp-proxy` 将不会携带鉴权信息访问 MCP Server。\n\n## 5. Change log\n\n- `0.0.20250520-1`:\n  - ✨ 支持通过环境变量 `MCP_SERVER_CALL_TOOL_HEADERS` 和 `MCP_SERVER_CALL_TOOL_PARAMS` 指定 Call Tool 阶段的 Headers 和 Params \n- `0.0.20250507-1`:\n  - 🏗 升级 `@byted/mcp-client-sdk` 依赖版本到 `0.0.20250430-1`\n  - 🐛 修复 I18N 区域无法通过 `serviceAccountSecretKey` 获取 JWT 的问题\n- `0.0.20250428-3`:\n  - 🏗 当 `BytedMcpClient.loadAllTools` 失败时，捕获异常并且打印日志\n  - ✨ 支持 I18N 区域的 MCP Server 自动从 [bytefaas-cli](https://cloud.bytedance.net/docs/faas/docs/63d786117df7d2021dfc68e3/648a99992ca7dd02263c0d85) 的 SSO 数据里获取 JWT Token (不再需要显式指定`USER_JWT_TOKEN`)，通过 `APP_ENV=i18n bytefaas login` 登录后，登录态可以最长可以维持 1 个月\n- `0.0.20250427-2`:\n  - 🏗 在通过任意方式获取 JWT 后，进行 auth 验证，拦截无效的 JWT，并且打印有效 JWT 的身份信息\n  - ✨ 支持 CN 和 BOE 区域的 MCP Server 自动从 [bytefaas-cli](https://cloud.bytedance.net/docs/faas/docs/63d786117df7d2021dfc68e3/648a99992ca7dd02263c0d85) 的 SSO 数据里获取 JWT Token (不再需要显式指定`USER_JWT_TOKEN`)，通过 `APP_ENV=production bytefaas login` 登录后，登录态可以最长可以维持 1 年\n- `0.0.20250425-2`:\n  - 🏗 打印 Call Tool 阶段的 Request Header, Request Body, Response Body\n  - ✨ 支持通过环境变量 `MCP_REQUEST_TIMEOUT_MS` 配置 MCP 请求的超时时间，默认超时时间为 10 秒\n- `0.0.20250424-1`:\n  - 🏗 升级 `@byted/mcp-client-sdk` 依赖版本到 `0.0.20250423-1` \n- `0.0.20250422-2`:\n  - 🏗 升级 `@byted/mcp-client-sdk` 依赖版本到 `0.0.20250421-6`\n  - ✨ 支持每 30 分钟更新由 `serviceAccountSecretKey` 生成的 JWT Token\n  - ✨ 支持在环境变量中直接指定 `SERVICE_ACCOUNT_SECRET_KEY` 和 `USER_JWT_TOKEN` (不过，为了避免 `serviceAccountSecretKey` 泄露，以及提升鉴权配置文件的复用度，推荐配置 `AUTHENTICATION_PROFILE_PATH` 鉴权 )\n- `0.0.20250420-2`: \n  - ✨ 支持透传 `AUTHENTICATION_PROFILE_PATH` 里的 `userJwtToken`\n  - ✨ 支持通过 `serviceAccountSecretKey` 获取 JWT Token 后调用 MCP Server\n\n## 6. Luban\n- https://luban.bytedance.net/npm/publish/detail/8489/versions\n","version":"0.0.20250521-4-rollback","devDependencies":{"ts-node":"^10.9.2","typescript-eslint":"^8.29.0","globals":"^16.0.0","@types/jsonwebtoken":"^8.5.1","typescript":"^5.8.3","@biomejs/biome":"^1.9.4","@types/node":"^22.8.1","@eslint/js":"^9.23.0","vitest":"^3.1.1","@rslib/core":"^0.6.3","eslint":"^9.23.0","shx":"^0.3.4","prettier":"^3.5.3"},"readmeFilename":"README.md","type":"module","bin":{"mcp-proxy":"dist/index.js"},"_npmUser":{"email":"yangyang.jeff@bytedance.com","name":"yangyang.jeff"},"main":"./dist/index.cjs","exports":{".":{"import":"./dist/index.js","require":"./dist/index.cjs","types":"./dist/index.d.ts"}},"scripts":{"playground":"ts-node __test__/playground.ts","build":"rslib build","check":"biome check --write","dev":"rslib build --watch","format":"prettier --write .","lint":"eslint .","test":"vitest run"},"maintainers":[{"name":"yangyang.jeff","email":"yangyang.jeff@bytedance.com"}],"files":["dist"],"description":"## 0. Introduction `@byted/mcp-proxy` 是一个用于将 ByteFaaS MCP Server 代理到本地的工具，适配各种第三方 MCP Client，如： - Trae (推荐) - Cursor - Windsurf - VS Code Cline","module":"./dist/index.js"},"0.0.20250521-3":{"readmeFilename":"README.md","bin":{"mcp-proxy":"dist/index.js"},"type":"module","dist":{"shasum":"718cc79508b63e559fc9a45ed178ba72ca329239","integrity":"sha512-yCghkchMSTh2kdWXelJMRgJFuAFpA6habEc1C4qfQ/1CiNucR1E1t6RngtKBkFKV23elAMM/mVswG52y3ge3kg==","tarball":"https://bnpm.byted.org/@byted/mcp-proxy/-/mcp-proxy-0.0.20250521-3.tgz","size":10080,"unpackedSize":60319,"fileCount":8},"name":"@byted/mcp-proxy","main":"./dist/index.cjs","description":"## 0. Introduction","module":"./dist/index.js","maintainers":[{"email":"yangyang.jeff@bytedance.com","name":"yangyang.jeff"}],"scripts":{"dev"