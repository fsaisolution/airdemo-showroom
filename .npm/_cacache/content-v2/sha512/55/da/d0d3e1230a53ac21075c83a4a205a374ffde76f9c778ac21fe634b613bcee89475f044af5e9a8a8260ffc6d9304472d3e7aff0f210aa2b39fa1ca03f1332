.debug(`Available tools: ${tools.map((t) => t.name).join(',')}`);\n\n  const result = await client.callTool(testData.toolName, testData.args);\n  ctx.logger.debug(\n          `Result from ${testData.toolName}: ${JSON.stringify(result)}`,\n  );\n})();\n\n```\n\n## API\n\n### `new BytedMcpClient(connections)`\n\n**Description:**\n\n创建 `BytedMcpClient` 的实例。此客户端用于管理与一个或多个 MCP 服务器的连接，并调用这些服务器上的工具。\n\n**Parameters:**\n\n-   `connections` (`Record<string, HttpConnection>`): 一个对象，其中键是服务器的自定义名称（例如，`'myServer'`），值是 `HttpConnection` 对象，用于配置如何连接到该 MCP 服务器。\n    -   `HttpConnection` 包含以下字段：\n        -   `transport` (`'http'`): 传输协议，目前仅支持 'http'。\n        -   `url` (`string`, 可选): MCP 服务器的 HTTP 端点 URL。`url` 和 `psm` 必须提供其中一个。\n        -   `psm` (`string`, 可选): MCP 服务器的 PSM 标识。`url` 和 `psm` 必须提供其中一个。\n        -   `headers` (`Record<string, string>`, 可选): 发送到 MCP 服务器的自定义 HTTP 请求头。\n        -   `timeout` (`number`, 可选): 请求超时时间（毫秒）。\n        -   `mcpGatewayRegion` (`MCP_GATEWAY_REGION`, 可选): 当使用 `psm` 连接时，此字段为必需，指定 MCP 网关区域（`BOE`, `CN`, `I18N`）。\n\n### `client.connectAll({ ctx })`\n\n**Description:**\n\n异步连接到构造函数中配置的所有 MCP 服务器。此方法会尝试为每个配置的服务器建立连接，并在使用 PSM 时解析其 URL。\n\n**Parameters:**\n\n-   `ctx` (`BytedMcpClientContext`): 包含 `logger` 和 `logId` 的上下文对象，用于日志记录和追踪。\n\n### `client.registerBeforeCallHook({ serverName, beforeCallHook, ctx })`\n\n**Description:**\n\n为指定的 MCP 服务器或所有服务器注册一个前置调用钩子。此钩子函数会在向 MCP 服务器发送请求之前执行，允许修改请求头或请求体。\n\n**Parameters:**\n\n-   `serverName` (`string`): 要注册钩子的服务器名称（在构造函数中定义的键）。如果为 `'*'`，则为所有已连接的服务器注册钩子。\n-   `beforeCallHook` (`BeforeCallHook`): 一个异步函数，接收包含 `headers` 和 `body` 的对象，并允许对其进行修改。\n-   `ctx` (`BytedMcpClientContext`): 包含 `logger` 和 `logId` 的上下文对象。\n\n### `client.registerAfterCallHook({ serverName, afterCallHook, ctx })`\n\n**Description:**\n\n为指定的 MCP 服务器或所有服务器注册一个后置调用钩子。此钩子函数会在收到 MCP 服务器响应之后，但在 `callTool` 返回结果之前执行，允许检查或修改响应体。\n\n**Parameters:**\n\n-   `serverName` (`string`): 要注册钩子的服务器名称（在构造函数中定义的键）。如果为 `'*'`，则为所有已连接的服务器注册钩子。\n-   `afterCallHook` (`AfterCallHook`): 一个异步函数，接收包含响应 `body` 的对象，并允许对其进行修改。\n-   `ctx` (`BytedMcpClientContext`): 包含 `logger` 和 `logId` 的上下文对象。\n\n### `client.loadAllTools({ ctx })`\n\n**Description:**\n\n异步从所有已连接的 MCP 服务器加载并返回所有可用的工具列表。此方法会向每个服务器发送 `listTools` 请求。\n\n**Parameters:**\n\n-   `ctx` (`BytedMcpClientContext`): 包含 `logger` 和 `logId` 的上下文对象。\n\n**Returns:**\n\n-   `Promise<Tool[]>`: 一个包含所有服务器上所有工具的数组。每个 `Tool` 对象包含 `name`, `description`, `inputSchema`, 和 `modelConfig` (其中 `modelConfig._mcpServerName` 指示工具所属的服务器)。\n\n### `client.callTool(toolName, args)`\n\n**Description:**\n\n异步调用指定名称的 MCP 工具。客户端会自动查找该工具所在的服务器，并将请求发送到该服务器。\n\n**Parameters:**\n\n-   `toolName` (`string`): 要调用的工具的名称。\n-   `args` (`unknown`): 传递给工具的参数，其结构应符合工具的 `inputSchema`。\n\n**Returns:**\n\n-   `Promise<unknown>`: 工具执行的结果。\n\n## Change log\n\n- `1.0.0`:\n  - 🏗 发布第一个正式版本`\n- `0.0.20250803-1`:\n  - 🏗 迁移代码库到 `inf/bytedai-js`\n- `0.0.20250711-1`:\n  - 🏗 支持通过 CommonJS 消费本包\n- `0.0.20250524-1`:\n  - ✨ `generateAddCallToolHeadersHook` 支持指定 toolName = '*' 为所有 tool 调用指定 Request Header\n- `0.0.20250521-2`:\n  - 🐛 修复 `clearBeforeCallHook`, `registerBeforeCallHook`, `connectAll`, `loadAllTools` 函数类型定义错误\n  - 🚨 构造函数里的 `headers` 的值，不再作为 callTool 和 listTools 请求的 HTTP Header 的数据源，而是通过 callTool 请求的 `body._meta.headers` 传递，用于向 MCP Server 传递自定义 Header。新增函数 `generateAddHttpHeadersHook` 支持原 `headers` 构造函数参数的功能。\n  - ✨ 支持在构造函数里指定 `params` 的值，通过 callTool 请求的 `body._meta.params` 传递给 MCP Gateway，用于传递请求变量\n  - ✨ 新增函数 `generateAddCallToolParamsHook` 和 `generateAddCallToolHeadersHook` 用于生成 tool 级别添加 Headers 和 Params 的 hooks\n  - ✨ 新增函数 `generatePrintHeaderAndBodyBeforeCallHook` 和 `generatePrintBodyAfterCallHook` 用于打印 SDK 发出请求的 Request Header, Request Body, Response Body，方便排查问题\n- `0.0.20250516-1`:\n  - 🏗 当调用 `loadAllTools` 时，如果 `connectAll` 尚未执行完成，则直接抛出错误\n  - 🏗 增加 `constructor` 和 `connectAll` 的UT\n  - ✨ 支持通过设置环境变量 `BYTED_MCP_CLIENT_SDK_NETWORK_TYPE` 来强制指定办公网运行环境\n- `0.0.20250430-1`:\n  - 🏗 当 `callTool` 得到的 `jsonResponse.result` 为空时，抛出异常，调用方可根据业务诉求自行捕获\n- `0.0.20250428-1`:\n  - 🐛 修复 afterCallHook 执行 2 遍的问题\n- `0.0.20250423-1`:\n  - ✨ 支持通过判断环境变量 `BYTED_HOST_IP` 或 `BYTED_HOST_IPV6` 是否存在判定当前运行环境是否位于生产网，推导出不同的 MCP Gateway 域名\n- `0.0.20250421-6`:\n  - ✨ 支持直接导出 `generateBytedServiceLoggerWithLogId` 和 `generateDefaultLogId` 函数，简化初始化流程\n  - 🏗 合并 `getAllTools` 的功能进 `loadAllTools`，不在需要额外调用 `getAllTools`\n  - ✨ 为了适配 `@byted/mcp-langgraph-adapter`，拆分出同步函数 `listLoadedTools` 列出已经被 `loadAllTools` 函数加载的 Tools\n  - 📚 新增 README 里的 API 章节\n- `0.0.20250418-4`: \n  - ✨ 在调用 `connectAll`, `loadAllTools` 和 `getAllTools` 函数时，要求显式传递 `ctx` 参数，用于向下游透传 `logId` 和 `logger` 等信息\n  - ✨ 支持在 `loadTool` 阶段调用 `BeforeCallHook`\n  - 🚨 不再为所有 MCP Server 默认注册 `addZtiTokenHook`\n\n## Luban\n- https://luban.bytedance.net/npm/publish/detail/8408/versions\n","name":"@byted/mcp-client-sdk","_id":"@byted/mcp-client-sdk@1.0.0","files":["dist"],"dependencies":{"joi":"^17.9.2","@byted-service/fetch":"^2.6.5","@byted-service/logger":"^2.4.1","@byted-service/zti-helper":"^2.0.1"},"_npmUser":{"email":"yangyang.jeff@bytedance.com","name":"yangyang.jeff"},"main":"./dist/index.cjs","readmeFilename":"README.md","version":"1.0.0","devDependencies":{"@types/jest":"^29.5.12","typescript-eslint":"^8.25.0","typescript":"^5.8.2","eslint":"^9.21.0","@eslint/js":"^9.21.0","globals":"^16.0.0","ts-node":"^10.9.2","@types/node":"^22.8.1","tsx":"^4.19.4","jest":"^29.7.0","@biomejs/biome":"^1.9.4","prettier":"^3.5.2","ts-jest":"^29.1.2","@rslib/core":"^0.7.1"},"type":"module","dist":{"tarball":"https://bnpm.byted.org/@byted/mcp-client-sdk/-/mcp-client-sdk-1.0.0.tgz","size":13046,"unpackedSize":68123,"fileCount":20,"shasum":"6e00d1fe0754db6b1677a4575c38744893aa583b","integrity":"sha512-nIE12TLJGQKdHXlUtuxqQfeo1C51k6L/gQ0k2uSqBYZ5MQn5xQJf7qNf+cAQnPTASBSX61sZW/cYLcH1nQ5AZA=="},"exports":{".":{"import":{"default":"./dist/index.js","types":"./dist/index.d.ts"},"require":{"default":"./dist/index.cjs","types":"./dist/index.d.ts"}}},"scripts":{"format":"prettier --write .","lint":"eslint .","playground":"tsx __test__/playground.ts","test":"jest","build":"rslib build","check":"biome check --write","dev":"rslib build --watch"},"maintainers":[{"name":"yangyang.jeff","email":"yangyang.jeff@bytedance.com"}],"description":"## Bnpm - https://bnpm.bytedance.net/package/@byted/mcp-client-sdk","module":"./dist/index.js","types":"./dist/index.d.ts"},"0.0.20250803-1":{"files":["dist"],"_npmUser":{"name":"yangyang.jeff","email":"yangyang.jeff@bytedance.com"},"type":"module","types":"./dist/index.d.ts","version":"0.0.20250803-1","dependencies":{"@byted-service/fetch":"^2.6.5","@byted-service/logger":"^2.4.1","@byted-service/zti-helper":"^2.0.1","joi":"^17.9.2"},"scripts":{"test":"jest","build":"rslib build && node __test__/esm.consumer.mjs && node __test__/cjs.consumer.cjs","check":"biome check --write","dev":"rslib build --watch","format":"prettier --write .","lint":"eslint .","playground":"tsx __test__/playground.ts"},"dist":{"integrity":"sha512-iIpNlpyo8Vk45IwPTF2MU2jb4SENVTSdy7PcuB8dpgWOZnF2GqSstLaw9oDwK6FmwLI9EUrPGwADHDixtAWEcw==","tarball":"https://bnpm.byted.org/@byted/mcp-client-sdk/-/mcp-client-sdk-0.0.20250803-1.tgz","size":13037,"unpackedSize":68169,"fileCount":20,"shasum":"95b8d25c68a32c4e57037fedcf2ded277017aefd"},"maintainers":[{"name":"yangyang.jeff","email":"yangyang.jeff@bytedance.com"}],"module":"./dist/index.js","exports":{".":{"import":{"types":"./dist/index.d.ts","default":"./dist/index.js"},"require":{"types":"./dist/index.d.ts","default":"./dist/index.cjs"}}},"description":"## Bnpm - https://bnpm.bytedance.net/package/@byted/mcp-client-sdk","devDependencies":{"@rslib/core":"^0.7.1","@biomejs/biome":"^1.9.4","ts-node":"^10.9.2","@eslint/js":"^9.21.0","eslint":"^9.21.0","tsx":"^4.19.4","prettier":"^3.5.2","@types/jest":"^29.5.12","jest":"^29.7.0","ts-jest":"^29.1.2","typescript":"^5.8.2","@types/node":"^22.8.1","typescript-eslint":"^8.25.0","globals":"^16.0.0"},"main":"./dist/index.cjs","readmeFilename":"README.md","name":"@byted/mcp-client-sdk","readme":"# @byted/mcp-client-sdk\n\n## Bnpm\n- https://bnpm.bytedance.net/package/@byted/mcp-client-sdk\n\n\n## Setup\n\n```bash\nyarn\n```\n\n## Code sample\n\n```typescript\nimport {\n  BytedMcpClient, \n  MCP_GATEWAY_REGION,\n  addZtiTokenHook,\n  generateBytedServiceLoggerWithLogId, \n  generateDefaultLogId \n} from '@byted/mcp-client-sdk';\n\n(async () => {\n  const testData = {\n      psm: 'inf.sinf.sample_mcp',\n      mcpGatewayRegion: MCP_GATEWAY_REGION.CN,\n      toolName: 'get_airplane',\n      args: {\n          from: 'beijing',\n          to: 'hong kong',\n      },\n  };\n\n  const client = new BytedMcpClient({\n      sampleMcpServer: {\n          transport: 'http',\n          psm: testData.psm,\n          mcpGatewayRegion: testData.mcpGatewayRegion,\n      },\n  });\n\n  const logId = generateDefaultLogId();\n  const ctx: BytedMcpClientContext = {\n    logger: generateBytedServiceLoggerWithLogId({ logId }),\n    logId,\n  };\n  await client.connectAll({ ctx });\n\n  await client.registerBeforeCallHook({\n    serverName: 'sampleMcpServer',\n    beforeCallHook: async ({ headers, body }) => {\n      headers['x-tt-logid'] = 'NEW_LOG_ID_FROM_REQUEST_CONTEXT';\n      body['Customized-body'] = 'Added by beforeCallHook';\n    },\n    ctx,\n  });\n  await client.registerBeforeCallHook({\n    serverName: 'sampleMcpServer',\n    beforeCallHook: addZtiTokenHook,\n    ctx,\n  });\n\n  const tools = await client.loadAllTools({ ctx });\n  ctx.logger.debug(`Available tools: ${tools.map((t) => t.name).join(',')}`);\n\n  const result = await client.callTool(testData.toolName, testData.args);\n  ctx.logger.debug(\n          `Result from ${testData.toolName}: ${JSON.stringify(result)}`,\n  );\n})();\n\n```\n\n## API\n\n### `new BytedMcpClient(connections)`\n\n**Description:**\n\n创建 `BytedMcpClient` 的实例。此客户端用于管理与一个或多个 MCP 服务器的连接，并调用这些服务器上的工具。\n\n**Parameters:**\n\n-   `connections` (`Record<string, HttpConnection>`): 一个对象，其中键是服务器的自定义名称（例如，`'myServer'`），值是 `HttpConnection` 对象，用于配置如何连接到该 MCP 服务器。\n    -   `HttpConnection` 包含以下字段：\n        -   `transport` (`'http'`): 传输协议，目前仅支持 'http'。\n        -   `url` (`string`, 可选): MCP 服务器的 HTTP 端点 URL。`url` 和 `psm` 必须提供其中一个。\n        -   `psm` (`string`, 可选): MCP 服务器的 PSM 标识。`url` 和 `psm` 必须提供其中一个。\n        -   `headers` (`Record<string, string>`, 可选): 发送到 MCP 服务器的自定义 HTTP 请求头。\n        -   `timeout` (`number`, 可选): 请求超时时间（毫秒）。\n        -   `mcpGatewayRegion` (`MCP_GATEWAY_REGION`, 可选): 当使用 `psm` 连接时，此字段为必需，指定 MCP 网关区域（`BOE`, `CN`, `I18N`）。\n\n### `client.connectAll({ ctx })`\n\n**Description:**\n\n异步连接到构造函数中配置的所有 MCP 服务器。此方法会尝试为每个配置的服务器建立连接，并在使用 PSM 时解析其 URL。\n\n**Parameters:**\n\n-   `ctx` (`BytedMcpClientContext`): 包含 `logger` 和 `logId` 的上下文对象，用于日志记录和追踪。\n\n### `client.registerBeforeCallHook({ serverName, beforeCallHook, ctx })`\n\n**Description:**\n\n为指定的 MCP 服务器或所有服务器注册一个前置调用钩子。此钩子函数会在向 MCP 服务器发送请求之前执行，允许修改请求头或请求体。\n\n**Parameters:**\n\n-   `serverName` (`string`): 要注册钩子的服务器名称（在构造函数中定义的键）。如果为 `'*'`，则为所有已连接的服务器注册钩子。\n-   `beforeCallHook` (`BeforeCallHook`): 一个异步函数，接收包含 `headers` 和 `body` 的对象，并允许对其进行修改。\n-   `ctx` (`BytedMcpClientContext`): 包含 `logger` 和 `logId` 的上下文对象。\n\n### `client.registerAfterCallHook({ serverName, afterCallHook, ctx })`\n\n**Description:**\n\n为指定的 MCP 服务器或所有服务器注册一个后置调用钩子。此钩子函数会在收到 MCP 服务器响应之后，但在 `callTool` 返回结果之前执行，允许检查或修改响应体。\n\n**Parameters:**\n\n-   `serverName` (`string`): 要注册钩子的服务器名称（在构造函数中定义的键）。如果为 `'*'`，则为所有已连接的服务器注册钩子。\n-   `afterCallHook` (`AfterCallHook`): 一个异步函数，接收包含响应 `body` 的对象，并允许对其进行修改。\n-   `ctx` (`BytedMcpClientContext`): 包含 `logger` 和 `logId` 的上下文对象。\n\n### `client.loadAllTools({ ctx })`\n\n**Description:**\n\n异步从所有已连接的 MCP 服务器加载并返回所有可用的工具列表。此方法会向每个服务器发送 `listTools` 请求。\n\n**Parameters:**\n\n-   `ctx` (`BytedMcpClientContext`): 包含 `logger` 和 `logId` 的上下文对象。\n\n**Returns:**\n\n-   `Promise<Tool[]>`: 一个包含所有服务器上所有工具的数组。每个 `Tool` 对象包含 `name`, `description`, `inputSchema`, 和 `modelConfig` (其中 `modelConfig._mcpServerName` 指示工具所属的服务器)。\n\n### `client.callTool(toolName, args)`\n\n**Description:**\n\n异步调用指定名称的 MCP 工具。客户端会自动查找该工具所在的服务器，并将请求发送到该服务器。\n\n**Parameters:**\n\n-   `toolName` (`string`): 要调用的工具的名称。\n-   `args` (`unknown`): 传递给工具的参数，其结构应符合工具的 `inputSchema`。\n\n**Returns:**\n\n-   `Promise<unknown>`: 工具执行的结果。\n\n## Change log\n\n- `0.0.20250803-1`:\n  - 🏗 迁移代码库到 `inf/bytedai-js`\n- `0.0.20250711-1`:\n  - 🏗 支持通过 CommonJS 消费本包\n- `0.0.20250524-1`:\n  - ✨ `generateAddCallToolHeadersHook` 支持指定 toolName = '*' 为所有 tool 调用指定 Request Header\n- `0.0.20250521-2`:\n  - 🐛 修复 `clearBeforeCallHook`, `registerBeforeCallHook`, `connectAll`, `loadAllTools` 函数类型定义错误\n  - 🚨 构造函数里的 `headers` 的值，不再作为 callTool 和 listTools 请求的 HTTP Header 的数据源，而是通过 callTool 请求的 `body._meta.headers` 传递，用于向 MCP Server 传递自定义 Header。新增函数 `generateAddHttpHeadersHook` 支持原 `headers` 构造函数参数的功能。\n  - ✨ 支持在构造函数里指定 `params` 的值，通过 callTool 请求的 `body._meta.params` 传递给 MCP Gateway，用于传递请求变量\n  - ✨ 新增函数 `generateAddCallToolParamsHook` 和 `generateAddCallToolHeadersHook` 用于生成 tool 级别添加 Headers 和 Params 的 hooks\n  - ✨ 新增函数 `generatePrintHeaderAndBodyBeforeCallHook` 和 `generatePrintBodyAfterCallHook` 用于打印 SDK 发出请求的 Request Header, Request Body, Response Body，方便排查问题\n- `0.0.20250516-1`:\n  - 🏗 当调用 `loadAllTools` 时，如果 `connectAll` 尚未执行完成，则直接抛出错误\n  - 🏗 增加 `constructor` 和 `connectAll` 的UT\n  - ✨ 支持通过设置环境变量 `BYTED_MCP_CLIENT_SDK_NETWORK_TYPE` 来强制指定办公网运行环境\n- `0.0.20250430-1`:\n  - 🏗 当 `callTool` 得到的 `jsonResponse.result` 为空时，抛出异常，调用方可根据业务诉求自行捕获\n- `0.0.20250428-1`:\n  - 🐛 修复 afterCallHook 执行 2 遍的问题\n- `0.0.20250423-1`:\n  - ✨ 支持通过判断环境变量 `BYTED_HOST_IP` 或 `BYTED_HOST_IPV6` 是否存在判定当前运行环境是否位于生产网，推导出不同的 MCP Gateway 域名\n- `0.0.20250421-6`:\n  - ✨ 支持直接导出 `generateBytedServiceLoggerWithLogId` 和 `generateDefaultLogId` 函数，简化初始化流程\n  - 🏗 合并 `getAllTools` 的功能进 `loadAllTools`，不在需要额外调用 `getAllTools`\n  - ✨ 为了适配 `@byted/mcp-langgraph-adapter`，拆分出同步函数 `listLoadedTools` 列出已经被 `loadAllTools` 函数加载的 Tools\n  - 📚 新增 README 里的 API 章节\n- `0.0.20250418-4`: \n  - ✨ 在调用 `connectAll`, `loadAllTools` 和 `getAllTools` 函数时，要求显式传递 `ctx` 参数，用于向下游透传 `logId` 和 `logger` 等信息\n  - ✨ 支持在 `loadTool` 阶段调用 `BeforeCallHook`\n  - 🚨 不再为所有 MCP Server 默认注册 `addZtiTokenHook`\n\n## Luban\n- https://luban.bytedance.net/npm/publish/detail/8408/versions\n","_id":"@byted/mcp-client-sdk@0.0.20250803-1"},"0.0.20250421-6":{"scripts":{"playground":"tsx __test__/playground.ts","build":"rslib build","check":"biome check --write","dev":"rslib build --watch","format":"prettier --write .","lint":"eslint ."},"type":"module","version":"0.0.20250421-6","dependencies":{"@byted-service/fetch":"^2.6.5","@byted-service/logger":"^2.4.1","@byted-service/zti-helper":"^2.0.1","joi":"^17.9.2"},"types":"./dist/index.d.ts","devDependencies":{"@types/node":"^22.8.1","tsx":"4.7.0","typescript":"^5.8.2","@eslint/js":"^9.21.0","eslint":"^9.21.0","prettier":"^3.5.2","typescript-eslint":"^8.25.0","@biomejs/biome":"^1.9.4","globals":"^16.0.0","@rslib/core":"^0.6.1"},"_id":"@byted/mcp-client-sdk@0.0.20250421-6","dist":{"integrity":"sha512-FWZBL62lnbtpUQeSD6f0h/M/3pSURD9JUtAK4EMcM8S8srcvhwmuNNQpI12rXtxTIGPzmhQn+JdQO5PopDW/Uw==","tarball":"https://bnpm.byted.org/@byted/mcp-client-sdk/-/mcp-client-sdk-0.0.20250421-6.tgz","size":10762,"unpackedSize":57111,"fileCount":18,"shasum":"fd2d3f27e24f75e90923d220defe7d8da7c6c76a"},"module":"./dist/index.js","main":"./dist/index.cjs","readmeFilename":"README.md","_npmUser":{"name":"yangyang.jeff","email":"yangyang.jeff@bytedance.com"},"maintainers":[{"name":"yangyang.jeff","email":"yangyang.jeff@bytedance.com"}],"exports":{".":{"import":"./dist/index.js","require":"./dist/index.cjs","types":"./dist/index.d.ts"}},"name":"@byted/mcp-client-sdk","description":"## Bnpm - https://bnpm.bytedance.net/package/@byted/mcp-client-sdk","readme":"# @byted/mcp-client-sdk\n\n## Bnpm\n- https://bnpm.bytedance.net/package/@byted/mcp-client-sdk\n\n\n## Setup\n\n```bash\nyarn\n```\n\n## Code sample\n\n```typescript\nimport {\n  BytedMcpClient, \n  MCP_GATEWAY_REGION,\n  addZtiTokenHook,\n  generateBytedServiceLoggerWithLogId, \n  generateDefaultLogId \n} from '@byted/mcp-client-sdk';\n\n(async () => {\n  const testData = {\n      psm: 'inf.sinf.sample_mcp',\n      mcpGatewayRegion: MCP_GATEWAY_REGION.CN,\n      toolName: 'get_airplane',\n      args: {\n          from: 'beijing',\n          to: 'hong kong',\n      },\n  };\n\n  const client = new BytedMcpClient({\n      sampleMcpServer: {\n          transport: 'http',\n          psm: testData.psm,\n          mcpGatewayRegion: testData.mcpGatewayRegion,\n      },\n  });\n\n  const logId = generateDefaultLogId();\n  const ctx: BytedMcpClientContext = {\n    logger: generateBytedServiceLoggerWithLogId({ logId }),\n    logId,\n  };\n  await client.connectAll({ ctx });\n\n  await client.registerBeforeCallHook({\n    serverName: 'sampleMcpServer',\n    beforeCallHook: async ({ headers, body }) => {\n      headers['x-tt-logid'] = 'NEW_LOG_ID_FROM_REQUEST_CONTEXT';\n      body['Customized-body'] = 'Added by beforeCallHook';\n    },\n    ctx,\n  });\n  await client.registerBeforeCallHook({\n    serverName: 'sampleMcpServer',\n    beforeCallHook: addZtiTokenHook,\n    ctx,\n  });\n\n  const tools = await client.loadAllTools({ ctx });\n  ctx.logger.debug(`Available tools: ${tools.map((t) => t.name).join(',')}`);\n\n  const result = await client.callTool(testData.toolName, testData.args);\n  ctx.logger.debug(\n          `Result from ${testData.toolName}: ${JSON.stringify(result)}`,\n  );\n})();\n\n```\n\n## API\n\n### `new BytedMcpClient(connections)`\n\n**Description:**\n\n创建 `BytedMcpClient` 的实例。此客户端用于管理与一个或多个 MCP 服务器的连接，并调用这些服务器上的工具。\n\n**Parameters:**\n\n-   `connections` (`Record<string, HttpConnection>`): 一个对象，其中键是服务器的自定义名称（例如，`'myServer'`），值是 `HttpConnection` 对象，用于配置如何连接到该 MCP 服务器。\n    -   `HttpConnection` 包含以下字段：\n        -   `transport` (`'http'`): 传输协议，目前仅支持 'http'。\n        -   `url` (`string`, 可选): MCP 服务器的 HTTP 端点 URL。`url` 和 `psm` 必须提供其中一个。\n        -   `psm` (`string`, 可选): MCP 服务器的 PSM 标识。`url` 和 `psm` 必须提供其中一个。\n        -   `headers` (`Record<string, string>`, 可选): 发送到 MCP 服务器的自定义 HTTP 请求头。\n        -   `timeout` (`number`, 可选): 请求超时时间（毫秒）。\n        -   `mcpGatewayRegion` (`MCP_GATEWAY_REGION`, 可选): 当使用 `psm` 连接时，此字段为必需，指定 MCP 网关区域（`BOE`, `CN`, `I18N`）。\n\n### `client.connectAll({ ctx })`\n\n**Description:**\n\n异步连接到构造函数中配置的所有 MCP 服务器。此方法会尝试为每个配置的服务器建立连接，并在使用 PSM 时解析其 URL。\n\n**Parameters:**\n\n-   `ctx` (`BytedMcpClientContext`): 包含 `logger` 和 `logId` 的上下文对象，用于日志记录和追踪。\n\n### `client.registerBeforeCallHook({ serverName, beforeCallHook, ctx })`\n\n**Description:**\n\n为指定的 MCP 服务器或所有服务器注册一个前置调用钩子。此钩子函数会在向 MCP 服务器发送请求之前执行，允许修改请求头或请求体。\n\n**Parameters:**\n\n-   `serverName` (`string`): 要注册钩子的服务器名称（在构造函数中定义的键）。如果为 `'*'`，则为所有已连接的服务器注册钩子。\n-   `beforeCallHook` (`BeforeCallHook`): 一个异步函数，接收包含 `headers` 和 `body` 的对象，并允许对其进行修改。\n-   `ctx` (`BytedMcpClientContext`): 包含 `logger` 和 `logId` 的上下文对象。\n\n### `client.registerAfterCallHook({ serverName, afterCallHook, ctx })`\n\n**Description:**\n\n为指定的 MCP 服务器或所有服务器注册一个后置调用钩子。此钩子函数会在收到 MCP 服务器响应之后，但在 `callTool` 返回结果之前执行，允许检查或修改响应体。\n\n**Parameters:**\n\n-   `serverName` (`string`): 要注册钩子的服务器名称（在构造函数中定义的键）。如果为 `'*'`，则为所有已连接的服务器注册钩子。\n-   `afterCallHook` (`AfterCallHook`): 一个异步函数，接收包含响应 `body` 的对象，并允许对其进行修改。\n-   `ctx` (`BytedMcpClientContext`): 包含 `logger` 和 `logId` 的上下文对象。\n\n### `client.loadAllTools({ ctx })`\n\n**Description:**\n\n异步从所有已连接的 MCP 服务器加载并返回所有可用的工具列表。此方法会向每个服务器发送 `listTools` 请求。\n\n**Parameters:**\n\n-   `ctx` (`BytedMcpClientContext`): 包含 `logger` 和 `logId` 的上下文对象。\n\n**Returns:**\n\n-   `Promise<Tool[]>`: 一个包含所有服务器上所有工具的数组。每个 `Tool` 对象包含 `name`, `description`, `inputSchema`, 和 `modelConfig` (其中 `modelConfig._mcpServerName` 指示工具所属的服务器)。\n\n### `client.callTool(toolName, args)`\n\n**Description:**\n\n异步调用指定名称的 MCP 工具。客户端会自动查找该工具所在的服务器，并将请求发送到该服务器。\n\n**Parameters:**\n\n-   `toolName` (`string`): 要调用的工具的名称。\n-   `args` (`unknown`): 传递给工具的参数，其结构应符合工具的 `inputSchema`。\n\n**Returns:**\n\n-   `Promise<unknown>`: 工具执行的结果。\n\n## Change log\n\n- `0.0.20250421-6`:\n  - 支持直接导出 `generateBytedServiceLoggerWithLogId` 和 `generateDefaultLogId` 函数，简化初始化流程\n  - 合并 `getAllTools` 的功能进 `loadAllTools`，不在需要额外调用 `getAllTools`\n  - 为了适配 `@byted/mcp-langgraph-adapter`，拆分出同步函数 `listLoadedTools` 列出已经被 `loadAllTools` 函数加载的 Tools\n  - 新增 README 里的 API 章节\n- `0.0.20250418-4`: \n  - 在调用 `connectAll`, `loadAllTools` 和 `getAllTools` 函数时，要求显式传递 `ctx` 参数，用于向下游透传 `logId` 和 `logger` 等信息\n  - 支持在 `loadTool` 阶段调用 `BeforeCallHook`\n  - 不再为所有 MCP Server 默认注册 `addZtiTokenHook`\n\n## Luban\n- https://luban.bytedance.net/npm/publish/detail/8408/versions\n","files":["dist"]},"1.2.2":{"exports":{".":{"require":{"default":"./dist/index.cjs","types":"./dist/index.d.ts"},"import":{"default":"./dist/index.js","types":"./dist/index.d.ts"}}},"name":"@byted/mcp-client-sdk","maintainers":[{"name":"yangyang.jeff","email":"yangyang.jeff@bytedance.com"}],"_npmUser":{"email":"yangyang.jeff@bytedance.com","name":"yangyang.jeff"},"dependencies":{"joi":"^17.9.2","@byted-service/fetch":"^2.6.5","@byted-service/logger":"^2.4.1","@byted-service/zti-helper":"^2.0.1","@byted/ai-paas-env":"^1.0.2"},"type":"module","dist":{"shasum":"1fb594ed5979b284e87aa685a9e29b80a1f84c9e","integrity":"sha512-ZvAQxuiXJOq7hqtEuqS8dLG1+NoAyEovm1NKehqg66xSnCoXQo1z3yOHEmTipDI3dAv4lLTlEPeR5YW+wQFTaQ==","tarball":"https://bnpm.byted.org/@byted/mcp-client-sdk/-/mcp-client-sdk-1.2.2.tgz","size":13238,"unpackedSize":66236,"fileCount":22},"_id":"@byted/mcp-client-sdk@1.2.2","devDependencies":{"prettier":"^3.5.2","globals":"^16.0.0","@eslint/js":"^9.21.0","@rslib/core":"^0.7.1","@types/node":"^22.8.1","tsx":"^4.19.4","typescript-eslint":"^8.25.0","@biomejs/biome":"^1.9.4","typescript":"^5.8.2","@types/jest":"^29.5.12","jest":"^29.7.0","ts-jest":"^29.1.2","eslint":"^9.21.0","ts-node":"^10.9.2"},"main":"./dist/index.cjs","scripts":{"check":"biome check --write","dev":"rslib build --watch","format":"prettier --write .","lint":"eslint .","playground":"tsx __test__/playground.ts","test":"jest","build":"rslib build"},"module":"./dist/index.js","readme":"# @byted/mcp-client-sdk\n\n## Bnpm\n\n- https://bnpm.bytedance.net/package/@byted/mcp-client-sdk\n\n## Setup\n\n```bash\nyarn\n```\n\n## Code sample\n\n```typescript\nimport {\n  BytedMcpClient,\n  MCP_GATEWAY_REGION,\n  addZtiTokenHook,\n  generateBytedServiceLoggerWithLogId,\n  generateDefaultLogId,\n} from '@byted/mcp-client-sdk';\nimport { AI_PAAS_REGION } from '@byted/ai-paas-env';\n\n(async () => {\n  const testData = {\n    psm: 'inf.sinf.sample_mcp',\n    mcpGatewayRegion: AI_PAAS_REGION.CN,\n    toolName: 'get_airplane',\n    args: {\n      from: 'beijing',\n      to: 'hong kong',\n    },\n  };\n\n  const client = new BytedMcpClient({\n    sampleMcpServer: {\n      transport: 'http',\n      psm: testData.psm,\n      mcpGatewayRegion: testData.mcpGatewayRegion,\n    },\n  });\n\n  const logId = generateDefaultLogId();\n  const ctx: BytedMcpClientContext = {\n    logger: generateBytedServiceLoggerWithLogId({ logId }),\n    logId,\n  };\n  await client.connectAll({ ctx });\n\n  await client.registerBeforeCallHook({\n    serverName: 'sampleMcpServer',\n    beforeCallHook: async ({ headers, body }) => {\n      headers['x-tt-logid'] = 'NEW_LOG_ID_FROM_REQUEST_CONTEXT';\n      body['Customized-body'] = 'Added by beforeCallHook';\n    },\n    ctx,\n  });\n  await client.registerBeforeCallHook({\n    serverName: 'sampleMcpServer',\n    beforeCallHook: addZtiTokenHook,\n    ctx,\n  });\n\n  const tools = await client.loadAllTools({ ctx });\n  ctx.logger.debug(`Available tools: ${tools.map((t) => t.name).join(',')}`);\n\n  const result = await client.callTool(testData.toolName, testData.args);\n  ctx.logger.debug(\n    `Result from ${testData.toolName}: ${JSON.stringify(result)}`,\n  );\n})();\n```\n\n## API\n\n### `new BytedMcpClient(connections)`\n\n**Description:**\n\n创建 `BytedMcpClient` 的实例。此客户端用于管理与一个或多个 MCP 服务器的连接，并调用这些服务器上的工具。\n\n**Parameters:**\n\n- `connections` (`Record<string, HttpConnection>`): 一个对象，其中键是服务器的自定义名称（例如，`'myServer'`），值是 `HttpConnection` 对象，用于配置如何连接到该 MCP 服务器。\n  - `HttpConnection` 包含以下字段：\n    - `transport` (`'http'`): 传输协议，目前仅支持 'http'。\n    - `url` (`string`, 可选): MCP 服务器的 HTTP 端点 URL。`url` 和 `psm` 必须提供其中一个。\n    - `psm` (`string`, 可选): MCP 服务器的 PSM 标识。`url` 和 `psm` 必须提供其中一个。\n    - `headers` (`Record<string, string>`, 可选): 发送到 MCP 服务器的自定义 HTTP 请求头。\n    - `timeout` (`number`, 可选): 请求超时时间（毫秒）。\n    - `mcpGatewayRegion` (`MCP_GATEWAY_REGION`, 可选): 当使用 `psm` 连接时，此字段为必需，指定 MCP 网关区域（`BOE`, `CN`, `I18N`）。\n\n### `client.connectAll({ ctx })`\n\n**Description:**\n\n异步连接到构造函数中配置的所有 MCP 服务器。此方法会尝试为每个配置的服务器建立连接，并在使用 PSM 时解析其 URL。\n\n**Parameters:**\n\n- `ctx` (`BytedMcpClientContext`): 包含 `logger` 和 `logId` 的上下文对象，用于日志记录和追踪。\n\n### `client.registerBeforeCallHook({ serverName, beforeCallHook, ctx })`\n\n**Description:**\n\n为指定的 MCP 服务器或所有服务器注册一个前置调用钩子。此钩子函数会在向 MCP 服务器发送请求之前执行，允许修改请求头或请求体。\n\n**Parameters:**\n\n- `serverName` (`string`): 要注册钩子的服务器名称（在构造函数中定义的键）。如果为 `'*'`，则为所有已连接的服务器注册钩子。\n- `beforeCallHook` (`BeforeCallHook`): 一个异步函数，接收包含 `headers` 和 `body` 的对象，并允许对其进行修改。\n- `ctx` (`BytedMcpClientContext`): 包含 `logger` 和 `logId` 的上下文对象。\n\n### `client.registerAfterCallHook({ serverName, afterCallHook, ctx })`\n\n**Description:**\n\n为指定的 MCP 服务器或所有服务器注册一个后置调用钩子。此钩子函数会在收到 MCP 服务器响应之后，但在 `callTool` 返回结果之前执行，允许检查或修改响应体。\n\n**Parameters:**\n\n- `serverName` (`string`): 要注册钩子的服务器名称（在构造函数中定义的键）。如果为 `'*'`，则为所有已连接的服务器注册钩子。\n- `afterCallHook` (`AfterCallHook`): 一个异步函数，接收包含响应 `body` 的对象，并允许对其进行修改。\n- `ctx` (`BytedMcpClientContext`): 包含 `logger` 和 `logId` 的上下文对象。\n\n### `client.loadAllTools({ ctx })`\n\n**Description:**\n\n异步从所有已连接的 MCP 服务器加载并返回所有可用的工具列表。此方法会向每个服务器发送 `listTools` 请求。\n\n**Parameters:**\n\n- `ctx` (`BytedMcpClientContext`): 包含 `logger` 和 `logId` 的上下文对象。\n\n**Returns:**\n\n- `Promise<Tool[]>`: 一个包含所有服务器上所有工具的数组。每个 `Tool` 对象包含 `name`, `description`, `inputSchema`, 和 `modelConfig` (其中 `modelConfig._mcpServerName` 指示工具所属的服务器)。\n\n### `client.callTool(toolName, args)`\n\n**Description:**\n\n异步调用指定名称的 MCP 工具。客户端会自动查找该工具所在的服务器，并将请求发送到该服务器。\n\n**Parameters:**\n\n- `toolName` (`string`): 要调用的工具的名称。\n- `args` (`unknown`): 传递给工具的参数，其结构应符合工具的 `inputSchema`。\n\n**Returns:**\n\n- `Promise<unknown>`: 工具执行的结果。\n\n## Change log\n\n- `1.2.2`:\n  - 🏗 引入 `@byted/ai-paas-env` 依赖，规范化 AI PaaS 组件的 Region 命名\n- `1.1.2`:\n  - ✨ 新增函数 `inferMcpGatewayRegion` 用于根据环境变量推断 MCP 网关区域\n  - 🐛 修复 `inferMcpGatewayRegion` 对 FaaS Singapore-Central 区域的识别错误\n  - 🏗 导出 BaseLogger type\n- `1.0.1`:\n  - 🏗 发布第一个正式版本\n  - 🏗 将日志模块重构为基于抽象类的实现，提供更好的扩展性和类型安全\n  - 🏗 移除 allowImportingTsExtensions 配置并统一使用 .js 文件扩展名\n- `0.0.20250803-1`:\n  - 🏗 迁移代码库到 `inf/bytedai-js`\n- `0.0.20250711-1`:\n  - 🏗 支持通过 CommonJS 消费本包\n- `0.0.20250524-1`:\n  - ✨ `generateAddCallToolHeadersHook` 支持指定 toolName = '\\*' 为所有 tool 调用指定 Request Header\n- `0.0.20250521-2`:\n  - 🐛 修复 `clearBeforeCallHook`, `registerBeforeCallHook`, `connectAll`, `loadAllTools` 函数类型定义错误\n  - 🚨 构造函数里的 `headers` 的值，不再作为 callTool 和 listTools 请求的 HTTP Header 的数据源，而是通过 callTool 请求的 `body._meta.headers` 传递，用于向 MCP Server 传递自定义 Header。新增函数 `generateAddHttpHeadersHook` 支持原 `headers` 构造函数参数的功能。\n  - ✨ 支持在构造函数里指定 `params` 的值，通过 callTool 请求的 `body._meta.params` 传递给 MCP Gateway，用于传递请求变量\n  - ✨ 新增函数 `generateAddCallToolParamsHook` 和 `generateAddCallToolHeadersHook` 用于生成 tool 级别添加 Headers 和 Params 的 hooks\n  - ✨ 新增函数 `generatePrintHeaderAndBodyBeforeCallHook` 和 `generatePrintBodyAfterCallHook` 用于打印 SDK 发出请求的 Request Header, Request Body, Response Body，方便排查问题\n- `0.0.20250516-1`:\n  - 🏗 当调用 `loadAllTools` 时，如果 `connectAll` 尚未执行完成，则直接抛出错误\n  - 🏗 增加 `constructor` 和 `connectAll` 的UT\n  - ✨ 支持通过设置环境变量 `BYTED_MCP_CLIENT_SDK_NETWORK_TYPE` 来强制指定办公网运行环境\n- `0.0.20250430-1`:\n  - 🏗 当 `callTool` 得到的 `jsonResponse.result` 为空时，抛出异常，调用方可根据业务诉求自行捕获\n- `0.0.20250428-1`:\n  - 🐛 修复 afterCallHook 执行 2 遍的问题\n- `0.0.20250423-1`:\n  - ✨ 支持通过判断环境变量 `BYTED_HOST_IP` 或 `BYTED_HOST_IPV6` 是否存在判定当前运行环境是否位于生产网，推导出不同的 MCP Gateway 域名\n- `0.0.20250421-6`:\n  - ✨ 支持直接导出 `generateBytedServiceLoggerWithLogId` 和 `generateDefaultLogId` 函数，简化初始化流程\n  - 🏗 合并 `getAllTools` 的功能进 `loadAllTools`，不在需要额外调用 `getAllTools`\n  - ✨ 为了适配 `@byted/mcp-langgraph-adapter`，拆分出同步函数 `listLoadedTools` 列出已经被 `loadAllTools` 函数加载的 Tools\n  - 📚 新增 README 里的 API 章节\n- `0.0.20250418-4`:\n  - ✨ 在调用 `connectAll`, `loadAllTools` 和 `getAllTools` 函数时，要求显式传递 `ctx` 参数，用于向下游透传 `logId` 和 `logger` 等信息\n  - ✨ 支持在 `loadTool` 阶段调用 `BeforeCallHook`\n  - 🚨 不再为所有 MCP Server 默认注册 `addZtiTokenHook`\n\n## Luban\n\n- https://luban.bytedance.net/npm/publish/detail/8408/versions\n","files":["dist"],"version":"1.2.2","types":"./dist/index.d.ts","description":"## Bnpm","readmeFilename":"README.md"},"1.3.5-rc1":{"exports":{".":{"require":{"default":"./dist/index.cjs","types":"./dist/index.d.ts"},"import":{"types":"./dist/index.d.ts","default":"./dist/index.js"}}},"dist":{"shasum":"f7812a61fce22e1558247890343ee30415e75878","integrity":"sha512-DcGhayXY0P8LsRQGsGiMPKsDnKCxCpcYqtn9X+WpJYPlhpc066T4WcC4Cwu0DwHmKlYhpI8PdNat1jiukHpreg==","tarball":"https://bnpm.byted.org/@byted/mcp-client-sdk/-/mcp-client-sdk-1.3.5-rc1.tgz","size":14121,"unpackedSize":70854,"fileCount":34},"_id":"@byted/mcp-client-sdk@1.3.5-rc1","types":"./dist/index.d.ts","type":"module","files":["dist"],"scripts":{"dev":"rslib build --watch","format":"prettier --write .","lint":"eslint .","playground":"tsx __test__/playground.ts","test":"vitest","test:cov":"vitest run --coverage","build":"rslib build && yarn test:cov","check":"biome check --write"},"version":"1.3.5-rc1","dependencies":{"@byted/ai-paas-env":"^1.0.6","joi":"^17.9.2","@byted-service/fetch":"^2.6.5","@byted-service/logger":"^2.4.1","@byted-service/zti-helper":"^2.0.1"},"main":"./dist/index.cjs","module":"./dist/index.js","_npmUser":{"name":"baojinchang","email":"baojinchang@bytedance.com"},"readme":"# @byted/mcp-client-sdk\n\n## Bnpm\n\n- https://bnpm.bytedance.net/package/@byted/mcp-client-sdk\n\n## Setup\n\n```bash\nyarn\n```\n\n## 