esult as { content: { text: string }[] }).content[0].text +=\n            ' (Enjoy the MCP client, and this suffix was added by afterCallHook)';\n    });\n\n    const result = await client.callTool(testData.toolName, testData.args);\n    logger.debug(`Result from ${testData.toolName}: ${JSON.stringify(result)}`);\n})();\n\n```\n\n## Change log\n\n- 0.0.20250418-1: 在调用 `connectAll` 和 `getAllTools` 函数时，要求显式传递 `ctx` 参数，用于向下游透传 `logId` 和 `logger` 等信息\n\n## Luban\n- https://luban.bytedance.net/npm/publish/detail/8408/versions\n","main":"./dist/index.cjs","scripts":{"lint":"eslint .","playground":"tsx __test__/playground.ts","build":"rslib build","check":"biome check --write","dev":"rslib build --watch","format":"prettier --write ."},"maintainers":[{"email":"yangyang.jeff@bytedance.com","name":"yangyang.jeff"}],"version":"0.0.20250418-1","exports":{".":{"require":"./dist/index.cjs","types":"./dist/index.d.ts","import":"./dist/index.js"}},"type":"module"},"0.0.20250418-4":{"dist":{"shasum":"4772e6fc1d19d27f5d5b3b2ab7cdcc05b961b730","integrity":"sha512-pAxEdmoBKa2QU/csK4LBT0sXM64Ldwhj7HA3+mwqSLZquM1EVQY1MUPsvdXOEkwBuRKpATbnQYBFfoF31m4wvA==","tarball":"https://bnpm.byted.org/@byted/mcp-client-sdk/-/mcp-client-sdk-0.0.20250418-4.tgz","size":8592,"unpackedSize":47772,"fileCount":16},"main":"./dist/index.cjs","files":["dist"],"type":"module","devDependencies":{"@rslib/core":"^0.6.1","@eslint/js":"^9.21.0","tsx":"4.7.0","eslint":"^9.21.0","@biomejs/biome":"^1.9.4","globals":"^16.0.0","typescript-eslint":"^8.25.0","@types/node":"^22.8.1","prettier":"^3.5.2","typescript":"^5.8.2"},"version":"0.0.20250418-4","name":"@byted/mcp-client-sdk","readme":"# @byted/mcp-client-sdk\n\n## Bnpm\n- https://bnpm.bytedance.net/package/@byted/mcp-client-sdk\n\n\n## Setup\n\n```bash\nyarn\n```\n\n## Code sample\n\n```typescript\nimport { BytedMcpClient, MCP_GATEWAY_REGION } from '@byted/mcp-client-sdk';\nimport Logger from '@byted-service/logger';\nimport { randomBytes } from 'crypto';\nconst logge