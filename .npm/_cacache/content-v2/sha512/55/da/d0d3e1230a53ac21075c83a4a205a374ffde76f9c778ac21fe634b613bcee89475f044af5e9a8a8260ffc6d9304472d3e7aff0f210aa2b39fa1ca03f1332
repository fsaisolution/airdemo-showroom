ok)';\n    });\n\n    const result = await client.callTool('get_weather', {\n        city: 'Singapore',\n    });\n    logger.debug(`Result from get_weather:`, result);\n})();\n```\n\n## Luban\n- https://luban.bytedance.net/npm/publish/detail/8408/versions\n","scripts":{"lint":"eslint .","playground":"tsx __test__/playground.ts","build":"rslib build","check":"biome check --write","dev":"rslib build --watch","format":"prettier --write ."},"dependencies":{"@byted-service/fetch":"^2.6.5","@byted-service/logger":"^2.4.1","@byted-service/zti-helper":"^2.0.1","joi":"^17.9.2"},"name":"@byted/mcp-client-sdk","exports":{".":{"require":"./dist/index.cjs","types":"./dist/index.d.ts","import":"./dist/index.js"}},"version":"0.0.20250417-2"},"0.0.20250421-4":{"files":["dist"],"maintainers":[{"name":"yangyang.jeff","email":"yangyang.jeff@bytedance.com"}],"dist":{"fileCount":18,"shasum":"21d8020c0be44fcf7df7b23dc55c2efb8ec185c7","integrity":"sha512-kmljn7RddEawlrWI1l8QXjDzwO2+WsyAuMbDgTaeyiYxsR3QTbk6F4wLiFbVutU/bQpGDCuqx7I7gW9vEQyxTA==","tarball":"https://bnpm.byted.org/@byted/mcp-client-sdk/-/mcp-client-sdk-0.0.20250421-4.tgz","size":10636,"unpackedSize":56681},"devDependencies":{"typescript-eslint":"^8.25.0","globals":"^16.0.0","@rslib/core":"^0.6.1","@biomejs/biome":"^1.9.4","typescript":"^5.8.2","tsx":"4.7.0","eslint":"^9.21.0","@eslint/js":"^9.21.0","prettier":"^3.5.2","@types/node":"^22.8.1"},"types":"./dist/index.d.ts","description":"## Bnpm - https://bnpm.bytedance.net/package/@byted/mcp-client-sdk","_npmUser":{"name":"yangyang.jeff","email":"yangyang.jeff@bytedance.com"},"type":"module","readme":"# @byted/mcp-client-sdk\n\n## Bnpm\n- https://bnpm.bytedance.net/package/@byted/mcp-client-sdk\n\n\n## Setup\n\n```bash\nyarn\n```\n\n## Code sample\n\n```typescript\nimport {\n  BytedMcpClient, \n  MCP_GATEWAY_REGION,\n  addZtiTokenHook,\n  generateBytedServiceLoggerWithLogId, \n  generateDefaultLogId \n} from '@byted/mcp-client-sdk';\n\n(async () => {\n  const testData = {\n      psm: 'inf.sinf.sample_mcp',\n      mcpGatewayRegion: MCP_GATEWAY_REGION.CN,\n      toolName: 'get_airplane',\n      args: {\n          from: 'beijing',\n          to: 'hong kong',\n      },\n  };\n\n  const client = new BytedMcpClient({\n      sampleMcpServer: {\n          transport: 'http',\n          psm: testData.psm,\n          mcpGatewayRegion: testData.mcpGatewayRegion,\n      },\n  });\n\n  const logId = generateDefaultLogId();\n  const ctx: BytedMcpClientContext = {\n    logger: generateBytedServiceLoggerWithLogId({ logId }),\n    logId,\n  };\n  await client.connectAll({ ctx });\n\n  await client.registerBeforeCallHook({\n    serverName: 'sampleMcpServer',\n    beforeCallHook: async ({ headers, body }) => {\n      headers['x-tt-logid'] = 'NEW_LOG_ID_FROM_REQUEST_CONTEXT';\n      body['Customized-body'] = 'Added by beforeCallHook';\n    },\n    ctx,\n  });\n  await client.registerBeforeCallHook({\n    serverName: 'sampleMcpServer',\n    beforeCallHook: addZtiTokenHook,\n    ctx,\n  });\n\n  const tools = await client.loadAllTools({ ctx });\n  ctx.logger.debug(`Available tools: ${tools.map((t) => t.name).join(',')}`);\n\n  const result = await client.callTool(testData.toolName, testData.args);\n  ctx.logger.debug(\n          `Result from ${testData.toolName}: ${JSON.stringify(result)}`,\n  );\n})();\n\n```\n\n## API\n\n### `new BytedMcpClient(connections)`\n\n**Description:**\n\n创建 `BytedMcpClient` 的实例。此客户端用于管理与一个或多个 MCP 服务器的连接，并调用这些服务器上的工具。\n\n**Parameters:**\n\n-   `connections` (`Record<string, HttpConnection>`): 一个对象，其中键是服务器的自定义名称（例如，`'myServer'`），值是 `HttpConnection` 对象，用于配置如何连接到该 MCP 服务器。\n    -   `HttpConnection` 包含以下字段：\n        -   `transport` (`'http'`): 传输协议，目前仅支持 'http'。\n        -   `url` (`string`, 可选): MCP 服务器的 HTTP 端点 URL。`url` 和 `psm` 必须提供其中一个。\n        -   `psm` (`string`, 可选): MCP 服务器的 PSM 标识。`url` 和 `psm` 必须提供其中一个。\n        -   `headers` (`Record<string, string>`, 可选): 发送到 MCP 服务器的自定义 HTTP 请求头。\n        -   `timeout` (`number`, 可选): 请求超时时间（毫秒）。\n        -   `mcpGatewayRegion` (`MCP_GATEWAY_REGION`, 可选): 当使用 `psm` 连接时，此字段为必需，指定 MCP 网关区域（`BOE`, `CN`, `I18N`）。\n\n### `client.connectAll({ ctx })`\n\n**Description:**\n\n异步连接到构造函数中配置的所有 MCP 服务器。此方法会尝试为每个配置的服务器建立连接，并在使用 PSM 时解析其 URL。\n\n**Parameters:**\n\n-   `ctx` (`BytedMcpClientContext`): 包含 `logger` 和 `logId` 的上下文对象，用于日志记录和追踪。\n\n### `client.registerBeforeCallHook({ serverName, beforeCallHook, ctx })`\n\n**Description:**\n\n为指定的 MCP 服务器或所有服务器注册一个前置调用钩子。此钩子函数会在向 MCP 服务器发送请求之前执行，允许修改请求头或请求体。\n\n**Parameters:**\n\n-   `serverName` (`string`): 要注册钩子的服务器名称（在构造函数中定义的键）。如果为 `'*'`，则为所有已连接的服务器注册钩子。\n-   `beforeCallHook` (`BeforeCallHook`): 一个异步函数，接收包含 `headers` 和 `body` 的对象，并允许对其进行修改。\n-   `ctx` (`BytedMcpClientContext`): 包含 `logger` 和 `logId` 的上下文对象。\n\n### `client.registerAfterCallHook({ serverName, afterCallHook, ctx })`\n\n**Description:**\n\n为指定的 MCP 服务器或所有服务器注册一个后置调用钩子。此钩子函数会在收到 MCP 服务器响应之后，但在 `callTool` 返回结果之前执行，允许检查或修改响应体。\n\n**Parameters:**\n\n-   `serverName` (`string`): 要注册钩子的服务器名称（在构造函数中定义的键）。如果为 `'*'`，则为所有已连接的服务器注册钩子。\n-   `afterCallHook` (`AfterCallHook`): 一个异步函数，接收包含响应 `body` 的对象，并允许对其进行修改。\n-   `ctx` (`BytedMcpClientContext`): 包含 `logger` 和 `logId` 的上下文对象。\n\n### `client.loadAllTools({ ctx })`\n\n**Description:**\n\n异步从所有已连接的 MCP 服务器加载并返回所有可用的工具列表。此方法会向每个服务器发送 `listTools` 请求。\n\n**Parameters:**\n\n-   `ctx` (`BytedMcpClientContext`): 包含 `logger` 和 `logId` 的上下文对象。\n\n**Returns:**\n\n-   `Promise<Tool[]>`: 一个包含所有服务器上所有工具的数组。每个 `Tool` 对象包含 `name`, `description`, `inputSchema`, 和 `modelConfig` (其中 `modelConfig._mcpServerName` 指示工具所属的服务器)。\n\n### `client.callTool(toolName, args, { ctx })`\n\n**Description:**\n\n异步调用指定名称的 MCP 工具。客户端会自动查找该工具所在的服务器，并将请求发送到该服务器。\n\n**Parameters:**\n\n-   `toolName` (`string`): 要调用的工具的名称。\n-   `args` (`unknown`): 传递给工具的参数，其结构应符合工具的 `inputSchema`。\n-   `ctx` (`BytedMcpClientContext`): 包含 `logger` 和 `logId` 的上下文对象。\n\n**Returns:**\n\n-   `Promise<unknown>`: 工具执行的结果。\n\n## Change log\n\n- `0.0.20250421-4`:\n  - 支持直接导出 generateBytedServiceLoggerWithLogId 和 generateDefaultLogId 函数，简化初始化流程\n  - 合并 `getAllTools` 的功能进 `loadAllTools`，不在需要额外调用 `getAllTools`\n  - 新增 README 里的 API 章节\n- `0.0.20250418-4`: \n  - 在调用 `connectAll`, `loadAllTools` 和 `getAllTools` 函数时，要求显式传递 `ctx` 参数，用于向下游透传 `logId` 和 `logger` 等信息\n  - 支持在 `loadTool` 阶段调用 `BeforeCallHook`\n  - 不再为所有 MCP Server 默认注册 `addZtiTokenHook`\n\n## Luban\n- https://luban.bytedance.net/npm/publish/detail/8408/versions\n","_id":"@byted/mcp-client-sdk@0.0.20250421-4","dependencies":{"joi":"^17.9.2","@byted-service/fetch":"^2.6.5","@byted-service/logger":"^2.4.1","@byted-service/zti-helper":"^2.0.1"},"module":"./dist/index.js","version":"0.0.20250421-4","scripts":{"check":"biome check --write","dev":"rslib build --watch","format":"prettier --write .","lint":"eslint .","playground":"tsx __test__/playground.ts","build":"rslib build"},"readmeFilename":"README.md","name":"@byted/mcp-client-sdk","main":"./dist/index.cjs","exports":{".":{"require":"./dist/index.cjs","types":"./dist/index.d.ts","import":"./dist/index.js"}}},"1.3.6-alpha.huguangyu.1.20260118170417":{"_id":"@byted/mcp-client-sdk@1.3.6-alpha.huguangyu.1.20260118170417","exports":{".":{"import":{"types":"./dist/index.d.ts","default":"./dist/index.js"},"require":{"default":"./dist/index.cjs","types":"./dist/index.d.ts"}}},"main":"./dist/index.cjs","_nodeVersion":"20.19.6","dependencies":{"@byted-service/zti-helper":"^2.0.1","@byted/ai-paas-env":"^1.0.6","joi":"^17.9.2","@byted-service/fetch":"^2.6.5","@byted-service/logger":"^2.4.1"},"devDependencies":{"prettier":"^3.5.2","@vitest/coverage-v8":"^1.6.0","@eslint/js":"^9.21.0","@types/node":"^22.8.1","@rslib/core":"^0.7.1","typescript":"^5.8.2","globals":"^16.0.0","tsx":"^4.19.4","typescript-eslint":"^8.25.0","ts-node":"^10.9.2","eslint":"^9.21.0","vitest":"^1.6.0","@biomejs/biome":"^1.9.4"},"dist":{"unpackedSize":91018,"fileCount":38,"integrity":"sha512-AwlbbXflLFmYar0LiURlmbdrXs7EtS7LD/0YfjqGNQPNh01JWlq0hQKTwQwh/voEF5jOug41VRlEIJPqEglK5w==","shasum":"9aaa223d8473597d685031399b666499e917d650","tarball":"https://bnpm.byted.org/@byted/mcp-client-sdk/-/mcp-client-sdk-1.3.6-alpha.huguangyu.1.20260118170417.tgz","size":15511},"version":"1.3.6-alpha.huguangyu.1.20260118170417","_npmVersion":"10.8.2","_npmUser":{"email":"huguangyu.1@bytedance.com","name":"huguangyu.1"},"module":"./dist/index.js","types":"./dist/index.d.ts","maintainers":[{"email":"yangyang.jeff@bytedance.com","name":"yangyang.jeff"},{"name":"mario7lorenzo","email":"mario7lorenzo@bytedance.com"},{"email":"wangnan.33@bytedance.com","name":"wangnan.33"},{"email":"baojinchang@bytedance.com","name":"baojinchang"},{"name":"benn.tay","email":"benn.tay@bytedance.com"},{"email":"huguangyu.1@bytedance.com","name":"huguangyu.1"}],"gitHead":"9b0011bc4187e38fcb02daa9e6daf87b95ea69e0","description":"## Bnpm","files":["dist"],"readme":"# @byted/mcp-client-sdk\n\n## Bnpm\n\n- https://bnpm.bytedance.net/package/@byted/mcp-client-sdk\n\n## Setup\n\n```bash\nyarn\n```\n\n## Code sample\n\n```typescript\nimport {\n  BytedMcpClient,\n  MCP_GATEWAY_REGION,\n  addZtiTokenHook,\n  generateBytedServiceLoggerWithLogId,\n  generateDefaultLogId,\n} from '@byted/mcp-client-sdk';\nimport { AI_PAAS_REGION } from '@byted/ai-paas-env';\n\n(async () => {\n  const testData = {\n    psm: 'inf.sinf.sample_mcp',\n    mcpGatewayRegion: AI_PAAS_REGION.CN,\n    toolName: 'get_airplane',\n    args: {\n      from: 'beijing',\n      to: 'hong kong',\n    },\n  };\n\n  const client = new BytedMcpClient({\n    sampleMcpServer: {\n      transport: 'http',\n      psm: testData.psm,\n      mcpGatewayRegion: testData.mcpGatewayRegion,\n    },\n  });\n\n  const logId = generateDefaultLogId();\n  const ctx: BytedMcpClientContext = {\n    logger: generateBytedServiceLoggerWithLogId({ logId }),\n    logId,\n  };\n  await client.connectAll({ ctx });\n\n  await client.registerBeforeCallHook({\n    serverName: 'sampleMcpServer',\n    beforeCallHook: async ({ headers, body }) => {\n      headers['x-tt-logid'] = 'NEW_LOG_ID_FROM_REQUEST_CONTEXT';\n      body['Customized-body'] = 'Added by beforeCallHook';\n    },\n    ctx,\n  });\n  await client.registerBeforeCallHook({\n    serverName: 'sampleMcpServer',\n    beforeCallHook: addZtiTokenHook,\n    ctx,\n  });\n\n  const tools = await client.loadAllTools({ ctx });\n  ctx.logger.debug(`Available tools: ${tools.map((t) => t.name).join(',')}`);\n\n  const result = await client.callTool(testData.toolName, testData.args);\n  ctx.logger.debug(\n    `Result from ${testData.toolName}: ${JSON.stringify(result)}`,\n  );\n})();\n```\n\n## API\n\n### `new BytedMcpClient(connections)`\n\n**Description:**\n\n创建 `BytedMcpClient` 的实例。此客户端用于管理与一个或多个 MCP 服务器的连接，并调用这些服务器上的工具。\n\n**Parameters:**\n\n- `connections` (`Record<string, HttpConnection>`): 一个对象，其中键是服务器的自定义名称（例如，`'myServer'`），值是 `HttpConnection` 对象，用于配置如何连接到该 MCP 服务器。\n  - `HttpConnection` 包含以下字段：\n    - `transport` (`'http'`): 传输协议，目前仅支持 'http'。\n    - `url` (`string`, 可选): MCP 服务器的 HTTP 端点 URL。`url` 和 `psm` 必须提供其中一个。\n    - `psm` (`string`, 可选): MCP 服务器的 PSM 标识。`url` 和 `psm` 必须提供其中一个。\n    - `env` (`string`, 可选): MCP 服务器的环境标识，默认值为 `'prod'`。\n    - `headers` (`Record<string, string>`, 可选): 发送到 MCP 服务器的自定义 HTTP 请求头。\n    - `timeout` (`number`, 可选): 请求超时时间（毫秒）。\n    - `mcpGatewayRegion` (`MCP_GATEWAY_REGION`, 可选): 当使用 `psm` 连接时，此字段为必需，指定 MCP 网关区域（`BOE`, `CN`, `I18N`）。\n\n### `client.connectAll({ ctx })`\n\n**Description:**\n\n异步连接到构造函数中配置的所有 MCP 服务器。此方法会尝试为每个配置的服务器建立连接，并在使用 PSM 时解析其 URL。\n\n**Parameters:**\n\n- `ctx` (`BytedMcpClientContext`): 包含 `logger` 和 `logId` 的上下文对象，用于日志记录和追踪。\n\n### `client.registerBeforeCallHook({ serverName, beforeCallHook, ctx })`\n\n**Description:**\n\n为指定的 MCP 服务器或所有服务器注册一个前置调用钩子。此钩子函数会在向 MCP 服务器发送请求之前执行，允许修改请求头或请求体。\n\n**Parameters:**\n\n- `serverName` (`string`): 要注册钩子的服务器名称（在构造函数中定义的键）。如果为 `'*'`，则为所有已连接的服务器注册钩子。\n- `beforeCallHook` (`BeforeCallHook`): 一个异步函数，接收包含 `headers` 和 `body` 的对象，并允许对其进行修改。\n- `ctx` (`BytedMcpClientContext`): 包含 `logger` 和 `logId` 的上下文对象。\n\n### `client.registerAfterCallHook({ serverName, afterCallHook, ctx })`\n\n**Description:**\n\n为指定的 MCP 服务器或所有服务器注册一个后置调用钩子。此钩子函数会在收到 MCP 服务器响应之后，但在 `callTool` 返回结果之前执行，允许检查或修改响应体。\n\n**Parameters:**\n\n- `serverName` (`string`): 要注册钩子的服务器名称（在构造函数中定义的键）。如果为 `'*'`，则为所有已连接的服务器注册钩子。\n- `afterCallHook` (`AfterCallHook`): 一个异步函数，接收包含响应 `body` 的对象，并允许对其进行修改。\n- `ctx` (`BytedMcpClientContext`): 包含 `logger` 和 `logId` 的上下文对象。\n\n### `client.loadAllTools({ ctx })`\n\n**Description:**\n\n异步从所有已连接的 MCP 服务器加载并返回所有可用的工具列表。此方法会向每个服务器发送 `listTools` 请求。\n\n**Parameters:**\n\n- `ctx` (`BytedMcpClientContext`): 包含 `logger` 和 `logId` 的上下文对象。\n\n**Returns:**\n\n- `Promise<Tool[]>`: 一个包含所有服务器上所有工具的数组。每个 `Tool` 对象包含 `name`, `description`, `inputSchema`, 和 `modelConfig` (其中 `modelConfig._mcpServerName` 指示工具所属的服务器)。\n\n### `client.callTool(toolName, args)`\n\n**Description:**\n\n异步调用指定名称的 MCP 工具。客户端会自动查找该工具所在的服务器，并将请求发送到该服务器。\n\n**Parameters:**\n\n- `toolName` (`string`): 要调用的工具的名称。\n- `args` (`unknown`): 传递给工具的参数，其结构应符合工具的 `inputSchema`。\n\n**Returns:**\n\n- `Promise<unknown>`: 工具执行的结果。\n\n## Change log\n\n- `1.3.6`\n  - 🏗 支持合规域名\n- `1.3.5`\n  - ✨ 支持访问mcp ppe环境\n- `1.3.1`\n  - ✨ 支持 MCP Client 的 close 方法，实现析构，避免内存泄漏\n  - 🏗 修改 I18N 区域 MCP 网关域名为 `mcp.tiktok-row.net`\n- `1.2.4`:\n  - 🏗 引入 `@byted/ai-paas-env` 依赖，规范化 AI PaaS 组件的 Region 命名\n  - 🏗 提升单元测试覆盖率到 100%\n- `1.1.2`:\n  - ✨ 新增函数 `inferMcpGatewayRegion` 用于根据环境变量推断 MCP 网关区域\n  - 🐛 修复 `inferMcpGatewayRegion` 对 FaaS Singapore-Central 区域的识别错误\n  - 🏗 导出 BaseLogger type\n- `1.0.1`:\n  - 🏗 发布第一个正式版本\n  - 🏗 将日志模块重构为基于抽象类的实现，提供更好的扩展性和类型安全\n  - 🏗 移除 allowImportingTsExtensions 配置并统一使用 .js 文件扩展名\n- `0.0.20250803-1`:\n  - 🏗 迁移代码库到 `inf/bytedai-js`\n- `0.0.20250711-1`:\n  - 🏗 支持通过 CommonJS 消费本包\n- `0.0.20250524-1`:\n  - ✨ `generateAddCallToolHeadersHook` 支持指定 toolName = '\\*' 为所有 tool 调用指定 Request Header\n- `0.0.20250521-2`:\n  - 🐛 修复 `clearBeforeCallHook`, `registerBeforeCallHook`, `connectAll`, `loadAllTools` 函数类型定义错误\n  - 🚨 构造函数里的 `headers` 的值，不再作为 callTool 和 listTools 请求的 HTTP Header 的数据源，而是通过 callTool 请求的 `body._meta.headers` 传递，用于向 MCP Server 传递自定义 Header。新增函数 `generateAddHttpHeadersHook` 支持原 `headers` 构造函数参数的功能。\n  - ✨ 支持在构造函数里指定 `params` 的值，通过 callTool 请求的 `body._meta.params` 传递给 MCP Gateway，用于传递请求变量\n  - ✨ 新增函数 `generateAddCallToolParamsHook` 和 `generateAddCallToolHeadersHook` 用于生成 tool 级别添加 Headers 和 Params 的 hooks\n  - ✨ 新增函数 `generatePrintHeaderAndBodyBeforeCallHook` 和 `generatePrintBodyAfterCallHook` 用于打印 SDK 发出请求的 Request Header, Request Body, Response Body，方便排查问题\n- `0.0.20250516-1`:\n  - 🏗 当调用 `loadAllTools` 时，如果 `connectAll` 尚未执行完成，则直接抛出错误\n  - 🏗 增加 `constructor` 和 `connectAll` 的UT\n  - ✨ 支持通过设置环境变量 `BYTED_MCP_CLIENT_SDK_NETWORK_TYPE` 来强制指定办公网运行环境\n- `0.0.20250430-1`:\n  - 🏗 当 `callTool` 得到的 `jsonResponse.result` 为空时，抛出异常，调用方可根据业务诉求自行捕获\n- `0.0.20250428-1`:\n  - 🐛 修复 afterCallHook 执行 2 遍的问题\n- `0.0.20250423-1`:\n  - ✨ 支持通过判断环境变量 `BYTED_HOST_IP` 或 `BYTED_HOST_IPV6` 是否存在判定当前运行环境是否位于生产网，推导出不同的 MCP Gateway 域名\n- `0.0.20250421-6`:\n  - ✨ 支持直接导出 `generateBytedServiceLoggerWithLogId` 和 `generateDefaultLogId` 函数，简化初始化流程\n  - 🏗 合并 `getAllTools` 的功能进 `loadAllTools`，不在需要额外调用 `getAllTools`\n  - ✨ 为了适配 `@byted/mcp-langgraph-adapter`，拆分出同步函数 `listLoadedTools` 列出已经被 `loadAllTools` 函数加载的 Tools\n  - 📚 新增 README 里的 API 章节\n- `0.0.20250418-4`:\n  - ✨ 在调用 `connectAll`, `loadAllTools` 和 `getAllTools` 函数时，要求显式传递 `ctx` 参数，用于向下游透传 `logId` 和 `logger` 等信息\n  - ✨ 支持在 `loadTool` 阶段调用 `BeforeCallHook`\n  - 🚨 不再为所有 MCP Server 默认注册 `addZtiTokenHook`\n\n## Luban\n\n- https://luban.bytedance.net/npm/publish/detail/8408/versions\n","name":"@byted/mcp-client-sdk","type":"module","readmeFilename":"README.md","scripts":{"dev":"rslib build --watch","publish:alpha":"npm version $(node -p \"require('./package.json').version\")-alpha.$(git config user.name | tr -d ' ').$(date +%Y%m%d%H%M%S) --no-git-tag-version && npm publish --tag alpha","format":"prettier --write .","playground":"tsx __test__/playground.ts","check":"biome check --write","test":"vitest","lint":"eslint .","build":"rslib build && yarn test:cov","test:cov":"vitest run --coverage"}}},"_rev":"70"}