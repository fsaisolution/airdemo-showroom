roupKey('<nodeName>', '<key>');\n        console.log('getGroupKey res: ', res);\n    } catch (error) {\n        if (error.code === TccErrorCode.errKeyNotFound) {\n            console.log('[tcc-general] key not found, error: ', error);\n        } else {\n            console.log('[tcc-general] getGroupKey error : ', error);\n        }\n    }\n})().then(() => {});\n```\n","readmeFilename":"README.en.md","_nodeVersion":"18.20.4","repository":{"type":"git","url":"https://code.byted.org/nodejs/byted-service"},"_npmVersion":"lerna/undefined/node@v18.20.4+x64 (linux)","version":"2.0.7","types":"lib/index.d.ts","license":"MIT","_id":"@byted-service/tcc-general@2.0.7","scripts":{"build":"rm -rf lib && tsc","prepublish":"npm run build","test":"ROUTE_IP=10.225.130.44 RUNTIME_IDC_NAME=boe ../../node_modules/.bin/jest --config ./jest.config.json --coverage --env=node"},"engines":{"node":">=10.0.0"},"files":["lib","index.js"],"description":"[![bnpm](https://web-bnpm.byted.org/badge/v/@byted-service/tcc-general.svg?style=flat-square)](https://web-bnpm.byted.org/package/@byted-service/tcc-general) [![download](https://2y8ngapf.fn.bytedance.net/d?p=@byted-service/tcc-general)](https://web-bnpm.byted.org/package/@byted-service/tcc-general)","author":{"name":"sunjie"},"name":"@byted-service/tcc-general"},"0.0.5-alpha.0":{"keywords":[],"version":"0.0.5-alpha.0","publish_time":1616907600492,"description":"> [TCC general docs](https://bytedance.feishu.cn/docs/doccnjcN6Uy6YG7Ohl5JuQOEmsd)","dist":{"shasum":"a1a94376b0f95b8e64e30235c79874ffb6be5f67","size":15745,"tarball":"https://bnpm.byted.org/@byted-service/tcc-general/-/tcc-general-0.0.5-alpha.0.tgz","key":"/@byted-service/tcc-general/-/@byted-service/tcc-general-0.0.5-alpha.0.tgz"},"_id":"@byted-service/tcc-general@0.0.5-alpha.0","_publish_on_cnpm":true,"license":"ISC","_npmVersion":"lerna/undefined/node@v12.21.0+x64 (linux)","_nodeVersion":"12.21.0","types":"lib/index.d.ts","files":["lib","index.js"],"scripts":{"build":"rm -rf lib && 