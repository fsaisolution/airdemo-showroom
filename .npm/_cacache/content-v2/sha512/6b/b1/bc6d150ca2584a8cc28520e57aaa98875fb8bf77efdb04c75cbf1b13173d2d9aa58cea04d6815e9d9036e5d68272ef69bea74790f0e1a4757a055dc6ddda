n    try {\n        // group config node\n        res = await tccGeneral.getGroupKey('<nodeName>', '<key>');\n        console.log('getGroupKey res: ', res);\n    } catch (error) {\n        if (error.code === TccErrorCode.errKeyNotFound) {\n            console.log('[tcc-general] key not found, error: ', error);\n        } else {\n            console.log('[tcc-general] getGroupKey error : ', error);\n        }\n    }\n})().then(() => {});\n```\n","scripts":{"build":"rm -rf lib && ../../node_modules/.bin/tsc","prepublish":"npm run build","test":"ROUTE_IP=10.225.130.44 RUNTIME_IDC_NAME=boe ../../node_modules/.bin/jest --config ./jest.config.json --coverage --env=node"},"description":"[![bnpm](https://web-bnpm.byted.org/badge/v/@byted-service/tcc-general.svg?style=flat-square)](https://web-bnpm.byted.org/package/@byted-service/tcc-general) [![download](https://2y8ngapf.fn.bytedance.net/d?p=@byted-service/tcc-general)](https://web-bnpm.byted.org/package/@byted-service/tcc-general)","dependencies":{"@byted-service/env":"^1.12.2","@byted-service/logger":"^2.1.2","@byted-service/metrics":"^1.13.4","node-fetch":"^2.6.1","tslib":"^1.9.3","@byted-service/consul":"^2.1.3"},"readmeFilename":"README.en.md","_id":"@byted-service/tcc-general@2.0.0","version":"2.0.0","_npmUser":{"name":"nodejs-team","email":"nodejs-team@bytedance.com"},"license":"MIT","_npmVersion":"lerna/undefined/node@v14.19.3+x64 (linux)","engines":{"node":">=10.0.0"},"files":["lib","index.js"],"types":"lib/index.d.ts","dist":{"fileCount":23,"integrity":"sha512-JJ++YU4mugenmBBzRT4HaxVUfXWDVj0hh5U82y2FDhGaRoKwmjN4QT3iUgjzazsLU6gel9fDrn9S0qJXXmPo0w==","shasum":"7d8424ae514108e7887928a1add60c1d1788b17b","size":11858,"tarball":"https://bnpm.byted.org/@byted-service/tcc-general/-/tcc-general-2.0.0.tgz","unpackedSize":46724},"author":{"name":"sunjie"},"name":"@byted-service/tcc-general","maintainers":[{"email":"nodejs-team@bnpm.com","name":"nodejs-team","avatar":""},{"email":"xieweicheng@bytedance.com","name":"xieweiche