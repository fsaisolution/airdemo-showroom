erviceName>',\n    });\n\n    let res;\n    try {\n        // normal config node, watch out the exception that throw by sdk\n        res = await tccGeneral.get('<nodeName>');\n        console.log('getNode res: ', res);\n    } catch (error) {\n        if (error.code === TccErrorCode.errKeyNotFound) {\n            console.log('[tcc-general] key not found, error: ', error);\n        } else {\n            console.log('[tcc-general] get error : ', error);\n        }\n    }\n\n    try {\n        // group config node\n        res = await tccGeneral.getGroupKey('<nodeName>', '<key>');\n        console.log('getGroupKey res: ', res);\n    } catch (error) {\n        if (error.code === TccErrorCode.errKeyNotFound) {\n            console.log('[tcc-general] key not found, error: ', error);\n        } else {\n            console.log('[tcc-general] getGroupKey error : ', error);\n        }\n    }\n})().then(() => {});\n```\n","dist":{"shasum":"c7a53fa9b508e4f95fdc59732150bdf1994213c2","tarball":"https://bnpm.byted.org/@byted-service/tcc-general/-/tcc-general-2.0.8-alpha.0.tgz","size":12433,"unpackedSize":49458,"fileCount":23,"integrity":"sha512-s4qrhwDL3g53j9XXI2Yfg3SSvd4pVJx50lCJVLjP60Yj9wYVGwySTjTHC1E0mGSE4eDeUqEJNgo2sXp2FM5lnw=="},"license":"MIT","scripts":{"build":"rm -rf lib && tsc","prepublish":"npm run build","test":"ROUTE_IP=10.225.130.44 RUNTIME_IDC_NAME=boe ../../node_modules/.bin/jest --config ./jest.config.json --coverage --env=node"},"_npmVersion":"lerna/undefined/node@v16.20.1+x64 (linux)","engines":{"node":">=10.0.0"},"readmeFilename":"README.en.md","maintainers":[{"email":"nodejs-team@bnpm.com","name":"nodejs-team","avatar":""},{"email":"xieweicheng@bytedance.com","name":"xieweicheng","avatar":"https://s1-fs.pstatp.com/static-resource/v1/f27851c0-d3e8-4851-a606-1a3d9361b82g~?image_size=72x72&cut_type=&quality=&format=png&sticker_format=.webp"}],"main":"index.js","repository":{"type":"git","url":"https://code.byted.org/nodejs/byted-service"},"author":{"name":"sunjie"