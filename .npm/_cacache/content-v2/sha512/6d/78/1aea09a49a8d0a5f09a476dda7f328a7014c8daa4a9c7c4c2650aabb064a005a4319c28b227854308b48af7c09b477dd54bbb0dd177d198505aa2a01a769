/xxx');\n```\n","repository":{"type":"git","url":"https://code.byted.org/nodejs/byted-service"},"_nodeVersion":"14.20.0","author":"","engines":{"node":">=10.0.0"},"main":"lib/index.js","maintainers":[{"avatar":"https://s3-fs.pstatp.com/static-resource/v1/bf5207f4-07f4-4c43-9004-b01af1aff365~?image_size=72x72&cut_type=&quality=&format=png&sticker_format=.webp","email":"liyubei@bytedance.com","name":"liyubei"},{"avatar":"","email":"nodejs-team@bnpm.com","name":"nodejs-team"},{"email":"ouyangyadong@bytedance.com","name":"ouyangyadong","avatar":"https://s1-fs.pstatp.com/static-resource/v1/d27d000e276d58ace3df~?image_size=72x72&cut_type=&quality=&format=png&sticker_format=.webp"},{"avatar":"https://s1-fs.pstatp.com/static-resource/v1/a339a912-f731-4fe7-9e51-d91e1871180g~?image_size=240x240&cut_type=&quality=&format=image&sticker_format=.webp","email":"xieda@bytedance.com","name":"xieda"}],"name":"@byted-service/fetch-protocol-faas","scripts":{"build":"rm -rf lib && ../../node_modules/.bin/tsc","prepublish":"npm run build","test":"ROUTE_IP=10.225.130.44 RUNTIME_IDC_NAME=boe ../../node_modules/.bin/jest --config ./jest.config.json --coverage --env=node"},"_npmVersion":"lerna/undefined/node@v14.20.0+x64 (linux)","description":"faas protocol for @byted-service/fetch","dist":{"fileCount":12,"integrity":"sha512-ZSHdgCjvk1zhCbWNoDYCmn7YmkW3z8BQ85YwB3eYR3bgD/poVVc/q7luEGAFl708CU0tyb/HcQZly6bGf2tzOw==","shasum":"33f2a3154386b908632126fd5bc0a0bf7f9c746f","size":8385,"tarball":"https://bnpm.byted.org/@byted-service/fetch-protocol-faas/-/fetch-protocol-faas-2.3.3-alpha.1.tgz","unpackedSize":31968},"gitHead":"13075453c4c5fb6285e099d1fe0e6337da5d831d","readmeFilename":"README.en.md","version":"2.3.3-alpha.1"},"1.2.3":{"dist":{"integrity":"sha512-6xPVlwdLMd2l+y59a0yDQgOKVR7vVmezeeq9Bd1ZPItUOwWLVeUgKizLYsG6/IUD5/6k6JKSQBcMuLWyLvR+SQ==","shasum":"eec8541a60d1e3fb36592db26068071f3dcc94a3","tarball":"https://bnpm.byted.org/@byted-service/fetch-protocol-faas/-/fetch-protocol-faas-1.2.3.tgz"