 incr(1),         // 增加一个 RateCounter\n  incrCounter(1),  // 增加一个 Counter\n  incrMeter(1),    // 增加一个 Meter\n  observe(1),      // 增加一个 Timer\n  store(1),        // 增加一个 Store\n)\n```\n\n使用默认多值\n\n```ts\nimport { Client, incr, incrCounter, incrMeter, observe, store } from '@byted-nodex/metrics';\n\nconst client = new Client(); // 创建 metric client \nconst metric = client.newMetric('nodejs.test', { // 创建一个 metric 操作对象\n  tagNames: [ 'foo', 'bar' ],\n  forceMultiFields: true, // 开启多值\n});\n\nmetric.withTags({  // withTags 是根据 tags 检索出对应的序列管理器（ 如果没有序列会创建一个 ）\n  foo: 'a',\n  bar: 'b',\n}).emit(           // 调用序列管理器的 emit 增加指标项\n  incr(1),         // 增加一个 RateCounter ，多值 field 为 rate\n  incrCounter(1),  // 增加一个 Counter ，多值 field 为 counter\n  incrMeter(1),    // 增加一个 Meter ，多值 field 为 meter 跟 meter.rate\n  observe(1),      // 增加一个 Timer ，多值 field 为 timer.min/timer.max/timer.avg/timer.sum/timer.counter/... \n  store(1),        // 增加一个 Store ，多值 field 为 store\n)\n```\n\n使用自定义多值\n\n```ts\nimport {\n  Client,\n  incr,\n  incrCounter,\n  incrMeter,\n  observe,\n  store,\n  newRateCounterField,\n  newTimerField,\n  newCounterField,\n  newMeterField,\n  newStoreField,\n} from '@byted-nodex/metrics';\n\nconst client = new Client(); // 创建 metric client \nconst metric = client.newMetric('nodejs.test', { // 创建一个 metric 操作对象\n  tagNames: [ 'foo', 'bar' ],\n  forceMultiFields: true, // 开启多值\n  fields: [\n    newRateCounterField('my_rate'), // 自定义一个 my_rate 的 RateCounter 值\n    newTimerField('my_timer'),      // 自定义一个 my_timer 的 Timer 值\n    newCounterField('my_counter'),  // 自定义一个 my_counter 的 Counter 值\n    newMeterField('my_meter'),      // 自定义一个 my_meter 的 Meter 值\n    newStoreField('my_store'),      // 自定义一个 my_store 的 Store 值\n  ]\n});\n\nmetric.withTags({  // withTags 是根据 tags 检索出对应的序列管理器（ 如果没有序列会创建一个 ）\n  foo: 'a',\n  bar: 'b',\n}).emit(           // 调用序列管理器的 emit 增加指标项\n  withField('my_rate').incr(1),         // 增加一个 RateCounter ，多值 field 为 my_rate\n  withField('my_counter').incrCounter(1),  // 增加一个 Counter ，多值 field 为 my_counter\n  withField('my_meter').incrMeter(1),    // 增加一个 Meter ，多值 field 为 my_meter 跟 my_meter.rate\n  withField('my_timer').observe(1),      // 增加一个 Timer ，多值 field 为 my_timer.min/my_timer.max/my_timer.avg/my_timer.sum/my_timer.counter/... \n  withField('my_store').store(1),        // 增加一个 Store ，多值 field 为 my_store\n)\n```\n\n多值查询\n\n![image](https://code.byted.org/nodejs/byted-nodex/uploads/53a80ea237cc728726888e4008f19706/image.png)\n\n## 性能测试\n\n根据压测以及本地 benchmark 数据来看，v2 的近端聚合相比于 v1 频繁 udpSend ，在性能上大概有 8 倍左右的提升（ 压测 900qps vs 80+qps ，benchmark 80000+ ops/sec vs 10000 ops/sec ）\n\n### 压测\n\n在 boe 环境进行了压测，[压测报告](https://bytedance.feishu.cn/docx/ZdtUd7fDLo6wjWxlnmoc1rNKngX)\n\n### Benchmark\n\n测试机器规格：开发机 Debian 10 linux 5.4 ，8c16g\n\n```\nclient v2( define tag ) x 86,807 ops/sec ±5.35% (67 runs sampled)\nclient v2( not define tag ) x 48,456 ops/sec ±31.91% (60 runs sampled)\nclient v2( compatible usage ) x 17,568 ops/sec ±3.68% (76 runs sampled)\nclient v1( not define tag ) x 10,715 ops/sec ±42.24% (52 runs sampled)\nclient v1( define tag ) x 3,849 ops/sec ±49.20% (18 runs sampled)\n```\n\n## 开发指南\n\n[DEVELOPMENT.md](./DEVELOPMENT.md)\n\n"},"1.1.7-alpha.0":{"scripts":{"build:watch":"tsc --watch","test":"jest --config ./jest.config.js --coverage","test:watch":"jest --config ./jest.config.js --coverage --watch","build":"rm -rf lib && tsc"},"gitHead":"9c1794b42d358c8664d51cb531d8101856be3d9d","dist":{"integrity":"sha512-u3p1Cr28ujVXfzAegOXJGi538mw1zn9aTplMftFAcg3lIp8ZGLRHDohWVgttwuRy1SM/xfr7/2hjwf9dNUBBlA==","shasum":"94de21227d6de35451edfca00e91283553a17c2f","tarball":"https://bnpm.byted.org/@byted-nodex/metrics/-/metrics-1.1.7-alpha.0.tgz","size":31897,"unpackedSize":127989,"fileCount":60},"files":["lib","README.md"],"_npmVersion":"10.8.2","keywords":["metrics"],"readmeFilename":"README.md","version":"1.1.7-alpha.0","repository":{"url":"https://code.byted.org/nodejs/byted-nodex/tree/master/packages-inner/metrics","type