"test:watch":"jest --config ./jest.config.js --coverage --watch","build":"rm -rf lib && tsc","build:watch":"tsc --watch"},"_npmUser":{"email":"gulux-team@bytedance.com","name":"gulux-team"},"_from":"file:byted-nodex-metrics-1.1.1.tgz","dependencies":{"@byted-nodex/logger-core":"^1.1.2","@byted-nodex/metrics-codec":"^1.0.0","@byted-service/env":"^1.15.0","generic-pool":"^3.9.0","ip":"^1.1.8","node-unix-socket":"^0.2.4","type-fest":"^3.11.1"},"description":"Metrics V2 SDK"},"1.1.10-alpha.1":{"name":"@byted-nodex/metrics","description":"Metrics V2 SDK","devDependencies":{"ts-node":"^10.9.1","@byted-service/metrics":"^1.14.0","@types/ip":"^1.1.3","benchmark":"^2.1.4"},"keywords":["metrics"],"bugs":{"url":"https://code.byted.org/nodejs/byted-nodex/issues"},"files":["lib","README.md"],"version":"1.1.10-alpha.1","_npmVersion":"10.8.2","author":{"name":"wanghongxing.1108@bytedance.com"},"readmeFilename":"README.md","_npmUser":{"name":"shanshengkai","email":"shanshengkai@bytedance.com"},"dist":{"tarball":"https://bnpm.byted.org/@byted-nodex/metrics/-/metrics-1.1.10-alpha.1.tgz","size":31930,"unpackedSize":128123,"fileCount":60,"integrity":"sha512-9+gwtOQQMg85kWh2nPXKj8ahSQyQWkhopdGZtq3PoQDiHA13BbgYOrRD5kI2S2hq6hIm2gnvHIt5aAk6XamFyQ==","shasum":"d59622c8958fca0cc47d288f59dd56568aa75fe7"},"maintainers":[{"name":"wanggan.kk","email":"wanggan.kk@bytedance.com"},{"name":"wanghongxing.1108","email":"wanghongxing.1108@bytedance.com"},{"email":"gulux-team@bytedance.com","name":"gulux-team"}],"repository":{"url":"https://code.byted.org/nodejs/byted-nodex/tree/master/packages-inner/metrics","type":"git"},"types":"./lib/index.d.ts","gitHead":"0819d1c8bbbc3a8d971474094cab38d53de7d31b","_nodeVersion":"20.17.0","main":"lib/index.js","scripts":{"test":"jest --config ./jest.config.js --coverage","test:watch":"jest --config ./jest.config.js --coverage --watch","build":"rm -rf lib && tsc","build:watch":"tsc --watch"},"_id":"@byted-nodex/metrics@1.1.10-alpha.1","dependencies":{"@byted-nodex/logger-core":"^1.1.6","@byted-nodex/metrics-codec":"^1.0.0","@byted-service/env":"^1.15.0","generic-pool":"^3.9.0","ip":"^1.1.8","node-unix-socket":"^0.2.7","type-fest":"^3.11.1"},"readme":"# @byted-nodex/metrics\n\nMetrics V2 SDK ( 能力对齐 [golang metrics v4 版本](https://bytedance.feishu.cn/wiki/wikcndhGxB3yS3eEAXoQvB5G8jg) ) ，[方案背景](https://bytedance.feishu.cn/docx/JZYJdEn7OolD9AxpavTc0UR3n6b)\n\n> **注意**，该 SDK 为 GuluX Metrics 的基础能力库，不建议单独使用！！\n\n## 安装\n\n```bash\n$ npm i @byted-nodex/metrics --save\n```\n\n## 使用\n\n常规使用\n\n```ts\nimport { Client, incr, incrCounter, incrMeter, observe, store } from '@byted-nodex/metrics';\n\nconst client = new Client(); // 创建 metric client \nconst metric = client.newMetric('nodejs.test', { // 创建一个 metric 操作对象\n  tagNames: [ 'foo', 'bar' ],\n});\n\nmetric.withTags({  // withTags 是根据 tags 检索出对应的序列管理器（ 如果没有序列会创建一个 ）\n  foo: 'a',\n  bar: 'b',\n}).emit(           // 调用序列管理器的 emit 增加指标项\n  incr(1),         // 增加一个 RateCounter\n  incrCounter(1),  // 增加一个 Counter\n  incrMeter(1),    // 增加一个 Meter\n  observe(1),      // 增加一个 Timer\n  store(1),        // 增加一个 Store\n)\n```\n\n使用默认多值\n\n```ts\nimport { Client, incr, incrCounter, incrMeter, observe, store } from '@byted-nodex/metrics';\n\nconst client = new Client(); // 创建 metric client \nconst metric = client.newMetric('nodejs.test', { // 创建一个 metric 操作对象\n  tagNames: [ 'foo', 'bar' ],\n  forceMultiFields: true, // 开启多值\n});\n\nmetric.withTags({  // withTags 是根据 tags 检索出对应的序列管理器（ 如果没有序列会创建一个 ）\n  foo: 'a',\n  bar: 'b',\n}).emit(           // 调用序列管理器的 emit 增加指标项\n  incr(1),         // 增加一个 RateCounter ，多值 field 为 rate\n  incrCounter(1),  // 增加一个 Counter ，多值 field 为 counter\n  incrMeter(1),    // 增加一个 Meter ，多值 field 为 meter 跟 meter.rate\n  observe(1),      // 增加一个 Timer ，多值 field 为 timer.min/timer.max/timer.avg/timer.sum/timer.counter/... \n  store(1),        // 增加一个 Store ，多值 field 为 store\n)\n```\n\n使用自定义多值\n\n```ts\nimport {\n  Client,\n  incr,\n  incrCounter,\n  incrMeter,\n  observe,\n  store,\n  newRateCounterField,\n  newTimerField,\n  newCounterField,\n  newMeterField,\n  newStoreField,\n} from '@byted-nodex/metrics';\n\nconst client = new Client(); // 创建 metric client \nconst metric = client.newMetric('nodejs.test', { // 创建一个 metric 操作对象\n  tagNames: [ 'foo', 'bar' ],\n  forceMultiFields: true, // 开启多值\n  fields: [\n    newRateCounterField('my_rate'), // 自定义一个 my_rate 的 RateCounter 值\n    newTimerField('my_timer'),      // 自定义一个 my_timer 的 Timer 值\n    newCounterField('my_counter'),  // 自定义一个 my_counter 的 Counter 值\n    newMeterField('my_meter'),      // 自定义一个 my_meter 的 Meter 值\n    newStoreField('my_store'),      // 自定义一个 my_store 的 Store 值\n  ]\n});\n\nmetric.withTags({  // withTags 是根据 tags 检索出对应的序列管理器（ 如果没有序列会创建一个 ）\n  foo: 'a',\n  bar: 'b',\n}).emit(           // 调用序列管理器的 emit 增加指标项\n  withField('my_rate').incr(1),         // 增加一个 RateCounter ，多值 field 为 my_rate\n  withField('my_counter').incrCounter(1),  // 增加一个 Counter ，多值 field 为 my_counter\n  withField('my_meter').incrMeter(1),    // 增加一个 Meter ，多值 field 为 my_meter 跟 my_meter.rate\n  withField('my_timer').observe(1),      // 增加一个 Timer ，多值 field 为 my_timer.min/my_timer.max/my_timer.avg/my_timer.sum/my_timer.counter/... \n  withField('my_store').store(1),        // 增加一个 Store ，多值 field 为 my_store\n)\n```\n\n多值查询\n\n![image](https://code.byted.org/nodejs/byted-nodex/uploads/53a80ea237cc728726888e4008f19706/image.png)\n\n## 性能测试\n\n根据压测以及本地 benchmark 数据来看，v2 的近端聚合相比于 v1 频繁 udpSend ，在性能上大概有 8 倍左右的提升（ 压测 900qps vs 80+qps ，benchmark 80000+ ops/sec vs 10000 ops/sec ）\n\n### 压测\n\n在 boe 环境进行了压测，[压测报告](https://bytedance.feishu.cn/docx/ZdtUd7fDLo6wjWxlnmoc1rNKngX)\n\n### Benchmark\n\n测试机器规格：开发机 Debian 10 linux 5.4 ，8c16g\n\n```\nclient v2( define tag ) x 86,807 ops/sec ±5.35% (67 runs sampled)\nclient v2( not define tag ) x 48,456 ops/sec ±31.91% (60 runs sampled)\nclient v2( compatible usage ) x 17,568 ops/sec ±3.68% (76 runs sampled)\nclient v1( not define tag ) x 10,715 ops/sec ±42.24% (52 runs sampled)\nclient v1( define tag ) x 3,849 ops/sec ±49.20% (18 runs sampled)\n```\n\n## 开发指南\n\n[DEVELOPMENT.md](./DEVELOPMENT.md)\n\n"},"1.0.0-alpha.1":{"_id":"@byted-nodex/metrics@1.0.0-alpha.1","_npmVersion":"lerna/undefined/node@v14.20.0+x64 (linux)","types":"./lib/index.d.ts","author":{"name":"wanggan"},"main":"lib/index.js","gitHead":"f0539a9970fa70c41c129d457d6988d6cdc03b5f","readme":"## @byted-nodex/metrics\n","description":"","repository":{"type":"git","url":"https://code.byted.org/nodejs/byted-nodex/tree/master/packages-inner/metrics"},"_nodeVersion":"14.20.0","keywords":["example"],"maintainers":[{"email":"wanggan.kk@bytedance.com","name":"wanggan.kk"}],"dist":{"shasum":"cc87b56f3eee9baa36ebc2373a626463e1e03e2c","size":21894,"tarball":"https://bnpm.byted.org/@byted-nodex/metrics/-/metrics-1.0.0-alpha.1.tgz","unpackedSize":90272,"fileCount":58,"integrity":"sha512-7s6uV0Dweco9dsvsxUllZQkBgqfKwRNNSJ726cBf3T12zfC+EvB9uNHETHb0bUFzBVpPu5MZN6eWpw59QVsdew=="},"bugs":{"url":"https://code.byted.org/nodejs/byted-nodex/issues"},"version":"1.0.0-alpha.1","devDependencies":{"benchmark":"^2.1.4","ts-node":"^10.9.1","@byted-service/metrics":"^1.14.0"},"dependencies":{"@byted-nodex/metrics-codec":"^1.0.0-alpha.1","@byted-service/env":"^1.15.0","generic-pool":"^3.9.0","node-unix-socket":"^0.2.4","type-fest":"^3.11.1","@byted-nodex/logger-core":"^1.1.2"},"_npmUser":{"name":"wanggan.kk","email":"wanggan.kk@bytedance.com"},"readmeFilename":"README.en.md","files":["lib","CHANGELOG.md","README.md","README.en.md"],"scripts":{"build:watch":"tsc --watch","test":"jest --config ./jest.config.js --coverage","test:watch":"jest --config ./jest.config.js --coverage --watch","build":"rm -rf lib && tsc"},"name":"@byted-nodex/metrics"},"1.1.9-alpha.0":{"_id":"@byted-nodex/metrics@1.1.9-alpha.0","main":"lib/index.js","_npmUser":{"email":"shanshengkai@bytedance.com","name":"shanshengkai"},"types":"./lib/index.d.ts","author":{"name":"wanghongxing.1108@bytedance.com"},"scripts":{"test:watch":"jes