82g~?image_size=72x72&cut_type=&quality=&format=png&sticker_format=.webp","email":"xieweicheng@bytedance.com","name":"xieweicheng"},{"avatar":"https://s3-fs.pstatp.com/static-resource/v1/43d80005ffccbded38e9~?image_size=72x72&cut_type=&quality=&format=png&sticker_format=.webp","email":"yeyuanfeng@bytedance.com","name":"yeyuanfeng"},{"avatar":"https://s3-fs.pstatp.com/static-resource/v1/1e3e0921-ad28-4445-81f3-b136ac22229g~?image_size=240x240&cut_type=&quality=&format=image&sticker_format=.webp","email":"zhangsong.loves@bytedance.com","name":"zhangsong.loves"}],"readmeFilename":"README.md","version":"1.3.2","_cnpm_publish_time":1550727039715,"_publish_on_cnpm":true,"dist":{"key":"/@byted-service/logger/-/@byted-service/logger-1.3.2.tgz","shasum":"22eb5e386073438de586183664a019d7dbf81aed","size":6360,"tarball":"https://bnpm.byted.org/@byted-service/logger/-/logger-1.3.2.tgz"},"license":"ISC","scripts":{"test":"RUNTIME_IDC_NAME=lf ../../node_modules/.bin/jest --config ./jest.config.json --coverage --env=node","build":"rm -rf lib && npx tsc -t ES5 -m commonjs --outDir lib","prepublish":"npm run build"},"publish_time":1550727039715,"_npmUser":{"email":"yeyuanfeng@bytedance.com","name":"yeyuanfeng"},"author":{"email":"yeyuanfeng@bytedance.com","name":"Yaphet Ye"},"dependencies":{"moment":"^2.22.2","winston":"^3.0.0","winston-daily-rotate-file":"^3.3.1","@byted-service/databus":"^1.2.0","@byted-service/env":"^1.2.0","@byted-service/logagent":"^1.2.0","@byted-service/metrics":"^1.2.0","mkdirp":"^0.5.1","tslib":"^1.9.3"},"devDependencies":{"typescript":"3.1.6"},"files":["lib"]},"2.0.6":{"_nodeVersion":"14.16.0","license":"MIT","readme":"# @byted-service/logger\n\n[![bnpm](https://web-bnpm.byted.org/badge/v/@byted-service/logger.svg?style=flat-square)](https://web-bnpm.byted.org/package/@byted-service/logger) [![download](https://2y8ngapf.fn.bytedance.net/d?p=@byted-service/logger)](https://web-bnpm.byted.org/package/@byted-service/logger)\n\n[简体中文](https://code.byted.org/nodejs/byted-service/blob/master/packages/logger/README.md) | [English](https://code.byted.org/nodejs/byted-service/blob/master/packages/logger/README.en.md) | [CHANGELOG](https://code.byted.org/nodejs/byted-service/blob/master/packages/logger/CHANGELOG.md)\n\n> The following is **@byted-service/logger@2.x** document, **1.x** document see [logger-v1.x](https://code.byted.org/nodejs/byted-service/tree/logger-v1.x/packages/logger), [@byted-service/logger@2.0.0 release log](https://bytedance.feishu.cn/wiki/wikcnwTrFMBrI0oZaYHxybzW0je)\n\n**@byted-service/logger** is the company's basic logging module. The main features are as follows:\n\n-   Output logs that meet the company's internal log specifications, see [Node.js log usage guide - @bytedservice/logger](https://bytedance.feishu.cn/wiki/wikcnsLn77LSSKg996gVsKapAXg).\n-   Supports [@byted-service/logagent](https://code.byted.org/nodejs/byted-service/blob/master/packages/logagent/README.md) to report logs to the `MS platform`.\n\nIf the framework you are using has integrated logger. It is not recommended to use this module directly, you can directly use the provided plugins.\n\n-   Gulu: [@gulu/access-log](https://code.byted.org/nodejs/gulu/tree/master/packages/byted-gulu-access-log).\n-   Koa & Express: [@fe/middlewares](https://web-bnpm.byted.org/package/@fe/middlewares).\n\n## Installation\n\n```bash\nnpm install @byted-service/logger --registry=http://bnpm.byted.org\n```\n\n## Quick start\n\n```js\nconst { Logger } = require('@byted-service/logger');\nconst logger = new Logger();\n\nlogger.info('hello world');\n// The log formatting rules are the same as util.format.\nlogger.info('hello %s', 'world');\nlogger.log({\n    level: 'info',\n    message: 'hello %s',\n    splat: ['world'],\n});\n```\n\nTips: [util.format](https://nodejs.org/dist/latest/docs/api/util.html#util_util_format_format_args)\n\n## API\n\n### new Logger([options])\n\n-   `options`\n    -   `level`: Log ouput level, the default value is `debug`. Logs below this level will not be processed.\n    -   `defaultLevel`: Default log level, the default value is `info`.\n    -   `streams`: Log output stream, see [Streams](#streams)\n    -   `flushInterval`: Specify the log refresh interval, the default value is `10s`.\n    -   `consoleLogLevel`: `console` log level, the default value is `options.level`.\n    -   `fileLogLevel`: `file` log level, the default value is `options.level`.\n    -   `agentLogLevel`: `logagent` log level, the default value is `options.level`.\n    -   `metricsLevel`: `metrics` level, the default value is `warn`.\n    -   `enableConsoleLog`: Whether to enable the `console` log, the default value is `!env.isTest() && !env.isProd()` ( `true` in the local development environment, enable the `console` log ), see [@byted-service/env](https://code.byted.org/nodejs/byted-service/tree/master/packages/env/README.en.md).\n    -   `enableFileLog`: Whether to open the `file` log, the default value is `env.isTest() || env.isProd()` ( `false` in the local development environment, close the `file` log ), see [@byted-service/env](https://code.byted.org/nodejs/byted-service/tree/master/packages/env/README.en.md).\n    -   `enableAgentLog`: Whether to enable the `logagent` log, the default value is `env.isTest() || env.isProd()` ( `false` in the local development environment, close the `logagent` log ), see [@byted-service/env](https://code.byted.org/nodejs/byted-service/tree/master/packages/env/README.en.md).\n    -   `enableMetrics`: Whether to enable `metrics`, the default value is `true`.\n    -   `psm`: Project `psm`, the default value is `env.getPSM()`, see [@byted-service/env](https://code.byted.org/nodejs/byted-service/tree/master/packages/env/README.en.md).\n    -   `prefix`: The default `prefix` of log messages.\n    -   `tags`: Global log `tags`.\n    -   `tagKeys`: Log `tagKeys`, used to quickly serialize log `tags`.\n    -   `callSiteFrameIndex`: The stack depth is used to obtain the call log location. If you need to perform upper packaging based on `@byted-service/logger`, please pay attention to setting this value.\n    -   `enableSecMark`: Whether to enable the `security mark`, the default value is `false`. At the `TTP` environment, the default value is `true`. After enabling it, the `key=value` will be converted to `{{key=value}}`. See [TTP environment usage guide - @byted-service/logger](https://bytedance.feishu.cn/wiki/wikcn9yu4qGfXObjt40GN8ni9Lu).\n    -   `file`: The log file, when it is an array, will try to create the file one by one unit the file is writable.\n    -   `rotatePattern`: Log cutting `cron` expressions, **only part of cron expressions are implemented, please use the beta function with caution**, cut once every hour by default.\n        -   `0 0 0 * *`: Cut once every day.\n        -   `0 0 * * *`: Cut once every hour.\n        -   `0 * * * *`: Cut once every minute.\n        -   `0 0 0,12 * *`: Cut at 0 o'clock and 12 o'clock every day.\n        -   `0 0 0-3 * *`: Cut from 0 o'clock to 3 o'clock every day.\n        -   `0 0 *\\/2 * *`: Cutting even hours every day.\n    -   `fileFormatter`: Log cutting file `formatter`, the default format is `/path/to/p.s.m.log.YYYY-MM-DD_HH:mm:ss`.\n        -   `file: Original log file.\n        -   `date`: Corresponding cutting date.\n    -   `dir`: Log storage directory, when `env.isTest() || env.isProd()` is `true` (`false` in the local development environment), the default value is `/opt/tiger/toutiao/log/app`, otherwise the default value is `${process.cwd()}/log`, see [@byted-service/env](https://code.byted.org/nodejs/byted-service/tree/master/packages/env/README.en.md).\n    -   `filename`: The name of the log file, the default value is `options.psm`.\n    -   `ext`: The log file suffix, the default value is `.log`.\n        -   If it is an access log, fill in `.access.log`.\n        -   If it is an `rpc` log, fill in `.call.log`.\n    -   `fallbackDirs`: The attempted directory after the log directory creation fails, the default value is `` [`${process.cwd()}/log`, `${os.tmpdir()}/log`] ``. If all fail, the creation of the log instance fails.\n    -   `disableDirFallbackWarning`: Whether to turn off the output when the log directory creation fails, the default value is `false`.\n    -   `agent`: `logagent` construction parameters, see [@byted-service/logagent](https://code.byted.org/nodejs/byted-service/blob/master/packages/logagent/README.en.md).\n    -   `taskName`: `logagent` log type mark, `_rpc` means `rpc` log, the default value is `options.psm`.\n    -   `metrics`: `metrics` construction parameter, or `metrics` instance, see [@byted-service/metrics](https://code.byted.org/nodejs/byted-service/blob/master/packages/metrics/README.en.md).\n\n### logger.level\n\nLog output level, the default value is `options.level`, which can be set dynamically.\n\n```js\nconst { Logger } = require('@byted-service/logger');\nconst logger = new Logger();\n\nlogger.level = 'info';\nlogger.info('hello world at info level'); // Output.\n\nlogger.level = 'warn';\nlogger.info('hello world at warn level'); // Not output.\n```\n\nTips: Because the `API` is too flexible, it is not recommended to use it directly.\n\n#### logger.levels\n\nSupported log level, the default value is\n\n```js\n{\n    trace: 10,\n    debug: 20,\n    info: 30,\n    warn: 40,\n    error: 50,\n    fatal: 60,\n}\n```\n\n#### logger.defaultLevel\n\nDefault log level, the default value is `options.defaultLevel`.\n\n#### logger.tags\n\nGlobal log `tags`, the default value is `options.tags`, used as an index to query on the `MS platform`.\n\n#### logger.tagKeys\n\nLog `tagKeys`, used to quickly serialize log `tags` to improve performance.\n\n#### logger.isLevelEnabled(level)\n\nWhether the log level is turned on.\n\n#### logger.fatal(message, [...splat])\n\n#### logger.error(message, [...splat])\n\n#### logger.warn(message, [...splat])\n\n#### logger.info(message, [...splat])\n\n#### logger.debug(message, [...splat])\n\n#### logger.trace(message, [...splat])\n\n```js\nconst { Logger } = require('@byted-service/logger');\nconst logger = new Logger();\n\nlogger.fatal('hello world');\nlogger.error('hello world');\nlogger.warn('hello world');\nlogger.info('hello world');\nlogger.debug('hello world');\nlogger.trace('hello world');\n```\n\n#### logger.log([args])\n\n-   args\n    -   level: Log level, the default value is `options.defaultlevel`.\n    -   message: Log content.\n    -   splat: Log formatting parameters.\n    -   logId: Log `logId`, usually completed automatically by the framework, see [x-tt-logid](https://bytedance.feishu.cn/wiki/wikcn2L5x9IgQ4iLEdHofSMPVQc#qUpuqi).\n    -   location: The log call stack location, which is automatically calculated by default.\n    -   tags: Log `tags`, merged with `options.tags` in the form of `Object.assign()`, used as an index for query on the `MS platform`.\n\n```js\nconst { Logger } = require('@byted-service/logger');\nconst logger = new Logger();\n\nlogger.log({\n    level: 'info',\n    message: 'hello %s',\n    splat: ['world'],\n    logId: 'some logid',\n    location: 'some location',\n    tags: {\n        some: 'tags',\n    },\n});\n```\n\n#### logger.flush()\n\nFlush the log asynchronously to [Streams](#streams), by default it is automatically refreshed according to `options.flushInterval`.\n\n```js\nconst { Logger } = require('@byted-service/logger');\nconst logger = new Logger();\n\nlogger.info('hello world');\nlogger.flush();\n```\n\n#### logger.flushSync()\n\nFlush the log synchronously to [Streams](#streams).\n\n```js\nconst { Logger } = require('@byted-service/logger');\nconst logger = new Logger();\n\nlogger.info('hello world');\nlogger.flushSync();\n```\n\n#### logger.clone([options])\n\nCopy log instance, a lightweight copy, and share the same with the original `logger` [Streams](#streams) by default.\n\n```js\nconst { Logger } = require('@byted-service/logger');\nconst logger = new Logger();\nconst childLogger = logger.clone();\n\nchildLogger.info('hello world');\n```\n\n#### logger.addStream(level, stream)\n\nAdd [Streams](#streams).\n\n```js\nconst { Logger } = require('@byted-service/logger');\nconst logger = new Logger();\n\nlogger.addStream('info', {\n    write(msg) {\n        console.log(msg);\n    },\n});\n\nlogger.info('hello world');\n```\n\n#### logger.deleteStream(level, stream)\n\nDelete [Streams](#streams).\n\n```js\nconst { Logger } = require('@byted-service/logger');\nconst logger = new Logger();\n\nconst stream = {\n    write(msg) {\n        console.log(msg);\n    },\n};\nlogger.addStream('info', stream);\nlogger.deleteStream('info', stream);\n\nlogger.info('hello world');\n```\n\n### logger.getFinalLogger()\n\nObtain a synchronous logger, which can be used in situations where it is impossible to write logs asynchronously. E.g:\n\n-   process.on('uncaughtException')\n-   process.on('unhandledRejection')\n\nPlease do not use console.log directly, because whether console.log is synchronized or not depends on the environment. For details, see the document: https://nodejs.org/dist/latest-v12.x/docs/api/process.html#process_a_note_on_process_i_o\n\n-   Only applicable to file log writing. `logagent` are not supported.\n\n```js\nconst { Logger } = require('@byted-service/logger');\nconst logger = new Logger();\nconst finalLogger = logger.getFinalLogger();\n\nprocess.on('uncaughtException', (err) => {\n    finalLogger.error(err, 'uncaughtException');\n    process.exit(1);\n});\n```\n\n### Streams\n\nLog output stream. In `@byted-service/logger`, four log output streams, `console`, `file`, `logagent`, and `metrcis`, are built in by default.\n\n-   If you use [new Logger(\\[options\\])](#new-loggeroptions), the above log output stream will be added by default, which can be controlled by parameters and environment variables.\n-   If you use [new CoreLogger(\\[options\\])](#new-coreloggeroptions), it can be controlled by `logger.addStream()` and `logger.deleteStream()`.\n\n#### createConsole()\n\nCreate `console` output stream.\n\n```js\nconst { CoreLogger, createConsole } = require('@byted-service/logger');\nconst logger = new CoreLogger();\n\nlogger.addStream('info', createConsole());\n\nlogger.info('hello world');\n```\n\n#### createFileRotate([options])\n\nCreate `file` output stream, **compatible with the old version of `logger`**, see [@byted-service/logger upgrade instructions](https://bytedance.feishu.cn/wiki/wikcn5dsQLTFYuGBdbB7ULRFHpb#99sYNJ).\n\n-   `options`\n    -   `psm`: Project `psm`, the default value is `env.getPSM()`, see [@byted-service/env](https://code.byted.org/nodejs/byted-service/tree/master/packages/env/README.en.md).\n    -   `file`: The log file, when it is an array, will try to create the file one by one unit the file is writable.\n    -   `rotatePattern`: Log cutting `cron` expressions, **only part of cron expressions are implemented, please use the beta function with caution**, cut once every hour by default.\n        -   `0 0 0 * *`: Cut once every day.\n        -   `0 0 * * *`: Cut once every hour.\n        -   `0 * * * *`: Cut once every minute.\n        -   `0 0 0,12 * *`: Cut at 0 o'clock and 12 o'clock every day.\n        -   `0 0 0-3 * *`: Cut from 0 o'clock to 3 o'clock every day.\n        -   `0 0 *\\/2 * *`: Cutting even hours every day.\n    -   `fileFormatter`: Log cutting file `formatter`, the default format is `/path/to/p.s.m.log.YYYY-MM-DD_HH:mm:ss`.\n        -   `file: Original log file.\n        -   `date`: Corresponding cutting date.\n    -   `dir`: Log storage directory, when `env.isTest() || env.isProd()` is `true` (`false` in the local development environment), the default value is `/opt/tiger/toutiao/log/app`, otherwise the default value is `${process.cwd()}/log`, see [@byted-service/env](https://code.byted.org/nodejs/byted-service/tree/master/packages/env/README.en.md).\n    -   `filename`: The name of the log file, the default value is `options.psm`.\n    -   `ext`: The log file suffix, the default value is `.log`.\n        -   If it is an access log, fill in `.access.log`.\n        -   If it is an `rpc` log, fill in `.call.log`.\n    -   `fallbackDirs`: The attempted directory after the log directory creation fails, the default value is `` [`${process.cwd()}/log`, `${os.tmpdir()}/log`] ``. If all fail, the creation of the log instance fails.\n    -   `disableDirFallbackWarning`: Whether to turn off the output when the log directory creation fails, the default value is `false`.\n\n```js\nconst { CoreLogger, createFileRotate } = require('@byted-service/logger');\nconst logger = new CoreLogger();\n\nlogger.addStream('info', createFileRotate({\n    file: '/path/to/xxx.log';\n}));\n\nlogger.info('hello world');\n```\n\n#### createLogAgent([options])\n\nCreate `logagent` output stream.\n\n-   `options`\n    -   `agent`: `logagent` construction parameters, see [@byted-service/logagent](https://code.byted.org/nodejs/byted-service/blob/master/packages/logagent/README.en.md).\n    -   `taskName`: `logagent` log type mark, `_rpc` means `rpc` log, the default value is `env.getPSM()`, see [@byted-service/env](https://code.byted.org/nodejs/byted-service/tree/master/packages/env/README.en.md).\n\n```js\nconst { CoreLogger, createLogAgent } = require('@byted-service/logger');\nconst logger = new CoreLogger();\n\nlogger.addStream('info', createLogAgent());\n\nlogger.info('hello world');\n```\n\n#### createMetrics([options])\n\nCreate `metrics` output stream.\n\n-   `options`\n    -   `metrics`: `metrics` construction parameter, or `metrics` instance, see [@byted-service/metrics](https://code.byted.org/nodejs/byted-service/blob/master/packages/metrics/README.en.md).\n\n```js\nconst { CoreLogger, createLogAgent } = require('@byted-service/logger');\nconst logger = new CoreLogger();\n\nlogger.addStream('info', createMetrics());\n\nlogger.info('hello world');\n```\n\n#### new FileRotateStream(options)\n\nCreate `file` output stream, **not compatible with the old version of `logger`**, see [@byted-service/logger upgrade instructions](https://bytedance.feishu.cn/wiki/wikcn5dsQLTFYuGBdbB7ULRFHpb#99sYNJ).\n\n-   `options`\n    -   `file`: The log file, when it is an array, will try to create the file one by one unit the file is writable.\n    -   `rotatePattern`: Log cutting `cron` expressions, **only part of cron expressions are implemented, please use the beta function with caution**, cut once every hour by default.\n        -   `0 0 0 * *`: Cut once every day.\n        -   `0 0 * * *`: Cut once every hour.\n        -   `0 * * * *`: Cut once every minute.\n        -   `0 0 0,12 * *`: Cut at 0 o'clock and 12 o'clock every day.\n        -   `0 0 0-3 * *`: Cut from 0 o'clock to 3 o'clock every day.\n        -   `0 0 *\\/2 * *`: Cutting even hours every day.\n    -   `fileFormatter`: Log cutting file `formatter`, the default format is `/path/to/p.s.m.log.YYYY-MM-DD_HH:mm:ss`.\n        -   `file: Original log file.\n        -   `date`: Corresponding cutting date.\n\n```js\nconst { CoreLogger, FileRotateStream } = require('@byted-service/logger');\nconst logger = new CoreLogger();\n\nlogger.addStream(\n    'info',\n    new FileRotateStream({\n        file: '/path/to/xxx.log',\n    })\n);\n\nlogger.info('hello world');\n```\n\n### new CoreLogger([options])\n\nThe core of `logger`, which can be used to customize the implementation of `logger` to the maximum extent.\n\n-   `options`\n    -   `level`: Log ouput level, the default value is `debug`. Logs below this level will not be processed.\n    -   `defaultLevel`: Default log level, the default value is `info`.\n    -   `formatter`: Log formatter.\n    -   `streams`: Log output stream, see [Streams](#streams)\n    -   `flushInterval`: Specify the log refresh interval, the default value is `10s`.\n\n## Environment variable\n\nYou can control the log output without modifying the code by corresponding environment variables.\n\n### Log level\n\n-   Optional value ( values not in the range of optional values will be directly ignored ).\n\n    -   `fatal`: Serious errors that make the program unusable.\n    -   `error`: For a serious error of an operation, but the program is not affected.\n    -   `warn`: Problems that may cause the program to enter an abnormal state.\n    -   `info`: Normal information ( such as service start/stop ).\n    -   `debug`: Information for program debugging.\n    -   `trace`: Information used to track program operation or request call chain.\n\n-   Level size: `fatal` > `error` > `warn` > `info` > `debug` > `trace`\n\nRelated environment variables:\n\n-   `LOGGER_OUTPUT_LEVEL`: The default log level, logs below this level will not be processed.\n-   `LOGGER_LEVEL_CONSOLE`: `console` log level.\n-   `LOGGER_LEVEL_FILE`: `file` log level.\n-   `LOGGER_LEVEL_LOGAGENT`: `logagent` log level.\n-   `LOGGER_LEVEL_METRICS`: `metrics` log level.\n\n```shell\n# At this time, all logs below the error level will not be output\nLOGGER_OUTPUT_LEVEL=error node app.js\n```\n\nParameter priority:\n\n-   General log level: `options.level` > `LOGGER_OUTPUT_LEVEL` > `info level`\n-   `console` log level: `options.consoleLogLevel` > `LOGGER_LEVEL_CONSOLE` > `options.level` > `LOGGER_OUTPUT_LEVEL` > `info level`\n-   `file` log level: `options.fileLogLevel` > `LOGGER_LEVEL_FILE` > `options.level` > `LOGGER_OUTPUT_LEVEL` > `info level`\n-   `logagent` log level: `options.agentLogLevel` > `LOGGER_LEVEL_LOGAGENT` > `options.level` > `LOGGER_OUTPUT_LEVEL` > `info level`\n-   `metrics` log level: `options.metricsLevel` > `LOGGER_LEVEL_METRICS` > `warn level`\n\n### Log component\n\n-   Optional value ( values not in the range of optional values will be directly ignored )\n    -   `true`: Open log.\n    -   `false`: Close log.\n\nRelated environment variables:\n\n-   `LOGGER_ENABLE_CONSOLE`: Whether to enable the console log.\n-   `LOGGER_ENABLE_FILE`: Whether to enable file log.\n-   `LOGGER_ENABLE_LOGAGENT`: Whether to enable logagent log.\n-   `LOGGER_ENABLE_METRICS`: Whether to enable metrics log.\n\n```shell\n# At this time, all logagent logs will not be output\nLOGGER_ENABLE_LOGAGENT=false node app.js\n```\n\nParameter priority:\n\n-   `consule` log: `options.enableConsoleLog` > `LOGGER_ENABLE_CONSOLE` > `!env.isTest() && !env.isProd()` ( The local development environment is true )\n-   `file` log: `options.enableFileLog` > `LOGGER_ENABLE_FILE` > `env.isTest() || env.isProd()` ( The local development environment is false )\n-   `logagent` log: `options.enableAgentLog` > `LOGGER_ENABLE_LOGAGENT` > `env.isTest() || env.isProd()` ( The local development environment is false )\n-   `metrics` log: `options.enableMetrics` > `LOGGER_ENABLE_METRICS` > `true`\n\n### Log Timezone\n\nRelated environment variables:\n\n-   `LOGGER_TIME_ZONE`: Log Timezone.\n\n```shell\n# At this time, the log timezone is America/New_York.\nLOGGER_TIME_ZONE=America/New_York node app.js\n```\n\n## Metrics\n\nIndicator name:\n\n```\n// Log call count, can be modified by options.metrics parameter\ntoutiao.service.log.${psm}.throughput\n```\n\n**tags**:\n\n<details>\n  <summary>History</summary>\n\n-   `v2.0.6`: Support `env`, `version`.\n\n</details>\n\n-   `level`: Log level.\n-   `cluster`\n-   `env`\n-   `version`: The version of `@byted-service/logger`.\n","readmeFilename":"README.en.md","_id":"@byted-service/logger@2.0.6","devDependencies":{"pump":"^3.0.0","rimraf":"^3.0.2"},"files":["lib","index.js"],"gitHead":"bd308e0f5571379ca447cd3c08c9cb65a01b652a","main":"index.js","repository":{"type":"git","url":"https://code.byted.org/nodejs/byted-service"},"author":"","dist":{"shasum":"2e8bc22a41ae5b29964cec5cf26da7f7ff67a454","tarball":"https://bnpm.byted.org/@byted-service/logger/-/logger-2.0.6.tgz","integrity":"sha512-OrEnN15UG9RnbeONAqm+9hBc2IoPbl01Ftor90xHdDG2zB/XqnUmzNDmOX6T72z1HqmjijK8IJ3yW74zqYhhTA=="},"maintainers":[{"avatar":"https://s3-fs.pstatp.com/static-resource/v1/bf5207f4-07f4-4c43-9004-b01af1aff365~?image_size=72x72&cut_type=&quality=&format=png&sticker_format=.webp","email":"liyubei@bytedance.com","name":"liyubei"},{"avatar":"","email":"nodejs-team@bnpm.com","name":"nodejs-team"},{"name":"ouyangyadong","avatar":"https://s1-fs.pstatp.com/static-resource/v1/d27d000e276d58ace3df~?image_size=72x72&cut_type=&quality=&format=png&sticker_format=.webp","email":"ouyangyadong@bytedance.com"},{"avatar":"https://s1-fs.pstatp.com/static-resource/v1/ef40014f9ad1f7011ec~?image_size=72x72&cut_type=&quality=&format=png&sticker_format=.webp","email":"shenchen@bytedance.com","name":"shenchen"},{"avatar":"https://s1-fs.pstatp.com/static-resource/v1/a339a912-f731-4fe7-9e51-d91e1871180g~?image_size=240x240&cut_type=&quality=&format=image&sticker_format=.webp","email":"xieda@bytedance.com","name":"xieda"},{"name":"xieweicheng","avatar":"https://s1-fs.pstatp.com/static-resource/v1/f27851c0-d3e8-4851-a606-1a3d9361b82g~?image_size=72x72&cut_type=&quality=&format=png&sticker_format=.webp","email":"xieweicheng@bytedance.com"},{"avatar":"https://s3-fs.pstatp.com/static-resource/v1/43d80005ffccbded38e9~?image_size=72x72&cut_type=&quality=&format=png&sticker_format=.webp","email":"yeyuanfeng@bytedance.com","name":"yeyuanfeng"},{"avatar":"https://s3-fs.pstatp.com/static-resource/v1/1e3e0921-ad28-4445-81f3-b136ac22229g~?image_size=240x240&cut_type=&quality=&format=image&sticker_format=.webp","email":"zhangsong.loves@bytedance.com","name":"zhangsong.loves"}],"scripts":{"test":"ROUTE_IP=10.227.30.24 RUNTIME_IDC_NAME=boe ../../node_modules/.bin/jest --config ./jest.config.json --coverage --env=node","bench":"node benchmarks","build":"rm -rf lib && ../../node_modules/.bin/tsc","prepublish":"npm run build"},"types":"lib/index.d.ts","version":"2.0.6","_npmUser":{"email":"nodejs-team@bytedance.com","name":"nodejs-team"},"_npmVersion":"lerna/undefined/node@v14.16.0+x64 (linux)","dependencies":{"@byted-service/env":"^1.10.4","@byted-service/logagent":"^1.7.4","sonic-boom":"^1.4.1","mkdirp":"^0.5.1","tslib":"^1.9.3","@byted-service/metrics":"^1.12.1","chalk":"^4.1.1","dayjs":"^1.10.5","lru-cache":"^6.0.0"},"description":"Logger for bytedance","name":"@byted-service/logger"},"2.2.0":{"_npmUser":{"email":"nodejs-team@bytedance.com","name":"nodejs-team"},"_npmVersion":"lerna/undefined/node@v14.21.2+x64 (linux)","readme":"# @byted-service/logger\n\n[![bnpm](https://web-bnpm.byted.org/badge/v/@byted-service/logger.svg?style=flat-square)](https://web-bnpm.byted.org/package/@byted-service/logger) [![download](https://2y8ngapf.fn.bytedance.net/d?p=@byted-service/logger)](https://web-bnpm.byted.org/package/@byted-service/logger)\n\n[简体中文](https://code.byted.org/nodejs/byted-service/blob/master/packages/logger/README.md) | [English](https://code.byted.org/nodejs/byted-service/blob/master/packages/logger/README.en.md) | [CHANGELOG](https://code.byted.org/nodejs/byted-service/blob/master/packages/logger/CHANGELOG.md)\n\n> The following is **@byted-service/logger@2.x** document, **1.x** document see [logger-v1.x](https://code.byted.org/nodejs/byted-service/tree/logger-v1.x/packages/logger), [@byted-service/logger@2.0.0 release log](https://bytedance.feishu.cn/wiki/wikcnwTrFMBrI0oZaYHxybzW0je)\n\n**@byted-service/logger** is the company's basic logging module. The main features are as follows:\n\n-   Output logs that meet the company's internal log specifications, see [Node.js log usage guide - @bytedservice/logger](https://bytedance.feishu.cn/wiki/wikcnsLn77LSSKg996gVsKapAXg).\n-   Supports [@byted-service/logagent](https://code.byted.org/nodejs/byted-service/blob/master/packages/logagent/README.md) to report logs to the `MS platform`.\n\nIf the framework you are using has integrated logger. It is not recommended to use this module directly, you can directly use the provided plugins.\n\n-   Gulu: [@gulu/access-log](https://code.byted.org/nodejs/gulu/tree/master/packages/byted-gulu-access-log).\n-   Koa & Express: [@fe/middlewares](https://web-bnpm.byted.org/package/@fe/middlewares).\n\n## Installation\n\n```bash\nnpm install @byted-service/logger --registry=http://bnpm.byted.org\n```\n\n## Quick start\n\n```js\nconst { Logger } = require('@byted-service/logger');\nconst logger = new Logger();\n\nlogger.info('hello world');\n// The log formatting rules are the same as util.format.\nlogger.info('hello %s', 'world');\nlogger.log({\n    level: 'info',\n    message: 'hello %s',\n    splat: ['world'],\n});\n```\n\nTips: [util.format](https://nodejs.org/dist/latest/docs/api/util.html#util_util_format_format_args)\n\n## API\n\n### new Logger([options])\n\n-   `options`\n    -   `level`: Log ouput level, the default value is `debug`. Logs below this level will not be processed.\n    -   `defaultLevel`: Default log level, the default value is `info`.\n    -   `streams`: Log output stream, see [Streams](#streams)\n    -   `flushInterval`: Specify the log refresh interval, the default value is `10s`.\n    -   `consoleLogLevel`: `console` log level, the default value is `options.level`.\n    -   `fileLogLevel`: `file` log level, the default value is `options.level`.\n    -   `agentLogLevel`: `logagent` log level, the default value is `options.level`.\n    -   `metricsLevel`: `metrics` level, the default value is `warn`.\n    -   `enableConsoleLog`: Whether to enable the `console` log, the default value is `isCloudIDE() || !isInTCE()` (Includes local development environment, Cloud IDE and Devbox), see [@byted-service/env](https://code.byted.org/nodejs/byted-service/tree/master/packages/env/README.en.md).\n    -   `enableFileLog`: Whether to open the `file` log, the default value is `true`\n    -   `enableAgentLog`: Whether to enable the `logagent` log, the default value is `!(isCloudIDE() || !isInTCE())`\n    -   `enableMetrics`: Whether to enable `metrics`, the default value is `true`.\n    -   `psm`: Project `psm`, the default value is `env.getPSM()`, see [@byted-service/env](https://code.byted.org/nodejs/byted-service/tree/master/packages/env/README.en.md).\n    -   `prefix`: The default `prefix` of log messages.\n    -   `tags`: Global log `tags`.\n    -   `tagKeys`: Log `tagKeys`, used to quickly serialize log `tags`.\n    -   `callSiteFrameIndex`: The stack depth is used to obtain the call log location. If you need to perform upper packaging based on `@byted-service/logger`, please pay attention to setting this value.\n    -   `enableSecMark`: Whether to enable the `security mark`, the default value is `false`. At the `TTP` environment, the default value is `true`. After enabling it, the `key=value` will be converted to `{{key=value}}`. See [TTP environment usage guide - @byted-service/logger](https://bytedance.feishu.cn/wiki/wikcn9yu4qGfXObjt40GN8ni9Lu).\n    -   `file`: The log file, when it is an array, will try to create the file one by one unit the file is writable.\n    -   `rotatePattern`: Log cutting `cron` expressions, **only part of cron expressions are implemented, please use the beta function with caution**, cut once every hour by default.\n        -   `0 0 0 * *`: Cut once every day.\n        -   `0 0 * * *`: Cut once every hour.\n        -   `0 * * * *`: Cut once every minute.\n        -   `0 0 0,12 * *`: Cut at 0 o'clock and 12 o'clock every day.\n        -   `0 0 0-3 * *`: Cut from 0 o'clock to 3 o'clock every day.\n        -   `0 0 *\\/2 * *`: Cutting even hours every day.\n    -   `fileFormatter`: Log cutting file `formatter`, the default format is `/path/to/p.s.m.log.YYYY-MM-DD_HH:mm:ss`.\n        -   `file: Original log file.\n        -   `date`: Corresponding cutting date.\n    -   `dir`: Log storage directory, when `env.isTest() || env.isProd()` is `true` (`false` in the local development environment), the default value is `/opt/tiger/toutiao/log/app`, otherwise the default value is `${process.cwd()}/log`, see [@byted-service/env](https://code.byted.org/nodejs/byted-service/tree/master/packages/env/README.en.md).\n    -   `filename`: The name of the log file, the default value is `options.psm`.\n    -   `ext`: The log file suffix, the default value is `.log`.\n        -   If it is an access log, fill in `.access.log`.\n        -   If it is an `rpc` log, fill in `.call.log`.\n    -   `fallbackDirs`: The attempted directory after the log directory creation fails, the default value is `` [`${process.cwd()}/log`, `${os.tmpdir()}/log`] ``. If all fail, the creation of the log instance fails.\n    -   `disableDirFallbackWarning`: Whether to turn off the output when the log directory creation fails, the default value is `false`.\n    -   `agent`: `logagent` construction parameters, see [@byted-service/logagent](https://code.byted.org/nodejs/byted-service/blob/master/packages/logagent/README.en.md).\n    -   `taskName`: `logagent` log type mark, `_rpc` means `rpc` log, the default value is `options.psm`.\n    -   `metrics`: `metrics` construction parameter, or `metrics` instance, see [@byted-service/metrics](https://code.byted.org/nodejs/byted-service/blob/master/packages/metrics/README.en.md).\n\n### logger.level\n\nLog output level, the default value is `options.level`, which can be set dynamically.\n\n```js\nconst { Logger } = require('@byted-service/logger');\nconst logger = new Logger();\n\nlogger.level = 'info';\nlogger.info('hello world at info level'); // Output.\n\nlogger.level = 'warn';\nlogger.info('hello world at warn level'); // Not output.\n```\n\nTips: Because the `API` is too flexible, it is not recommended to use it directly.\n\n#### logger.levels\n\nSupported log level, the default value is\n\n```js\n{\n    trace: 10,\n    debug: 20,\n    info: 30,\n    warn: 40,\n    error: 50,\n    fatal: 60,\n}\n```\n\n#### logger.defaultLevel\n\nDefault log level, the default value is `options.defaultLevel`.\n\n#### logger.tags\n\nGlobal log `tags`, the default value is `options.tags`, used as an index to query on the `MS platform`.\n\n#### logger.tagKeys\n\nLog `tagKeys`, used to quickly serialize log `tags` to improve performance.\n\n#### logger.isLevelEnabled(level)\n\nWhether the log level is turned on.\n\n#### logger.fatal(message, [...splat])\n\n#### logger.error(message, [...splat])\n\n#### logger.warn(message, [...splat])\n\n#### logger.info(message, [...splat])\n\n#### logger.debug(message, [...splat])\n\n#### logger.trace(message, [...splat])\n\n```js\nconst { Logger } = require('@byted-service/logger');\nconst logger = new Logger();\n\nlogger.fatal('hello world');\nlogger.error('hello world');\nlogger.warn('hello world');\nlogger.info('hello world');\nlogger.debug('hello world');\nlogger.trace('hello world');\n```\n\n#### logger.log([args])\n\n-   args\n    -   level: Log level, the default value is `options.defaultlevel`.\n    -   message: Log content.\n    -   splat: Log formatting parameters.\n    -   logId: Log `logId`, usually completed automatically by the framework, see [x-tt-logid](https://bytedance.feishu.cn/wiki/wikcn2L5x9IgQ4iLEdHofSMPVQc#qUpuqi).\n    -   location: The log call stack location, which is automatically calculated by default.\n    -   tags: Log `tags`, merged with `options.tags` in the form of `Object.assign()`, used as an index for query on the `MS platform`.\n\n```js\nconst { Logger } = require('@byted-service/logger');\nconst logger = new Logger();\n\nlogger.log({\n    level: 'info',\n    message: 'hello %s',\n    splat: ['world'],\n    logId: 'some logid',\n    location: 'some location',\n    tags: {\n        some: 'tags',\n    },\n});\n```\n\n#### logger.flush()\n\nFlush the log asynchronously to [Streams](#streams), by default it is automatically refreshed according to `options.flushInterval`.\n\n```js\nconst { Logger } = require('@byted-service/logger');\nconst logger = new Logger();\n\nlogger.info('hello world');\nlogger.flush();\n```\n\n#### logger.flushSync()\n\nFlush the log synchronously to [Streams](#streams).\n\n```js\nconst { Logger } = require('@byted-service/logger');\nconst logger = new Logger();\n\nlogger.info('hello world');\nlogger.flushSync();\n```\n\n#### logger.clone([options])\n\nCopy log instance, a lightweight copy, and share the same with the original `logger` [Streams](#streams) by default.\n\n```js\nconst { Logger } = require('@byted-service/logger');\nconst logger = new Logger();\nconst childLogger = logger.clone();\n\nchildLogger.info('hello world');\n```\n\n#### logger.addStream(level, stream)\n\nAdd [Streams](#streams).\n\n```js\nconst { Logger } = require('@byted-service/logger');\nconst logger = new Logger();\n\nlogger.addStream('info', {\n    write(msg) {\n        console.log(msg);\n    },\n});\n\nlogger.info('hello world');\n```\n\n#### logger.deleteStream(level, stream)\n\nDelete [Streams](#streams).\n\n```js\nconst { Logger } = require('@byted-service/logger');\nconst logger = new Logger();\n\nconst stream = {\n    write(msg) {\n        console.log(msg);\n    },\n};\nlogger.addStream('info', stream);\nlogger.deleteStream('info', stream);\n\nlogger.info('hello world');\n```\n\n### logger.getFinalLogger()\n\nObtain a synchronous logger, which can be used in situations where it is impossible to write logs asynchronously. E.g:\n\n-   process.on('uncaughtException')\n-   process.on('unhandledRejection')\n\nPlease do not use console.log directly, because whether console.log is synchronized or not depends on the environment. For details, see the document: https://nodejs.org/dist/latest-v12.x/docs/api/process.html#process_a_note_on_process_i_o\n\n-   Only applicable to file log writing. `logagent` are not supported.\n\n```js\nconst { Logger } = require('@byted-service/logger');\nconst logger = new Logger();\nconst finalLogger = logger.getFinalLogger();\n\nprocess.on('uncaughtException', (err) => {\n    finalLogger.error(err, 'uncaughtException');\n    process.exit(1);\n});\n```\n\n### Streams\n\nLog output stream. In `@byted-service/logger`, four log output streams, `console`, `file`, `logagent`, and `metrcis`, are built in by default.\n\n-   If you use [new Logger(\\[options\\])](#new-loggeroptions), the above log output stream will be added by default, which can be controlled by parameters and environment variables.\n-   If you use [new CoreLogger(\\[options\\])](#new-coreloggeroptions), it can be controlled by `logger.addStream()` and `logger.deleteStream()`.\n\n#### createConsole()\n\nCreate `console` output stream.\n\n```js\nconst { CoreLogger, createConsole } = require('@byted-service/logger');\nconst logger = new CoreLogger();\n\nlogger.addStream('info', createConsole());\n\nlogger.info('hello world');\n```\n\n#### createFileRotate([options])\n\nCreate `file` output stream, **compatible with the old version of `logger`**, see [@byted-service/logger upgrade instructions](https://bytedance.feishu.cn/wiki/wikcn5dsQLTFYuGBdbB7ULRFHpb#99sYNJ).\n\n-   `options`\n    -   `psm`: Project `psm`, the default value is `env.getPSM()`, see [@byted-service/env](https://code.byted.org/nodejs/byted-service/tree/master/packages/env/README.en.md).\n    -   `file`: The log file, when it is an array, will try to create the file one by one unit the file is writable.\n    -   `rotatePattern`: Log cutting `cron` expressions, **only part of cron expressions are implemented, please use the beta function with caution**, cut once every hour by default.\n        -   `0 0 0 * *`: Cut once every day.\n        -   `0 0 * * *`: Cut once every hour.\n        -   `0 * * * *`: Cut once every minute.\n        -   `0 0 0,12 * *`: Cut at 0 o'clock and 12 o'clock every day.\n        -   `0 0 0-3 * *`: Cut from 0 o'clock to 3 o'clock every day.\n        -   `0 0 *\\/2 * *`: Cutting even hours every day.\n    -   `fileFormatter`: Log cutting file `formatter`, the default format is `/path/to/p.s.m.log.YYYY-MM-DD_HH:mm:ss`.\n        -   `file: Original log file.\n        -   `date`: Corresponding cutting date.\n    -   `dir`: Log storage directory, when `env.isTest() || env.isProd()` is `true` (`false` in the local development environment), the default value is `/opt/tiger/toutiao/log/app`, otherwise the default value is `${process.cwd()}/log`, see [@byted-service/env](https://code.byted.org/nodejs/byted-service/tree/master/packages/env/README.en.md).\n    -   `filename`: The name of the log file, the default value is `options.psm`.\n    -   `ext`: The log file suffix, the default value is `.log`.\n        -   If it is an access log, fill in `.access.log`.\n        -   If it is an `rpc` log, fill in `.call.log`.\n    -   `fallbackDirs`: The attempted directory after the log directory creation fails, the default value is `` [`${process.cwd()}/log`, `${os.tmpdir()}/log`] ``. If all fail, the creation of the log instance fails.\n    -   `disableDirFallbackWarning`: Whether to turn off the output when the log directory creation fails, the default value is `false`.\n\n```js\nconst { CoreLogger, createFileRotate } = require('@byted-service/logger');\nconst logger = new CoreLogger();\n\nlogger.addStream('info', createFileRotate({\n    file: '/path/to/xxx.log';\n}));\n\nlogger.info('hello world');\n```\n\n#### createLogAgent([options])\n\nCreate `logagent` output stream.\n\n-   `options`\n    -   `agent`: `logagent` construction parameters, see [@byted-service/logagent](https://code.byted.org/nodejs/byted-service/blob/master/packages/logagent/README.en.md).\n    -   `taskName`: `logagent` log type mark, `_rpc` means `rpc` log, the default value is `env.getPSM()`, see [@byted-service/env](https://code.byted.org/nodejs/byted-service/tree/master/packages/env/README.en.md).\n\n```js\nconst { CoreLogger, createLogAgent } = require('@byted-service/logger');\nconst logger = new CoreLogger();\n\nlogger.addStream('info', createLogAgent());\n\nlogger.info('hello world');\n```\n\n#### createMetrics([options])\n\nCreate `metrics` output stream.\n\n-   `options`\n    -   `metrics`: `metrics` construction parameter, or `metrics` instance, see [@byted-service/metrics](https://code.byted.org/nodejs/byted-service/blob/master/packages/metrics/README.en.md).\n\n```js\nconst { CoreLogger, createLogAgent } = require('@byted-service/logger');\nconst logger = new CoreLogger();\n\nlogger.addStream('info', createMetrics());\n\nlogger.info('hello world');\n```\n\n#### new FileRotateStream(options)\n\nCreate `file` output stream, **not compatible with the old version of `logger`**, see [@byted-service/logger upgrade instructions](https://bytedance.feishu.cn/wiki/wikcn5dsQLTFYuGBdbB7ULRFHpb#99sYNJ).\n\n-   `options`\n    -   `file`: The log file, when it is an array, will try to create the file one by one unit the file is writable.\n    -   `rotatePattern`: Log cutting `cron` expressions, **only part of cron expressions are implemented, please use the beta function with caution**, cut once every hour by default.\n        -   `0 0 0 * *`: Cut once every day.\n        -   `0 0 * * *`: Cut once every hour.\n        -   `0 * * * *`: Cut once every minute.\n        -   `0 0 0,12 * *`: Cut at 0 o'clock and 12 o'clock every day.\n        -   `0 0 0-3 * *`: Cut from 0 o'clock to 3 o'clock every day.\n        -   `0 0 *\\/2 * *`: Cutting even hours every day.\n    -   `fileFormatter`: Log cutting file `formatter`, the default format is `/path/to/p.s.m.log.YYYY-MM-DD_HH:mm:ss`.\n        -   `file: Original log file.\n        -   `date`: Corresponding cutting date.\n\n```js\nconst { CoreLogger, FileRotateStream } = require('@byted-service/logger');\nconst logger = new CoreLogger();\n\nlogger.addStream(\n    'info',\n    new FileRotateStream({\n        file: '/path/to/xxx.log',\n    })\n);\n\nlogger.info('hello world');\n```\n\n### new CoreLogger([options])\n\nThe core of `logger`, which can be used to customize the implementation of `logger` to the maximum extent.\n\n-   `options`\n    -   `level`: Log ouput level, the default value is `debug`. Logs below this level will not be processed.\n    -   `defaultLevel`: Default log level, the default value is `info`.\n    -   `formatter`: Log formatter.\n    -   `streams`: Log output stream, see [Streams](#streams)\n    -   `flushInterval`: Specify the log refresh interval, the default value is `10s`.\n\n## Environment variable\n\nYou can control the log output without modifying the code by corresponding environment variables.\n\n### Log level\n\n-   Optional value ( values not in the range of optional values will be directly ignored ).\n\n    -   `fatal`: Serious errors that make the program unusable.\n    -   `error`: For a serious error of an operation, but the program is not affected.\n    -   `warn`: Problems that may cause the program to enter an abnormal state.\n    -   `info`: Normal information ( such as service start/stop ).\n    -   `debug`: Information for program debugging.\n    -   `trace`: Information used to track program operation or request call chain.\n\n-   Level size: `fatal` > `error` > `warn` > `info` > `debug` > `trace`\n\nRelated environment variables:\n\n-   `LOGGER_OUTPUT_LEVEL`: The default log level, logs below this level will not be processed.\n-   `LOGGER_LEVEL_CONSOLE`: `console` log level.\n-   `LOGGER_LEVEL_FILE`: `file` log level.\n-   `LOGGER_LEVEL_LOGAGENT`: `logagent` log level.\n-   `LOGGER_LEVEL_METRICS`: `metrics` log level.\n\n```shell\n# At this time, all logs below the error level will not be output\nLOGGER_OUTPUT_LEVEL=error node app.js\n```\n\nParameter priority:\n\n-   General log level: `options.level` > `LOGGER_OUTPUT_LEVEL` > `info level`\n-   `console` log level: `options.consoleLogLevel` > `LOGGER_LEVEL_CONSOLE` > `options.level` > `LOGGER_OUTPUT_LEVEL` > `info level`\n-   `file` log level: `options.fileLogLevel` > `LOGGER_LEVEL_FILE` > `options.level` > `LOGGER_OUTPUT_LEVEL` > `info level`\n-   `logagent` log level: `options.agentLogLevel` > `LOGGER_LEVEL_LOGAGENT` > `options.level` > `LOGGER_OUTPUT_LEVEL` > `info level`\n-   `metrics` log level: `options.metricsLevel` > `LOGGER_LEVEL_METRICS` > `warn level`\n\n### Log component\n\n-   Optional value ( values not in the range of optional values will be directly ignored )\n    -   `true`: Open log.\n    -   `false`: Close log.\n\nRelated environment variables:\n\n-   `LOGGER_ENABLE_CONSOLE`: Whether to enable the console log.\n-   `LOGGER_ENABLE_FILE`: Whether to enable file log.\n-   `LOGGER_ENABLE_LOGAGENT`: Whether to enable logagent log.\n-   `LOGGER_ENABLE_METRICS`: Whether to enable metrics log.\n\n```shell\n# At this time, all logagent logs will not be output\nLOGGER_ENABLE_LOGAGENT=false node app.js\n```\n\nParameter priority:\n\n-   `console` log: `options.enableConsoleLog` > `LOGGER_ENABLE_CONSOLE` > `default rule`\n-   `file` log: `options.enableFileLog` > `LOGGER_ENABLE_FILE` > `default rule`\n-   `logagent` log: `options.enableAgentLog` > `LOGGER_ENABLE_LOGAGENT` > `default rule`\n-   `metrics` log: `options.enableMetrics` > `LOGGER_ENABLE_METRICS` > `default rule`\n\nThe default rule is as follows：\n\n![](./images/1.jpg)\n\n### Log Timezone\n\nRelated environment variables:\n\n-   `LOGGER_TIME_ZONE`: Log Timezone.\n\n```shell\n# At this time, the log timezone is America/New_York.\nLOGGER_TIME_ZONE=America/New_York node app.js\n```\n\n### Security Mark\n\nRelated environment variables:\n\n-   `LOGGER_ENABLE_SEC_MARK`: Whether to enable `Security Mark` for `TTP` environment, see [TTP environment usage guide - @byted-service/logger](https://bytedance.feishu.cn/wiki/wikcn9yu4qGfXObjt40GN8ni9Lu).\n\n```shell\n# Close Security Mark.\nLOGGER_ENABLE_SEC_MARK=false node app.js\n```\n\n## Metrics\n\nIndicator name:\n\n```\n// Log call count, can be modified by options.metrics parameter\ntoutiao.service.log.${psm}.throughput\n```\n\n**tags**:\n\n<details>\n  <summary>History</summary>\n\n-   `v2.0.6`: Support `env`, `version`.\n\n</details>\n\n-   `level`: Log level.\n-   `cluster`\n-   `env`\n-   `version`: The version of `@byted-service/logger`.\n","types":"lib/index.d.ts","version":"2.2.0","_nodeVersion":"14.21.2","files":["lib","images","index.js"],"readmeFilename":"README.en.md","repository":{"type":"git","url":"https://code.byted.org/nodejs/byted-service"},"_id":"@byted-service/logger@2.2.0","author":"","devDependencies":{"pump":"^3.0.0","rimraf":"^3.0.2"},"dist":{"fileCount":36,"integrity":"sha512-jZvKP9y7nL+lGN+N0Ntex6gn5gbN8+etWhSHMHvJlHQxMvJQ7jzDL7Q8QXJ2Hh2eS3rCaUXOZP8HZroZ7qMiMQ==","shasum":"fc80890e216a474bf86eaf0f43b34894097220c6","size":264582,"tarball":"https://bnpm.byted.org/@byted-service/logger/-/logger-2.2.0.tgz","unpackedSize":379969},"gitHead":"2a7028d52a76247fd6cd6a045c470fddfeca1eaf","dependencies":{"@byted-service/logagent":"^1.8.1","chalk":"^4.1.1","mkdirp":"^0.5.1","@byted-service/env":"^1.15.0","dayjs":"^1.10.5","lru-cache":"^6.0.0","sonic-boom":"^1.4.1","tslib":"^1.9.3","@byted-service/metrics":"^1.13.4"},"description":"Logger for bytedance","license":"MIT","main":"index.js","maintainers":[{"avatar":"https://s3-fs.pstatp.com/static-resource/v1/bf5207f4-07f4-4c43-9004-b01af1aff365~?image_size=72x72&cut_type=&quality=&format=png&sticker_format=.webp","email":"liyubei@bytedance.com","name":"liyubei"},{"avatar":"","email":"nodejs-team@bnpm.com","name":"nodejs-team"},{"avatar":"https://s1-fs.pstatp.com/static-resource/v1/d27d000e276d58ace3df~?image_size=72x72&cut_type=&quality=&format=png&sticker_format=.webp","email":"ouyangyadong@bytedance.com","name":"ouyangyadong"},{"avatar":"https://s1-fs.pstatp.com/static-resource/v1/ef40014f9ad1f7011ec~?image_size=72x72&cut_type=&quality=&format=png&sticker_format=.webp","email":"shenchen@bytedance.com","name":"shenchen"},{"avatar":"https://s1-fs.pstatp.com/static-resource/v1/a339a912-f731-4fe7-9e51-d91e1871180g~?image_size=240x240&cut_type=&quality=&format=image&sticker_format=.webp","email":"xieda@bytedance.com","name":"xieda"},{"name":"xieweicheng","avatar":"https://s1-fs.pstatp.com/static-resource/v1/f27851c0-d3e8-4851-a606-1a3d9361b82g~?image_size=72x72&cut_type=&quality=&format=png&sticker_format=.webp","email":"xieweicheng@bytedance.com"},{"name":"yeyuanfeng","avatar":"https://s3-fs.pstatp.com/static-resource/v1/43d80005ffccbded38e9~?image_size=72x72&cut_type=&quality=&format=png&sticker_format=.webp","email":"yeyuanfeng@bytedance.com"},{"avatar":"https://s3-fs.pstatp.com/static-resource/v1/1e3e0921-ad28-4445-81f3-b136ac22229g~?image_size=240x240&cut_type=&quality=&format=image&sticker_format=.webp","email":"zhangsong.loves@bytedance.com","name":"zhangsong.loves"}],"name":"@byted-service/logger","scripts":{"test":"ROUTE_IP=10.225.130.44 RUNTIME_IDC_NAME=boe ../../node_modules/.bin/jest --config ./jest.config.json --coverage --env=node","bench":"node benchmarks","build":"rm -rf lib && ../../node_modules/.bin/tsc","prepublish":"npm run build"}},"2.1.0-alpha.5":{"description":"Logger for bytedance","gitHead":"93cc651103e6e3356e67849c67da5a8704fe2de4","license":"MIT","main":"index.js","maintainers":[{"avatar":"https://s3-fs.pstatp.com/static-resource/v1/bf5207f4-07f4-4c43-9004-b01af1aff365~?image_size=72x72&cut_type=&quality=&format=png&sticker_format=.webp","email":"liyubei@bytedance.com","name":"liyubei"},{"avatar":"","email":"nodejs-team@bnpm.com","name":"nodejs-team"},{"avatar":"https://s1-fs.pstatp.com/static-resource/v1/d27d000e276d58ace3df~?image_size=72x72&cut_type=&quality=&format=png&sticker_format=.webp","email":"ouyangyadong@bytedance.com","name":"ouyangyadong"},{"name":"shenchen","avatar":"https://s1-fs.pstatp.com/static-resource/v1/ef40014f9ad1f7011ec~?image_size=72x72&cut_type=&quality=&format=png&sticker_format=.webp","email":"shenchen@bytedance.com"},{"avatar":"https://s1-fs.pstatp.com/static-resource/v1/a339a912-f731-4fe7-9e51-d91e1871180g~?image_size=240x240&cut_type=&quality=&format=image&sticker_format=.webp","email":"xieda@bytedance.com","name":"xieda"},{"avatar":"https://s1-fs.pstatp.com/static-resource/v1/f27851c0-d3e8-4851-a606-1a3d9361b82g~?image_size=72x72&cut_type=&quality=&format=png&sticker_format=.webp","email":"xieweicheng@bytedance.com","name":"xieweicheng"},{"name":"yeyuanfeng","avatar":"https://s3-fs.pstatp.com/static-resource/v1/43d80005ffccbded38e9~?image_size=72x72&cut_type=&quality=&format=png&sticker_format=.webp","email":"yeyuanfeng@bytedance.com"},{"avatar":"https://s3-fs.pstatp.com/static-resource/v1/1e3e0921-ad28-4445-81f3-b136ac22229g~?image_size=240x240&cut_type=&quality=&format=image&sticker_format=.webp","email":"zhangsong.loves@bytedance.com","name":"zhangsong.loves"}],"name":"@byted-service/logger","readme":"# @byted-service/logger\n\n[![bnpm](https://web-bnpm.byted.org/badge/v/@byted-service/logger.svg?style=flat-square)](https://web-bnpm.byted.org/package/@byted-service/logger) [![download](https://2y8ngapf.fn.bytedance.net/d?p=@byted-service/logger)](https://web-bnpm.byted.org/package/@byted-service/logger)\n\n[简体中文](https://code.byted.org/nodejs/byted-service/blob/master/packages/logger/README.md) | [English](https://code.byted.org/nodejs/byted-service/blob/master/packages/logger/README.en.md) | [CHANGELOG](https://code.byted.org/nodejs/byted-service/blob/master/packages/logger/CHANGELOG.md)\n\n> The following is **@byted-service/logger@2.x** document, **1.x** document see [logger-v1.x](https://code.byted.org/nodejs/byted-service/tree/logger-v1.x/packages/logger), [@byted-service/logger@2.0.0 release log](https://bytedance.feishu.cn/wiki/wikcnwTrFMBrI0oZaYHxybzW0je)\n\n**@byted-service/logger** is the company's basic logging module. The main features are as follows:\n\n-   Output logs that meet the company's internal log specifications, see [Node.js log usage guide - @bytedservice/logger](https://bytedance.feishu.cn/wiki/wikcnsLn77LSSKg996gVsKapAXg).\n-   Supports [@byted-service/logagent](https://code.byted.org/nodejs/byted-service/blob/master/packages/logagent/README.md) to report logs to the `MS platform`.\n\nIf the framework you are using has integrated logger. It is not recommended to use this module directly, you can directly use the provided plugins.\n\n-   Gulu: [@gulu/access-log](https://code.byted.org/nodejs/gulu/tree/master/packages/byted-gulu-access-log).\n-   Koa & Express: [@fe/middlewares](https://web-bnpm.byted.org/package/@fe/middlewares).\n\n## Installation\n\n```bash\nnpm install @byted-service/logger --registry=http://bnpm.byted.org\n```\n\n## Quick start\n\n```js\nconst { Logger } = require('@byted-service/logger');\nconst logger = new Logger();\n\nlogger.info('hello world');\n// The log formatting rules are the same as util.format.\nlogger.info('hello %s', 'world');\nlogger.log({\n    level: 'info',\n    message: 'hello %s',\n    splat: ['world'],\n});\n```\n\nTips: [util.format](https://nodejs.org/dist/latest/docs/api/util.html#util_util_format_format_args)\n\n## API\n\n### new Logger([options])\n\n-   `options`\n    -   `level`: Log ouput level, the default value is `debug`. Logs below this level will not be processed.\n    -   `defaultLevel`: Default log level, the default value is `info`.\n    -   `streams`: Log output stream, see [Streams](#streams)\n    -   `flushInterval`: Specify the log refresh interval, the default value is `10s`.\n    -   `consoleLogLevel`: `console` log level, the default value is `options.level`.\n    -   `fileLogLevel`: `file` log level, the default value is `options.level`.\n    -   `agentLogLevel`: `logagent` log level, the default value is `options.level`.\n    -   `metricsLevel`: `metrics` level, the default value is `warn`.\n    -   `enableConsoleLog`: Whether to enable the `console` log, the default value is `!env.isTest() && !env.isProd()` ( `true` in the local development environment, enable the `console` log ), see [@byted-service/env](https://code.byted.org/nodejs/byted-service/tree/master/packages/env/README.en.md).\n    -   `enableFileLog`: Whether to open the `file` log, the default value is `env.isTest() || env.isProd()` ( `false` in the local development environment, close the `file` log ), see [@byted-service/env](https://code.byted.org/nodejs/byted-service/tree/master/packages/env/README.en.md).\n    -   `enableAgentLog`: Whether to enable the `logagent` log, the default value is `env.isTest() || env.isProd()` ( `false` in the local development environment, close the `logagent` log ), see [@byted-service/env](https://code.byted.org/nodejs/byted-service/tree/master/packages/env/README.en.md).\n    -   `enableMetrics`: Whether to enable `metrics`, the default value is `true`.\n    -   `psm`: Project `psm`, the default value is `env.getPSM()`, see [@byted-service/env](https://code.byted.org/nodejs/byted-service/tree/master/packages/env/README.en.md).\n    -   `prefix`: The default `prefix` of log messages.\n    -   `tags`: Global log `tags`.\n    -   `tagKeys`: Log `tagKeys`, used to quickly serialize log `tags`.\n    -   `callSiteFrameIndex`: The stack depth is used to obtain the call log location. If you need to perform upper packaging based on `@byted-service/logger`, please pay attention to setting this value.\n    -   `enableSecMark`: Whether to enable the `security mark`, the default value is `false`. At the `TTP` environment, the default value is `true`. After enabling it, the `key=value` will be converted to `{{key=value}}`. See [TTP environment usage guide - @byted-service/logger](https://bytedance.feishu.cn/wiki/wikcn9yu4qGfXObjt40GN8ni9Lu).\n    -   `file`: The log file, when it is an array, will try to create the file one by one unit the file is writable.\n    -   `rotatePattern`: Log cutting `cron` expressions, **only part of cron expressions are implemented, please use the beta function with caution**, cut once every hour by default.\n        -   `0 0 0 * *`: Cut once every day.\n        -   `0 0 * * *`: Cut once every hour.\n        -   `0 * * * *`: Cut once every minute.\n        -   `0 0 0,12 * *`: Cut at 0 o'clock and 12 o'clock every day.\n        -   `0 0 0-3 * *`: Cut from 0 o'clock to 3 o'clock every day.\n        -   `0 0 *\\/2 * *`: Cutting even hours every day.\n    -   `fileFormatter`: Log cutting file `formatter`, the default format is `/path/to/p.s.m.log.YYYY-MM-DD_HH:mm:ss`.\n        -   `file: Original log file.\n        -   `date`: Corresponding cutting date.\n    -   `dir`: Log storage directory, when `env.isTest() || env.isProd()` is `true` (`false` in the local development environment), the default value is `/opt/tiger/toutiao/log/app`, otherwise the default value is `${process.cwd()}/log`, see [@byted-service/env](https://code.byted.org/nodejs/byted-service/tree/master/packages/env/README.en.md).\n    -   `filename`: The name of the log file, the default value is `options.psm`.\n    -   `ext`: The log file suffix, the default value is `.log`.\n        -   If it is an access log, fill in `.access.log`.\n        -   If it is an `rpc` log, fill in `.call.log`.\n    -   `fallbackDirs`: The attempted directory after the log directory creation fails, the default value is `` [`${process.cwd()}/log`, `${os.tmpdir()}/log`] ``. If all fail, the creation of the log instance fails.\n    -   `disableDirFallbackWarning`: Whether to turn off the output when the log directory creation fails, the default value is `false`.\n    -   `agent`: `logagent` construction parameters, see [@byted-service/logagent](https://code.byted.org/nodejs/byted-service/blob/master/packages/logagent/README.en.md).\n    -   `taskName`: `logagent` log type mark, `_rpc` means `rpc` log, the default value is `options.psm`.\n    -   `metrics`: `metrics` construction parameter, or `metrics` instance, see [@byted-service/metrics](https://code.byted.org/nodejs/byted-service/blob/master/packages/metrics/README.en.md).\n\n### logger.level\n\nLog output level, the default value is `options.level`, which can be set dynamically.\n\n```js\nconst { Logger } = require('@byted-service/logger');\nconst logger = new Logger();\n\nlogger.level = 'info';\nlogger.info('hello world at info level'); // Output.\n\nlogger.level = 'warn';\nlogger.info('hello world at warn level'); // Not output.\n```\n\nTips: Because the `API` is too flexible, it is not recommended to use it directly.\n\n#### logger.levels\n\nSupported log level, the default value is\n\n```js\n{\n    trace: 10,\n    debug: 20,\n    info: 30,\n    warn: 40,\n    error: 50,\n    fatal: 60,\n}\n```\n\n#### logger.defaultLevel\n\nDefault log level, the default value is `options.defaultLevel`.\n\n#### logger.tags\n\nGlobal log `tags`, the default value is `options.tags`, used as an index to query on the `MS platform`.\n\n#### logger.tagKeys\n\nLog `tagKeys`, used to quickly serialize log `tags` to improve performance.\n\n#### logger.isLevelEnabled(level)\n\nWhether the log level is turned on.\n\n#### logger.fatal(message, [...splat])\n\n#### logger.error(message, [...splat])\n\n#### logger.warn(message, [...splat])\n\n#### logger.info(message, [...splat])\n\n#### logger.debug(message, [...splat])\n\n#### logger.trace(message, [...splat])\n\n```js\nconst { Logger } = require('@byted-service/logger');\nconst logger = new Logger();\n\nlogger.fatal('hello world');\nlogger.error('hello world');\nlogger.warn('hello world');\nlogger.info('hello world');\nlogger.debug('hello world');\nlogger.trace('hello world');\n```\n\n#### logger.log([args])\n\n-   args\n    -   level: Log level, the default value is `options.defaultlevel`.\n    -   message: Log content.\n    -   splat: Log formatting parameters.\n    -   logId: Log `logId`, usually completed automatically by the framework, see [x-tt-logid](https://bytedance.feishu.cn/wiki/wikcn2L5x9IgQ4iLEdHofSMPVQc#qUpuqi).\n    -   location: The log call stack location, which is automatically calculated by default.\n    -   tags: Log `tags`, merged with `options.tags` in the form of `Object.assign()`, used as an index for query on the `MS platform`.\n\n```js\nconst { Logger } = require('@byted-service/logger');\nconst logger = new Logger();\n\nlogger.log({\n    level: 'info',\n    message: 'hello %s',\n    splat: ['world'],\n    logId: 'some logid',\n    location: 'some location',\n    tags: {\n        some: 'tags',\n    },\n});\n```\n\n#### logger.flush()\n\nFlush the log asynchronously to [Streams](#streams), by default it is automatically refreshed according to `options.flushInterval`.\n\n```js\nconst { Logger } = require('@byted-service/logger');\nconst logger = new Logger();\n\nlogger.info('hello world');\nlogger.flush();\n```\n\n#### logger.flushSync()\n\nFlush the log synchronously to [Streams](#streams).\n\n```js\nconst { Logger } = require('@byted-service/logger');\nconst logger = new Logger();\n\nlogger.info('hello world');\nlogger.flushSync();\n```\n\n#### logger.clone([options])\n\nCopy log instance, a lightweight copy, and share the same with the original `logger` [Streams](#streams) by default.\n\n```js\nconst { Logger } = require('@byted-service/logger');\nconst logger = new Logger();\nconst childLogger = logger.clone();\n\nchildLogger.info('hello world');\n```\n\n#### logger.addStream(level, stream)\n\nAdd [Streams](#streams).\n\n```js\nconst { Logger } = require('@byted-service/logger');\nconst logger = new Logger();\n\nlogger.addStream('info', {\n    write(msg) {\n        console.log(msg);\n    },\n});\n\nlogger.info('hello world');\n```\n\n#### logger.deleteStream(level, stream)\n\nDelete [Streams](#streams).\n\n```js\nconst { Logger } = require('@byted-service/logger');\nconst logger = new Logger();\n\nconst stream = {\n    write(msg) {\n        console.log(msg);\n    },\n};\nlogger.addStream('info', stream);\nlogger.deleteStream('info', stream);\n\nlogger.info('hello world');\n```\n\n### logger.getFinalLogger()\n\nObtain a synchronous logger, which can be used in situations where it is impossible to write logs asynchronously. E.g:\n\n-   process.on('uncaughtException')\n-   process.on('unhandledRejection')\n\nPlease do not use console.log directly, because whether console.log is synchronized or not depends on the environment. For details, see the document: https://nodejs.org/dist/latest-v12.x/docs/api/process.html#process_a_note_on_process_i_o\n\n-   Only applicable to file log writing. `logagent` are not supported.\n\n```js\nconst { Logger } = require('@byted-service/logger');\nconst logger = new Logger();\nconst finalLogger = logger.getFinalLogger();\n\nprocess.on('uncaughtException', (err) => {\n    finalLogger.error(err, 'uncaughtException');\n    process.exit(1);\n});\n```\n\n### Streams\n\nLog output stream. In `@byted-service/logger`, four log output streams, `console`, `file`, `logagent`, and `metrcis`, are built in by default.\n\n-   If you use [new Logger(\\[options\\])](#new-loggeroptions), the above log output stream will be added by default, which can be controlled by parameters and environment variables.\n-   If you use [new CoreLogger(\\[options\\])](#new-coreloggeroptions), it can be controlled by `logger.addStream()` and `logger.deleteStream()`.\n\n#### createConsole()\n\nCreate `console` output stream.\n\n```js\nconst { CoreLogger, createConsole } = require('@byted-service/logger');\nconst logger = new CoreLogger();\n\nlogger.addStream('info', createConsole());\n\nlogger.info('hello world');\n```\n\n#### createFileRotate([options])\n\nCreate `file` output stream, **compatible with the old version of `logger`**, see [@byted-service/logger upgrade instructions](https://bytedance.feishu.cn/wiki/wikcn5dsQLTFYuGBdbB7ULRFHpb#99sYNJ).\n\n-   `options`\n    -   `psm`: Project `psm`, the default value is `env.getPSM()`, see [@byted-service/env](https://code.byted.org/nodejs/byted-service/tree/master/packages/env/README.en.md).\n    -   `file`: The log file, when it is an array, will try to create the file one by one unit the file is writable.\n    -   `rotatePattern`: Log cutting `cron` expressions, **only part of cron expressions are implemented, please use the beta function with caution**, cut once every hour by default.\n        -   `0 0 0 * *`: Cut once every day.\n        -   `0 0 * * *`: Cut once every hour.\n        -   `0 * * * *`: Cut once every minute.\n        -   `0 0 0,12 * *`: Cut at 0 o'clock and 12 o'clock every day.\n        -   `0 0 0-3 * *`: Cut from 0 o'clock to 3 o'clock every day.\n        -   `0 0 *\\/2 * *`: Cutting even hours every day.\n    -   `fileFormatter`: Log cutting file `formatter`, the default format is `/path/to/p.s.m.log.YYYY-MM-DD_HH:mm:ss`.\n        -   `file: Original log file.\n        -   `date`: Corresponding cutting date.\n    -   `dir`: Log storage directory, when `env.isTest() || env.isProd()` is `true` (`false` in the local development environment), the default value is `/opt/tiger/toutiao/log/app`, otherwise the default value is `${process.cwd()}/log`, see [@byted-service/env](https://code.byted.org/nodejs/byted-service/tree/master/packages/env/README.en.md).\n    -   `filename`: The name of the log file, the default value is `options.psm`.\n    -   `ext`: The log file suffix, the default value is `.log`.\n        -   If it is an access log, fill in `.access.log`.\n        -   If it is an `rpc` log, fill in `.call.log`.\n    -   `fallbackDirs`: The attempted directory after the log directory creation fails, the default value is `` [`${process.cwd()}/log`, `${os.tmpdir()}/log`] ``. If all fail, the creation of the log instance fails.\n    -   `disableDirFallbackWarning`: Whether to turn off the output when the log directory creation fails, the default value is `false`.\n\n```js\nconst { CoreLogger, createFileRotate } = require('@byted-service/logger');\nconst logger = new CoreLogger();\n\nlogger.addStream('info', createFileRotate({\n    file: '/path/to/xxx.log';\n}));\n\nlogger.info('hello world');\n```\n\n#### createLogAgent([options])\n\nCreate `logagent` output stream.\n\n-   `options`\n    -   `agent`: `logagent` construction parameters, see [@byted-service/logagent](https://code.byted.org/nodejs/byted-service/blob/master/packages/logagent/README.en.md).\n    -   `taskName`: `logagent` log type mark, `_rpc` means `rpc` log, the default value is `env.getPSM()`, see [@byted-service/env](https://code.byted.org/nodejs/byted-service/tree/master/packages/env/README.en.md).\n\n```js\nconst { CoreLogger, createLogAgent } = require('@byted-service/logger');\nconst logger = new CoreLogger();\n\nlogger.addStream('info', createLogAgent());\n\nlogger.info('hello world');\n```\n\n#### createMetrics([options])\n\nCreate `metrics` output stream.\n\n-   `options`\n    -   `metrics`: `metrics` construction parameter, or `metrics` instance, see [@byted-service/metrics](https://code.byted.org/nodejs/byted-service/blob/master/packages/metrics/README.en.md).\n\n```js\nconst { CoreLogger, createLogAgent } = require('@byted-service/logger');\nconst logger = new CoreLogger();\n\nlogger.addStream('info', createMetrics());\n\nlogger.info('hello world');\n```\n\n#### new FileRotateStream(options)\n\nCreate `file` output stream, **not compatible with the old version of `logger`**, see [@byted-service/logger upgrade instructions](https://bytedance.feishu.cn/wiki/wikcn5dsQLTFYuGBdbB7ULRFHpb#99sYNJ).\n\n-   `options`\n    -   `file`: The log file, when it is an array, will try to create the file one by one unit the file is writable.\n    -   `rotatePattern`: Log cutting `cron` expressions, **only part of cron expressions are implemented, please use the beta function with caution**, cut once every hour by default.\n        -   `0 0 0 * *`: Cut once every day.\n        -   `0 0 * * *`: Cut once every hour.\n        -   `0 * * * *`: Cut once every minute.\n        -   `0 0 0,12 * *`: Cut at 0 o'clock and 12 o'clock every day.\n        -   `0 0 0-3 * *`: Cut from 0 o'clock to 3 o'clock every day.\n        -   `0 0 *\\/2 * *`: Cutting even hours every day.\n    -   `fileFormatter`: Log cutting file `formatter`, the default format is `/path/to/p.s.m.log.YYYY-MM-DD_HH:mm:ss`.\n        -   `file: Original log file.\n        -   `date`: Corresponding cutting date.\n\n```js\nconst { CoreLogger, FileRotateStream } = require('@byted-service/logger');\nconst logger = new CoreLogger();\n\nlogger.addStream(\n    'info',\n    new FileRotateStream({\n        file: '/path/to/xxx.log',\n    })\n);\n\nlogger.info('hello world');\n```\n\n### new CoreLogger([options])\n\nThe core of `logger`, which can be used to customize the implementation of `logger` to the maximum extent.\n\n-   `options`\n    -   `level`: Log ouput level, the default value is `debug`. Logs below this level will not be processed.\n    -   `defaultLevel`: Default log level, the default value is `info`.\n    -   `formatter`: Log formatter.\n    -   `streams`: Log output stream, see [Streams](#streams)\n    -   `flushInterval`: Specify the log refresh interval, the default value is `10s`.\n\n## Environment variable\n\nYou can control the log output without modifying the code by corresponding environment variables.\n\n### Log level\n\n-   Optional value ( values not in the range of optional values will be directly ignored ).\n\n    -   `fatal`: Serious errors that make the program unusable.\n    -   `error`: For a serious error of an operation, but the program is not affected.\n    -   `warn`: Problems that may cause the program to enter an abnormal state.\n    -   `info`: Normal information ( such as service start/stop ).\n    -   `debug`: Information for program debugging.\n    -   `trace`: Information used to track program operation or request call chain.\n\n-   Level size: `fatal` > `error` > `warn` > `info` > `debug` > `trace`\n\nRelated environment variables:\n\n-   `LOGGER_OUTPUT_LEVEL`: The default log level, logs below this level will not be processed.\n-   `LOGGER_LEVEL_CONSOLE`: `console` log level.\n-   `LOGGER_LEVEL_FILE`: `file` log level.\n-   `LOGGER_LEVEL_LOGAGENT`: `logagent` log level.\n-   `LOGGER_LEVEL_METRICS`: `metrics` log level.\n\n```shell\n# At this time, all logs below the error level will not be output\nLOGGER_OUTPUT_LEVEL=error node app.js\n```\n\nParameter priority:\n\n-   General log level: `options.level` > `LOGGER_OUTPUT_LEVEL` > `info level`\n-   `console` log level: `options.consoleLogLevel` > `LOGGER_LEVEL_CONSOLE` > `options.level` > `LOGGER_OUTPUT_LEVEL` > `info level`\n-   `file` log level: `options.fileLogLevel` > `LOGGER_LEVEL_FILE` > `options.level` > `LOGGER_OUTPUT_LEVEL` > `info level`\n-   `logagent` log level: `options.agentLogLevel` > `LOGGER_LEVEL_LOGAGENT` > `options.level` > `LOGGER_OUTPUT_LEVEL` > `info level`\n-   `metrics` log level: `options.metricsLevel` > `LOGGER_LEVEL_METRICS` > `warn level`\n\n### Log component\n\n-   Optional value ( values not in the range of optional values will be directly ignored )\n    -   `true`: Open log.\n    -   `false`: Close log.\n\nRelated environment variables:\n\n-   `LOGGER_ENABLE_CONSOLE`: Whether to enable the console log.\n-   `LOGGER_ENABLE_FILE`: Whether to enable file log.\n-   `LOGGER_ENABLE_LOGAGENT`: Whether to enable logagent log.\n-   `LOGGER_ENABLE_METRICS`: Whether to enable metrics log.\n\n```shell\n# At this time, all logagent logs will not be output\nLOGGER_ENABLE_LOGAGENT=false node app.js\n```\n\nParameter priority:\n\n-   `console` log: `options.enableConsoleLog` > `LOGGER_ENABLE_CONSOLE` > `!env.isTest() && !env.isProd()` ( The local development environment is true )\n-   `file` log: `options.enableFileLog` > `LOGGER_ENABLE_FILE` > `env.isTest() || env.isProd()` ( The local development environment is false )\n-   `logagent` log: `options.enableAgentLog` > `LOGGER_ENABLE_LOGAGENT` > `env.isTest() || env.isProd()` ( The local development environment is false )\n-   `metrics` log: `options.enableMetrics` > `LOGGER_ENABLE_METRICS` > `true`\n\n### Log Timezone\n\nRelated environment variables:\n\n-   `LOGGER_TIME_ZONE`: Log Timezone.\n\n```shell\n# At this time, the log timezone is America/New_York.\nLOGGER_TIME_ZONE=America/New_York node app.js\n```\n\n### Security Mark\n\nRelated environment variables:\n\n-   `LOGGER_ENABLE_SEC_MARK`: Whether to enable `Security Mark` for `TTP` environment, see [TTP environment usage guide - @byted-service/logger](https://bytedance.feishu.cn/wiki/wikcn9yu4qGfXObjt40GN8ni9Lu).\n\n```shell\n# Close Security Mark.\nLOGGER_ENABLE_SEC_MARK=false node app.js\n```\n\n## Metrics\n\nIndicator name:\n\n```\n// Log call count, can be modified by options.metrics parameter\ntoutiao.service.log.${psm}.throughput\n```\n\n**tags**:\n\n<details>\n  <summary>History</summary>\n\n-   `v2.0.6`: Support `env`, `version`.\n\n</details>\n\n-   `level`: Log level.\n-   `cluster`\n-   `env`\n-   `version`: The version of `@byted-service/logger`.\n","author":"","version":"2.1.0-alpha.5","readmeFilename":"README.en.md","dependencies":{"dayjs":"^1.10.5","lru-cache":"^6.0.0","mkdirp":"^0.5.1","tslib":"^1.9.3","@byted-service/logagent":"^1.8.0-alpha.4","chalk":"^4.1.1","sonic-boom":"^1.4.1","@byted-service/env":"^1.11.1","@byted-service/metrics":"^1.12.8"},"files":["lib","index.js"],"repository":{"type":"git","url":"https://code.byted.org/nodejs/byted-service"},"_npmVersion":"lerna/undefined/node@v14.18.1+x64 (linux)","devDependencies":{"pump":"^3.0.0","rimraf":"^3.0.2"},"dist":{"integrity":"sha512-mSA8ZjMa9wwwC+0dyl0vDRIGqfPzzjZIhOibPExJFtsvEhvVnX8smUWVcLvjF8dB16PYOQS9TYv7PoRb666/tQ==","shasum":"a249dc59d9dc11a8b47d07af44a8d9b202448d40","tarball":"https://bnpm.byted.org/@byted-service/logger/-/logger-2.1.0-alpha.5.tgz"},"_nodeVersion":"14.18.1","_npmUser":{"email":"nodejs-team@bytedance.com","name":"nodejs-team"},"scripts":{"test":"ROUTE_IP=10.225.130.44 RUNTIME_IDC_NAME=boe ../../node_modules/.bin/jest --config ./jest.config.json --coverage --env=node","bench":"node benchmarks","build":"rm -rf lib && ../../node_modules/.bin/tsc","prepublish":"npm run build"},"types":"lib/index.d.ts","_id":"@byted-service/logger@2.1.0-alpha.5"},"1.13.6":{"_npmVersion":"lerna/undefined/node@v14.16.0+x64 (linux)","description":"base logger component for app logger, access logger and rpc logger","gitHead":"4d4d1a92651940a16054d041c2ab8be5c0249585","main":"index.js","readmeFilename":"README.en.md","repository":{"type":"git","url":"https://code.byted.org/nodejs/byted-service"},"_nodeVersion":"14.16.0","_npmUser":{"email":"nodejs-team@bnpm.com","name":"nodejs-team"},"dist":{"tarb