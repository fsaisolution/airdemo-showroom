rball":"https://bnpm.byted.org/@byted-service/env/-/env-1.0.2.tgz"},"_npmUser":{"email":"ecomfe@gmail.com","name":"liyubei"},"_npmVersion":"6.4.0","publish_time":1534768117472,"version":"1.0.2","repository":{"type":"git","url":"https://code.byted.org/ies/byted-service"},"license":"ISC","_nodeVersion":"8.9.3","name":"@byted-service/env"},"1.14.0-alpha.0":{"files":["lib","index.js","index.d.ts"],"_npmUser":{"name":"nodejs-team","email":"nodejs-team@bytedance.com"},"name":"@byted-service/env","gitHead":"7a8c75009ae5a15f8719ee4fb2803883f86bedf8","_npmVersion":"lerna/undefined/node@v14.20.0+x64 (linux)","dist":{"integrity":"sha512-PrX0G0Y7nfYA6dtwftVSBWYkjhvUs1siSvcdYHDen2ZklDEfnS88TE+HTa32i/w00h4/3iM8asx3oq/IKXh1xw==","shasum":"da638ddad617e425bf3bc4cfdbb5fc618eb4d6ab","size":32027,"tarball":"https://bnpm.byted.org/@byted-service/env/-/env-1.14.0-alpha.0.tgz","unpackedSize":139022,"fileCount":38},"_nodeVersion":"14.20.0","types":"index.d.ts","scripts":{"prepublish":"npm run build","test":"ROUTE_IP=10.225.130.44 RUNTIME_IDC_NAME=boe ../../node_modules/.bin/jest --config ./jest.config.json --coverage --env=node","build":"rm -rf lib && ../../node_modules/.bin/tsc"},"license":"MIT","author":"","version":"1.14.0-alpha.0","dependencies":{"tslib":"^1.9.3"},"main":"index.js","readmeFilename":"README.en.md","repository":{"url":"https://code.byted.org/nodejs/byted-service","type":"git"},"maintainers":[{"email":"liyubei@bytedance.com","name":"liyubei","avatar":"https://s3-fs.pstatp.com/static-resource/v1/bf5207f4-07f4-4c43-9004-b01af1aff365~?image_size=72x72&cut_type=&quality=&format=png&sticker_format=.webp"},{"email":"nodejs-team@bnpm.com","name":"nodejs-team","avatar":""},{"email":"ouyangyadong@bytedance.com","name":"ouyangyadong","avatar":"https://s1-fs.pstatp.com/static-resource/v1/d27d000e276d58ace3df~?image_size=72x72&cut_type=&quality=&format=png&sticker_format=.webp"},{"avatar":"https://ee.bytedance.net/ratak/employees/3863359/avatar/?format=noop.png","email":"qizihan@bytedance.com","name":"qizi"},{"avatar":"https://s1-fs.pstatp.com/static-resource/v1/ef40014f9ad1f7011ec~?image_size=72x72&cut_type=&quality=&format=png&sticker_format=.webp","email":"shenchen@bytedance.com","name":"shenchen"},{"avatar":"https://s1-fs.pstatp.com/static-resource/v1/a339a912-f731-4fe7-9e51-d91e1871180g~?image_size=240x240&cut_type=&quality=&format=image&sticker_format=.webp","email":"xieda@bytedance.com","name":"xieda"},{"avatar":"https://s3-fs.pstatp.com/static-resource/v1/43d80005ffccbded38e9~?image_size=72x72&cut_type=&quality=&format=png&sticker_format=.webp","email":"yeyuanfeng@bytedance.com","name":"yeyuanfeng"}],"description":"The basic environment variable SDK for Node.js","_id":"@byted-service/env@1.14.0-alpha.0","readme":"# @byted-service/env\n\n[![bnpm](https://web-bnpm.byted.org/badge/v/@byted-service/env.svg?style=flat-square)](https://web-bnpm.byted.org/package/@byted-service/env) [![download](https://2y8ngapf.fn.bytedance.net/d?p=@byted-service/env)](https://web-bnpm.byted.org/package/@byted-service/env)\n\n[简体中文](https://code.byted.org/nodejs/byted-service/blob/master/packages/env/README.md) | [English](https://code.byted.org/nodejs/byted-service/blob/master/packages/env/README.en.md) | [CHANGELOG](https://code.byted.org/nodejs/byted-service/blob/master/packages/env/CHANGELOG.md)\n\n**@byted-service/env** is the basic environment variable `SDK` on the `Node.js` side of the company. It is widely integrated in `@byted-service/xxx`. The main data sources are as follows:\n\n-   [gopkg/env](https://code.byted.org/gopkg/env).\n-   [TCE > Default Environment Variables of TCE](https://bytedance.feishu.cn/wiki/wikcnR7f17phbl2h7ZVnj4KgRfg).\n-   [FaaS > System default environment variable description](https://bytedance.feishu.cn/wiki/wikcndu0chhW1HyIZ0u4Puu7Cqh).\n\n## Installation\n\n```bash\nnpm install @byted-service/env --registry=http://bnpm.byted.org\n```\n\n## Quick Start\n\n```ts\nimport { isProd } from '@byted-service/env';\n\nisProd();\n```\n\n## API\n\n### Runtime Environment\n\n#### env.isProd()\n\nWhether it is production environment. Compared with `env.isProduct()`, it also supports `NODE_ENV`.\n\n#### env.isTest()\n\nWhether it is test environment ( `Boe` environment is also considered test environment ).\n\n#### env.isTesting()\n\nUnknown.\n\n#### env.isBoe()\n\nWhether it is `Boe` environment ( `boe` + `boei18n` + `boexfl` + `boettp` ).\n\n#### env.isBoeCN()\n\nWhether it is `Boe` environment ( `boe` ).\n\n#### env.isBoeI18N()\n\nWhether it is `Boe` environment ( `boei18n` ).\n\n#### env.isBoeXfl()\n\nWhether it is `Boe` environment ( `boexfl` )\n\n#### env.isBoeTTP()\n\nWhether it is `Boe` environment ( `boettp` )\n\n#### env.isPPE()\n\nWhether it is `PPE` environment.\n\n#### env.isEdgeEnvironment()\n\nUnknown.\n\n#### env.isProduct()\n\nWhether it is `Prod` environment.\n\n### PSM + Cluster + IDC + Env + Region + Stage + VDC + VRegion\n\n#### env.getPSM()\n\nService `PSM`.\n\n#### env.setPSM(psm)\n\nSet service `PSM`.\n\n#### env.getCluster()\n\nService `Cluster`.\n\n#### env.setCluster(cluster)\n\nSet service `Cluster`.\n\n#### env.getIDC()\n\nService `IDC`.\n\n#### env.getIDCFromHost(ip)\n\nResolve service `IDC` from `IP`.\n\nTips: When `@byted-service/env` is initializing, it will load the data of the `IDC` network segment from the following files in sequence:\n\n-   [/opt/tmp/consul_agent/netsegment](#opttmpconsul_agentnetsegment) ( `IPv4` )\n-   [/opt/tiger/chadc/netsegment](#opttigerchadcnetsegment) ( `IPv4` )\n-   [/opt/tmp/consul_agent/netsegment6](#opttmpconsul_agentnetsegment6) ( `IPv6` )\n-   [/opt/tiger/chadc/netsegment6](#opttigerchadcnetsegment6) ( `IPv6` )\n\n#### env.getIDCList()\n\nService `IDC` list.\n\n#### env.setIDC(v)\n\nSet service `IDC`.\n\n#### env.setIDCFile(file)\n\nSet `IDC` network segment file (`IPv4`).\n\n#### env.setIpv6File(file)\n\nSet `IDC` network segment file (`IPv6`).\n\n#### env.getEnv()\n\nService `Env`, see [Env-based traffic scheduling](https://bytedance.feishu.cn/docs/ws0Kg2Q539Rzqc18VFc98f).\n\n#### env.isValidEnv()\n\nCheck whether the service `Env` is valid, see [Env naming specification ( final ) > Specific details](https://bytedance.feishu.cn/docs/doccn2zIJMueBhHi4kjrYKqaVYc#BTZPX3).\n\n#### env.getRegion()\n\nService `Region`.\n\n#### env.getRegionFromIDC(idc)\n\nGet service `Region` from service `IDC`.\n\nTips: When `@byted-service/env` is initializing, it will load the data of the `Region` from the following files in sequence:\n\n-   [/opt/tiger/chadc/region.json](#opttigerchadcregionjson)\n\n#### env.setRegionFile(file)\n\nSet `Region` file.\n\n#### env.getStage()\n\nService `Stage`.\n\n#### env.getVRegionFromVDC(vdc)\n\nGet service `VRegion` from service `VDC`.\n\n#### env.getCurrentVRegion()\n\nService `VRegion`.\n\n#### env.getVRegionFromHost(ip)\n\nResolve service `VRegion` from `IP`.\n\n#### env.getGovernanceVRegionFromVDC(vdc)\n\nGet service `VRegion` by real governace rules from service `VDC`.\n\n### Machine / Container Information\n\n#### env.getHostIP()\n\nMachine / container `IP` address, compatibility interface, return `IPv4` first, followed by `IPv6`.\n\n#### env.getHostIPV4()\n\nMachine / container `IPv4` address.\n\n#### env.getHostIPV6()\n\nMachine / container `IPv6` address.\n\n#### env.getIPv4()\n\nMachine / container `IPv4` address.\n\n#### env.getIPv6()\n\nMachine / container `IPv6` address.\n\n#### env.getIP()\n\nMachine / container `IP` address, return `IPv6` first, followed by `IPv4`.\n\n#### env.getIPStr()\n\nSee [env.getIP()](#envgetip).\n\n#### env.hasIPv4()\n\nDoes the machine / container have an `IPv4` address.\n\n#### env.hasIPv6()\n\nDoes the machine / container have an `IPv6` address.\n\n#### env.isDualStack()\n\nWhether the machine / container is `dual stack`, that is, there are both `IPv4` and `IPv6` addresses.\n\n#### env.isIPv4Only()\n\nWhether the machine / container is `IPv4 only`, that is, there are only `IPv4` addresses.\n\n#### env.isIPv6Only()\n\nWhether the machine / container is `IPv6 only`, that is, there are only `IPv6` addresses.\n\n#### env.getTCEServicePort()\n\nThe `primary` port configured by the user on the `TCE` platform.\n\n#### env.getTCEDebugPort()\n\nThe `debug` port configured by the user on the `TCE` platform.\n\n#### env.isInTCE()\n\nWhether it is in the `TCE` container.\n\n#### env.getPodName()\n\nThe `Pod` name of the `TCE` container.\n\n#### env.getImageVersion()\n\nThe `tag` of `TCE` image.\n\n#### env.getCloudEnv()\n\nThe `CloudEnv` of container,\n\n#### env.inVolcanoCloud()\n\nWhether it is in the `Volcano Cloud`.\n\n### Other\n\n#### env.init()\n\nInitialize `@byted-service/env`. By default, all `API`s have different levels of caching mechanism. Therefore, after modifying environment variables, you need to call this method to reinitialize `@byted-service/env`.\n\n#### env.defaultPSM\n\nService `PSM` default value, the value is `-`.\n\n#### env.defaultCluster\n\nService `Cluster` default value, the value is `default`.\n\n#### env.defaultIDC\n\nService `IDC` default value, the value is empty string.\n\n#### env.defaultEnv\n\nService `Env` default value, the value is `prod`.\n\n#### env.defaultStage\n\nService `Stage` default value, the value is `-`.\n\n#### env.defaultPodName\n\nContainer `Pod` name default value, the value is `-`.\n\n#### env.defaultImageVersion\n\nImage `tag` default value, the value is `-`.\n\n#### env.defaultCloudEnv\n\nContainer `CloudEnv` default value, the value is `-`.\n\n#### env.PSMUnknown\n\n#### env.ClusterDefault\n\n#### env.IDC\n\nEnumeration of known service `IDC`.\n\n#### env.REGION\n\nEnumeration of known service `Region`.\n\n#### env.STAGE\n\nEnumeration of known service `Stage`.\n\n#### env.VDC\n\nEnumeration of known service `VDC`.\n\n#### env.VREGION\n\nEnumeration of known service `VRegion`.\n\n## Environment Variables / Configuration Files\n\nThe environment variables used in `@byted-service/env` are as follows:\n\n```sh\nIS_TCE_DOCKER_ENV # Whether it is TCE container environment.\nNODE_ENV # Node.js only environment variable, when it is prod or production, it means the production environment.\n\nLOAD_SERVICE_PSM # Service PSM.\nPSM # Same as LOAD_SERVICE_PSM, but lower priority.\nTCE_PSM # Same as PSM, but lower priority.\nSERVICE_CLUSTER # Service Cluster.\nRUNTIME_IDC_NAME # Service IDC.\nSERVICE_ENV # Service Env.\nTCE_ENV # Same as SERVICE_ENV, but lower priority.\nTCE_STAGE # Service Stage.\n\nMY_HOST_IP # IPv4 of the physical machine where the instance is located.\nMY_HOST_IPV6 # IPv6 of the physical machine where the instance is located.\nTCE_PRIMARY_PORT # The primary port configured by the user on the TCE platform.\nTCE_DEBUG_PORT # The debug port configured by the user on the TCE platform.\n\nIS_PROD_RUNTIME # Whether it is Prod environment. Deprecated.\nTESTING_PREFIX # Unknown.\nIS_EDGE_ENVIRONMENT # Unknown.\nTCE_HOST_ENV # Env of the TCE control plane.\nMY_POD_NAME # Pod name of TCE container.\nCURRENT_VERSION # Tag of TCE image.\n```\n\nSee more environment variables:\n\n-   [TCE > Default Environment Variables of TCE](https://bytedance.feishu.cn/wiki/wikcnR7f17phbl2h7ZVnj4KgRfg).\n-   [FaaS > System default environment variable description](https://bytedance.feishu.cn/wiki/wikcndu0chhW1HyIZ0u4Puu7Cqh).\n\nTips: Some variables are injected at runtime, so they cannot be obtained directly through `echo $XXX`, but can be obtained by the following.\n\n```sh\nps -ef | grep node\n# $pid changed to correspond to the Node.js process pid.\ncat /proc/$pid/environ | tr \"\\0\" \"\\n\" | grep XXX\n```\n\n### /opt/tiger/chadc/netsegment\n\n`IDC` network segment file ( `IPv4` ), see [inf/chadc](https://code.byted.org/inf/chadc/blob/master/netsegment).\n\n### /opt/tmp/consul_agent/netsegment\n\nSee [/opt/tiger/chadc/netsegment](#opttigerchadcnetsegment).\n\n### /opt/tiger/chadc/netsegment6\n\n`IDC` network segment file ( `IPv6` ), see [inf/chadc](https://code.byted.org/inf/chadc/blob/master/netsegment6).\n\n### /opt/tmp/consul_agent/netsegment6\n\nSee [/opt/tiger/chadc/netsegment6](#opttigerchadcnetsegment6).\n\n### /opt/tiger/chadc/region.json\n\n`Region` file, see [inf/chadc](https://code.byted.org/inf/chadc/blob/master/region.json).\n\n## Privatization deployment / DevBox\n\nFor those who need privatization deployment / `DevBox`, you can set environment variables and files as follows.\n\n### Boe / BoeI18N\n\n```sh\n# Whether it is TCE container environment.\nIS_TCE_DOCKER_ENV=1\n# Node.js only environment variable.\n# NODE_ENV=test\n\n# Service PSM.\nTCE_PSM=p.s.m\n# Service Cluster.\nSERVICE_CLUSTER=default\n# Service IDC ( boe means Boe environment, boei18n means BoeI18N environment ).\nRUNTIME_IDC_NAME=boe\n# Service Env ( the default value is prod, If it is a lane, use the lane name ).\nSERVICE_ENV=prod\n# Service Stage.\n# TCE_STAGE=single_dc\n\n# IPv4 of the physical machine where the instance is located.\n# MY_HOST_IP=127.0.0.1\n# IPv6 of the physical machine where the instance is located.\n# MY_HOST_IPV6=::\n# The primary port configured by the user on the TCE platform.\n# TCE_PRIMARY_PORT=3000\n# The debug port configured by the user on the TCE platform.\n# TCE_DEBUG_PORT=8080\n\n# Env of the TCE control plane ( fixed value cannot be modified ).\nTCE_HOST_ENV=boe\n# Pod name of TCE container.\n# MY_POD_NAME=pod-xxx\n# Tag of TCE image.\n# CURRENT_VERSION=123456\n```\n\n-   [/opt/tiger/chadc/netsegment](#opttigerchadcnetsegment): Optional, `IDC` network segment file ( `IPv4` ).\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n-   [/opt/tiger/chadc/netsegment6](#opttigerchadcnetsegment6): Optional, `IDC` network segment file ( `IPv6` ).\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n-   [/opt/tiger/chadc/region.json](#opttigerchadcregionjson): Optional, `Region` file.\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n\n### PPE\n\n```sh\n# Whether it is TCE container environment.\nIS_TCE_DOCKER_ENV=1\n# Node.js only environment variable ( the PPE environment is the same as the Prod environment, both are prod ).\n# NODE_ENV=prod\n\n# Service PSM.\nTCE_PSM=p.s.m\n# Service Cluster.\nSERVICE_CLUSTER=default\n# Service IDC ( lf means langfang machine room, you can fill in by yourself ).\nRUNTIME_IDC_NAME=lf\n# Service Env ( PPE plane name ).\nSERVICE_ENV=ppe_xxx\n# Service Stage.\n# TCE_STAGE=single_dc\n\n# IPv4 of the physical machine where the instance is located.\n# MY_HOST_IP=127.0.0.1\n# IPv6 of the physical machine where the instance is located.\n# MY_HOST_IPV6=::\n# The primary port configured by the user on the TCE platform.\n# TCE_PRIMARY_PORT=3000\n# The debug port configured by the user on the TCE platform.\n# TCE_DEBUG_PORT=8080\n\n# Env of the TCE control plane ( fixed value cannot be modified ).\nTCE_HOST_ENV=ppe\n# Pod name of TCE container.\n# MY_POD_NAME=pod-xxx\n# Tag of TCE image.\n# CURRENT_VERSION=123456\n```\n\n-   [/opt/tiger/chadc/netsegment](#opttigerchadcnetsegment): Optional, `IDC` network segment file ( `IPv4` ).\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n-   [/opt/tiger/chadc/netsegment6](#opttigerchadcnetsegment6): Optional, `IDC` network segment file ( `IPv6` ).\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n-   [/opt/tiger/chadc/region.json](#opttigerchadcregionjson): Optional, `Region` file.\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n\n### Prod\n\n```sh\n# Whether it is TCE container environment.\nIS_TCE_DOCKER_ENV=1\n# Node.js only environment variable.\n# NODE_ENV=prod\n\n# Service PSM.\nTCE_PSM=p.s.m\n# Service Cluster.\nSERVICE_CLUSTER=default\n# Service IDC ( lf means langfang machine room, you can fill in by yourself ).\nRUNTIME_IDC_NAME=lf\n# Service Env ( fixed value cannot be modified ).\nSERVICE_ENV=prod\n# Service Stage.\n# TCE_STAGE=single_dc\n\n# IPv4 of the physical machine where the instance is located.\n# MY_HOST_IP=127.0.0.1\n# IPv6 of the physical machine where the instance is located.\n# MY_HOST_IPV6=::\n# The primary port configured by the user on the TCE platform.\n# TCE_PRIMARY_PORT=3000\n# The debug port configured by the user on the TCE platform.\n# TCE_DEBUG_PORT=8080\n\n# Env of the TCE control plane ( fixed value cannot be modified ).\n# TCE_HOST_ENV=online\n# Pod name of TCE container.\n# MY_POD_NAME=pod-xxx\n# Tag of TCE image.\n# CURRENT_VERSION=123456\n```\n\n-   [/opt/tiger/chadc/netsegment](#opttigerchadcnetsegment): Optional, `IDC` network segment file ( `IPv4` ).\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n-   [/opt/tiger/chadc/netsegment6](#opttigerchadcnetsegment6): Optional, `IDC` network segment file ( `IPv6` ).\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n-   [/opt/tiger/chadc/region.json](#opttigerchadcregionjson): Optional, `Region` file.\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n\n## Documents\n\n-   [TCE > Default Environment Variables of TCE](https://bytedance.feishu.cn/wiki/wikcnR7f17phbl2h7ZVnj4KgRfg).\n-   [FaaS > System default environment variable description](https://bytedance.feishu.cn/wiki/wikcndu0chhW1HyIZ0u4Puu7Cqh).\n-   [How to judge the deployment environment > Server](https://bytedance.feishu.cn/wiki/wikcnmVz29FwukFO4Ux1Rtmc23c#sxJRso).\n"},"1.16.0-alpha.0":{"license":"MIT","scripts":{"test":"ROUTE_IP=10.225.130.44 RUNTIME_IDC_NAME=boe ../../node_modules/.bin/jest --config ./jest.config.json --coverage --env=node","build":"rm -rf lib && ../../node_modules/.bin/tsc","prepublish":"npm run build"},"maintainers":[{"email":"liyubei@bytedance.com","name":"liyubei","avatar":"https://s3-fs.pstatp.com/static-resource/v1/bf5207f4-07f4-4c43-9004-b01af1aff365~?image_size=72x72&cut_type=&quality=&format=png&sticker_format=.webp"},{"avatar":"","email":"nodejs-team@bnpm.com","name":"nodejs-team"},{"avatar":"https://s1-fs.pstatp.com/static-resource/v1/d27d000e276d58ace3df~?image_size=72x72&cut_type=&quality=&format=png&sticker_format=.webp","email":"ouyangyadong@bytedance.com","name":"ouyangyadong"},{"email":"qizihan@bytedance.com","name":"qizi","avatar":"https://ee.bytedance.net/ratak/employees/3863359/avatar/?format=noop.png"},{"name":"shenchen","avatar":"https://s1-fs.pstatp.com/static-resource/v1/ef40014f9ad1f7011ec~?image_size=72x72&cut_type=&quality=&format=png&sticker_format=.webp","email":"shenchen@bytedance.com"},{"avatar":"https://s1-fs.pstatp.com/static-resource/v1/a339a912-f731-4fe7-9e51-d91e1871180g~?image_size=240x240&cut_type=&quality=&format=image&sticker_format=.webp","email":"xieda@bytedance.com","name":"xieda"},{"avatar":"https://s3-fs.pstatp.com/static-resource/v1/43d80005ffccbded38e9~?image_size=72x72&cut_type=&quality=&format=png&sticker_format=.webp","email":"yeyuanfeng@bytedance.com","name":"yeyuanfeng"}],"_npmUser":{"name":"nodejs-team","email":"nodejs-team@bytedance.com"},"readmeFilename":"README.en.md","name":"@byted-service/env","types":"index.d.ts","_id":"@byted-service/env@1.16.0-alpha.0","description":"The basic environment variable SDK for Node.js","author":"","dist":{"unpackedSize":163153,"fileCount":40,"integrity":"sha512-+roBHsvrlYy0cVl8UBKsjGN83SQJcAAL+MddckFkNvEeYYiTloi0Lw7d1E9X6H8UmTeX3Wc0th6R3UNubck/XQ==","shasum":"63a06ca753dd24d0d36bd45a34ded281c528a882","size":35684,"tarball":"https://bnpm.byted.org/@byted-service/env/-/env-1.16.0-alpha.0.tgz"},"dependencies":{"tslib":"^1.9.3"},"repository":{"url":"https://code.byted.org/nodejs/byted-service","type":"git"},"_nodeVersion":"14.20.0","main":"index.js","_npmVersion":"lerna/undefined/node@v14.20.0+x64 (linux)","files":["lib","index.js","index.d.ts"],"version":"1.16.0-alpha.0","gitHead":"a1f40be1809920208b04eb757d569520eeb6985a","readme":"# @byted-service/env\n\n[![bnpm](https://web-bnpm.byted.org/badge/v/@byted-service/env.svg?style=flat-square)](https://web-bnpm.byted.org/package/@byted-service/env) [![download](https://2y8ngapf.fn.bytedance.net/d?p=@byted-service/env)](https://web-bnpm.byted.org/package/@byted-service/env)\n\n[简体中文](https://code.byted.org/nodejs/byted-service/blob/master/packages/env/README.md) | [English](https://code.byted.org/nodejs/byted-service/blob/master/packages/env/README.en.md) | [CHANGELOG](https://code.byted.org/nodejs/byted-service/blob/master/packages/env/CHANGELOG.md)\n\n**@byted-service/env** is the basic environment variable `SDK` on the `Node.js` side of the company. It is widely integrated in `@byted-service/xxx`. The main data sources are as follows:\n\n-   [gopkg/env](https://code.byted.org/gopkg/env).\n-   [TCE > Default Environment Variables of TCE](https://bytedance.feishu.cn/wiki/wikcnR7f17phbl2h7ZVnj4KgRfg).\n-   [FaaS > System default environment variable description](https://bytedance.feishu.cn/wiki/wikcndu0chhW1HyIZ0u4Puu7Cqh).\n-   (TikTok only) [tiktok/region_lib](https://code.byted.org/tiktok/region_lib) [Doc](https://bytedance.feishu.cn/wiki/wikcn4YwQncW4hTDEfCQZEizo9c).\n\n## Installation\n\n```bash\nnpm install @byted-service/env --registry=http://bnpm.byted.org\n```\n\n## Quick Start\n\n```ts\nimport { isProd } from '@byted-service/env';\n\nisProd();\n```\n\n## API\n\n### Runtime Environment\n\n#### env.isProd()\n\nWhether it is production environment. Compared with `env.isProduct()`, it also supports `NODE_ENV`.\n\n#### env.isTest()\n\nWhether it is test environment ( `Boe` environment is also considered test environment ).\n\n#### env.isTesting()\n\nUnknown.\n\n#### env.isBoe()\n\nWhether it is `Boe` environment ( `boe` + `boei18n` + `boexfl` + `boettp` ).\n\n#### env.isBoeCN()\n\nWhether it is `Boe` environment ( `boe` ).\n\n#### env.isBoeI18N()\n\nWhether it is `Boe` environment ( `boei18n` ).\n\n#### env.isBoeXfl()\n\nWhether it is `Boe` environment ( `boexfl` )\n\n#### env.isBoeTTP()\n\nWhether it is `Boe` environment ( `boettp` )\n\n#### env.isPPE()\n\nWhether it is `PPE` environment.\n\n#### env.isEdgeEnvironment()\n\nUnknown.\n\n#### env.isProduct()\n\nWhether it is `Prod` environment.\n\n### PSM + Cluster + IDC + Env + Region + Stage + VDC + VRegion\n\n#### env.getPSM()\n\nService `PSM`.\n\n#### env.setPSM(psm)\n\nSet service `PSM`.\n\n#### env.getCluster()\n\nService `Cluster`.\n\n#### env.setCluster(cluster)\n\nSet service `Cluster`.\n\n#### env.getIDC()\n\nService `IDC`.\n\n#### env.getIDCFromHost(ip)\n\nResolve service `IDC` from `IP`.\n\nTips: When `@byted-service/env` is initializing, it will load the data of the `IDC` network segment from the following files in sequence:\n\n-   [/opt/tmp/consul_agent/netsegment](#opttmpconsul_agentnetsegment) ( `IPv4` )\n-   [/opt/tiger/chadc/netsegment](#opttigerchadcnetsegment) ( `IPv4` )\n-   [/opt/tmp/consul_agent/netsegment6](#opttmpconsul_agentnetsegment6) ( `IPv6` )\n-   [/opt/tiger/chadc/netsegment6](#opttigerchadcnetsegment6) ( `IPv6` )\n\n#### env.getIDCList()\n\nService `IDC` list.\n\n#### env.setIDC(v)\n\nSet service `IDC`.\n\n#### env.setIDCFile(file)\n\nSet `IDC` network segment file (`IPv4`).\n\n#### env.setIpv6File(file)\n\nSet `IDC` network segment file (`IPv6`).\n\n#### env.getEnv()\n\nService `Env`, see [Env-based traffic scheduling](https://bytedance.feishu.cn/docs/ws0Kg2Q539Rzqc18VFc98f).\n\n#### env.isValidEnv()\n\nCheck whether the service `Env` is valid, see [Env naming specification ( final ) > Specific details](https://bytedance.feishu.cn/docs/doccn2zIJMueBhHi4kjrYKqaVYc#BTZPX3).\n\n#### env.getRegion()\n\nService `Region`.\n\n#### env.getRegionFromIDC(idc)\n\nGet service `Region` from service `IDC`.\n\nTips: When `@byted-service/env` is initializing, it will load the data of the `Region` from the following files in sequence:\n\n-   [/opt/tiger/chadc/region.json](#opttigerchadcregionjson)\n\n#### env.setRegionFile(file)\n\nSet `Region` file.\n\n#### env.getStage()\n\nService `Stage`.\n\n#### env.getVRegionFromVDC(vdc)\n\nGet service `VRegion` from service `VDC`.\n\n#### env.getCurrentVRegion()\n\nService `VRegion`.\n\n#### env.getVRegionFromHost(ip)\n\nResolve service `VRegion` from `IP`.\n\n#### env.getGovernanceVRegionFromVDC(vdc)\n\nGet service `VRegion` by real governace rules from service `VDC`.\n\n### TikTok IDC/Region information and related helper functions\n\n#### env.tt.VDC\n\ndefinition of vDC used by TikTok\n\n#### env.tt.VREGION\n\ndefinition of vRegion used by TikTok\n\n#### env.tt.TT_VGEO\n\ndefinition of vGeo used by TikTok\n\n#### env.tt.getVDC()\n\nget current vDC, environment not used by TikTok will return env.tt.VDC.VDC_UNKNOWN (\"-\")\n\n#### env.tt.getVRegion()\n\nget current vRegion, environment not used by TikTok will return env.tt.VREGION.VREGION_UNKNOWN (\"-\")\n\n#### env.tt.getVGeo()\n\nget current vGeo, environment not used  by TikTok or not belong to any vGeo will return env.tt.VGEO.VGEO_UNKNOWN (\"-\")\n\n获取当前 vGeo，非 TikTok 使用或者不属于任何 vGeo 的环境会返回 env.tt.VGEO.VGEO_UNKNOWN (\"-\")\n\n#### env.tt.isVGeoUS()\n\n判断当前环境是否属于 US 的 vGeo\n\n#### env.tt.isVGeoEU()\n\n判断当前环境是否属于 US 的 vGeo\n\n#### env.tt.isTexasRegion(regionCode: string)\n\n判断一个 regionCode 是否属于 Project Texas\n\n#### env.tt.isCloverRegion(regionCode: string)\n\n判断一个 regionCode 是否属于 Project Clover\n\n### Machine / Container Information\n\n#### env.getHostIP()\n\nMachine / container `IP` address, compatibility interface, return `IPv4` first, followed by `IPv6`.\n\n#### env.getHostIPV4()\n\nMachine / container `IPv4` address.\n\n#### env.getHostIPV6()\n\nMachine / container `IPv6` address.\n\n#### env.getIPv4()\n\nMachine / container `IPv4` address.\n\n#### env.getIPv6()\n\nMachine / container `IPv6` address.\n\n#### env.getIP()\n\nMachine / container `IP` address, return `IPv6` first, followed by `IPv4`.\n\n#### env.getIPStr()\n\nSee [env.getIP()](#envgetip).\n\n#### env.hasIPv4()\n\nDoes the machine / container have an `IPv4` address.\n\n#### env.hasIPv6()\n\nDoes the machine / container have an `IPv6` address.\n\n#### env.isDualStack()\n\nWhether the machine / container is `dual stack`, that is, there are both `IPv4` and `IPv6` addresses.\n\n#### env.isIPv4Only()\n\nWhether the machine / container is `IPv4 only`, that is, there are only `IPv4` addresses.\n\n#### env.isIPv6Only()\n\nWhether the machine / container is `IPv6 only`, that is, there are only `IPv6` addresses.\n\n#### env.getTCEServicePort()\n\nThe `primary` port configured by the user on the `TCE` platform.\n\n#### env.getTCEDebugPort()\n\nThe `debug` port configured by the user on the `TCE` platform.\n\n#### env.isInTCE()\n\nWhether it is in the `TCE` container.\n\n#### env.getPodName()\n\nThe `Pod` name of the `TCE` container.\n\n#### env.getImageVersion()\n\nThe `tag` of `TCE` image.\n\n#### env.getCloudEnv()\n\nThe `CloudEnv` of container,\n\n#### env.inVolcanoCloud()\n\nWhether it is in the `Volcano Cloud`.\n\n#### env.isCloudIDE()\n\nIs it a Cloud IDE environment.\n\n### Other\n\n#### env.init()\n\nInitialize `@byted-service/env`. By default, all `API`s have different levels of caching mechanism. Therefore, after modifying environment variables, you need to call this method to reinitialize `@byted-service/env`.\n\n#### env.defaultPSM\n\nService `PSM` default value, the value is `-`.\n\n#### env.defaultCluster\n\nService `Cluster` default value, the value is `default`.\n\n#### env.defaultIDC\n\nService `IDC` default value, the value is empty string.\n\n#### env.defaultEnv\n\nService `Env` default value, the value is `prod`.\n\n#### env.defaultStage\n\nService `Stage` default value, the value is `-`.\n\n#### env.defaultPodName\n\nContainer `Pod` name default value, the value is `-`.\n\n#### env.defaultImageVersion\n\nImage `tag` default value, the value is `-`.\n\n#### env.defaultCloudEnv\n\nContainer `CloudEnv` default value, the value is `-`.\n\n#### env.PSMUnknown\n\n#### env.ClusterDefault\n\n#### env.IDC\n\nEnumeration of known service `IDC`.\n\n#### env.REGION\n\nEnumeration of known service `Region`.\n\n#### env.STAGE\n\nEnumeration of known service `Stage`.\n\n#### env.VDC\n\nEnumeration of known service `VDC`.\n\n#### env.VREGION\n\nEnumeration of known service `VRegion`.\n\n## Environment Variables / Configuration Files\n\nThe environment variables used in `@byted-service/env` are as follows:\n\n```sh\nIS_TCE_DOCKER_ENV # Whether it is TCE container environment.\nNODE_ENV # Node.js only environment variable, when it is prod or production, it means the production environment.\n\nLOAD_SERVICE_PSM # Service PSM.\nPSM # Same as LOAD_SERVICE_PSM, but lower priority.\nTCE_PSM # Same as PSM, but lower priority.\nSERVICE_CLUSTER # Service Cluster.\nRUNTIME_IDC_NAME # Service IDC.\nSERVICE_ENV # Service Env.\nTCE_ENV # Same as SERVICE_ENV, but lower priority.\nTCE_STAGE # Service Stage.\n\nMY_HOST_IP # IPv4 of the physical machine where the instance is located.\nMY_HOST_IPV6 # IPv6 of the physical machine where the instance is located.\nTCE_PRIMARY_PORT # The primary port configured by the user on the TCE platform.\nTCE_DEBUG_PORT # The debug port configured by the user on the TCE platform.\n\nIS_PROD_RUNTIME # Whether it is Prod environment. Deprecated.\nTESTING_PREFIX # Unknown.\nIS_EDGE_ENVIRONMENT # Unknown.\nTCE_HOST_ENV # Env of the TCE control plane.\nMY_POD_NAME # Pod name of TCE container.\nCURRENT_VERSION # Tag of TCE image.\n```\n\nSee more environment variables:\n\n-   [TCE > Default Environment Variables of TCE](https://bytedance.feishu.cn/wiki/wikcnR7f17phbl2h7ZVnj4KgRfg).\n-   [FaaS > System default environment variable description](https://bytedance.feishu.cn/wiki/wikcndu0chhW1HyIZ0u4Puu7Cqh).\n\nTips: Some variables are injected at runtime, so they cannot be obtained directly through `echo $XXX`, but can be obtained by the following.\n\n```sh\nps -ef | grep node\n# $pid changed to correspond to the Node.js process pid.\ncat /proc/$pid/environ | tr \"\\0\" \"\\n\" | grep XXX\n```\n\n### /opt/tiger/chadc/netsegment\n\n`IDC` network segment file ( `IPv4` ), see [inf/chadc](https://code.byted.org/inf/chadc/blob/master/netsegment).\n\n### /opt/tmp/consul_agent/netsegment\n\nSee [/opt/tiger/chadc/netsegment](#opttigerchadcnetsegment).\n\n### /opt/tiger/chadc/netsegment6\n\n`IDC` network segment file ( `IPv6` ), see [inf/chadc](https://code.byted.org/inf/chadc/blob/master/netsegment6).\n\n### /opt/tmp/consul_agent/netsegment6\n\nSee [/opt/tiger/chadc/netsegment6](#opttigerchadcnetsegment6).\n\n### /opt/tiger/chadc/region.json\n\n`Region` file, see [inf/chadc](https://code.byted.org/inf/chadc/blob/master/region.json).\n\n## Privatization deployment / DevBox\n\nFor those who need privatization deployment / `DevBox`, you can set environment variables and files as follows.\n\n### Boe / BoeI18N\n\n```sh\n# Whether it is TCE container environment.\nIS_TCE_DOCKER_ENV=1\n# Node.js only environment variable.\n# NODE_ENV=test\n\n# Service PSM.\nTCE_PSM=p.s.m\n# Service Cluster.\nSERVICE_CLUSTER=default\n# Service IDC ( boe means Boe environment, boei18n means BoeI18N environment ).\nRUNTIME_IDC_NAME=boe\n# Service Env ( the default value is prod, If it is a lane, use the lane name ).\nSERVICE_ENV=prod\n# Service Stage.\n# TCE_STAGE=single_dc\n\n# IPv4 of the physical machine where the instance is located.\n# MY_HOST_IP=127.0.0.1\n# IPv6 of the physical machine where the instance is located.\n# MY_HOST_IPV6=::\n# The primary port configured by the user on the TCE platform.\n# TCE_PRIMARY_PORT=3000\n# The debug port configured by the user on the TCE platform.\n# TCE_DEBUG_PORT=8080\n\n# Env of the TCE control plane ( fixed value cannot be modified ).\nTCE_HOST_ENV=boe\n# Pod name of TCE container.\n# MY_POD_NAME=pod-xxx\n# Tag of TCE image.\n# CURRENT_VERSION=123456\n```\n\n-   [/opt/tiger/chadc/netsegment](#opttigerchadcnetsegment): Optional, `IDC` network segment file ( `IPv4` ).\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n-   [/opt/tiger/chadc/netsegment6](#opttigerchadcnetsegment6): Optional, `IDC` network segment file ( `IPv6` ).\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n-   [/opt/tiger/chadc/region.json](#opttigerchadcregionjson): Optional, `Region` file.\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n\n### PPE\n\n```sh\n# Whether it is TCE container environment.\nIS_TCE_DOCKER_ENV=1\n# Node.js only environment variable ( the PPE environment is the same as the Prod environment, both are prod ).\n# NODE_ENV=prod\n\n# Service PSM.\nTCE_PSM=p.s.m\n# Service Cluster.\nSERVICE_CLUSTER=default\n# Service IDC ( lf means langfang machine room, you can fill in by yourself ).\nRUNTIME_IDC_NAME=lf\n# Service Env ( PPE plane name ).\nSERVICE_ENV=ppe_xxx\n# Service Stage.\n# TCE_STAGE=single_dc\n\n# IPv4 of the physical machine where the instance is located.\n# MY_HOST_IP=127.0.0.1\n# IPv6 of the physical machine where the instance is located.\n# MY_HOST_IPV6=::\n# The primary port configured by the user on the TCE platform.\n# TCE_PRIMARY_PORT=3000\n# The debug port configured by the user on the TCE platform.\n# TCE_DEBUG_PORT=8080\n\n# Env of the TCE control plane ( fixed value cannot be modified ).\nTCE_HOST_ENV=ppe\n# Pod name of TCE container.\n# MY_POD_NAME=pod-xxx\n# Tag of TCE image.\n# CURRENT_VERSION=123456\n```\n\n-   [/opt/tiger/chadc/netsegment](#opttigerchadcnetsegment): Optional, `IDC` network segment file ( `IPv4` ).\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n-   [/opt/tiger/chadc/netsegment6](#opttigerchadcnetsegment6): Optional, `IDC` network segment file ( `IPv6` ).\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n-   [/opt/tiger/chadc/region.json](#opttigerchadcregionjson): Optional, `Region` file.\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n\n### Prod\n\n```sh\n# Whether it is TCE container environment.\nIS_TCE_DOCKER_ENV=1\n# Node.js only environment variable.\n# NODE_ENV=prod\n\n# Service PSM.\nTCE_PSM=p.s.m\n# Service Cluster.\nSERVICE_CLUSTER=default\n# Service IDC ( lf means langfang machine room, you can fill in by yourself ).\nRUNTIME_IDC_NAME=lf\n# Service Env ( fixed value cannot be modified ).\nSERVICE_ENV=prod\n# Service Stage.\n# TCE_STAGE=single_dc\n\n# IPv4 of the physical machine where the instance is located.\n# MY_HOST_IP=127.0.0.1\n# IPv6 of the physical machine where the instance is located.\n# MY_HOST_IPV6=::\n# The primary port configured by the user on the TCE platform.\n# TCE_PRIMARY_PORT=3000\n# The debug port configured by the user on the TCE platform.\n# TCE_DEBUG_PORT=8080\n\n# Env of the TCE control plane ( fixed value cannot be modified ).\n# TCE_HOST_ENV=online\n# Pod name of TCE container.\n# MY_POD_NAME=pod-xxx\n# Tag of TCE image.\n# CURRENT_VERSION=123456\n```\n\n-   [/opt/tiger/chadc/netsegment](#opttigerchadcnetsegment): Optional, `IDC` network segment file ( `IPv4` ).\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n-   [/opt/tiger/chadc/netsegment6](#opttigerchadcnetsegment6): Optional, `IDC` network segment file ( `IPv6` ).\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n-   [/opt/tiger/chadc/region.json](#opttigerchadcregionjson): Optional, `Region` file.\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n\n## Documents\n\n-   [TCE > Default Environment Variables of TCE](https://bytedance.feishu.cn/wiki/wikcnR7f17phbl2h7ZVnj4KgRfg).\n-   [FaaS > System default environment variable description](https://bytedance.feishu.cn/wiki/wikcndu0chhW1HyIZ0u4Puu7Cqh).\n-   [How to judge the deployment environment > Server](https://bytedance.feishu.cn/wiki/wikcnmVz29FwukFO4Ux1Rtmc23c#sxJRso).\n"},"1.17.14":{"_npmVersion":"lerna/undefined/node@v18.20.4+x64 (linux)","main":"index.js","files":["lib","index.js","index.d.ts"],"maintainers":[{"name":"liyubei","avatar":"https://s3-fs.pstatp.com/static-resource/v1/bf5207f4-07f4-4c43-9004-b01af1aff365~?image_size=72x72&cut_type=&quality=&format=png&sticker_format=.webp","email":"liyubei@bytedance.com"},{"avatar":"","email":"nodejs-team@bnpm.com","name":"nodejs-team"},{"email":"ouyangyadong@bytedance.com","name":"ouyangyadong","avatar":"https://s1-fs.pstatp.com/static-resource/v1/d27d000e276d58ace3df~?image_size=72x72&cut_type=&quality=&format=png&sticker_format=.webp"},{"email":"qizihan@bytedance.com","name":"qizi","avatar":"https://ee.bytedance.net/ratak/employees/3863359/avatar/?format=noop.png"},{"name":"shenchen","avatar":"https://s1-fs.pstatp.com/static-resource/v1/ef40014f9ad1f7011ec~?image_size=72x72&cut_type=&quality=&format=png&sticker_format=.webp","email":"shenchen@bytedance.com"},{"name":"xieda","avatar":"https://s1-fs.pstatp.com/static-resource/v1/a339a912-f731-4fe7-9e51-d91e1871180g~?image_size=240x240&cut_type=&quality=&format=image&sticker_format=.webp","email":"xieda@bytedance.com"},{"email":"yeyuanfeng@bytedance.com","name":"yeyuanfeng","avatar":"https://s3-fs.pstatp.com/static-resource/v1/43d80005ffccbded38e9~?image_size=72x72&cut_type=&quality=&format=png&sticker_format=.webp"}],"readmeFilename":"README.en.md","readme":"# @byted-service/env\n\n[![bnpm](https://web-bnpm.byted.org/badge/v/@byted-service/env.svg?style=flat-square)](https://web-bnpm.byted.org/package/@byted-service/env) [![download](https://2y8ngapf.fn.bytedance.net/d?p=@byted-service/env)](https://web-bnpm.byted.org/package/@byted-service/env)\n\n[简体中文](https://code.byted.org/nodejs/byted-service/blob/master/packages/env/README.md) | [English](https://code.byted.org/nodejs/byted-service/blob/master/packages/env/README.en.md) | [CHANGELOG](https://code.byted.org/nodejs/byted-service/blob/master/packages/env/CHANGELOG.md)\n\n**@byted-service/env** is the basic environment variable `SDK` on the `Node.js` side of the company. It is widely integrated in `@byted-service/xxx`. The main data sources are as follows:\n\n-   [gopkg/env](https://code.byted.org/gopkg/env).\n-   [TCE > Default Environment Variables of TCE](https://bytedance.feishu.cn/wiki/wikcnR7f17phbl2h7ZVnj4KgRfg).\n-   [FaaS > System default environment variable description](https://bytedance.feishu.cn/wiki/wikcndu0chhW1HyIZ0u4Puu7Cqh).\n-   (TikTok only) [tiktok/region_lib](https://code.byted.org/tiktok/region_lib) [Doc](https://bytedance.feishu.cn/wiki/wikcn4YwQncW4hTDEfCQZEizo9c).\n\n## Installation\n\n```bash\nnpm install @byted-service/env --registry=http://bnpm.byted.org\n```\n\n## Quick Start\n\n```ts\nimport { isProd } from '@byted-service/env';\n\nisProd();\n```\n\n## API\n\n### Runtime Environment\n\n#### env.isProd()\n\nWhether it is production environment. Compared with `env.isProduct()`, it also supports `NODE_ENV`.\n\n#### env.isTest()\n\nWhether it is test environment ( `Boe` environment is also considered test environment ).\n\n#### env.isTesting()\n\nUnknown.\n\n#### env.isBoe()\n\nWhether it is `Boe` environment ( `boe` + `boei18n` + `boexfl` + `boettp` ).\n\n#### env.isBoeCN()\n\nWhether it is `Boe` environment ( `boe` ).\n\n#### env.isBoeI18N()\n\nWhether it is `Boe` environment ( `boei18n` ).\n\n#### env.isBoeXfl()\n\nWhether it is `Boe` environment ( `boexfl` )\n\n#### env.isBoeTTP()\n\nWhether it is `Boe` environment ( `boettp` )\n\n#### env.isPPE()\n\nWhether it is `PPE` environment.\n\n#### env.isEdgeEnvironment()\n\nUnknown.\n\n#### env.isProduct()\n\nWhether it is `Prod` environment.\n\n### PSM + Cluster + IDC + Env + Region + Stage + VDC + VRegion\n\n#### env.getPSM()\n\nService `PSM`.\n\n#### env.setPSM(psm)\n\nSet service `PSM`.\n\n#### env.getCluster()\n\nService `Cluster`.\n\n#### env.setCluster(cluster)\n\nSet service `Cluster`.\n\n#### env.getIDC()\n\nService `IDC`.\n\n#### env.getIDCFromHost(ip)\n\nResolve service `IDC` from `IP`.\n\nTips: When `@byted-service/env` is initializing, it will load the data of the `IDC` network segment from the following files in sequence:\n\n-   [/opt/tmp/consul_agent/netsegment](#opttmpconsul_agentnetsegment) ( `IPv4` )\n-   [/opt/tiger/chadc/netsegment](#opttigerchadcnetsegment) ( `IPv4` )\n-   [/opt/tmp/consul_agent/netsegment6](#opttmpconsul_agentnetsegment6) ( `IPv6` )\n-   [/opt/tiger/chadc/netsegment6](#opttigerchadcnetsegment6) ( `IPv6` )\n\n#### env.getIDCList()\n\nService `IDC` list.\n\n#### env.setIDC(v)\n\nSet service `IDC`.\n\n#### env.setIDCFile(file)\n\nSet `IDC` network segment file (`IPv4`).\n\n#### env.setIpv6File(file)\n\nSet `IDC` network segment file (`IPv6`).\n\n#### env.getEnv()\n\nService `Env`, see [Env-based traffic scheduling](https://bytedance.feishu.cn/docs/ws0Kg2Q539Rzqc18VFc98f).\n\n#### env.isValidEnv()\n\nCheck whether the service `Env` is valid, see [Env naming specification ( final ) > Specific details](https://bytedance.feishu.cn/docs/doccn2zIJMueBhHi4kjrYKqaVYc#BTZPX3).\n\n#### env.getRegion()\n\nService `Region`.\n\n#### env.getRegionFromIDC(idc)\n\nGet service `Region` from service `IDC`.\n\nTips: When `@byted-service/env` is initializing, it will load the data of the `Region` from the following files in sequence:\n\n-   [/opt/tiger/chadc/region.json](#opttigerchadcregionjson)\n\n#### env.setRegionFile(file)\n\nSet `Region` file.\n\n#### env.getStage()\n\nService `Stage`.\n\n#### env.getVRegionFromVDC(vdc)\n\nGet service `VRegion` from service `VDC`.\n\n#### env.getCurrentVRegion()\n\nService `VRegion`.\n\n#### env.getVRegionFromHost(ip)\n\nResolve service `VRegion` from `IP`.\n\n#### env.getGovernanceVRegionFromVDC(vdc)\n\nGet service `VRegion` by real governace rules from service `VDC`.\n\n### TikTok IDC/Region information and related helper functions\n\n#### env.tt.VDC\n\ndefinition of vDC used by TikTok\n\n#### env.tt.VREGION\n\ndefinition of vRegion used by TikTok\n\n#### env.tt.VGEO\n\ndefinition of vGeo used by TikTok\n\n#### env.tt.getVDC()\n\nget current vDC, environment not used by TikTok will return env.tt.VDC.VDC_UNKNOWN (\"-\")\n\n#### env.tt.getVRegion()\n\nget current vRegion, environment not used by TikTok will return env.tt.VREGION.VREGION_UNKNOWN (\"-\")\n\n#### env.tt.getVGeo()\n\nget current vGeo, environment not used  by TikTok or not belong to any vGeo will return env.tt.VGEO.VGEO_UNKNOWN (\"-\")\n\n#### env.tt.isVGeoUS()\n\ncheck current environment belongs to vGeo of US\n\n#### env.tt.isVGeoEU()\n\ncheck current environment belongs to vGeo of EU\n\n#### env.tt.isTexasRegion(regionCode: string)\n\ncheck regionCode belongs to Project Texas\n\n#### env.tt.isCloverRegion(regionCode: string)\n\ncheck regionCode belongs to  Project Clover\n\n#### env.tt.isROWRegion(regionCode: string)\n\ncheck regionCode belongs to  ROW\n\n#### env.tt.getComplianceRegion(regionCode: string)\n\ncheck Region Code ComplianceRegionType（ ROW | Texas | Clover | - ）\n\n### Machine / Container Information\n\n#### env.getHostIP()\n\nMachine / container `IP` address, compatibility interface, return `IPv4` first, followed by `IPv6`.\n\n#### env.getHostIPV4()\n\nMachine / container `IPv4` address.\n\n#### env.getHostIPV6()\n\nMachine / container `IPv6` address.\n\n#### env.getIPv4()\n\nMachine / container `IPv4` address.\n\n#### env.getIPv6()\n\nMachine / container `IPv6` address.\n\n#### env.getIP()\n\nMachine / container `IP` address, return `IPv6` first, followed by `IPv4`.\n\n#### env.getIPStr()\n\nSee [env.getIP()](#envgetip).\n\n#### env.hasIPv4()\n\nDoes the machine / container have an `IPv4` address.\n\n#### env.hasIPv6()\n\nDoes the machine / container have an `IPv6` address.\n\n#### env.isDualStack()\n\nWhether the machine / container is `dual stack`, that is, there are both `IPv4` and `IPv6` addresses.\n\n#### env.isIPv4Only()\n\nWhether the machine / container is `IPv4 only`, that is, there are only `IPv4` addresses.\n\n#### env.isIPv6Only()\n\nWhether the machine / container is `IPv6 only`, that is, there are only `IPv6` addresses.\n\n#### env.getTCEServicePort()\n\nThe `primary` port configured by the user on the `TCE` platform.\n\n#### env.getTCEDebugPort()\n\nThe `debug` port configured by the user on the `TCE` platform.\n\n#### env.TCEServicePortRegistered()\n\nReturn the access port corresponding to the `primary` port configured by the user on the `TCE` platform.\n\n#### env.TCEDebugPortRegistered()\n\nReturn the access port corresponding to the `debug` port configured by the user on the `TCE` platform.\n\n#### env.isInTCE()\n\nWhether it is in the `TCE` container.\n\n#### env.getPodName()\n\nThe `Pod` name of the `TCE` container.\n\n#### env.getImageVersion()\n\nThe `tag` of `TCE` image.\n\n#### env.getCloudEnv()\n\nThe `CloudEnv` of container,\n\n#### env.inVolcanoCloud()\n\nWhether it is in the `Volcano Cloud`.\n\n#### env.isHostNetwork()\n\nWhether the network mode set to host or autohost mode\n\n#### env.isCloudIDE()\n\nIs it a Cloud IDE environment.\n\n### Other\n\n#### env.init()\n\nInitialize `@byted-service/env`. By default, all `API`s have different levels of caching mechanism. Therefore, after modifying environment variables, you need to call this method to reinitialize `@byted-service/env`.\n\n#### env.defaultPSM\n\nService `PSM` default value, the value is `-`.\n\n#### env.defaultCluster\n\nService `Cluster` default value, the value is `default`.\n\n#### env.defaultIDC\n\nService `IDC` default value, the value is empty string.\n\n#### env.defaultEnv\n\nService `Env` default value, the value is `prod`.\n\n#### env.defaultStage\n\nService `Stage` default value, the value is `-`.\n\n#### env.defaultPodName\n\nContainer `Pod` name default value, the value is `-`.\n\n#### env.defaultImageVersion\n\nImage `tag` default value, the value is `-`.\n\n#### env.defaultCloudEnv\n\nContainer `CloudEnv` default value, the value is `-`.\n\n#### env.PSMUnknown\n\n#### env.ClusterDefault\n\n#### env.IDC\n\nEnumeration of known service `IDC`.\n\n#### env.REGION\n\nEnumeration of known service `Region`.\n\n#### env.STAGE\n\nEnumeration of known service `Stage`.\n\n#### env.VDC\n\nEnumeration of known service `VDC`.\n\n#### env.VREGION\n\nEnumeration of known service `VRegion`.\n\n## Environment Variables / Configuration Files\n\nThe environment variables used in `@byted-service/env` are as follows:\n\n```sh\nIS_TCE_DOCKER_ENV # Whether it is TCE container environment.\nNODE_ENV # Node.js only environment variable, when it is prod or production, it means the production environment.\n\nLOAD_SERVICE_PSM # Service PSM.\nPSM # Same as LOAD_SERVICE_PSM, but lower priority.\nTCE_PSM # Same as PSM, but lower priority.\nSERVICE_CLUSTER # Service Cluster.\nRUNTIME_IDC_NAME # Service IDC.\nSERVICE_ENV # Service Env.\nTCE_ENV # Same as SERVICE_ENV, but lower priority.\nTCE_STAGE # Service Stage.\n\nMY_HOST_IP # IPv4 of the physical machine where the instance is located.\nMY_HOST_IPV6 # IPv6 of the physical machine where the instance is located.\nTCE_PRIMARY_PORT # The primary port configured by the user on the TCE platform.\nTCE_DEBUG_PORT # The debug port configured by the user on the TCE platform.\n\nIS_PROD_RUNTIME # Whether it is Prod environment. Deprecated.\nTESTING_PREFIX # Unknown.\nIS_EDGE_ENVIRONMENT # Unknown.\nTCE_HOST_ENV # Env of the TCE control plane.\nMY_POD_NAME # Pod name of TCE container.\nCURRENT_VERSION # Tag of TCE image.\n```\n\nSee more environment variables:\n\n-   [TCE > Default Environment Variables of TCE](https://bytedance.feishu.cn/wiki/wikcnR7f17phbl2h7ZVnj4KgRfg).\n-   [FaaS > System default environment variable description](https://bytedance.feishu.cn/wiki/wikcndu0chhW1HyIZ0u4Puu7Cqh).\n\nTips: Some variables are injected at runtime, so they cannot be obtained directly through `echo $XXX`, but can be obtained by the following.\n\n```sh\nps -ef | grep node\n# $pid changed to correspond to the Node.js process pid.\ncat /proc/$pid/environ | tr \"\\0\" \"\\n\" | grep XXX\n```\n\n### /opt/tiger/chadc/netsegment\n\n`IDC` network segment file ( `IPv4` ), see [inf/chadc](https://code.byted.org/inf/chadc/blob/master/netsegment).\n\n### /opt/tmp/consul_agent/netsegment\n\nSee [/opt/tiger/chadc/netsegment](#opttigerchadcnetsegment).\n\n### /opt/tiger/chadc/netsegment6\n\n`IDC` network segment file ( `IPv6` ), see [inf/chadc](https://code.byted.org/inf/chadc/blob/master/netsegment6).\n\n### /opt/tmp/consul_agent/netsegment6\n\nSee [/opt/tiger/chadc/netsegment6](#opttigerchadcnetsegment6).\n\n### /opt/tiger/chadc/region.json\n\n`Region` file, see [inf/chadc](https://code.byted.org/inf/chadc/blob/master/region.json).\n\n## Privatization deployment / DevBox\n\nFor those who need privatization deployment / `DevBox`, you can set environment variables and files as follows.\n\n### Boe / BoeI18N\n\n```sh\n# Whether it is TCE container environment.\nIS_TCE_DOCKER_ENV=1\n# Node.js only environment variable.\n# NODE_ENV=test\n\n# Service PSM.\nTCE_PSM=p.s.m\n# Service Cluster.\nSERVICE_CLUSTER=default\n# Service IDC ( boe means Boe environment, boei18n means BoeI18N environment ).\nRUNTIME_IDC_NAME=boe\n# Service Env ( the default value is prod, If it is a lane, use the lane name ).\nSERVICE_ENV=prod\n# Service Stage.\n# TCE_STAGE=single_dc\n\n# IPv4 of the physical machine where the instance is located.\n# MY_HOST_IP=127.0.0.1\n# IPv6 of the physical machine where the instance is located.\n# MY_HOST_IPV6=::\n# The primary port configured by the user on the TCE platform.\n# TCE_PRIMARY_PORT=3000\n# The debug port configured by the user on the TCE platform.\n# TCE_DEBUG_PORT=8080\n\n# Env of the TCE control plane ( fixed value cannot be modified ).\nTCE_HOST_ENV=boe\n# Pod name of TCE container.\n# MY_POD_NAME=pod-xxx\n# Tag of TCE image.\n# CURRENT_VERSION=123456\n```\n\n-   [/opt/tiger/chadc/netsegment](#opttigerchadcnetsegment): Optional, `IDC` network segment file ( `IPv4` ).\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n-   [/opt/tiger/chadc/netsegment6](#opttigerchadcnetsegment6): Optional, `IDC` network segment file ( `IPv6` ).\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n-   [/opt/tiger/chadc/region.json](#opttigerchadcregionjson): Optional, `Region` file.\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n\n### PPE\n\n```sh\n# Whether it is TCE container environment.\nIS_TCE_DOCKER_ENV=1\n# Node.js only environment variable ( the PPE environment is the same as the Prod environment, both are prod ).\n# NODE_ENV=prod\n\n# Service PSM.\nTCE_PSM=p.s.m\n# Service Cluster.\nSERVICE_CLUSTER=default\n# Service IDC ( lf means langfang machine room, you can fill in by yourself ).\nRUNTIME_IDC_NAME=lf\n# Service Env ( PPE plane name ).\nSERVICE_ENV=ppe_xxx\n# Service Stage.\n# TCE_STAGE=single_dc\n\n# IPv4 of the physical machine where the instance is located.\n# MY_HOST_IP=127.0.0.1\n# IPv6 of the physical machine where the instance is located.\n# MY_HOST_IPV6=::\n# The primary port configured by the user on the TCE platform.\n# TCE_PRIMARY_PORT=3000\n# The debug port configured by the user on the TCE platform.\n# TCE_DEBUG_PORT=8080\n\n# Env of the TCE control plane ( fixed value cannot be modified ).\nTCE_HOST_ENV=ppe\n# Pod name of TCE container.\n# MY_POD_NAME=pod-xxx\n# Tag of TCE image.\n# CURRENT_VERSION=123456\n```\n\n-   [/opt/tiger/chadc/netsegment](#opttigerchadcnetsegment): Optional, `IDC` network segment file ( `IPv4` ).\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n-   [/opt/tiger/chadc/netsegment6](#opttigerchadcnetsegment6): Optional, `IDC` network segment file ( `IPv6` ).\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n-   [/opt/tiger/chadc/region.json](#opttigerchadcregionjson): Optional, `Region` file.\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n\n### Prod\n\n```sh\n# Whether it is TCE container environment.\nIS_TCE_DOCKER_ENV=1\n# Node.js only environment variable.\n# NODE_ENV=prod\n\n# Service PSM.\nTCE_PSM=p.s.m\n# Service Cluster.\nSERVICE_CLUSTER=default\n# Service IDC ( lf means langfang machine room, you can fill in by yourself ).\nRUNTIME_IDC_NAME=lf\n# Service Env ( fixed value cannot be modified ).\nSERVICE_ENV=prod\n# Service Stage.\n# TCE_STAGE=single_dc\n\n# IPv4 of the physical machine where the instance is located.\n# MY_HOST_IP=127.0.0.1\n# IPv6 of the physical machine where the instance is located.\n# MY_HOST_IPV6=::\n# The primary port configured by the user on the TCE platform.\n# TCE_PRIMARY_PORT=3000\n# The debug port configured by the user on the TCE platform.\n# TCE_DEBUG_PORT=8080\n\n# Env of the TCE control plane ( fixed value cannot be modified ).\n# TCE_HOST_ENV=online\n# Pod name of TCE container.\n# MY_POD_NAME=pod-xxx\n# Tag of TCE image.\n# CURRENT_VERSION=123456\n```\n\n-   [/opt/tiger/chadc/netsegment](#opttigerchadcnetsegment): Optional, `IDC` network segment file ( `IPv4` ).\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n-   [/opt/tiger/chadc/netsegment6](#opttigerchadcnetsegment6): Optional, `IDC` network segment file ( `IPv6` ).\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n-   [/opt/tiger/chadc/region.json](#opttigerchadcregionjson): Optional, `Region` file.\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n\n## Documents\n\n-   [TCE > Default Environment Variables of TCE](https://bytedance.feishu.cn/wiki/wikcnR7f17phbl2h7ZVnj4KgRfg).\n-   [FaaS > System default environment variable description](https://bytedance.feishu.cn/wiki/wikcndu0chhW1HyIZ0u4Puu7Cqh).\n-   [How to judge the deployment environment > Server](https://bytedance.feishu.cn/wiki/wikcnmVz29FwukFO4Ux1Rtmc23c#sxJRso).\n","_id":"@byted-service/env@1.17.14","_npmUser":{"email":"nodejs-team@bytedance.com","name":"nodejs-team"},"description":"The basic environment variable SDK for Node.js","types":"index.d.ts","scripts":{"prepublish":"npm run build","test":"ROUTE_IP=10.225.130.44 RUNTIME_IDC_NAME=boe ../../node_modules/.bin/jest --config ./jest.config.json --coverage --env=node","build":"rm -rf lib && tsc"},"author":"","name":"@byted-service/env","gitHead":"9c4aa42d1208d057ac0b391c57d3f5f742c7dbfd","license":"MIT","_nodeVersion":"18.20.4","dependencies":{"tslib":"^2.6.3"},"dist":{"tarball":"https://bnpm.byted.org/@byted-service/env/-/env-1.17.14.tgz","size":42226,"unpackedSize":191572,"fileCount":42,"integrity":"sha512-BGRG9KQkOKdiETFFT47HbXPE+fN0MYWND0yB7VsqzsjC1XVtjaqNo1gVkw7kBXaE4axAQ59O6HIOSg+hG2g4DQ==","shasum":"554295c8d6e9ca7f5f9da40f1866d1a4a855bdc4"},"version":"1.17.14","repository":{"url":"https://code.byted.org/nodejs/byted-service","type":"git"}},"1.17.5":{"types":"index.d.ts","description":"The basic environment variable SDK for Node.js","dependencies":{"tslib":"^1.9.3"},"author":"","main":"index.js","_npmUser":{"name":"nodejs-team","email":"nodejs-team@bytedance.com"},"name":"@byted-service/env","license":"MIT","gitHead":"0511ba59547baefe9ffc85c6032277d14992ac7d","_nodeVersion":"14.21.3","repository":{"url":"https://code.byted.org/nodejs/byted-service","type":"git"},"scripts":{"build":"rm -rf lib && tsc","prepublish":"npm run build","test":"ROUTE_IP=10.225.130.44 RUNTIME_IDC_NAME=boe ../../node_modules/.bin/jest --config ./jest.config.json --coverage --env=node"},"readme":"# @byted-service/env\n\n[![bnpm](https://web-bnpm.byted.org/badge/v/@byted-service/env.svg?style=flat-square)](https://web-bnpm.byted.org/package/@byted-service/env) [![download](https://2y8ngapf.fn.bytedance.net/d?p=@byted-service/env)](https://web-bnpm.byted.org/package/@byted-service/env)\n\n[简体中文](https://code.byted.org/nodejs/byted-service/blob/master/packages/env/README.md) | [English](https://code.byted.org/nodejs/byted-service/blob/master/packages/env/README.en.md) | [CHANGELOG](https://code.byted.org/nodejs/byted-service/blob/master/packages/env/CHANGELOG.md)\n\n**@byted-service/env** is the basic environment variable `SDK` on the `Node.js` side of the company. It is widely integrated in `@byted-service/xxx`. The main data sources are as follows:\n\n-   [gopkg/env](https://code.byted.org/gopkg/env).\n-   [TCE > Default Environment Variables of TCE](https://bytedance.feishu.cn/wiki/wikcnR7f17phbl2h7ZVnj4KgRfg).\n-   [FaaS > System default environment variable description](https://bytedance.feishu.cn/wiki/wikcndu0chhW1HyIZ0u4Puu7Cqh).\n-   (TikTok only) [tiktok/region_lib](https://code.byted.org/tiktok/region_lib) [Doc](https://bytedance.feishu.cn/wiki/wikcn4YwQncW4hTDEfCQZEizo9c).\n\n## Installation\n\n```bash\nnpm install @byted-service/env --registry=http://bnpm.byted.org\n```\n\n## Quick Start\n\n```ts\nimport { isProd } from '@byted-service/env';\n\nisProd();\n```\n\n## API\n\n### Runtime Environment\n\n#### env.isProd()\n\nWhether it is production environment. Compared with `env.isProduct()`, it also supports `NODE_ENV`.\n\n#### env.isTest()\n\nWhether it is test environment ( `Boe` environment is also considered test environment ).\n\n#### env.isTesting()\n\nUnknown.\n\n#### env.isBoe()\n\nWhether it is `Boe` environment ( `boe` + `boei18n` + `boexfl` + `boettp` ).\n\n#### env.isBoeCN()\n\nWhether it is `Boe` environment ( `boe` ).\n\n#### env.isBoeI18N()\n\nWhether it is `Boe` environment ( `boei18n` ).\n\n#### env.isBoeXfl()\n\nWhether it is `Boe` environment ( `boexfl` )\n\n#### env.isBoeTTP()\n\nWhether it is `Boe` environment ( `boettp` )\n\n#### env.isPPE()\n\nWhether it is `PPE` environment.\n\n#### env.isEdgeEnvironment()\n\nUnknown.\n\n#### env.isProduct()\n\nWhether it is `Prod` environment.\n\n### PSM + Cluster + IDC + Env + Region + Stage + VDC + VRegion\n\n#### env.getPSM()\n\nService `PSM`.\n\n#### env.setPSM(psm)\n\nSet service `PSM`.\n\n#### env.getCluster()\n\nService `Cluster`.\n\n#### env.setCluster(cluster)\n\nSet service `Cluster`.\n\n#### env.getIDC()\n\nService `IDC`.\n\n#### env.getIDCFromHost(ip)\n\nResolve service `IDC` from `IP`.\n\nTips: When `@byted-service/env` is initializing, it will load the data of the `IDC` network segment from the following files in sequence:\n\n-   [/opt/tmp/consul_agent/netsegment](#opttmpconsul_agentnetsegment) ( `IPv4` )\n-   [/opt/tiger/chadc/netsegment](#opttigerchadcnetsegment) ( `IPv4` )\n-   [/opt/tmp/consul_agent/netsegment6](#opttmpconsul_agentnetsegment6) ( `IPv6` )\n-   [/opt/tiger/chadc/netsegment6](#opttigerchadcnetsegment6) ( `IPv6` )\n\n#### env.getIDCList()\n\nService `IDC` list.\n\n#### env.setIDC(v)\n\nSet service `IDC`.\n\n#### env.setIDCFile(file)\n\nSet `IDC` network segment file (`IPv4`).\n\n#### env.setIpv6File(file)\n\nSet `IDC` network segment file (`IPv6`).\n\n#### env.getEnv()\n\nService `Env`, see [Env-based traffic scheduling](https://bytedance.feishu.cn/docs/ws0Kg2Q539Rzqc18VFc98f).\n\n#### env.isValidEnv()\n\nCheck whether the service `Env` is valid, see [Env naming specification ( final ) > Specific details](https://bytedance.feishu.cn/docs/doccn2zIJMueBhHi4kjrYKqaVYc#BTZPX3).\n\n#### env.getRegion()\n\nService `Region`.\n\n#### env.getRegionFromIDC(idc)\n\nGet service `Region` from service `IDC`.\n\nTips: When `@byted-service/env` is initializing, it will load the data of the `Region` from the following files in sequence:\n\n-   [/opt/tiger/chadc/region.json](#opttigerchadcregionjson)\n\n#### env.setRegionFile(file)\n\nSet `Region` file.\n\n#### env.getStage()\n\nService `Stage`.\n\n#### env.getVRegionFromVDC(vdc)\n\nGet service `VRegion` from service `VDC`.\n\n#### env.getCurrentVRegion()\n\nService `VRegion`.\n\n#### env.getVRegionFromHost(ip)\n\nResolve service `VRegion` from `IP`.\n\n#### env.getGovernanceVRegionFromVDC(vdc)\n\nGet service `VRegion` by real governace rules from service `VDC`.\n\n### TikTok IDC/Region information and related helper functions\n\n#### env.tt.VDC\n\ndefinition of vDC used by TikTok\n\n#### env.tt.VREGION\n\ndefinition of vRegion used by TikTok\n\n#### env.tt.VGEO\n\ndefinition of vGeo used by TikTok\n\n#### env.tt.getVDC()\n\nget current vDC, environment not used by TikTok will return env.tt.VDC.VDC_UNKNOWN (\"-\")\n\n#### env.tt.getVRegion()\n\nget current vRegion, environment not used by TikTok will return env.tt.VREGION.VREGION_UNKNOWN (\"-\")\n\n#### env.tt.getVGeo()\n\nget current vGeo, environment not used  by TikTok or not belong to any vGeo will return env.tt.VGEO.VGEO_UNKNOWN (\"-\")\n\n#### env.tt.isVGeoUS()\n\ncheck current environment belongs to vGeo of US\n\n#### env.tt.isVGeoEU()\n\ncheck current environment belongs to vGeo of EU\n\n#### env.tt.isTexasRegion(regionCode: string)\n\ncheck regionCode belongs to Project Texas\n\n#### env.tt.isCloverRegion(regionCode: string)\n\ncheck regionCode belongs to  Project Clover\n\n#### env.tt.isROWRegion(regionCode: string)\n\ncheck regionCode belongs to  ROW\n\n#### env.tt.getComplianceRegion(regionCode: string)\n\ncheck Region Code ComplianceRegionType（ ROW | Texas | Clover | - ）\n\n### Machine / Container Information\n\n#### env.getHostIP()\n\nMachine / container `IP` address, compatibility interface, return `IPv4` first, followed by `IPv6`.\n\n#### env.getHostIPV4()\n\nMachine / container `IPv4` address.\n\n#### env.getHostIPV6()\n\nMachine / container `IPv6` address.\n\n#### env.getIPv4()\n\nMachine / container `IPv4` address.\n\n#### env.getIPv6()\n\nMachine / container `IPv6` address.\n\n#### env.getIP()\n\nMachine / container `IP` address, return `IPv6` first, followed by `IPv4`.\n\n#### env.getIPStr()\n\nSee [env.getIP()](#envgetip).\n\n#### env.hasIPv4()\n\nDoes the machine / container have an `IPv4` address.\n\n#### env.hasIPv6()\n\nDoes the machine / container have an `IPv6` address.\n\n#### env.isDualStack()\n\nWhether the machine / container is `dual stack`, that is, there are both `IPv4` and `IPv6` addresses.\n\n#### env.isIPv4Only()\n\nWhether the machine / container is `IPv4 only`, that is, there are only `IPv4` addresses.\n\n#### env.isIPv6Only()\n\nWhether the machine / container is `IPv6 only`, that is, there are only `IPv6` addresses.\n\n#### env.getTCEServicePort()\n\nThe `primary` port configured by the user on the `TCE` platform.\n\n#### env.getTCEDebugPort()\n\nThe `debug` port configured by the user on the `TCE` platform.\n\n#### env.TCEServicePortRegistered()\n\nReturn the access port corresponding to the `primary` port configured by the user on the `TCE` platform.\n\n#### env.TCEDebugPortRegistered()\n\nReturn the access port corresponding to the `debug` port configured by the user on the `TCE` platform.\n\n#### env.isInTCE()\n\nWhether it is in the `TCE` container.\n\n#### env.getPodName()\n\nThe `Pod` name of the `TCE` container.\n\n#### env.getImageVersion()\n\nThe `tag` of `TCE` image.\n\n#### env.getCloudEnv()\n\nThe `CloudEnv` of container,\n\n#### env.inVolcanoCloud()\n\nWhether it is in the `Volcano Cloud`.\n\n#### env.isHostNetwork()\n\nWhether the network mode set to host or autohost mode\n\n#### env.isCloudIDE()\n\nIs it a Cloud IDE environment.\n\n### Other\n\n#### env.init()\n\nInitialize `@byted-service/env`. By default, all `API`s have different levels of caching mechanism. Therefore, after modifying environment variables, you need to call this method to reinitialize `@byted-service/env`.\n\n#### env.defaultPSM\n\nService `PSM` default value, the value is `-`.\n\n#### env.defaultCluster\n\nService `Cluster` default value, the value is `default`.\n\n#### env.defaultIDC\n\nService `IDC` default value, the value is empty string.\n\n#### env.defaultEnv\n\nService `Env` default value, the value is `prod`.\n\n#### env.defaultStage\n\nService `Stage` default value, the value is `-`.\n\n#### env.defaultPodName\n\nContainer `Pod` name default value, the value is `-`.\n\n#### env.defaultImageVersion\n\nImage `tag` default value, the value is `-`.\n\n#### env.defaultCloudEnv\n\nContainer `CloudEnv` default value, the value is `-`.\n\n#### env.PSMUnknown\n\n#### env.ClusterDefault\n\n#### env.IDC\n\nEnumeration of known service `IDC`.\n\n#### env.REGION\n\nEnumeration of known service `Region`.\n\n#### env.STAGE\n\nEnumeration of known service `Stage`.\n\n#### env.VDC\n\nEnumeration of known service `VDC`.\n\n#### env.VREGION\n\nEnumeration of known service `VRegion`.\n\n## Environment Variables / Configuration Files\n\nThe environment variables used in `@byted-service/env` are as follows:\n\n```sh\nIS_TCE_DOCKER_ENV # Whether it is TCE container environment.\nNODE_ENV # Node.js only environment variable, when it is prod or production, it means the production environment.\n\nLOAD_SERVICE_PSM # Service PSM.\nPSM # Same as LOAD_SERVICE_PSM, but lower priority.\nTCE_PSM # Same as PSM, but lower priority.\nSERVICE_CLUSTER # Service Cluster.\nRUNTIME_IDC_NAME # Service IDC.\nSERVICE_ENV # Service Env.\nTCE_ENV # Same as SERVICE_ENV, but lower priority.\nTCE_STAGE # Service Stage.\n\nMY_HOST_IP # IPv4 of the physical machine where the instance is located.\nMY_HOST_IPV6 # IPv6 of the physical machine where the instance is located.\nTCE_PRIMARY_PORT # The primary port configured by the user on the TCE platform.\nTCE_DEBUG_PORT # The debug port configured by the user on the TCE platform.\n\nIS_PROD_RUNTIME # Whether it is Prod environment. Deprecated.\nTESTING_PREFIX # Unknown.\nIS_EDGE_ENVIRONMENT # Unknown.\nTCE_HOST_ENV # Env of the TCE control plane.\nMY_POD_NAME # Pod name of TCE container.\nCURRENT_VERSION # Tag of TCE image.\n```\n\nSee more environment variables:\n\n-   [TCE > Default Environment Variables of TCE](https://bytedance.feishu.cn/wiki/wikcnR7f17phbl2h7ZVnj4KgRfg).\n-   [FaaS > System default environment variable description](https://bytedance.feishu.cn/wiki/wikcndu0chhW1HyIZ0u4Puu7Cqh).\n\nTips: Some variables are injected at runtime, so they cannot be obtained directly through `echo $XXX`, but can be obtained by the following.\n\n```sh\nps -ef | grep node\n# $pid changed to correspond to the Node.js process pid.\ncat /proc/$pid/environ | tr \"\\0\" \"\\n\" | grep XXX\n```\n\n### /opt/tiger/chadc/netsegment\n\n`IDC` network segment file ( `IPv4` ), see [inf/chadc](https://code.byted.org/inf/chadc/blob/master/netsegment).\n\n### /opt/tmp/consul_agent/netsegment\n\nSee [/opt/tiger/chadc/netsegment](#opttigerchadcnetsegment).\n\n### /opt/tiger/chadc/netsegment6\n\n`IDC` network segment file ( `IPv6` ), see [inf/chadc](https://code.byted.org/inf/chadc/blob/master/netsegment6).\n\n### /opt/tmp/consul_agent/netsegment6\n\nSee [/opt/tiger/chadc/netsegment6](#opttigerchadcnetsegment6).\n\n### /opt/tiger/chadc/region.json\n\n`Region` file, see [inf/chadc](https://code.byted.org/inf/chadc/blob/master/region.json).\n\n## Privatization deployment / DevBox\n\nFor those who need privatization deployment / `DevBox`, you can set environment variables and files as follows.\n\n### Boe / BoeI18N\n\n```sh\n# Whether it is TCE container environment.\nIS_TCE_DOCKER_ENV=1\n# Node.js only environment variable.\n# NODE_ENV=test\n\n# Service PSM.\nTCE_PSM=p.s.m\n# Service Cluster.\nSERVICE_CLUSTER=default\n# Service IDC ( boe means Boe environment, boei18n means BoeI18N environment ).\nRUNTIME_IDC_NAME=boe\n# Service Env ( the default value is prod, If it is a lane, use the lane name ).\nSERVICE_ENV=prod\n# Service Stage.\n# TCE_STAGE=single_dc\n\n# IPv4 of the physical machine where the instance is located.\n# MY_HOST_IP=127.0.0.1\n# IPv6 of the physical machine where the instance is located.\n# MY_HOST_IPV6=::\n# The primary port configured by the user on the TCE platform.\n# TCE_PRIMARY_PORT=3000\n# The debug port configured by the user on the TCE platform.\n# TCE_DEBUG_PORT=8080\n\n# Env of the TCE control plane ( fixed value cannot be modified ).\nTCE_HOST_ENV=boe\n# Pod name of TCE container.\n# MY_POD_NAME=pod-xxx\n# Tag of TCE image.\n# CURRENT_VERSION=123456\n```\n\n-   [/opt/tiger/chadc/netsegment](#opttigerchadcnetsegment): Optional, `IDC` network segment file ( `IPv4` ).\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n-   [/opt/tiger/chadc/netsegment6](#opttigerchadcnetsegment6): Optional, `IDC` network segment file ( `IPv6` ).\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n-   [/opt/tiger/chadc/region.json](#opttigerchadcregionjson): Optional, `Region` file.\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n\n### PPE\n\n```sh\n# Whether it is TCE container environment.\nIS_TCE_DOCKER_ENV=1\n# Node.js only environment variable ( the PPE environment is the same as the Prod environment, both are prod ).\n# NODE_ENV=prod\n\n# Service PSM.\nTCE_PSM=p.s.m\n# Service Cluster.\nSERVICE_CLUSTER=default\n# Service IDC ( lf means langfang machine room, you can fill in by yourself ).\nRUNTIME_IDC_NAME=lf\n# Service Env ( PPE plane name ).\nSERVICE_ENV=ppe_xxx\n# Service Stage.\n# TCE_STAGE=single_dc\n\n# IPv4 of the physical machine where the instance is located.\n# MY_HOST_IP=127.0.0.1\n# IPv6 of the physical machine where the instance is located.\n# MY_HOST_IPV6=::\n# The primary port configured by the user on the TCE platform.\n# TCE_PRIMARY_PORT=3000\n# The debug port configured by the user on the TCE platform.\n# TCE_DEBUG_PORT=8080\n\n# Env of the TCE control plane ( fixed value cannot be modified ).\nTCE_HOST_ENV=ppe\n# Pod name of TCE container.\n# MY_POD_NAME=pod-xxx\n# Tag of TCE image.\n# CURRENT_VERSION=123456\n```\n\n-   [/opt/tiger/chadc/netsegment](#opttigerchadcnetsegment): Optional, `IDC` network segment file ( `IPv4` ).\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n-   [/opt/tiger/chadc/netsegment6](#opttigerchadcnetsegment6): Optional, `IDC` network segment file ( `IPv6` ).\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n-   [/opt/tiger/chadc/region.json](#opttigerchadcregionjson): Optional, `Region` file.\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n\n### Prod\n\n```sh\n# Whether it is TCE container environment.\nIS_TCE_DOCKER_ENV=1\n# Node.js only environment variable.\n# NODE_ENV=prod\n\n# Service PSM.\nTCE_PSM=p.s.m\n# Service Cluster.\nSERVICE_CLUSTER=default\n# Service IDC ( lf means langfang machine room, you can fill in by yourself ).\nRUNTIME_IDC_NAME=lf\n# Service Env ( fixed value cannot be modified ).\nSERVICE_ENV=prod\n# Service Stage.\n# TCE_STAGE=single_dc\n\n# IPv4 of the physical machine where the instance is located.\n# MY_HOST_IP=127.0.0.1\n# IPv6 of the physical machine where the instance is located.\n# MY_HOST_IPV6=::\n# The primary port configured by the user on the TCE platform.\n# TCE_PRIMARY_PORT=3000\n# The debug port configured by the user on the TCE platform.\n# TCE_DEBUG_PORT=8080\n\n# Env of the TCE control plane ( fixed value cannot be modified ).\n# TCE_HOST_ENV=online\n# Pod name of TCE container.\n# MY_POD_NAME=pod-xxx\n# Tag of TCE image.\n# CURRENT_VERSION=123456\n```\n\n-   [/opt/tiger/chadc/netsegment](#opttigerchadcnetsegment): Optional, `IDC` network segment file ( `IPv4` ).\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n-   [/opt/tiger/chadc/netsegment6](#opttigerchadcnetsegment6): Optional, `IDC` network segment file ( `IPv6` ).\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n-   [/opt/tiger/chadc/region.json](#opttigerchadcregionjson): Optional, `Region` file.\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n\n## Documents\n\n-   [TCE > Default Environment Variables of TCE](https://bytedance.feishu.cn/wiki/wikcnR7f17phbl2h7ZVnj4KgRfg).\n-   [FaaS > System default environment variable description](https://bytedance.feishu.cn/wiki/wikcndu0chhW1HyIZ0u4Puu7Cqh).\n-   [How to judge the deployment environment > Server](https://bytedance.feishu.cn/wiki/wikcnmVz29FwukFO4Ux1Rtmc23c#sxJRso).\n","readmeFilename":"README.en.md","maintainers":[{"email":"liyubei@bytedance.com","name":"liyubei","avatar":"https://s3-fs.pstatp.com/static-resource/v1/bf5207f4-07f4-4c43-9004-b01af1aff365~?image_size=72x72&cut_type=&quality=&format=png&sticker_format=.webp"},{"name":"nodejs-team","avatar":"","email":"nodejs-team@bnpm.com"},{"email":"ouyangyadong@bytedance.com","name":"ouyangyadong","avatar":"https://s1-fs.pstatp.com/static-resource/v1/d27d000e276d58ace3df~?image_size=72x72&cut_type=&quality=&format=png&sticker_format=.webp"},{"email":"qizihan@bytedance.com","name":"qizi","avatar":"https://ee.bytedance.net/ratak/employees/3863359/avatar/?format=noop.png"},{"name":"shenchen","avatar":"https://s1-fs.pstatp.com/static-resource/v1/ef40014f9ad1f7011ec~?image_size=72x72&cut_type=&quality=&format=png&sticker_format=.webp","email":"shenchen@bytedance.com"},{"email":"xieda@bytedance.com","name":"xieda","avatar":"https://s1-fs.pstatp.com/static-resource/v1/a339a912-f731-4fe7-9e51-d91e1871180g~?image_size=240x240&cut_type=&quality=&format=image&sticker_format=.webp"},{"email":"yeyuanfeng@bytedance.com","name":"yeyuanfeng","avatar":"https://s3-fs.pstatp.com/static-resource/v1/43d80005ffccbded38e9~?image_size=72x72&cut_type=&quality=&format=png&sticker_format=.webp"}],"files":["lib","index.js","index.d.ts"],"_id":"@byted-service/env@1.17.5","_npmVersion":"lerna/undefined/node@v14.21.3+x64 (linux)","version":"1.17.5","dist":{"tarball":"https://bnpm.byted.org/@byted-service/env/-/env-1.17.5.tgz","unpackedSize":180831,"fileCount":40,"integrity":"sha512-EIAZZZGrtLmEjKhXRQO8IZ4YCzb3uHirMC7MJB4/O9go3s/lj2zazMO1fGWEgRHvLPZH1cuHp/1ZzrQ/Xt6IpA==","shasum":"b54ed11b5139a201f6aadf87b09a977c81cb987b","size":39786}},"1.15.2":{"description":"The basic environment variable SDK for Node.js","types":"index.d.ts","_npmVersion":"lerna/undefined/node@v14.21.2+x64 (linux)","_nodeVersion":"14.21.2","files":["lib","index.js","index.d.ts"],"dependencies":{"tslib":"^1.9.3"},"readmeFilename":"README.en.md","repository":{"url":"https://code.byted.org/nodejs/byted-service","type":"git"},"main":"index.js","readme":"# @byted-service/env\n\n[![bnpm](https://web-bnpm.byted.org/badge/v/@byted-service/env.svg?style=flat-square)](https://web-bnpm.byted.org/package/@byted-service/env) [![download](https://2y8ngapf.fn.bytedance.net/d?p=@byted-service/env)](https://web-bnpm.byted.org/package/@byted-service/env)\n\n[简体中文](https://code.byted.org/nodejs/byted-service/blob/master/packages/env/README.md) | [English](https://code.byted.org/nodejs/byted-service/blob/master/packages/env/README.en.md) | [CHANGELOG](https://code.byted.org/nodejs/byted-service/blob/master/packages/env/CHANGELOG.md)\n\n**@byted-service/env** is the basic environment variable `SDK` on the `Node.js` side of the company. It is widely integrated in `@byted-service/xxx`. The main data sources are as follows:\n\n-   [gopkg/env](https://code.byted.org/gopkg/env).\n-   [TCE > Default Environment Variables of TCE](https://bytedance.feishu.cn/wiki/wikcnR7f17phbl2h7ZVnj4KgRfg).\n-   [FaaS > System default environment variable description](https://bytedance.feishu.cn/wiki/wikcndu0chhW1HyIZ0u4Puu7Cqh).\n\n## Installation\n\n```bash\nnpm install @byted-service/env --registry=http://bnpm.byted.org\n```\n\n## Quick Start\n\n```ts\nimport { isProd } from '@byted-service/env';\n\nisProd();\n```\n\n## API\n\n### Runtime Environment\n\n#### env.isProd()\n\nWhether it is production environment. Compared with `env.isProduct()`, it also supports `NODE_ENV`.\n\n#### env.isTest()\n\nWhether it is test environment ( `Boe` environment is also considered test environment ).\n\n#### env.isTesting()\n\nUnknown.\n\n#### env.isBoe()\n\nWhether it is `Boe` environment ( `boe` + `boei18n` + `boexfl` + `boettp` ).\n\n#### env.isBoeCN()\n\nWhether it is `Boe` environment ( `boe` ).\n\n#### env.isBoeI18N()\n\nWhether it is `Boe` environment ( `boei18n` ).\n\n#### env.isBoeXfl()\n\nWhether it is `Boe` environment ( `boexfl` )\n\n#### env.isBoeTTP()\n\nWhether it is `Boe` environment ( `boettp` )\n\n#### env.isPPE()\n\nWhether it is `PPE` environment.\n\n#### env.isEdgeEnvironment()\n\nUnknown.\n\n#### env.isProduct()\n\nWhether it is `Prod` environment.\n\n### PSM + Cluster + IDC + Env + Region + Stage + VDC + VRegion\n\n#### env.getPSM()\n\nService `PSM`.\n\n#### env.setPSM(psm)\n\nSet service `PSM`.\n\n#### env.getCluster()\n\nService `Cluster`.\n\n#### env.setCluster(cluster)\n\nSet service `Cluster`.\n\n#### env.getIDC()\n\nService `IDC`.\n\n#### env.getIDCFromHost(ip)\n\nResolve service `IDC` from `IP`.\n\nTips: When `@byted-service/env` is initializing, it will load the data of the `IDC` network segment from the following files in sequence:\n\n-   [/opt/tmp/consul_agent/netsegment](#opttmpconsul_agentnetsegment) ( `IPv4` )\n-   [/opt/tiger/chadc/netsegment](#opttigerchadcnetsegment) ( `IPv4` )\n-   [/opt/tmp/consul_agent/netsegment6](#opttmpconsul_agentnetsegment6) ( `IPv6` )\n-   [/opt/tiger/chadc/netsegment6](#opttigerchadcnetsegment6) ( `IPv6` )\n\n#### env.getIDCList()\n\nService `IDC` list.\n\n#### env.setIDC(v)\n\nSet service `IDC`.\n\n#### env.setIDCFile(file)\n\nSet `IDC` network segment file (`IPv4`).\n\n#### env.setIpv6File(file)\n\nSet `IDC` network segment file (`IPv6`).\n\n#### env.getEnv()\n\nService `Env`, see [Env-based traffic scheduling](https://bytedance.feishu.cn/docs/ws0Kg2Q539Rzqc18VFc98f).\n\n#### env.isValidEnv()\n\nCheck whether the service `Env` is valid, see [Env naming specification ( final ) > Specific details](https://bytedance.feishu.cn/docs/doccn2zIJMueBhHi4kjrYKqaVYc#BTZPX3).\n\n#### env.getRegion()\n\nService `Region`.\n\n#### env.getRegionFromIDC(idc)\n\nGet service `Region` from service `IDC`.\n\nTips: When `@byted-service/env` is initializing, it will load the data of the `Region` from the following files in sequence:\n\n-   [/opt/tiger/chadc/region.json](#opttigerchadcregionjson)\n\n#### env.setRegionFile(file)\n\nSet `Region` file.\n\n#### env.getStage()\n\nService `Stage`.\n\n#### env.getVRegionFromVDC(vdc)\n\nGet service `VRegion` from service `VDC`.\n\n#### env.getCurrentVRegion()\n\nService `VRegion`.\n\n#### env.getVRegionFromHost(ip)\n\nResolve service `VRegion` from `IP`.\n\n#### env.getGovernanceVRegionFromVDC(vdc)\n\nGet service `VRegion` by real governace rules from service `VDC`.\n\n### Machine / Container Information\n\n#### env.getHostIP()\n\nMachine / container `IP` address, compatibility interface, return `IPv4` first, followed by `IPv6`.\n\n#### env.getHostIPV4()\n\nMachine / container `IPv4` address.\n\n#### env.getHostIPV6()\n\nMachine / container `IPv6` address.\n\n#### env.getIPv4()\n\nMachine / container `IPv4` address.\n\n#### env.getIPv6()\n\nMachine / container `IPv6` address.\n\n#### env.getIP()\n\nMachine / container `IP` address, return `IPv6` first, followed by `IPv4`.\n\n#### env.getIPStr()\n\nSee [env.getIP()](#envgetip).\n\n#### env.hasIPv4()\n\nDoes the machine / container have an `IPv4` address.\n\n#### env.hasIPv6()\n\nDoes the machine / container have an `IPv6` address.\n\n#### env.isDualStack()\n\nWhether the machine / container is `dual stack`, that is, there are both `IPv4` and `IPv6` addresses.\n\n#### env.isIPv4Only()\n\nWhether the machine / container is `IPv4 only`, that is, there are only `IPv4` addresses.\n\n#### env.isIPv6Only()\n\nWhether the machine / container is `IPv6 only`, that is, there are only `IPv6` addresses.\n\n#### env.getTCEServicePort()\n\nThe `primary` port configured by the user on the `TCE` platform.\n\n#### env.getTCEDebugPort()\n\nThe `debug` port configured by the user on the `TCE` platform.\n\n#### env.isInTCE()\n\nWhether it is in the `TCE` container.\n\n#### env.getPodName()\n\nThe `Pod` name of the `TCE` container.\n\n#### env.getImageVersion()\n\nThe `tag` of `TCE` image.\n\n#### env.getCloudEnv()\n\nThe `CloudEnv` of container,\n\n#### env.inVolcanoCloud()\n\nWhether it is in the `Volcano Cloud`.\n\n#### env.isCloudIDE()\n\nIs it a Cloud IDE environment.\n\n### Other\n\n#### env.init()\n\nInitialize `@byted-service/env`. By default, all `API`s have different levels of caching mechanism. Therefore, after modifying environment variables, you need to call this method to reinitialize `@byted-service/env`.\n\n#### env.defaultPSM\n\nService `PSM` default value, the value is `-`.\n\n#### env.defaultCluster\n\nService `Cluster` default value, the value is `default`.\n\n#### env.defaultIDC\n\nService `IDC` default value, the value is empty string.\n\n#### env.defaultEnv\n\nService `Env` default value, the value is `prod`.\n\n#### env.defaultStage\n\nService `Stage` default value, the value is `-`.\n\n#### env.defaultPodName\n\nContainer `Pod` name default value, the value is `-`.\n\n#### env.defaultImageVersion\n\nImage `tag` default value, the value is `-`.\n\n#### env.defaultCloudEnv\n\nContainer `CloudEnv` default value, the value is `-`.\n\n#### env.PSMUnknown\n\n#### env.ClusterDefault\n\n#### env.IDC\n\nEnumeration of known service `IDC`.\n\n#### env.REGION\n\nEnumeration of known service `Region`.\n\n#### env.STAGE\n\nEnumeration of known service `Stage`.\n\n#### env.VDC\n\nEnumeration of known service `VDC`.\n\n#### env.VREGION\n\nEnumeration of known service `VRegion`.\n\n## Environment Variables / Configuration Files\n\nThe environment variables used in `@byted-service/env` are as follows:\n\n```sh\nIS_TCE_DOCKER_ENV # Whether it is TCE container environment.\nNODE_ENV # Node.js only environment variable, when it is prod or production, it means the production environment.\n\nLOAD_SERVICE_PSM # Service PSM.\nPSM # Same as LOAD_SERVICE_PSM, but lower priority.\nTCE_PSM # Same as PSM, but lower priority.\nSERVICE_CLUSTER # Service Cluster.\nRUNTIME_IDC_NAME # Service IDC.\nSERVICE_ENV # Service Env.\nTCE_ENV # Same as SERVICE_ENV, but lower priority.\nTCE_STAGE # Service Stage.\n\nMY_HOST_IP # IPv4 of the physical machine where the instance is located.\nMY_HOST_IPV6 # IPv6 of the physical machine where the instance is located.\nTCE_PRIMARY_PORT # The primary port configured by the user on the TCE platform.\nTCE_DEBUG_PORT # The debug port configured by the user on the TCE platform.\n\nIS_PROD_RUNTIME # Whether it is Prod environment. Deprecated.\nTESTING_PREFIX # Unknown.\nIS_EDGE_ENVIRONMENT # Unknown.\nTCE_HOST_ENV # Env of the TCE control plane.\nMY_POD_NAME # Pod name of TCE container.\nCURRENT_VERSION # Tag of TCE image.\n```\n\nSee more environment variables:\n\n-   [TCE > Default Environment Variables of TCE](https://bytedance.feishu.cn/wiki/wikcnR7f17phbl2h7ZVnj4KgRfg).\n-   [FaaS > System default environment variable description](https://bytedance.feishu.cn/wiki/wikcndu0chhW1HyIZ0u4Puu7Cqh).\n\nTips: Some variables are injected at runtime, so they cannot be obtained directly through `echo $XXX`, but can be obtained by the following.\n\n```sh\nps -ef | grep node\n# $pid changed to correspond to the Node.js process pid.\ncat /proc/$pid/environ | tr \"\\0\" \"\\n\" | grep XXX\n```\n\n### /opt/tiger/chadc/netsegment\n\n`IDC` network segment file ( `IPv4` ), see [inf/chadc](https://code.byted.org/inf/chadc/blob/master/netsegment).\n\n### /opt/tmp/consul_agent/netsegment\n\nSee [/opt/tiger/chadc/netsegment](#opttigerchadcnetsegment).\n\n### /opt/tiger/chadc/netsegment6\n\n`IDC` network segment file ( `IPv6` ), see [inf/chadc](https://code.byted.org/inf/chadc/blob/master/netsegment6).\n\n### /opt/tmp/consul_agent/netsegment6\n\nSee [/opt/tiger/chadc/netsegment6](#opttigerchadcnetsegment6).\n\n### /opt/tiger/chadc/region.json\n\n`Region` file, see [inf/chadc](https://code.byted.org/inf/chadc/blob/master/region.json).\n\n## Privatization deployment / DevBox\n\nFor those who need privatization deployment / `DevBox`, you can set environment variables and files as follows.\n\n### Boe / BoeI18N\n\n```sh\n# Whether it is TCE container environment.\nIS_TCE_DOCKER_ENV=1\n# Node.js only environment variable.\n# NODE_ENV=test\n\n# Service PSM.\nTCE_PSM=p.s.m\n# Service Cluster.\nSERVICE_CLUSTER=default\n# Service IDC ( boe means Boe environment, boei18n means BoeI18N environment ).\nRUNTIME_IDC_NAME=boe\n# Service Env ( the default value is prod, If it is a lane, use the lane name ).\nSERVICE_ENV=prod\n# Service Stage.\n# TCE_STAGE=single_dc\n\n# IPv4 of the physical machine where the instance is located.\n# MY_HOST_IP=127.0.0.1\n# IPv6 of the physical machine where the instance is located.\n# MY_HOST_IPV6=::\n# The primary port configured by the user on the TCE platform.\n# TCE_PRIMARY_PORT=3000\n# The debug port configured by the user on the TCE platform.\n# TCE_DEBUG_PORT=8080\n\n# Env of the TCE control plane ( fixed value cannot be modified ).\nTCE_HOST_ENV=boe\n# Pod name of TCE container.\n# MY_POD_NAME=pod-xxx\n# Tag of TCE image.\n# CURRENT_VERSION=123456\n```\n\n-   [/opt/tiger/chadc/netsegment](#opttigerchadcnetsegment): Optional, `IDC` network segment file ( `IPv4` ).\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n-   [/opt/tiger/chadc/netsegment6](#opttigerchadcnetsegment6): Optional, `IDC` network segment file ( `IPv6` ).\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n-   [/opt/tiger/chadc/region.json](#opttigerchadcregionjson): Optional, `Region` file.\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n\n### PPE\n\n```sh\n# Whether it is TCE container environment.\nIS_TCE_DOCKER_ENV=1\n# Node.js only environment variable ( the PPE environment is the same as the Prod environment, both are prod ).\n# NODE_ENV=prod\n\n# Service PSM.\nTCE_PSM=p.s.m\n# Service Cluster.\nSERVICE_CLUSTER=default\n# Service IDC ( lf means langfang machine room, you can fill in by yourself ).\nRUNTIME_IDC_NAME=lf\n# Service Env ( PPE plane name ).\nSERVICE_ENV=ppe_xxx\n# Service Stage.\n# TCE_STAGE=single_dc\n\n# IPv4 of the physical machine where the instance is located.\n# MY_HOST_IP=127.0.0.1\n# IPv6 of the physical machine where the instance is located.\n# MY_HOST_IPV6=::\n# The primary port configured by the user on the TCE platform.\n# TCE_PRIMARY_PORT=3000\n# The debug port configured by the user on the TCE platform.\n# TCE_DEBUG_PORT=8080\n\n# Env of the TCE control plane ( fixed value cannot be modified ).\nTCE_HOST_ENV=ppe\n# Pod name of TCE container.\n# MY_POD_NAME=pod-xxx\n# Tag of TCE image.\n# CURRENT_VERSION=123456\n```\n\n-   [/opt/tiger/chadc/netsegment](#opttigerchadcnetsegment): Optional, `IDC` network segment file ( `IPv4` ).\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n-   [/opt/tiger/chadc/netsegment6](#opttigerchadcnetsegment6): Optional, `IDC` network segment file ( `IPv6` ).\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n-   [/opt/tiger/chadc/region.json](#opttigerchadcregionjson): Optional, `Region` file.\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n\n### Prod\n\n```sh\n# Whether it is TCE container environment.\nIS_TCE_DOCKER_ENV=1\n# Node.js only environment variable.\n# NODE_ENV=prod\n\n# Service PSM.\nTCE_PSM=p.s.m\n# Service Cluster.\nSERVICE_CLUSTER=default\n# Service IDC ( lf means langfang machine room, you can fill in by yourself ).\nRUNTIME_IDC_NAME=lf\n# Service Env ( fixed value cannot be modified ).\nSERVICE_ENV=prod\n# Service Stage.\n# TCE_STAGE=single_dc\n\n# IPv4 of the physical machine where the instance is located.\n# MY_HOST_IP=127.0.0.1\n# IPv6 of the physical machine where the instance is located.\n# MY_HOST_IPV6=::\n# The primary port configured by the user on the TCE platform.\n# TCE_PRIMARY_PORT=3000\n# The debug port configured by the user on the TCE platform.\n# TCE_DEBUG_PORT=8080\n\n# Env of the TCE control plane ( fixed value cannot be modified ).\n# TCE_HOST_ENV=online\n# Pod name of TCE container.\n# MY_POD_NAME=pod-xxx\n# Tag of TCE image.\n# CURRENT_VERSION=123456\n```\n\n-   [/opt/tiger/chadc/netsegment](#opttigerchadcnetsegment): Optional, `IDC` network segment file ( `IPv4` ).\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n-   [/opt/tiger/chadc/netsegment6](#opttigerchadcnetsegment6): Optional, `IDC` network segment file ( `IPv6` ).\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n-   [/opt/tiger/chadc/region.json](#opttigerchadcregionjson): Optional, `Region` file.\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n\n## Documents\n\n-   [TCE > Default Environment Variables of TCE](https://bytedance.feishu.cn/wiki/wikcnR7f17phbl2h7ZVnj4KgRfg).\n-   [FaaS > System default environment variable description](https://bytedance.feishu.cn/wiki/wikcndu0chhW1HyIZ0u4Puu7Cqh).\n-   [How to judge the deployment environment > Server](https://bytedance.feishu.cn/wiki/wikcnmVz29FwukFO4Ux1Rtmc23c#sxJRso).\n","author":"","_npmUser":{"email":"nodejs-team@bytedance.com","name":"nodejs-team"},"_id":"@byted-service/env@1.15.2","dist":{"unpackedSize":140360,"fileCount":40,"integrity":"sha512-7Km8Tr5q7hzXnNFyu0ZcQiDZi6ytLXymb6WHbDkhWssjXwore1yDlQ+OyOjIGGaIxkIYGV2x4vtFNf34v4pthw==","shasum":"67a73e2330fad9f809bfaf7af759f5e5600d5ad6","size":32380,"tarball":"https://bnpm.byted.org/@byted-service/env/-/env-1.15.2.tgz"},"maintainers":[{"name":"liyubei","avatar":"https://s3-fs.pstatp.com/static-resource/v1/bf5207f4-07f4-4c43-9004-b01af1aff365~?image_size=72x72&cut_type=&quality=&format=png&sticker_format=.webp","email":"liyubei@bytedance.com"},{"email":"nodejs-team@bnpm.com","name":"nodejs-team","avatar":""},{"avatar":"https://s1-fs.pstatp.com/static-resource/v1/d27d000e276d58ace3df~?image_size=72x72&cut_type=&quality=&format=png&sticker_format=.webp","email":"ouyangyadong@bytedance.com","name":"ouyangyadong"},{"avatar":"https://ee.bytedance.net/ratak/employees/3863359/avatar/?format=noop.png","email":"qizihan@bytedance.com","name":"qizi"},{"name":"shenchen","avatar":"https://s1-fs.pstatp.com/static-resource/v1/ef40014f9ad1f7011ec~?image_size=72x72&cut_type=&quality=&format=png&sticker_format=.webp","email":"shenchen@bytedance.com"},{"email":"xieda@bytedance.com","name":"xieda","avatar":"https://s1-fs.pstatp.com/static-resource/v1/a339a912-f731-4fe7-9e51-d91e1871180g~?image_size=240x240&cut_type=&quality=&format=image&sticker_format=.webp"},{"name":"yeyuanfeng","avatar":"https://s3-fs.pstatp.com/static-resource/v1/43d80005ffccbded38e9~?image_size=72x72&cut_type=&quality=&format=png&sticker_format=.webp","email":"yeyuanfeng@bytedance.com"}],"name":"@byted-service/env","license":"MIT","scripts":{"prepublish":"npm run build","test":"ROUTE_IP=10.225.130.44 RUNTIME_IDC_NAME=boe ../../node_modules/.bin/jest --config ./jest.config.json --coverage --env=node","build":"rm -rf lib && ../../node_modules/.bin/tsc"},"gitHead":"db2a5effdb0d61d457aad9443853410cee33fc5c","version":"1.15.2"},"2.0.0-beta.1":{"description":"The basic environment variable SDK for Node.js","license":"MIT","_npmUser":{"email":"nodejs-team@bytedance.com","name":"nodejs-team"},"dependencies":{"tslib":"^1.9.3"},"scripts":{"prepublish":"npm run build","test":"ROUTE_IP=10.225.130.44 RUNTIME_IDC_NAME=boe ../../node_modules/.bin/jest --config ./jest.config.json --coverage --env=node","build":"rm -rf lib && tsc -p tsconfig.json"},"author":"","repository":{"type":"git","url":"https://code.byted.org/nodejs/byted-service"},"types":"index.d.ts","_npmVersion":"lerna/undefined/node@v14.20.0+x64 (linux)","main":"index.js","maintainers":[{"name":"liyubei","avatar":"https://s3-fs.pstatp.com/static-resource/v1/bf5207f4-07f4-4c43-9004-b01af1aff365~?image_size=72x72&cut_type=&quality=&format=png&sticker_format=.webp","email":"liyubei@bytedance.com"},{"avatar":"","email":"nodejs-team@bnpm.com","name":"nodejs-team"},{"name":"ouyangyadong","avatar":"https://s1-fs.pstatp.com/static-resource/v1/d27d000e276d58ace3df~?image_size=72x72&cut_type=&quality=&format=png&sticker_format=.webp","email":"ouyangyadong@bytedance.com"},{"name":"qizi","avatar":"https://ee.bytedance.net/ratak/employees/3863359/avatar/?format=noop.png","email":"qizihan@bytedance.com"},{"email":"shenchen@bytedance.com","name":"shenchen","avatar":"https://s1-fs.pstatp.com/static-resource/v1/ef40014f9ad1f7011ec~?image_size=72x72&cut_type=&quality=&format=png&sticker_format=.webp"},{"name":"xieda","avatar":"https://s1-fs.pstatp.com/static-resource/v1/a339a912-f731-4fe7-9e51-d91e1871180g~?image_size=240x240&cut_type=&quality=&format=image&sticker_format=.webp","email":"xieda@bytedance.com"},{"email":"yeyuanfeng@bytedance.com","name":"yeyuanfeng","avatar":"https://s3-fs.pstatp.com/static-resource/v1/43d80005ffccbded38e9~?image_size=72x72&cut_type=&quality=&format=png&sticker_format=.webp"}],"files":["lib","index.js","index.d.ts"],"_nodeVersion":"14.20.0","version":"2.0.0-beta.1","_id":"@byted-service/env@2.0.0-beta.1","gitHead":"d5dabf0333ed3534059eb6d54453ca5b32adbbb8","name":"@byted-service/env","dist":{"fileCount":42,"integrity":"sha512-luzUujnGpRBjHafXn2cwpCsWIpcm6bSH8LV6Md62/SWl+NFe9R80MsOqic0MmbmzEOY42LcfHr0iK6abLItH3w==","shasum":"3fd20538c75b3189d77b902b837a22a891a3f9cc","size":36187,"tarball":"https://bnpm.byted.org/@byted-service/env/-/env-2.0.0-beta.1.tgz","unpackedSize":162368},"readme":"# @byted-service/env\n\n[![bnpm](https://web-bnpm.byted.org/badge/v/@byted-service/env.svg?style=flat-square)](https://web-bnpm.byted.org/package/@byted-service/env) [![download](https://2y8ngapf.fn.bytedance.net/d?p=@byted-service/env)](https://web-bnpm.byted.org/package/@byted-service/env)\n\n[简体中文](https://code.byted.org/nodejs/byted-service/blob/master/packages/env/README.md) | [English](https://code.byted.org/nodejs/byted-service/blob/master/packages/env/README.en.md) | [CHANGELOG](https://code.byted.org/nodejs/byted-service/blob/master/packages/env/CHANGELOG.md)\n\n**@byted-service/env** is the basic environment variable `SDK` on the `Node.js` side of the company. It is widely integrated in `@byted-service/xxx`. The main data sources are as follows:\n\n-   [gopkg/env](https://code.byted.org/gopkg/env).\n-   [TCE > Default Environment Variables of TCE](https://bytedance.feishu.cn/wiki/wikcnR7f17phbl2h7ZVnj4KgRfg).\n-   [FaaS > System default environment variable description](https://bytedance.feishu.cn/wiki/wikcndu0chhW1HyIZ0u4Puu7Cqh).\n-   (TikTok only) [tiktok/region_lib](https://code.byted.org/tiktok/region_lib) [Doc](https://bytedance.feishu.cn/wiki/wikcn4YwQncW4hTDEfCQZEizo9c).\n\n## Installation\n\n```bash\nnpm install @byted-service/env --registry=http://bnpm.byted.org\n```\n\n## Quick Start\n\n```ts\nimport { isProd } from '@byted-service/env';\n\nisProd();\n```\n\n## API\n\n### Runtime Environment\n\n#### env.isProd()\n\nWhether it is production environment. Compared with `env.isProduct()`, it also supports `NODE_ENV`.\n\n#### env.isTest()\n\nWhether it is test environment ( `Boe` environment is also considered test environment ).\n\n#### env.isTesting()\n\nUnknown.\n\n#### env.isBoe()\n\nWhether it is `Boe` environment ( `boe` + `boei18n` + `boexfl` + `boettp` ).\n\n#### env.isBoeCN()\n\nWhether it is `Boe` environment ( `boe` ).\n\n#### env.isBoeI18N()\n\nWhether it is `Boe` environment ( `boei18n` ).\n\n#### env.isBoeXfl()\n\nWhether it is `Boe` environment ( `boexfl` )\n\n#### env.isBoeTTP()\n\nWhether it is `Boe` environment ( `boettp` )\n\n#### env.isPPE()\n\nWhether it is `PPE` environment.\n\n#### env.isEdgeEnvironment()\n\nUnknown.\n\n#### env.isProduct()\n\nWhether it is `Prod` environment.\n\n### PSM + Cluster + IDC + Env + Region + Stage + VDC + VRegion\n\n#### env.getPSM()\n\nService `PSM`.\n\n#### env.setPSM(psm)\n\nSet service `PSM`.\n\n#### env.getCluster()\n\nService `Cluster`.\n\n#### env.setCluster(cluster)\n\nSet service `Cluster`.\n\n#### env.getIDC()\n\nService `IDC`.\n\n#### env.getIDCFromHost(ip)\n\nResolve service `IDC` from `IP`.\n\nTips: When `@byted-service/env` is initializing, it will load the data of the `IDC` network segment from the following files in sequence:\n\n-   [/opt/tmp/consul_agent/netsegment](#opttmpconsul_agentnetsegment) ( `IPv4` )\n-   [/opt/tiger/chadc/netsegment](#opttigerchadcnetsegment) ( `IPv4` )\n-   [/opt/tmp/consul_agent/netsegment6](#opttmpconsul_agentnetsegment6) ( `IPv6` )\n-   [/opt/tiger/chadc/netsegment6](#opttigerchadcnetsegment6) ( `IPv6` )\n\n#### env.getIDCList()\n\nService `IDC` list.\n\n#### env.setIDC(v)\n\nSet service `IDC`.\n\n#### env.setIDCFile(file)\n\nSet `IDC` network segment file (`IPv4`).\n\n#### env.setIpv6File(file)\n\nSet `IDC` network segment file (`IPv6`).\n\n#### env.getEnv()\n\nService `Env`, see [Env-based traffic scheduling](https://bytedance.feishu.cn/docs/ws0Kg2Q539Rzqc18VFc98f).\n\n#### env.isValidEnv()\n\nCheck whether the service `Env` is valid, see [Env naming specification ( final ) > Specific details](https://bytedance.feishu.cn/docs/doccn2zIJMueBhHi4kjrYKqaVYc#BTZPX3).\n\n#### env.getRegion()\n\nService `Region`.\n\n#### env.getRegionFromIDC(idc)\n\nGet service `Region` from service `IDC`.\n\nTips: When `@byted-service/env` is initializing, it will load the data of the `Region` from the following files in sequence:\n\n-   [/opt/tiger/chadc/region.json](#opttigerchadcregionjson)\n\n#### env.setRegionFile(file)\n\nSet `Region` file.\n\n#### env.getStage()\n\nService `Stage`.\n\n#### env.getVRegionFromVDC(vdc)\n\nGet service `VRegion` from service `VDC`.\n\n#### env.getCurrentVRegion()\n\nService `VRegion`.\n\n#### env.getVRegionFromHost(ip)\n\nResolve service `VRegion` from `IP`.\n\n#### env.getGovernanceVRegionFromVDC(vdc)\n\nGet service `VRegion` by real governace rules from service `VDC`.\n\n### TikTok IDC/Region information and related helper functions\n\n#### env.tt.VDC\n\ndefinition of vDC used by TikTok\n\n#### env.tt.VREGION\n\ndefinition of vRegion used by TikTok\n\n#### env.tt.VGEO\n\ndefinition of vGeo used by TikTok\n\n#### env.tt.getVDC()\n\nget current vDC, environment not used by TikTok will return env.tt.VDC.VDC_UNKNOWN (\"-\")\n\n#### env.tt.getVRegion()\n\nget current vRegion, environment not used by TikTok will return env.tt.VREGION.VREGION_UNKNOWN (\"-\")\n\n#### env.tt.getVGeo()\n\nget current vGeo, environment not used  by TikTok or not belong to any vGeo will return env.tt.VGEO.VGEO_UNKNOWN (\"-\")\n\n获取当前 vGeo，非 TikTok 使用或者不属于任何 vGeo 的环境会返回 env.tt.VGEO.VGEO_UNKNOWN (\"-\")\n\n#### env.tt.isVGeoUS()\n\n判断当前环境是否属于 US 的 vGeo\n\n#### env.tt.isVGeoEU()\n\n判断当前环境是否属于 US 的 vGeo\n\n#### env.tt.isTexasRegion(regionCode: string)\n\n判断一个 regionCode 是否属于 Project Texas\n\n#### env.tt.isCloverRegion(regionCode: string)\n\n判断一个 regionCode 是否属于 Project Clover\n\n### Machine / Container Information\n\n#### env.getHostIP()\n\nMachine / container `IP` address, compatibility interface, return `IPv4` first, followed by `IPv6`.\n\n#### env.getHostIPV4()\n\nMachine / container `IPv4` address.\n\n#### env.getHostIPV6()\n\nMachine / container `IPv6` address.\n\n#### env.getIPv4()\n\nMachine / container `IPv4` address.\n\n#### env.getIPv6()\n\nMachine / container `IPv6` address.\n\n#### env.getIP()\n\nMachine / container `IP` address, return `IPv6` first, followed by `IPv4`.\n\n#### env.getIPStr()\n\nSee [env.getIP()](#envgetip).\n\n#### env.hasIPv4()\n\nDoes the machine / container have an `IPv4` address.\n\n#### env.hasIPv6()\n\nDoes the machine / container have an `IPv6` address.\n\n#### env.isDualStack()\n\nWhether the machine / container is `dual stack`, that is, there are both `IPv4` and `IPv6` addresses.\n\n#### env.isIPv4Only()\n\nWhether the machine / container is `IPv4 only`, that is, there are only `IPv4` addresses.\n\n#### env.isIPv6Only()\n\nWhether the machine / container is `IPv6 only`, that is, there are only `IPv6` addresses.\n\n#### env.getTCEServicePort()\n\nThe `primary` port configured by the user on the `TCE` platform.\n\n#### env.getTCEDebugPort()\n\nThe `debug` port configured by the user on the `TCE` platform.\n\n#### env.isInTCE()\n\nWhether it is in the `TCE` container.\n\n#### env.getPodName()\n\nThe `Pod` name of the `TCE` container.\n\n#### env.getImageVersion()\n\nThe `tag` of `TCE` image.\n\n#### env.getCloudEnv()\n\nThe `CloudEnv` of container,\n\n#### env.inVolcanoCloud()\n\nWhether it is in the `Volcano Cloud`.\n\n#### env.isCloudIDE()\n\nIs it a Cloud IDE environment.\n\n### Other\n\n#### env.init()\n\nInitialize `@byted-service/env`. By default, all `API`s have different levels of caching mechanism. Therefore, after modifying environment variables, you need to call this method to reinitialize `@byted-service/env`.\n\n#### env.defaultPSM\n\nService `PSM` default value, the value is `-`.\n\n#### env.defaultCluster\n\nService `Cluster` default value, the value is `default`.\n\n#### env.defaultIDC\n\nService `IDC` default value, the value is empty string.\n\n#### env.defaultEnv\n\nService `Env` default value, the value is `prod`.\n\n#### env.defaultStage\n\nService `Stage` default value, the value is `-`.\n\n#### env.defaultPodName\n\nContainer `Pod` name default value, the value is `-`.\n\n#### env.defaultImageVersion\n\nImage `tag` default value, the value is `-`.\n\n#### env.defaultCloudEnv\n\nContainer `CloudEnv` default value, the value is `-`.\n\n#### env.PSMUnknown\n\n#### env.ClusterDefault\n\n#### env.IDC\n\nEnumeration of known service `IDC`.\n\n#### env.REGION\n\nEnumeration of known service `Region`.\n\n#### env.STAGE\n\nEnumeration of known service `Stage`.\n\n#### env.VDC\n\nEnumeration of known service `VDC`.\n\n#### env.VREGION\n\nEnumeration of known service `VRegion`.\n\n## Environment Variables / Configuration Files\n\nThe environment variables used in `@byted-service/env` are as follows:\n\n```sh\nIS_TCE_DOCKER_ENV # Whether it is TCE container environment.\nNODE_ENV # Node.js only environment variable, when it is prod or production, it means the production environment.\n\nLOAD_SERVICE_PSM # Service PSM.\nPSM # Same as LOAD_SERVICE_PSM, but lower priority.\nTCE_PSM # Same as PSM, but lower priority.\nSERVICE_CLUSTER # Service Cluster.\nRUNTIME_IDC_NAME # Service IDC.\nSERVICE_ENV # Service Env.\nTCE_ENV # Same as SERVICE_ENV, but lower priority.\nTCE_STAGE # Service Stage.\n\nMY_HOST_IP # IPv4 of the physical machine where the instance is located.\nMY_HOST_IPV6 # IPv6 of the physical machine where the instance is located.\nTCE_PRIMARY_PORT # The primary port configured by the user on the TCE platform.\nTCE_DEBUG_PORT # The debug port configured by the user on the TCE platform.\n\nIS_PROD_RUNTIME # Whether it is Prod environment. Deprecated.\nTESTING_PREFIX # Unknown.\nIS_EDGE_ENVIRONMENT # Unknown.\nTCE_HOST_ENV # Env of the TCE control plane.\nMY_POD_NAME # Pod name of TCE container.\nCURRENT_VERSION # Tag of TCE image.\n```\n\nSee more environment variables:\n\n-   [TCE > Default Environment Variables of TCE](https://bytedance.feishu.cn/wiki/wikcnR7f17phbl2h7ZVnj4KgRfg).\n-   [FaaS > System default environment variable description](https://bytedance.feishu.cn/wiki/wikcndu0chhW1HyIZ0u4Puu7Cqh).\n\nTips: Some variables are injected at runtime, so they cannot be obtained directly through `echo $XXX`, but can be obtained by the following.\n\n```sh\nps -ef | grep node\n# $pid changed to correspond to the Node.js process pid.\ncat /proc/$pid/environ | tr \"\\0\" \"\\n\" | grep XXX\n```\n\n### /opt/tiger/chadc/netsegment\n\n`IDC` network segment file ( `IPv4` ), see [inf/chadc](https://code.byted.org/inf/chadc/blob/master/netsegment).\n\n### /opt/tmp/consul_agent/netsegment\n\nSee [/opt/tiger/chadc/netsegment](#opttigerchadcnetsegment).\n\n### /opt/tiger/chadc/netsegment6\n\n`IDC` network segment file ( `IPv6` ), see [inf/chadc](https://code.byted.org/inf/chadc/blob/master/netsegment6).\n\n### /opt/tmp/consul_agent/netsegment6\n\nSee [/opt/tiger/chadc/netsegment6](#opttigerchadcnetsegment6).\n\n### /opt/tiger/chadc/region.json\n\n`Region` file, see [inf/chadc](https://code.byted.org/inf/chadc/blob/master/region.json).\n\n## Privatization deployment / DevBox\n\nFor those who need privatization deployment / `DevBox`, you can set environment variables and files as follows.\n\n### Boe / BoeI18N\n\n```sh\n# Whether it is TCE container environment.\nIS_TCE_DOCKER_ENV=1\n# Node.js only environment variable.\n# NODE_ENV=test\n\n# Service PSM.\nTCE_PSM=p.s.m\n# Service Cluster.\nSERVICE_CLUSTER=default\n# Service IDC ( boe means Boe environment, boei18n means BoeI18N environment ).\nRUNTIME_IDC_NAME=boe\n# Service Env ( the default value is prod, If it is a lane, use the lane name ).\nSERVICE_ENV=prod\n# Service Stage.\n# TCE_STAGE=single_dc\n\n# IPv4 of the physical machine where the instance is located.\n# MY_HOST_IP=127.0.0.1\n# IPv6 of the physical machine where the instance is located.\n# MY_HOST_IPV6=::\n# The primary port configured by the user on the TCE platform.\n# TCE_PRIMARY_PORT=3000\n# The debug port configured by the user on the TCE platform.\n# TCE_DEBUG_PORT=8080\n\n# Env of the TCE control plane ( fixed value cannot be modified ).\nTCE_HOST_ENV=boe\n# Pod name of TCE container.\n# MY_POD_NAME=pod-xxx\n# Tag of TCE image.\n# CURRENT_VERSION=123456\n```\n\n-   [/opt/tiger/chadc/netsegment](#opttigerchadcnetsegment): Optional, `IDC` network segment file ( `IPv4` ).\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n-   [/opt/tiger/chadc/netsegment6](#opttigerchadcnetsegment6): Optional, `IDC` network segment file ( `IPv6` ).\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n-   [/opt/tiger/chadc/region.json](#opttigerchadcregionjson): Optional, `Region` file.\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n\n### PPE\n\n```sh\n# Whether it is TCE container environment.\nIS_TCE_DOCKER_ENV=1\n# Node.js only environment variable ( the PPE environment is the same as the Prod environment, both are prod ).\n# NODE_ENV=prod\n\n# Service PSM.\nTCE_PSM=p.s.m\n# Service Cluster.\nSERVICE_CLUSTER=default\n# Service IDC ( lf means langfang machine room, you can fill in by yourself ).\nRUNTIME_IDC_NAME=lf\n# Service Env ( PPE plane name ).\nSERVICE_ENV=ppe_xxx\n# Service Stage.\n# TCE_STAGE=single_dc\n\n# IPv4 of the physical machine where the instance is located.\n# MY_HOST_IP=127.0.0.1\n# IPv6 of the physical machine where the instance is located.\n# MY_HOST_IPV6=::\n# The primary port configured by the user on the TCE platform.\n# TCE_PRIMARY_PORT=3000\n# The debug port configured by the user on the TCE platform.\n# TCE_DEBUG_PORT=8080\n\n# Env of the TCE control plane ( fixed value cannot be modified ).\nTCE_HOST_ENV=ppe\n# Pod name of TCE container.\n# MY_POD_NAME=pod-xxx\n# Tag of TCE image.\n# CURRENT_VERSION=123456\n```\n\n-   [/opt/tiger/chadc/netsegment](#opttigerchadcnetsegment): Optional, `IDC` network segment file ( `IPv4` ).\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n-   [/opt/tiger/chadc/netsegment6](#opttigerchadcnetsegment6): Optional, `IDC` network segment file ( `IPv6` ).\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n-   [/opt/tiger/chadc/region.json](#opttigerchadcregionjson): Optional, `Region` file.\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n\n### Prod\n\n```sh\n# Whether it is TCE container environment.\nIS_TCE_DOCKER_ENV=1\n# Node.js only environment variable.\n# NODE_ENV=prod\n\n# Service PSM.\nTCE_PSM=p.s.m\n# Service Cluster.\nSERVICE_CLUSTER=default\n# Service IDC ( lf means langfang machine room, you can fill in by yourself ).\nRUNTIME_IDC_NAME=lf\n# Service Env ( fixed value cannot be modified ).\nSERVICE_ENV=prod\n# Service Stage.\n# TCE_STAGE=single_dc\n\n# IPv4 of the physical machine where the instance is located.\n# MY_HOST_IP=127.0.0.1\n# IPv6 of the physical machine where the instance is located.\n# MY_HOST_IPV6=::\n# The primary port configured by the user on the TCE platform.\n# TCE_PRIMARY_PORT=3000\n# The debug port configured by the user on the TCE platform.\n# TCE_DEBUG_PORT=8080\n\n# Env of the TCE control plane ( fixed value cannot be modified ).\n# TCE_HOST_ENV=online\n# Pod name of TCE container.\n# MY_POD_NAME=pod-xxx\n# Tag of TCE image.\n# CURRENT_VERSION=123456\n```\n\n-   [/opt/tiger/chadc/netsegment](#opttigerchadcnetsegment): Optional, `IDC` network segment file ( `IPv4` ).\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n-   [/opt/tiger/chadc/netsegment6](#opttigerchadcnetsegment6): Optional, `IDC` network segment file ( `IPv6` ).\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n-   [/opt/tiger/chadc/region.json](#opttigerchadcregionjson): Optional, `Region` file.\n    -   Privatization deployment: You need to confirm with SRE whether the file exists, if it does not exist, you can add it yourself.\n    -   DevBox: It will be added by default, if the file is older, you can restart `DevBox` or contact `oncall`.\n\n## Documents\n\n-   [TCE > Default Environment Variables of TCE](https://bytedance.feishu.cn/wiki/wikcnR7f17phbl2h7ZVnj4KgRfg).\n-   [FaaS > System default environment variable description](https://bytedance.feishu.cn/wiki/wikcndu0chhW1HyIZ0u4Puu7Cqh).\n-   [How to judge the deployment environment > Server](https://bytedance.feishu.cn/wiki/wikcnmVz29FwukFO4Ux1Rtmc23c#sxJRso).\n","readmeFilename":"README.en.md"},"1.8.0":{"devD