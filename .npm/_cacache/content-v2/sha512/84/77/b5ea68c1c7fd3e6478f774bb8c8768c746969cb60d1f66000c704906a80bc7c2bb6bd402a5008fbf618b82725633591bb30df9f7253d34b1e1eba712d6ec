main.com/xxx');\n\n    console.log(await resp.text());\n})();\n```\n\nExcept for only support `http` and `https` protocol, others are the same as [@byted-service/fetch](https://code.byted.org/nodejs/byted-service/blob/master/packages/fetch/README.en.md).\n","license":"ISC","readmeFilename":"README.en.md","_id":"@byted-service/fetch-core"}