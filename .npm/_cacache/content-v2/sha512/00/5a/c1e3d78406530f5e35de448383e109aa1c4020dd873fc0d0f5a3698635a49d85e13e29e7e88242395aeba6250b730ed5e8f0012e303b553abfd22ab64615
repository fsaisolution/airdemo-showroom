g.json --coverage --env=node","build":"rm -rf lib && tsc"},"types":"lib/index.d.ts","engines":{"node":">=10.0.0"},"gitHead":"55bf87c01963d9b7b7ae760f5960ddf7f869c854","maintainers":[{"avatar":"https://s3-fs.pstatp.com/static-resource/v1/bf5207f4-07f4-4c43-9004-b01af1aff365~?image_size=72x72&cut_type=&quality=&format=png&sticker_format=.webp","email":"liyubei@bytedance.com","name":"liyubei"},{"avatar":"","email":"nodejs-team@bnpm.com","name":"nodejs-team"},{"name":"ouyangyadong","avatar":"https://s1-fs.pstatp.com/static-resource/v1/d27d000e276d58ace3df~?image_size=72x72&cut_type=&quality=&format=png&sticker_format=.webp","email":"ouyangyadong@bytedance.com"},{"avatar":"https://s1-fs.pstatp.com/static-resource/v1/a339a912-f731-4fe7-9e51-d91e1871180g~?image_size=240x240&cut_type=&quality=&format=image&sticker_format=.webp","email":"xieda@bytedance.com","name":"xieda"},{"email":"shanshengkai@bytedance.com","name":"shanshengkai"}],"version":"2.3.2","_nodeVersion":"14.21.3","_npmVersion":"lerna/undefined/node@v14.21.3+x64 (linux)","description":"consul protocol for @byted-service/fetch","readme":"# @byted-service/fetch-protocol-consul\n\n[![bnpm](https://web-bnpm.byted.org/badge/v/@byted-service/fetch-protocol-consul.svg?style=flat-square)](https://web-bnpm.byted.org/package/@byted-service/fetch-protocol-consul) [![download](https://2y8ngapf.fn.bytedance.net/d?p=@byted-service/fetch-protocol-consul)](https://web-bnpm.byted.org/package/@byted-service/fetch-protocol-consul)\n\n[简体中文](https://code.byted.org/nodejs/byted-service/blob/master/packages/fetch-protocol-consul/README.md) | [English](https://code.byted.org/nodejs/byted-service/blob/master/packages/fetch-protocol-consul/README.en.md) | [CHANGELOG](https://code.byted.org/nodejs/byted-service/blob/master/packages/fetch-protocol-consul/CHANGELOG.md)\n\n> The following is **@byted-service/fetch-protocol-consul@2.x** document, **1.x** document see [fetch-v1.x](https://code.byted.org/nodejs/byted-service/tree/fetch-v1.x/packages/fetch-protocol-consul), [@byted-service/fetch@2.0.0 release log](https://bytedance.feishu.cn/wiki/wikcnMNUcH3YbXKEeZSX4YqCavc).\n\n`@byted-service/fetch` consul protocol extention.\n\n1. support `consul://p.s.m/xxx`, [Node.js Service Discovery (Consul) User Guide](https://bytedance.feishu.cn/wiki/wikcnU8nNhyPfhV2OjHLCVQPX5g), [A Quick Start with Service Discovery ( Consul ) for Front-End Engineers](https://bytedance.feishu.cn/wiki/wikcn9QfY7pMwo9I9Jf1Y2q6R4d).\n2. suport [ByteMesh](https://bytedance.feishu.cn/wiki/wikcn3Kazqb9H1MZsHBet1q6RGc), [ByteMesh HTTP/1.1 & HTTP/2 protocol access agreement](https://bytedance.feishu.cn/docs/doccnBvELWkcTSb7PMU3H0GoRqd).\n\n## Installation\n\n```bash\nnpm install @byted-service/fetch-protocol-consul --registry=http://bnpm.byted.org\n```\n\n## Quick Start\n\n> Currently it is built-in in @byted-service/fetch, actually can be used without any operation.\n\n```ts\nimport { fetch } from '@byted-service/fetch';\nimport { protocol, handle } from '@byted-service/fetch-protocol-consul';\n\nfetch.register(protocol, handle);\n\n(async () => {\n    const resp = await fetch('consul://p.s.m/xxx');\n\n    console.log(await resp.text());\n})();\n```\n\n## API\n\n### fetch(url[, options])\n\nThe parameters of `@byted-service/fetch` have been extended. Generally, It is set by framework , and user unaware.\n\n<details>\n  <summary>History</summary>\n\n-   `v2.1.0`\n    -   Mark `options.consulClient`, `options.consulClientOptions`, `options.disableMesh` as deprecated.\n    -   Support `options.consulOption`, `options.consulLookupOption`, `options.enableMesh`.\n\n</details>\n\n-   `url`: request url.\n-   `options`:\n    -   `consul`: `Consul` instance, see [@byted-service/consul](https://code.byted.org/nodejs/byted-service/blob/master/packages/consul/README.en.md).\n    -   `consulOptions`: `Consul` construction options, see [@byted-service/consul](https://code.byted.org/nodejs/byted-service/blob/master/packages/consul/README.en.md).\n    -   `consulLookupOptions`: `consul.lookup()` options, see [@byted-service/consul](https://code.byted.org/nodejs/byted-service/blob/master/packages/consul/README.en.md).\n    -   `enableMesh`: Whether to send request through `http egress mesh`, the default value is `true`.\n\n## Mesh\n\nStarting from `@byted-service/fetch@1.6.0`, when the `tce` cluster is configured according to https://bytedance.feishu.cn/space/doc/doccnjPUcpCENG6vktQYID, requests in the form of `consul:` will be sent through the mesh proxy.\n\nIf it is in `faas && enable mesh and SERVICE_MESH_HTTP_EGRESS_ADDR is existed`, consul protocol will use [@byted/node-fetch](https://code.byted.org/nodejs/byted-node-fetch) to initiate a request.\n\n## Metrics\n\nRelated indicators and tags are the same as [@byted-service/fetch](https://code.byted.org/nodejs/byted-service/blob/master/packages/fetch/README.en.md#metrics), the modified part is listed below.\n\n-   `to`: Server psm.\n-   `to_cluster`: Server cluster, can be set by `options.consul.cluster`, the result of consul service discovery may be changed after modification.\n-   `to_idc`: Server idc, can be set by `options.consul.idc`, the result of consul service discovery may be changed after modification.\n-   `mesh`: Whether use http egress mesh, the default is `0`, judge according to environment variables and `options.disableMesh`.\n    -   `0`: No, `options.disableMesh = false` or `process.env.TCE_ENABLE_HTTP_SIDECAR_EGRESS !=='True'`, at this time, the address after consul service discovery will be requested.\n    -   `1`: Yes, `options.disableMesh = true` or `process.env.TCE_ENABLE_HTTP_SIDECAR_EGRESS ==='True'`, at this time, if on faas, `process.env.SERVICE_MESH_HTTP_EGRESS_ADDR` will be requested, otherwise, `127.0.0.1:process. env.MESH_EGRESS_PORT`.\n-   `ipv6`: The consul service found whether the returned ipv6 address, the default is `0`.\n    -   `0`: No.\n    -   `1`: Yes.\n\n## Logger\n\nRelated tags are the same as [@byted-service/fetch](