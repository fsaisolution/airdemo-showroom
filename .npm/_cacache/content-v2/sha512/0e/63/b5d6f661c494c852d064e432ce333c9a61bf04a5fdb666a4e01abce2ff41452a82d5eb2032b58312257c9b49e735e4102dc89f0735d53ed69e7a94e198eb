 && npm run gen:proto && npm run gen:ts","postinstall":"versiontool","build":"rm -rf lib && ../../node_modules/.bin/tsc && cp -r src/gen lib/","test":"ROUTE_IP=10.225.130.44 NODE_ENV=prod RUNTIME_IDC_NAME=boe ../../node_modules/.bin/jest --config ./jest.config.json --coverage --env=node","debug":"ROUTE_IP=10.225.130.44 RUNTIME_IDC_NAME=boe ts-node --files ./debug.ts","gen:proto":"protoc --js_out=import_style=commonjs,binary:./src/gen --proto_path=./proto/idl ./proto/idl/*.proto","benchmark":"source benchmark/start.sh","prepublish":"npm run build"},"devDependencies":{"@byted-service/trace":"^1.0.15","@types/google-protobuf":"^3.7.4","@types/jest":"^24.0.21","benchmark":"^2.1.4","grpc_tools_node_protoc_ts":"^4.1.5","ts-protoc-gen":"^0.14.0","@byted-service/logid":"^1.0.0"},"version":"1.6.2","main":"index.js","readme":"# bytedtrace Node.js 版本\n\n[![bnpm](https://web-bnpm.byted.org/badge/v/@byted-service/bytedtrace.svg?style=flat-square)](https://web-bnpm.byted.org/package/@byted-service/bytedtrace) [![download](https://2y8ngapf.fn.bytedance.net/d?p=@byted-service/bytedtrace)](https://web-bnpm.byted.org/package/@byted-service/bytedtrace)\n\n[简体中文](https://code.byted.org/nodejs/byted-service/blob/master/packages/bytedtrace/README.md) | [CHANGELOG](https://code.byted.org/nodejs/byted-service/blob/master/packages/bytedtrace/CHANGELOG.md)\n\n**_要求 Node.js 版本 10.5.0+_**\n\n> 咨询可直接找谢伟成(xieweicheng@bytedance.com) 或者单福平(fred.shan@bytedance.com)\n\n> 不建议业务代码中直接使用，这个 lib 会集成在 gulu/rpc/redis/fetch 等组件或者框架中并导出 BytedTracer 实例和生成的 root span 供业务代码使用\n\n## 安装\n\n```bash\nnpm install @byted-service/bytedtrace --registry=http://bnpm.byted.org\n```\n\n## 快速入门\n\n模拟上游调用下游场景 [demo](https://code.byted.org/nodejs/byted-service/blob/master/packages/bytedtrace/examples/demo.ts)\n\n## [API](https://code.byted.org/nodejs/byted-service/blob/master/packages/bytedtrace/docs/API.md)\n\n请见 [API 文档](https://code.byted.org/nodejs/byted-service/blob/master/packages/bytedtrace/docs/API.md)\n\n## Content\n\n-   [BytedTracer](https://code.byted.org/nodejs/byted-service/blob/master/packages/bytedtrace/docs/API.md#bytedtracer)\n-   [Span](https://code.byted.org/nodejs/byted-service/blob/master/packages/bytedtrace/docs/API.md#span)\n-   [SpanContext](https://code.byted.org/nodejs/byted-service/blob/master/packages/bytedtrace/docs/API.md#spancontext)\n-   [TraceEvent](https://code.byted.org/nodejs/byted-service/blob/master/packages/bytedtrace/docs/API.md#traceevent)\n-   [LogEvent](https://code.byted.org/nodejs/byted-service/blob/master/packages/bytedtrace/docs/API.md#logevent)\n-   [TraceId](https://code.byted.org/nodejs/byted-service/blob/master/packages/bytedtrace/docs/API.md#traceid)\n\n## 注意事项\n\n> 本地调试开发参考文档 [本地开发并上报数据](https://code.byted.org/nodejs/byted-service/blob/master/packages/bytedtrace/docs/develop_local.md)\n\n> 非正式环境不会上报数据到 argos\n\n> 在线上环境可通过命令行 `strace -f -s 65535 -p $YOUR_PID 2>&1 | grep \"bytedtrace.sdk\"` 查看上报给 log agent 的数据情况\n\n> 在禁用动态配置的条件下可以自定义采样策略，具体请看[自定义采样策略](https://code.byted.org/nodejs/byted-service/blob/master/packages/bytedtrace/docs/custom_sample_rate.md)\n\n## 相关文档&资料\n\n[当前版本的 trace 日志/埋点梳理](https://bytedance.feishu.cn/docs/doccnlWR44FUrLxtxtDHmuOzonl#)\n\n[日志 Trace2.0 Proposal](https://bytedance.feishu.cn/docs/doccnt4qPqW4qK67GjWSPzDkX1g#LLhru8)\n\n[Trace 2.0 / Log / Metrics 关联方案](https://bytedance.feishu.cn/docs/doccnqKqCeJh9ymo2EM2wUNnEub)\n\n[Bytedtrace Metrics 替换计划](https://bytedance.feishu.cn/docs/doccnCxe4BY0DQ6xZwtYzJwhDjb)\n\n[Trace 2.0 SDK 指标定义](https://bytedance.feishu.cn/docs/doccnSdegyK1YGD5ACGWQSVPksh)\n\n[Bytedtrace(Trace 2.0) Release Notes](https://bytedance.feishu.cn/docs/doccnyVEEyER3bow44gWW3dpanc)\n\n[byteLog 私有协议](https://bytedance.feishu.cn/docs/doccndEvBDduyL1SiwzUBHYrnBh)\n\n[@byted-service/bytedtrace 2.0 规划](https://bytedance.feishu.cn/docs/doccn3r689zpKwkKFLemqj6Tg5g)\n","dist":{"shasum":"052298ae758f3f7334bac4b581f5292bb8560b25","size":105782,"tarball":"https://bnpm.byted.org/@byted-service/bytedtrace/-/bytedtrace-1.6.2.tgz","unpackedSize":581628,"fileCount":154,"integrity":"sha512-lYUxPJpm5dRZfW7/l05UhfpCM0pXl6d1XzRYf4OGLt7/phEAoiRA04nQJK1iAlnoru2HkV60Km+T+W1mq90EWQ=="}},"0.0.1-alpha.2":{"license":"MIT","_id":"@byted-service/bytedtrace@0.0.1-alpha.2","maintainers":[{"avatar":"","email":"nodejs-team@bnpm.com","name":"nodejs-team"},{"name":"xieweicheng","avatar":"https://s1-fs.pstatp.com/static-resource/v1/f27851c0-d3e8-4851-a606-1a3d9361b82g~?image_size=72x72&cut_type=&quality=&format=png&sticker_format=.webp","email":"xieweicheng@bytedance.com"}],"_nodeVersion":"14.16.0","gitHead":"d72039e874b70c3e7a5bd21cca74be68623a3ff3","types":"lib/index.d.ts","main":"index.js","publish_time":1621595063505,"version":"0.0.1-alpha.2","_npmUser":{"email":"nodejs-team@bnpm.com","name":"nodejs-team"},"dependencies":{"ip":"^1.1.5","@byted-service/tcc-general":"^1.0.0","opentracing":"^0.14.5","@byted-service/metainfo":"^1.1.3","tslib":"^1.9.3","md5":"^2.3.0","@byted-service/metrics":"^1.10.1","@byted-service/version-tool":"^1.0.3","@byted-service/logger":"^1.13.7","@byted-service/singleflight":"^1.0.3","lodash.clonedeep":"^4.5.0","int64-buffer":"^1.0.1","@byted-service/logid":"^1.0.0","google-protobuf":"^3.15.6","@byted-service/env":"^1.9.3","dayjs":"^1.10.4","promise.allsettled":"^1.0.4"},"description":"```bash # 注意是 trace 2.0 版本 npm install @byted-service/bytedtrace --registry=http://bnpm.byted.org ```","_publish_on_cnpm":true,"readmeFilename":"README.md","files":["lib","index.js"],"dist":{"tarball":"https://bnpm.byted.org/@byted-service/bytedtrace/-/bytedtrace-0.0.1-alpha.2.tgz","key":"/@byted-service/bytedtrace/-/@byted-service/bytedtrace-0.0.1-alpha.2.tgz","shasum":"b5abb74def78c01ca1975895adc00d3aca695f02","size":128433},"_cnpm_publish_time":1621595063505,"devDependencies":{"@byted-service/fetch":"^1.16.3","@types/google-protobuf":"^3.7.4","ts-protoc-gen":"^0.14.0"},"name":"@byted-service/bytedtrace","versiontool":{"message":"此 lib 无法在当前 Node.js 版本运行，请及时升级运行环境的 Node.js 到 10.5.0 及以上版