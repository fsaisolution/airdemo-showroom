ize=72x72&cut_type=&quality=&format=png&sticker_format=.webp"}],"_npmVersion":"6.5.0","_publish_on_cnpm":true,"name":"@byted-service/fetch","_nodeVersion":"8.11.4","scripts":{"prepublish":"npm run build","test":"RUNTIME_IDC_NAME=lf ../../node_modules/.bin/jest --config ./jest.config.json --coverage --env=node","build":"rm -rf lib && npx tsc"},"contributors":[{"email":"liyubei@bytedance.com","name":"liyubei"}],"dependencies":{"@byted-service/consul":"^1.1.3","@byted-service/env":"^1.2.0","@byted-service/logger":"^1.2.1","@byted-service/metrics":"^1.4.0","node-fetch":"^2.2.0","tslib":"^1.9.3"},"author":{"email":"lupegnyu@bytedance.com","name":"lupengyu"},"repository":{"type":"git","url":"https://code.byted.org/nodejs/byted-service/packages/fetch"}},"2.3.2":{"types":"lib/index.d.ts","readme":"# @byted-service/fetch\n\n[![bnpm](https://web-bnpm.byted.org/badge/v/@byted-service/fetch.svg?style=flat-square)](https://web-bnpm.byted.org/package/@byted-service/fetch) [![download](https://2y8ngapf.fn.bytedance.net/d?p=@byted-service/fetch)](https://web-bnpm.byted.org/package/@byted-service/fetch)\n\n[简体中文](https://code.byted.org/nodejs/byted-service/blob/master/packages/fetch/README.md) | [English](https://code.byted.org/nodejs/byted-service/blob/master/packages/fetch/README.en.md) | [CHANGELOG](https://code.byted.org/nodejs/byted-service/blob/master/packages/fetch/CHANGELOG.md)\n\n> The following is **@byted-service/fetch@2.x** document, **1.x** document see [fetch-v1.x](https://code.byted.org/nodejs/byted-service/tree/fetch-v1.x/packages/fetch), [@byted-service/fetch@2.0.0 release log](https://bytedance.feishu.cn/wiki/wikcnMNUcH3YbXKEeZSX4YqCavc).\n\nThis module is a custom http fetch module based on [node-fetch](https://github.com/bitinn/node-fetch). The main features are as follows:\n\n-   Metrics, logger and bytedtrace are logged by default after each request, making it easy to view and locate issues on the ms platform.\n-   Support multiple protocols.\n    -   `http` / `https`: request with `domain`.\n    -   `consul`: request with `psm`, support http egress mesh.\n    -   `faas`: request with `faasid`.\n-   Support default timeout ( `3s` ).\n\nIf the framework you are using has integrated the module, it is not recommended to use the module directly, you can directly use the provided plugins.\n\n-   `Gulu`: [@gulu/fetch](https://code.byted.org/nodejs/gulu/tree/master/packages/byted-gulu-fetch)\n-   `Koa & Express`: [@fe/middlewares](https://code.byted.org/nodejs/middlewares)\n\nPS: Direct use may cause problems such as disconnection of the call chain log (cannot be queried), and incorrect traffic scheduling performance in environments such as ppe. If you cannot use the above plugins, please pass in the ctx parameter for the transfer of logId, env and other parameters.\n\n## Installation\n\n```bash\nnpm install @byted-service/fetch --registry=http://bnpm.byted.org\n```\n\n## Quick Start\n\n### Http / Https\n\n```js\nconst { fetch } = require('@byted-service/fetch');\n\n(async () => {\n    const resp = await fetch('http://some.domain.com/');\n\n    console.log('status:', resp.status);\n    console.log('body:', await resp.json());\n})();\n```\n\nThe usage method in this mode is almost the same as `node-fetch`, please refer to [node-fetch documentation](https://github.com/bitinn/node-fetch#usage).\n\n### Consul\n\n```js\nconst { fetch } = require('@byted-service/fetch');\n\n(async () => {\n    const resp = await fetch('consul://p.s.m/');\n\n    console.log('status:', resp.status);\n    console.log('body:', await resp.json());\n})();\n```\n\n-   [Node.js Service Discovery ( Consul ) User Guide](https://bytedance.feishu.cn/wiki/wikcnU8nNhyPfhV2OjHLCVQPX5g).\n-   [A Quick Start with Service Discovery ( Consul ) for Front-End Engineers](https://bytedance.feishu.cn/wiki/wikcn9QfY7pMwo9I9Jf1Y2q6R4d).\n\n### faas\n\n```js\nconst { fetch } = require('@byted-service/fetch');\n\n(async () => {\n    const resp = await fetch('faas://faasid/');\n\n    console.log('status:', resp.status);\n    console.log('body:', await resp.json());\n})();\n```\n\nUse faasid to directly request the corresponding faas function，[see](https://code.byted.org/nodejs/byted-service/blob/master/packages/fetch-protocol-faas/README.en.md).\n\n## API\n\n### fetch(url[, options])\n\nInitiate a request.\n\n<details>\n  <summary>History</summary>\n\n-   `v2.3.0`: Modify the default value of `options.enableLogger` and `options.enableMetrics` to `false`, and the features is supported by `bytedtrace`.\n-   `v2.2.0`\n    -   Mark `options.ctx`, `options.disableLogger`, `options.disableMetrics`, `options.disableTracer` as deprecated.\n    -   Support `options.fromMethod`, `options.psm`, `options.cluster`, `options.idc`, `options.env`, `options.from`, `options.fromCluster`, `options.fromIdc`, `options.to`, `options.toCluster`, `options.toIdc`, `options.enableLogger`, `options.location`, `options.enableMetrics`, `options.enableBytedtrace`, `options.span`, `options.trace`.\n\n</details>\n\n-   `url`: Request url.\n-   `options`: Request options.\n    -   `handleMethod`: Call method, the default value is `byted_service_fetch_default`, used for data display on `metrics`, `logger`, `trace`, `ms platforms`, and does not affect actual requests.\n    -   `fromMethod`: Current method, the default value is `byted_service_fetch_unknow_from_method`, used for data display on `metrics`, `logger`, `trace`, `ms platforms`, and does not affect actual requests.\n    -   `logId`: [x-tt-logid](https://bytedance.feishu.cn/wiki/wikcn2L5x9IgQ4iLEdHofSMPVQc#qUpuqi).\n    -   `stressTag`: [x-tt-stress](https://bytedance.feishu.cn/wiki/wikcn2L5x9IgQ4iLEdHofSMPVQc#gzmKsm).\n    -   `psm`: `Server psm`, used for data display on `metrics`, `logger`, `trace`, `ms platforms`. For service discovery (`consul` ), please see [Consul](#consul).\n    -   `cluster`: `Server cluster`.\n    -   `idc`: `Server idc`.\n    -   `env`: `Server env`.\n    -   `from`: `Client psm`.\n    -   `fromCluster`: `Client cluster`.\n    -   `fromIdc`: `Client idc`.\n    -   `to`: `Server psm`.\n    -   `toCluster`: `Server cluster`.\n    -   `toIdc`: `Server idc`.\n    -   `enableLogger`: Whether to enable `Logger`, the default value is `false`.\n    -   `logger`: `Logger` instance, see [@byted-service/logger](https://code.byted.org/nodejs/byted-service/blob/master/packages/logger/README.en.md).\n    -   `loggerOptions`: `Logger` construction options, see [@byted-service/logger](https://code.byted.org/nodejs/byted-service/blob/master/packages/logger/README.en.md).\n    -   `loggerTags`: `logger tags`.\n    -   `location`: Call location.\n    -   `enableMetrics`: Whether to enable `Metrics`, the default value is `false`.\n    -   `metrics`: `Metrics` instance, see [@byted-service/metrics](https://code.byted.org/nodejs/byted-service/blob/master/packages/metrics/README.en.md).\n    -   `metricsTags`: `metrics tags`.\n    -   `enableBytedtrace`: Whether to enable `bytedtrace`, the default value is `true`.\n    -   `span`: `span` instance, see [@byted-service/bytedtrace](https://code.byted.org/nodejs/byted-service/tree/master/packages/bytedtrace).\n    -   `trace`: [x-tt-trace](https://bytedance.feishu.cn/wiki/wikcn2L5x9IgQ4iLEdHofSMPVQc#nLI02S).\n    -   `retry`: Number of retries, the default value is `0` ( no retry ).\n    -   `enableProxy`: Whether to enable the proxy feature, the default value is `false`, after enabling it, the request proxy will be set according to `options.proxy` and environment variables, see [Proxy](#proxy).\n    -   `proxy`: Proxy server address, currently only supports `http` and `https`, see [Proxy](#proxy).\n    -   `disableUsePPEHeader`: Whether to turn off the automatic setting of `x-use-ppe` ( default setting in ppe environment ), the default value is `false`.\n    -   Other options.\n        -   Such as `body`, `headers`, `method`, `timeout`, etc. Please refer to [node-fetch](https://github.com/bitinn/node-fetch).\n        -   Such as `consul`, `consulOptions`, `consulLookupOptions`, etc. Please refer to the specific document.\n            -   [Consul protocol](https://code.byted.org/nodejs/byted-service/blob/master/packages/fetch-protocol-consul/README.en.md)\n            -   [Faas protocol](https://code.byted.org/nodejs/byted-service/blob/master/packages/fetch-protocol-faas/README.en.md)\n\n### fetch.register(protocol, handle)\n\nRegister a custom protocol.\n\n-   `protocol`: Protocol name.\n-   `handle`: Protocol processing function.\n\n```js\nconst { fetch } = require('@byted-service/fetch');\n\nfetch.register('nexthttp', (ctx) => ctx.fetch());\n\n(async () => {\n    const resp = await fetch('nexthttp://some.domain.com/');\n\n    console.log('status:', resp.status);\n    console.log('body:', await resp.json());\n})();\n```\n\nFor specific implementation methods and related APIs, please refer to\n\n-   [fetch-protocol-consul](https://code.byted.org/nodejs/byted-service/blob/master/packages/fetch-protocol-consul)\n-   [fetch-protocol-faas](https://code.byted.org/nodejs/byted-service/blob/master/packages/fetch-protocol-faas)\n\n## Proxy\n\n> Currently only supports http and https proxies.\n\n-   Proxy function enable switch: It can be turned on by `options.enableProxy = true` or `process.env.ENABLE_FETCH_PROXY = true`.\n-   Proxy server address.\n    -   `http`: It can be configured via `options.proxy`> `process.env.HTTP_PROXY`> `process.env.http_proxy`.\n    -   `https`: It can be configured via `options.proxy`> `process.env.HTTPS_PROXY`> `process.env.https_proxy`.\n\neg:\n\n```sh\nENABLE_FETCH_PROXY=true http_proxy=http://localhost:8888 node server.js\n```\n\nAfter opening `Service Mesh`, it will automatically try to execute the [public network traffic audit](https://bytedance.feishu.cn/docs/doccnkzpXYEgjWpI797a7EMXH2c#) related logic, which can be turned off by setting `options.enableMesh === false`.\n\n## ~~Metrics~~\n\n> Since @byted-service/fetch@2.3.0, the features are supported by Bytedtrace, see [Node.js Trace Troubleshooting Guide](https://bytedance.feishu.cn/wiki/wikcnwgrXUpn5m5FgfDolEyG0zd).\n\nEvery time the back-end http service is called by `@byted-service/fetch`, the following metrics will be automatically recorded by default, which can be viewed on the ms platform.\n\nFor more management specifications, see https://bytedance.feishu.cn/space/doc/opTvz5DIKHOT7NXaCAcrMb#SrkjFg\n\n### toutiao.service.thrift.{PSM}.call.success.latency.us\n\nCall success time-consuming.\n\n<details>\n  <summary>History</summary>\n\n-   `v2.2.0`: Support `from_method`.\n\n</details>\n\n**tags**\n\n-   `method`: Call method, the default value is `byted_service_fetch_default`, which can be set by `options.handleMethod`.\n-   `from_method`: Current method, the default value is `byted_service_fetch_unknow_from_method`, which can be set by `options.fromMethod`.\n-   `env`: `Server env`, the default value is `prod`, which can be set by `options.env`.\n-   `stress_tag`: Stress tag, the default value is `-`, which can be set by `options.stressTag`.\n-   `from`: `Client psm`, the default value is `env.getPSM()` ( If psm is `-` then metrics will not be recorded ), see [@byted-service/env](https://code.byted.org/nodejs/byted-service/blob/master/packages/env/README.en.md), which can be set by `options.from`.\n-   `from_cluster`: `Client cluster`, the default value is `env.getCluster()`, see [@byted-service/env](https://code.byted.org/nodejs/byted-service/blob/master/packages/env/README.en.md), which can be set by `options.fromCluster`.\n-   `from_idc`: `Client idc`, the default value is `env.getIDC()`, see [@byted-service/env](https://code.byted.org/nodejs/byted-service/blob/master/packages/env/README.en.md), which can be set by `options.fromIdc`.\n-   `to`: `Server domain / psm / faasid`, the result is determined by the specific agreement, which can be set by `options.to`.\n-   `to_cluster`: `Server cluster`, the default value is `default`, which can be set by `options.ctx.toCluster`.\n-   `to_idc`: `Server idc`, which can be set by `options.ctx.toIdc`.\n-   `status`: Call status code.\n-   `label`: Status code description.\n    -   `success`: The call is successful, the status is in `[200, 400)`.\n    -   `business_err`: The call failed, this status is not in `[200, 400)`.\n-   `retry`: Number of retries.\n-   `mesh`: Whether used `http egress mesh`, the default value is `0`.\n    -   `0`: No.\n    -   `1`: Yes.\n-   `ipv6`: Whether the server address is `ipv6`.\n    -   `0`: No.\n    -   `1`: Yes.\n-   `remote_protocol`: Remote protocol.\n-   For other tags, please refer to the specific protocol document.\n    -   [Consul protocol](https://code.byted.org/nodejs/byted-service/blob/master/packages/fetch-protocol-consul/README.en.md)\n    -   [Faas protocol](https://code.byted.org/nodejs/byted-service/blob/master/packages/fetch-protocol-faas/README.en.md)\n\n### toutiao.service.thrift.{PSM}.call.error.latency.us\n\nCall failure time-consuming.\n\n**tags**\n\nSame as above.\n\n### toutiao.service.thrift.{PSM}.call.success.throughput\n\nCall success count.\n\n**tags**\n\nSame as above.\n\n### toutiao.service.thrift.{PSM}.call.error.throughput\n\nCall failure count.\n\n**tags**\n\nSame as above.\n\n## ~~Logger~~\n\n> Since @byted-service/fetch@2.3.0, Logger was closed by default, and the features are supported by Bytedtrace, see [Node.js Trace Troubleshooting Guide](https://bytedance.feishu.cn/wiki/wikcnwgrXUpn5m5FgfDolEyG0zd).\n\nEvery time the backend http service is called through `@byted-service/fetch`, the following log will be automatically recorded by default, which can be viewed in the file.\n\n<details>\n  <summary>History</summary>\n\n-   `v2.2.0`\n    -   Remove `trace`.\n    -   Support `ipv6`, `rip`.\n\n</details>\n\n**tags**\n\n-   `method`: Call method, the default value is `byted_service_fetch_default`, which can be set by `options.handleMethod`.\n-   `from_method`: Current method, the default value is `byted_service_fetch_unknow_from_method`, which can be set by `options.fromMethod`.\n-   `env`: `Server env`, the default value is `prod`, which can be set by `options.env`.\n-   `stress_tag`: Stress tag, the default value is `-`, which can be set by `options.stressTag`.\n-   `to`: `Server domain / psm / faasid`, the result is determined by the specific agreement, which can be set by `options.to`.\n-   `to_cluster`: `Server cluster`, the default value is `default`, which can be set by `options.toCluster`.\n-   `to_idc`: `Server idc`, which can be set by `options.toIdc`.\n-   `status`: Call status code.\n-   `status_message`: Status code description.\n-   `cost`: Call time consuming.\n-   `retry`: Number of retries.\n-   `mesh`: Whether used `http egress mesh`, the default value is `0`.\n    -   `0`: No.\n    -   `1`: Yes.\n-   `ipv6`: Whether the server address is `ipv6`.\n    -   `0`: No.\n    -   `1`: Yes.\n-   `rip`: Real request `ip`.\n-   `called`: Original calling domain.\n-   `remote_protocol`: Remote protocol.\n-   For other tags, please refer to the specific protocol document.\n    -   [Consul protocol](https://code.byted.org/nodejs/byted-service/blob/master/packages/fetch-protocol-consul/README.en.md)\n    -   [Faas protocol](https://code.byted.org/nodejs/byted-service/blob/master/packages/fetch-protocol-faas/README.en.md)\n\n## FAQ\n\n### Description of traffic scheduling in PPE environment\n\n-   [Env-based traffic scheduling](https://bytedance.feishu.cn/docs/ws0Kg2Q539Rzqc18VFc98f)\n-   [About Env traffic scheduling in Node.js basic library](https://bytedance.feishu.cn/docs/doccngArac17h1v0IaOd6mhBtAg)\n","main":"index.js","gitHead":"b874c82041dfc2c92881f95f051eacc6c300ef50","dependencies":{"@byted-service/fetch-protocol-faas":"^2.2.1","@byted-service/fetch-protocol-http":"^1.1.2","tslib":"^1.9.3","@byted-service/fetch-core":"^2.3.1","@byted-service/fetch-protocol-consul":"^2.2.2"},"_nodeVersion":"14.19.3","version":"2.3.2","maintainers":[{"avatar":"https://s3-fs.pstat