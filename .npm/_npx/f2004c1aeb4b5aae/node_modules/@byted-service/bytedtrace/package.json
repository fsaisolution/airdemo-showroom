{
    "name": "@byted-service/bytedtrace",
    "version": "1.8.6",
    "description": "",
    "main": "index.js",
    "types": "lib/index.d.ts",
    "files": [
        "lib",
        "index.js"
    ],
    "license": "MIT",
    "scripts": {
        "build": "rm -rf lib && tsc && cp -r src/gen lib/",
        "prepublish": "npm run build",
        "test": "ROUTE_IP=10.225.130.44 RUNTIME_IDC_NAME=boe ../../node_modules/.bin/jest --config ./jest.config.json --coverage --env=node",
        "gen": "rm -rf ./src/gen/* && npm run gen:proto && npm run gen:ts",
        "gen:proto": "protoc --js_out=import_style=commonjs,binary:./src/gen --proto_path=./proto/idl ./proto/idl/*.proto",
        "gen:ts": "protoc --ts_out=:./src/gen --plugin=protoc-gen-ts=../../node_modules/.bin/protoc-gen-ts --proto_path=./proto/idl ./proto/idl/*.proto",
        "debug": "ROUTE_IP=10.225.130.44 RUNTIME_IDC_NAME=boe ts-node --files ./debug.ts",
        "benchmark": "source benchmark/start.sh"
    },
    "repository": {
        "type": "git",
        "url": "https://code.byted.org/nodejs/byted-service"
    },
    "author": "xieweicheng",
    "dependencies": {
        "@byted-nodex/metrics": "^1.1.7",
        "@byted-service/env": "^1.12.2",
        "@byted-service/fnv": "^1.0.1",
        "@byted-service/logger": "^2.1.2",
        "@byted-service/metrics": "^1.13.4",
        "@byted-service/singleflight": "^1.0.5",
        "@byted-service/tcc-general": "^2.0.3",
        "google-protobuf": "^3.15.6",
        "int64-buffer": "^1.0.1",
        "lodash.clonedeep": "^4.5.0",
        "md5": "^2.3.0",
        "promise.allsettled": "^1.0.4",
        "seed-random": "^2.2.0",
        "tslib": "^2.6.3"
    },
    "devDependencies": {
        "@byted-service/logid": "^1.0.2",
        "@byted-service/trace": "^1.0.15",
        "@types/google-protobuf": "^3.7.4",
        "@types/jest": "^24.0.21",
        "benchmark": "^2.1.4",
        "grpc_tools_node_protoc_ts": "^4.1.5",
        "ts-protoc-gen": "^0.14.0",
        "typescript": "^4.8.4"
    },
    "engines": {
        "node": ">=10.0.0"
    },
    "gitHead": "7ccfab0136c64c924073e1fccebe49ee3e40c164"
}
