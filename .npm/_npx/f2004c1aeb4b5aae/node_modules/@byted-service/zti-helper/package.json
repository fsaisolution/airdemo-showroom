{
    "name": "@byted-service/zti-helper",
    "version": "2.0.1",
    "main": "index.js",
    "types": "lib/index.d.ts",
    "files": [
        "lib",
        "index.js"
    ],
    "license": "MIT",
    "scripts": {
        "build": "rm -rf lib && tsc && cp -r src/gen lib/ && rm -rf lib/gen/__mocks__",
        "prepublish": "npm run build",
        "test": "ROUTE_IP=10.225.130.44 RUNTIME_IDC_NAME=boe ../../node_modules/.bin/jest --config ./jest.config.json --coverage --env=node",
        "gen": "rm -rf ./src/gen/* && npm run gen:proto && npm run gen:ts",
        "gen:proto": "grpc_tools_node_protoc --js_out=import_style=commonjs,binary:./src/gen --grpc_out=grpc_js:./src/gen --proto_path=./proto --plugin=grpc_tools_node_protoc_plugin ./proto/*.proto",
        "gen:ts": "grpc_tools_node_protoc --ts_out=service=grpc-node,mode=grpc-js:./src/gen --plugin=protoc-gen-ts=./node_modules/.bin/protoc-gen-ts --proto_path=./proto ./proto/*.proto"
    },
    "repository": {
        "type": "git",
        "url": "https://code.byted.org/nodejs/byted-service"
    },
    "author": "xieweicheng@bytedance.com",
    "dependencies": {
        "@byted-service/env": "^1.13.0",
        "@byted-service/logger": "^2.1.2",
        "@byted-service/metrics": "^1.13.4",
        "@byted-service/singleflight": "^1.0.5",
        "@grpc/grpc-js": "^1.9.2",
        "google-protobuf": "^3.13.0",
        "jsonwebtoken": "^9.0.2",
        "lodash.clonedeep": "^4.5.0",
        "tslib": "^2.6.3"
    },
    "devDependencies": {
        "@byted-service/infsec": "^3.1.1",
        "@types/google-protobuf": "^3.7.2",
        "@types/jest": "^24.0.21",
        "@types/jsonwebtoken": "^8.5.8",
        "grpc_tools_node_protoc_ts": "^4.1.5",
        "ts-protoc-gen": "^0.14.0",
        "typescript": "^4.8.4"
    },
    "engines": {
        "node": ">=12.0.0"
    },
    "gitHead": "370d394caff45de410d61d9447e10a4c254479fd"
}
