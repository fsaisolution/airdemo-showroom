{
  "name": "@byted/mcp-client-sdk",
  "version": "1.3.6",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rslib build && yarn test:cov",
    "check": "biome check --write",
    "dev": "rslib build --watch",
    "format": "prettier --write .",
    "lint": "eslint .",
    "playground": "tsx __test__/playground.ts",
    "test": "vitest",
    "test:cov": "vitest run --coverage"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@eslint/js": "^9.21.0",
    "@rslib/core": "^0.7.1",
    "@types/node": "^22.8.1",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^9.21.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.25.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@byted-service/fetch": "^2.6.5",
    "@byted-service/logger": "^2.4.1",
    "@byted-service/zti-helper": "^2.0.1",
    "@byted/ai-paas-env": "^1.0.6",
    "joi": "^17.9.2"
  }
}
