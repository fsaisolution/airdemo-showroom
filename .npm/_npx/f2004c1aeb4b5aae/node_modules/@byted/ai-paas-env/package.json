    "test:cov": "vitest run --coverage"
  },
  "devDependencies": {
    "@biomejs/biome": "2.1.3",
    "@rslib/core": "^0.12.4",
    "@types/node": "^22.18.0",
    "@vitest/coverage-v8": "^1.6.0",
    "typescript": "^5.9.2",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@byted-service/env": "^1.17.19"
  }
}
